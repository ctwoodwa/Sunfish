<!--
    POLICY-GATED PACKAGE.
    All changes require explicit reviewer sign-off per packages/compat-material-icons/POLICY.md.
    This package MUST NOT reference any Google Material Icons / Material Symbols NuGet. It also
    does NOT bundle any Material assets (SVG/fonts/CSS) — consumers remain responsible for
    loading Google's font/CSS (Google Fonts <link>, self-hosted webfont, or an existing
    MudBlazor/Blazorise asset pipeline).
-->
<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Compat.MaterialIcons</PackageId>
    <Description>Google-Material-Icons- and Material-Symbols-API-shaped compatibility surface over Sunfish components. Migration off-ramp for Blazor consumers of Material Icons / Material Symbols (MudBlazor.FontIcons.MaterialIcons, Blazorise.Icons.Material, MudBlazor.FontIcons.MaterialSymbols). Does not ship Material assets. Policy-gated.</Description>
    <PackageTags>blazor;compat;material;material-icons;material-symbols;icons;migration;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Sunfish.Compat.MaterialIcons</RootNamespace>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Compat.MaterialIcons.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\compat-shared\Sunfish.Compat.Shared.csproj" />
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
    <ProjectReference Include="..\ui-adapters-blazor\Sunfish.UIAdapters.Blazor.csproj" />
  </ItemGroup>
</Project>
