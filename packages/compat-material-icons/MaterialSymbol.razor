@namespace Sunfish.Compat.MaterialIcons
@using Microsoft.AspNetCore.Components
@using Sunfish.Foundation.Enums

<span class="@_classAttr"
      role="@(string.IsNullOrEmpty(AriaLabel) ? null : "img")"
      aria-label="@AriaLabel"
      @attributes="AdditionalAttributes">@Name</span>

@code {
    // --- Material-Symbols-shaped public parameters ---

    /// <summary>
    /// Material Symbols ligature identifier (lowercase_snake_case), e.g. <c>"home"</c>,
    /// <c>"calendar_today"</c>, or any <see cref="MaterialIconName"/> member (the
    /// ligature names are shared between Material Icons and Material Symbols).
    /// </summary>
    [Parameter] public string? Name { get; set; }

    /// <summary>
    /// Material Symbols stylistic variant — <see cref="MaterialSymbolVariant.Outlined"/>
    /// (default), <see cref="MaterialSymbolVariant.Rounded"/>, or
    /// <see cref="MaterialSymbolVariant.Sharp"/>. Selects the
    /// <c>material-symbols-outlined</c> / <c>material-symbols-rounded</c> /
    /// <c>material-symbols-sharp</c> base class so the corresponding variable-font
    /// file (loaded by the consumer) renders.
    /// </summary>
    [Parameter] public MaterialSymbolVariant Variant { get; set; } = MaterialSymbolVariant.Outlined;

    /// <summary>
    /// Sunfish-enum size. Emits a Sunfish-prefixed modifier class
    /// (<c>sf-material-size-sm/md/lg/xl</c>) alongside the <c>material-symbols-*</c>
    /// base class. Omit for the consumer's default sizing.
    /// </summary>
    [Parameter] public IconSize? Size { get; set; }

    /// <summary>Accessible label for the icon. When set, the host element uses <c>role="img"</c>.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    /// <summary>Additional attributes splatted onto the host <c>&lt;span&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? AdditionalAttributes { get; set; }

    private string _classAttr = "material-symbols-outlined sf-material-symbol";

    protected override void OnParametersSet()
    {
        var variantClass = MaterialSizeClass.ToSymbolClass(Variant);
        var sizeClass = MaterialSizeClass.ToClass(Size);
        _classAttr = string.IsNullOrEmpty(sizeClass)
            ? $"{variantClass} sf-material-symbol"
            : $"{variantClass} sf-material-symbol {sizeClass}";
    }
}
