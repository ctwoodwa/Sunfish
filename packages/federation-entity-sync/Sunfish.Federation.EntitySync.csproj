<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Federation.EntitySync</PackageId>
    <Description>Sunfish federation entity delta-sync — Automerge-style head announcement + change exchange with Ed25519 signature verification (spec §2.5, §3.6).</Description>
    <PackageTags>sunfish;federation;sync;entity;crdt</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Federation.EntitySync.Tests" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\federation-common\Sunfish.Federation.Common.csproj" />
  </ItemGroup>
</Project>
