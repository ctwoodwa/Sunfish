<!--
    POLICY-GATED PACKAGE.
    All changes require explicit reviewer sign-off per packages/compat-simple-icons/POLICY.md.
    This package MUST NOT reference any Simple Icons NuGet. It also does NOT bundle
    Simple Icons assets (SVG/font/CSS) — consumers remain responsible for loading
    the Simple Icons stylesheet/sprite themselves (CDN `<link>`, NPM, or self-hosted).
-->
<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Compat.SimpleIcons</PackageId>
    <Description>Simple-Icons-API-shaped compatibility surface over Sunfish components. Migration off-ramp for Simple Icons (brand/logo) Blazor consumers. Does not ship Simple Icons assets. Policy-gated. Upstream icons are CC0-1.0 (public domain); brand trademarks remain with their respective owners.</Description>
    <PackageTags>blazor;compat;simple-icons;brand;logos;icons;migration;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Sunfish.Compat.SimpleIcons</RootNamespace>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Compat.SimpleIcons.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\compat-shared\Sunfish.Compat.Shared.csproj" />
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
    <ProjectReference Include="..\ui-adapters-blazor\Sunfish.UIAdapters.Blazor.csproj" />
  </ItemGroup>
</Project>
