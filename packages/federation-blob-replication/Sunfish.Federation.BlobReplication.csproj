<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Federation.BlobReplication</PackageId>
    <Description>Sunfish federation blob-replication — IpfsBlobStore via Kubo HTTP RPC, IKuboHealthProbe implementation, swarm-key-gated private networks (spec §3.7, §10.4).</Description>
    <PackageTags>sunfish;federation;blob;ipfs;kubo;content-addressed</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Federation.BlobReplication.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\federation-common\Sunfish.Federation.Common.csproj" />
  </ItemGroup>
</Project>
