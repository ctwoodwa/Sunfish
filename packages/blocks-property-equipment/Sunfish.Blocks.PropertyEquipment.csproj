<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.PropertyEquipment</PackageId>
    <Description>Property-Equipment domain block — Equipment entity (FK to Property), EquipmentClass discriminator, EquipmentLifecycleEvent append-only log, in-memory repository + event store, and ISunfishEntityModule contribution. Cluster sibling under the property-operations cluster (`blocks-property-*` naming convention). Renamed from blocks-property-assets per UPF Rule 4 to disambiguate from foundation-tier `Sunfish.Foundation.Assets.Common`. Vehicle subtype + Trip events + EquipmentConditionAssessment integration + OCR ingest deferred to follow-up hand-offs.</Description>
    <PackageTags>property-equipment;equipment;real-estate;blocks;domain;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.PropertyEquipment.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-multitenancy\Sunfish.Foundation.MultiTenancy.csproj" />
    <ProjectReference Include="..\foundation-persistence\Sunfish.Foundation.Persistence.csproj" />
    <ProjectReference Include="..\blocks-properties\Sunfish.Blocks.Properties.csproj" />
  </ItemGroup>
</Project>
