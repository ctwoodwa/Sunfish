@inherits SunfishComponentBase
@using System.Linq.Expressions
@typeparam TValue
@implements IDisposable

@if (_messages.Any())
{
    <div class="@CombineClasses(CssProvider.ValidationMessageClass(ValidationSeverity.Error))"
         style="@CombineStyles()"
         @attributes="AdditionalAttributes">
        @if (Template != null)
        {
            @Template(_messages)
        }
        else
        {
            @foreach (var message in _messages)
            {
                <span class="sf-validation-message-text">@message</span>
            }
        }
    </div>
}

@code {
    private EditContext? _previousEditContext;
    private FieldIdentifier _fieldIdentifier;
    private IEnumerable<string> _messages = [];

    /// <summary>
    /// Expression identifying the model property to display validation messages for.
    /// </summary>
    [Parameter] public Expression<Func<TValue>>? For { get; set; }

    /// <summary>
    /// Custom template for rendering validation messages. Receives all messages for the field.
    /// </summary>
    [Parameter] public RenderFragment<IEnumerable<string>>? Template { get; set; }

    [CascadingParameter] private EditContext? CurrentEditContext { get; set; }

    protected override void OnParametersSet()
    {
        if (CurrentEditContext == null)
        {
            throw new InvalidOperationException(
                $"{nameof(SunfishValidationMessage<TValue>)} requires a cascading parameter of type {nameof(EditContext)}. " +
                $"Use this component inside a {nameof(SunfishForm)} or an EditForm.");
        }

        if (For == null)
        {
            throw new InvalidOperationException(
                $"{nameof(SunfishValidationMessage<TValue>)} requires a value for the {nameof(For)} parameter.");
        }

        if (CurrentEditContext != _previousEditContext)
        {
            DetachFromEditContext();
            _previousEditContext = CurrentEditContext;
            CurrentEditContext.OnValidationStateChanged += HandleValidationStateChanged;
        }

        _fieldIdentifier = FieldIdentifier.Create(For);
        UpdateMessages();
    }

    private void HandleValidationStateChanged(object? sender, ValidationStateChangedEventArgs e)
    {
        UpdateMessages();
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateMessages()
    {
        if (CurrentEditContext != null)
        {
            _messages = CurrentEditContext.GetValidationMessages(_fieldIdentifier);
        }
    }

    private void DetachFromEditContext()
    {
        if (_previousEditContext != null)
        {
            _previousEditContext.OnValidationStateChanged -= HandleValidationStateChanged;
        }
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing)
        {
            DetachFromEditContext();
        }
        base.Dispose(disposing);
    }
}
