@inherits SunfishComponentBase

<label class="@CombineClasses(CssProvider.RadioClass(IsChecked))" style="@CombineStyles()" @attributes="AdditionalAttributes">
    <input type="radio"
           name="@ResolvedName"
           value="@Value"
           checked="@IsChecked"
           disabled="@(!ResolvedEnabled)"
           @onchange="OnSelectionChanged" />
    @if (ChildContent is not null)
    {
        <span>@ChildContent</span>
    }
    else if (!string.IsNullOrEmpty(Label))
    {
        <span>@Label</span>
    }
</label>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;

    [CascadingParameter] public SunfishRadioGroup? RadioGroup { get; set; }

    private string ResolvedName => RadioGroup?.Name ?? Name;
    private bool ResolvedEnabled => RadioGroup?.Enabled ?? Enabled;
    private bool IsChecked => RadioGroup is not null
        ? string.Equals(RadioGroup.Value, Value, StringComparison.Ordinal)
        : IsSelected;

    private async Task OnSelectionChanged(ChangeEventArgs e)
    {
        if (RadioGroup is not null)
        {
            await RadioGroup.SelectValue(Value);
        }
        else
        {
            await ValueChanged.InvokeAsync(Value);
        }
    }
}
