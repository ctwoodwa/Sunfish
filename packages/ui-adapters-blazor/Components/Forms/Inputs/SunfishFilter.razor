@namespace Sunfish.UIAdapters.Blazor.Components.Forms.Inputs
@typeparam TItem
@inherits SunfishComponentBase
@using Sunfish.Foundation.Enums
@using Sunfish.UIAdapters.Blazor.Enums
@using FilterOperator = Sunfish.Foundation.Enums.FilterOperator

<div class="@CombineClasses("sf-filter")"
     style="@CombineStyles()"
     @attributes="AdditionalAttributes">

    @RenderComposite(_root, null)

    <div class="sf-filter__actions">
        <button type="button" class="sf-filter__apply-btn" @onclick="ApplyFilter">Apply</button>
    </div>
</div>

@code
{
    private RenderFragment RenderComposite(FilterCompositeDescriptor composite, FilterCompositeDescriptor? parent) =>
        @<div class="sf-filter__group">
            <div class="sf-filter__group-header">
                <select class="sf-filter__logic"
                        value="@composite.Logic"
                        @onchange="e => OnLogicChanged(composite, e)">
                    <option value="@FilterLogic.And">AND</option>
                    <option value="@FilterLogic.Or">OR</option>
                </select>
                <button type="button"
                        class="sf-filter__add-row-btn"
                        @onclick="() => AddLeaf(composite)">
                    + Filter
                </button>
                <button type="button"
                        class="sf-filter__add-group-btn"
                        @onclick="() => AddGroup(composite)">
                    + Group
                </button>
                @if (parent is not null)
                {
                    <button type="button"
                            class="sf-filter__remove-btn"
                            @onclick="() => Remove(parent, composite)"
                            aria-label="Remove group">&times;</button>
                }
            </div>
            <div class="sf-filter__group-body">
                @if (composite.Filters.Count == 0)
                {
                    <div class="sf-filter__empty">No filters applied.</div>
                }
                else
                {
                    @foreach (var child in composite.Filters.ToList())
                    {
                        @if (child is FilterCompositeDescriptor c)
                        {
                            @RenderComposite(c, composite)
                        }
                        else if (child is FilterLeafDescriptor l)
                        {
                            @RenderLeaf(l, composite)
                        }
                    }
                }
            </div>
        </div>;

    private RenderFragment RenderLeaf(FilterLeafDescriptor leaf, FilterCompositeDescriptor parent)
    {
        var field = ResolveField(leaf.Field);
        return
            @<div class="sf-filter__row">
                <select class="sf-filter__field"
                        value="@leaf.Field"
                        @onchange="e => OnFieldChanged(leaf, e)">
                    <option value="">(select field)</option>
                    @foreach (var f in Fields)
                    {
                        <option value="@f.Name">@(string.IsNullOrEmpty(f.Label) ? f.Name : f.Label)</option>
                    }
                </select>

                <select class="sf-filter__operator"
                        value="@leaf.Operator"
                        @onchange="e => OnOperatorChanged(leaf, e)">
                    @foreach (var op in OperatorsFor(field))
                    {
                        <option value="@op">@FormatOperator(op)</option>
                    }
                </select>

                @RenderValueInput(leaf, field)

                <button type="button"
                        class="sf-filter__remove-btn"
                        @onclick="() => Remove(parent, leaf)"
                        aria-label="Remove filter">&times;</button>
            </div>;
    }

    private RenderFragment RenderValueInput(FilterLeafDescriptor leaf, FilterField? field)
    {
        if (leaf.Operator is FilterOperator.IsNull or FilterOperator.IsNotNull)
        {
            return @<text></text>;
        }

        var type = field?.Type ?? FilterFieldType.Text;
        return type switch
        {
            FilterFieldType.Number =>
                @<input type="number"
                        class="sf-filter__value"
                        value="@(leaf.Value?.ToString() ?? string.Empty)"
                        @onchange="e => OnValueChanged(leaf, e)" />,
            FilterFieldType.Date =>
                @<input type="date"
                        class="sf-filter__value"
                        value="@(leaf.Value?.ToString() ?? string.Empty)"
                        @onchange="e => OnValueChanged(leaf, e)" />,
            FilterFieldType.Boolean =>
                @<input type="checkbox"
                        class="sf-filter__value sf-filter__value--bool"
                        checked="@(leaf.Value is bool b && b)"
                        @onchange="e => OnValueChanged(leaf, e)" />,
            FilterFieldType.Enum =>
                @<select class="sf-filter__value"
                         value="@(leaf.Value?.ToString() ?? string.Empty)"
                         @onchange="e => OnValueChanged(leaf, e)">
                    <option value=""></option>
                    @foreach (var ev in field?.EnumValues ?? Array.Empty<string>())
                    {
                        <option value="@ev">@ev</option>
                    }
                </select>,
            _ =>
                @<input type="text"
                        class="sf-filter__value"
                        placeholder="Value"
                        value="@(leaf.Value?.ToString() ?? string.Empty)"
                        @onchange="e => OnValueChanged(leaf, e)" />
        };
    }
}
