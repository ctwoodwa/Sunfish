@inherits SunfishComponentBase
@inject IJSRuntime JS
@implements IAsyncDisposable
@implements IColorPickerViewHost

@using Sunfish.Foundation.Enums
@using Sunfish.Foundation.Models

@*
    SunfishColorPicker — unified Gradient + Palette + Flat color picker (Tier 2 W2).

    Spec mapping:
      colorpicker      → default (FlatMode=false, View=Gradient)  — dropdown trigger with popup.
      flatcolorpicker  → FlatMode=true                            — same UI inline (no popup).
      colorgradient    → FlatMode=true, View=Gradient             — gradient surface only.
      colorpalette     → FlatMode=true, View=Palette              — palette swatches only.

    Views:
      Gradient         — HSV canvas + hue + (opacity) + text inputs.
      Palette          — swatch grid.
      GradientPalette  — both, side-by-side.
*@

@* View child-tag registrations (outside popup so they persist across open/close) *@
<CascadingValue Value="(IColorPickerViewHost)this" IsFixed="true">
    @ColorPickerViews
</CascadingValue>

@if (FlatMode)
{
    @* ── Flat (inline) layout — no trigger, no popup ────────────────── *@
    <div class="@CombineClasses("mar-colorpicker mar-colorpicker--flat " + SizeClass + " " + RoundedClass + " " + FillModeClass + (Enabled ? "" : " mar-colorpicker--disabled"))"
         style="@CombineStyles()"
         @attributes="AdditionalAttributes"
         @ref="_rootRef"
         role="group"
         aria-label="Color picker">
        @RenderPickerBody
    </div>
}
else
{
    @* ── Dropdown layout: trigger + popup ──────────────────────────── *@
    <div class="@CombineClasses("mar-colorpicker " + SizeClass + " " + RoundedClass + " " + FillModeClass + (Enabled ? "" : " mar-colorpicker--disabled"))"
         style="@CombineStyles()"
         @attributes="AdditionalAttributes"
         @ref="_rootRef">

        <button type="button"
                class="sf-colorpicker__btn"
                disabled="@(!Enabled)"
                aria-haspopup="dialog"
                aria-expanded="@_isOpen.ToString().ToLowerInvariant()"
                aria-label="@($"Color picker, current color: {Value}")"
                @onclick="TogglePopupAsync"
                @onkeydown="OnTriggerKeyDown">
            <span class="sf-colorpicker__color-swatch"
                  style="background-color: @(_currentColor ?? "transparent");"
                  aria-hidden="true"></span>
            @if (!string.IsNullOrEmpty(Icon))
            {
                <span class="sf-colorpicker__icon" aria-hidden="true">
                    <span class="sf-icon sf-icon-@Icon"></span>
                </span>
            }
            <span class="sf-colorpicker__arrow" aria-hidden="true">&#9660;</span>
        </button>

        @if (Preview && !string.IsNullOrEmpty(_currentColor))
        {
            <span class="sf-colorpicker__preview-ext"
                  style="background-color: @_currentColor;"
                  aria-hidden="true"></span>
        }

        @if (_isOpen)
        {
            <div class="sf-colorpicker__popup"
                 role="dialog"
                 aria-label="Color picker"
                 aria-modal="true"
                 @onclick:stopPropagation="true"
                 @onkeydown="OnPopupKeyDown">
                @RenderPickerBody
            </div>

            <div class="sf-colorpicker__backdrop"
                 aria-hidden="true"
                 @onclick="OnBackdropClickAsync"
                 @onclick:stopPropagation="false"></div>
        }
    </div>
}

@code {
    // ── Parameters: Value / Format ──────────────────────────────────────
    /// <summary>The current color value string (hex or rgb / rgba / hsl). Supports two-way binding.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Fires on every value change (two-way binding callback).</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// The value format returned to the application (Rgb or Hex).
    /// Retained for compat; prefer the new <see cref="Format"/> parameter.
    /// </summary>
    [Parameter] public ColorFormat ValueFormat { get; set; } = ColorFormat.Rgb;

    /// <summary>
    /// The text-input format shown inside the picker (Hex / Rgb / Hsl).
    /// When set, this drives both the displayed channel boxes and the emitted <see cref="Value"/>.
    /// </summary>
    [Parameter] public ColorPickerFormat? Format { get; set; }

    // ── Parameters: Views ───────────────────────────────────────────────
    /// <summary>
    /// Which view is active. <see cref="ColorPickerView.GradientPalette"/> renders both
    /// the gradient surface and the palette tiles side by side. Supports two-way binding.
    /// </summary>
    [Parameter] public ColorPickerView View { get; set; } = ColorPickerView.Gradient;
    [Parameter] public EventCallback<ColorPickerView> ViewChanged { get; set; }

    /// <summary>
    /// The views the user can switch between (shown as toolbar tabs).
    /// When null, defaults to both Gradient and Palette. Pass a single-item list
    /// to hide the view toggle entirely.
    /// </summary>
    [Parameter] public IList<ColorPickerView>? Views { get; set; }

    /// <summary>Custom views configuration child content.</summary>
    [Parameter] public RenderFragment? ColorPickerViews { get; set; }

    // ── Parameters: Palette ─────────────────────────────────────────────
    /// <summary>
    /// Palette source. Accepts a preset name string
    /// (<c>"basic"</c>, <c>"officecolors"</c>, <c>"applea"</c>, <c>"extended"</c>, <c>"flat"</c>)
    /// or an <see cref="IList{String}"/> / <see cref="IEnumerable{String}"/> of CSS colors.
    /// </summary>
    [Parameter] public object? Palette { get; set; }

    /// <summary>Number of palette columns. Default <c>10</c>.</summary>
    [Parameter] public int Columns { get; set; } = 10;

    /// <summary>Palette tile size in pixels (applied to both width and height). Default <c>24</c>.</summary>
    [Parameter] public int PaletteTileSize { get; set; } = 24;

    // ── Parameters: Behavior ────────────────────────────────────────────
    /// <summary>
    /// When <c>true</c>, renders inline (no dropdown trigger / no popup).
    /// Corresponds to the <c>SunfishFlatColorPicker</c> spec.
    /// </summary>
    [Parameter] public bool FlatMode { get; set; }

    /// <summary>Whether the component is enabled.</summary>
    [Parameter] public bool Enabled { get; set; } = true;

    /// <summary>Convenience alias: when <c>true</c> the component is disabled (sets Enabled = false).</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Whether to show Apply / Cancel buttons.</summary>
    [Parameter] public bool ShowButtons { get; set; } = true;

    /// <summary>Whether to show the clear (×) button.</summary>
    [Parameter] public bool ClearButton { get; set; } = true;

    /// <summary>Whether to show the before/after preview strip.</summary>
    [Parameter] public bool Preview { get; set; } = true;

    /// <summary>
    /// Whether to show the WCAG contrast-ratio checker beneath the color inputs.
    /// Compares the selected color against <see cref="ContrastBackground"/>.
    /// </summary>
    [Parameter] public bool ContrastTool { get; set; }

    /// <summary>Background color used by <see cref="ContrastTool"/> (default <c>#ffffff</c>).</summary>
    [Parameter] public string ContrastBackground { get; set; } = "#ffffff";

    /// <summary>Optional icon identifier (font-icon name) rendered inside the trigger button.</summary>
    [Parameter] public string? Icon { get; set; }

    // ── Parameters: Events ──────────────────────────────────────────────
    /// <summary>Fires when a color is committed (Apply, palette click with no buttons, or Enter).</summary>
    [Parameter] public EventCallback<object?> OnChange { get; set; }

    /// <summary>Fires before the popup opens. Set <c>IsCancelled = true</c> to prevent opening.</summary>
    [Parameter] public EventCallback<ColorPickerOpenEventArgs> OnOpen { get; set; }

    /// <summary>Fires before the popup closes. Set <c>IsCancelled = true</c> to prevent closing.</summary>
    [Parameter] public EventCallback<ColorPickerCloseEventArgs> OnClose { get; set; }

    // ── Parameters: Appearance ──────────────────────────────────────────
    [Parameter] public string? Size { get; set; }
    [Parameter] public string? Rounded { get; set; }
    [Parameter] public string? FillMode { get; set; }

    /// <summary>Adaptive rendering mode for the popup on mobile devices.</summary>
    [Parameter] public AdaptiveMode AdaptiveMode { get; set; } = AdaptiveMode.None;

    // ── Internal: HSV state ─────────────────────────────────────────────
    private double _hue;
    private double _sat;
    private double _val = 1.0;
    private double _alpha = 1.0;
    private double _thumbX;
    private double _thumbY;
    private int _r, _g, _b;
    private string _hexText = "#000000";
    private ColorPickerFormat _textFormat = ColorPickerFormat.Hex;
    private bool _showOpacity = true;

    // ── Internal: Palette state ─────────────────────────────────────────
    private List<string> _paletteColors = new();
    private int _effectiveColumns = 10;
    private string _paletteTilePx = "24px";

    // ── Internal: View configuration ────────────────────────────────────
    private readonly List<ColorPickerViewBase> _registeredViews = new();
    private ColorPickerView _activeView = ColorPickerView.Gradient;
    private bool _hasGradientView => ResolveAvailableViews().Contains(ColorPickerView.Gradient)
        || ResolveAvailableViews().Contains(ColorPickerView.GradientPalette);
    private bool _hasPaletteView => ResolveAvailableViews().Contains(ColorPickerView.Palette)
        || ResolveAvailableViews().Contains(ColorPickerView.GradientPalette);

    // ── Internal: Popup state ───────────────────────────────────────────
    private bool _isOpen;
    private string? _currentColor;
    private string? _previewColor;

    // ── Internal: JS interop ────────────────────────────────────────────
    private ElementReference _canvasRef;
    private ElementReference _rootRef;
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<SunfishColorPicker>? _dotNetRef;

    // ── Internal: Unique IDs for accessibility ──────────────────────────
    private readonly string _uid = Guid.NewGuid().ToString("N")[..8];
    private string _hueInputId => $"mar-cp-hue-{_uid}";
    private string _opacityInputId => $"mar-cp-opacity-{_uid}";
    private string _hexInputId => $"mar-cp-hex-{_uid}";
    private string _rInputId => $"mar-cp-r-{_uid}";
    private string _gInputId => $"mar-cp-g-{_uid}";
    private string _bInputId => $"mar-cp-b-{_uid}";
    private string _aInputId => $"mar-cp-a-{_uid}";

    // ── CSS helpers ─────────────────────────────────────────────────────
    private string SizeClass => Size is { Length: > 0 } s ? $"mar-colorpicker--{s}" : "mar-colorpicker--md";
    private string RoundedClass => Rounded is { Length: > 0 } r ? $"mar-colorpicker--rounded-{r}" : "";
    private string FillModeClass => FillMode is { Length: > 0 } f ? $"mar-colorpicker--{f}" : "mar-colorpicker--solid";

    // ── View management (IColorPickerViewHost) ──────────────────────────
    void IColorPickerViewHost.RegisterView(ColorPickerViewBase view)
    {
        if (!_registeredViews.Contains(view))
        {
            _registeredViews.Add(view);
            ApplyViewSettings();
            _ = InvokeAsync(StateHasChanged);
        }
    }

    void IColorPickerViewHost.UnregisterView(ColorPickerViewBase view)
    {
        _ = InvokeAsync(() =>
        {
            if (_registeredViews.Remove(view))
            {
                ApplyViewSettings();
                StateHasChanged();
            }
        });
    }

    private IReadOnlyCollection<ColorPickerView> ResolveAvailableViews()
    {
        if (Views is { Count: > 0 })
            return Views.Distinct().ToList();
        if (_registeredViews.Count > 0)
            return _registeredViews.Select(v => v.ViewType).Distinct().ToList();
        return new[] { ColorPickerView.Gradient, ColorPickerView.Palette };
    }

    private void ApplyViewSettings()
    {
        // Gradient child config
        var gradient = _registeredViews.OfType<ColorPickerGradientView>().FirstOrDefault();
        if (gradient is not null)
        {
            _showOpacity = gradient.ShowOpacityEditor;
            if (gradient.Format is ColorFormat fmt)
                _textFormat = fmt == ColorFormat.Hex ? ColorPickerFormat.Hex : ColorPickerFormat.Rgb;
        }

        // Palette child config
        var palette = _registeredViews.OfType<ColorPickerPaletteView>().FirstOrDefault();
        if (palette is not null)
        {
            _effectiveColumns = palette.Columns;
            _paletteTilePx = palette.TileWidth;
            if (palette.Colors is not null)
                _paletteColors = palette.Colors.ToList();
        }
    }

    // ── Lifecycle ───────────────────────────────────────────────────────
    protected override void OnParametersSet()
    {
        if (Disabled) Enabled = false;

        // Resolve text-input format (Format param wins, else ValueFormat, else Hex default).
        _textFormat = Format ?? (ValueFormat == ColorFormat.Hex ? ColorPickerFormat.Hex : ColorPickerFormat.Rgb);

        // Active view follows the View parameter.
        _activeView = View;
        // If the requested view isn't in the allowed list, fall back to the first allowed.
        var allowed = ResolveAvailableViews();
        if (!allowed.Contains(_activeView))
            _activeView = allowed.FirstOrDefault();

        _effectiveColumns = Math.Max(1, Columns);
        _paletteTilePx = $"{Math.Max(8, PaletteTileSize)}px";

        // Resolve palette colors from the Palette parameter.
        _paletteColors = Palette switch
        {
            string name when !string.IsNullOrWhiteSpace(name) => ColorPalettePresets.Resolve(name).ToList(),
            IEnumerable<string> list => list.ToList(),
            _ => ColorPalettePresets.Basic.ToList(),
        };

        // Parse incoming Value into HSV/RGB state.
        if (Value is { Length: > 0 } v && !string.Equals(v, _currentColor, StringComparison.OrdinalIgnoreCase))
        {
            _currentColor = v;
            ParseColorToHsv(v);
            SyncTextInputs();
        }
        else if (string.IsNullOrEmpty(Value))
        {
            _currentColor = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("eval", GetCanvasScript());
        }

        // Initialise canvas when the gradient surface is visible.
        var gradientVisible = (FlatMode || _isOpen)
            && (_activeView == ColorPickerView.Gradient || _activeView == ColorPickerView.GradientPalette)
            && _hasGradientView
            && _jsModule is not null;

        if (gradientVisible)
        {
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await _jsModule!.InvokeVoidAsync("initCanvas", _canvasRef, _dotNetRef, _hue, _sat, _val);
                await _jsModule!.InvokeVoidAsync("moveThumb", _thumbX, _thumbY);
            }
            catch { /* canvas not yet in DOM */ }
        }
    }

    // ── Popup open / close ──────────────────────────────────────────────
    public async Task Open()
    {
        if (_isOpen || !Enabled || FlatMode) return;
        var args = new ColorPickerOpenEventArgs();
        await OnOpen.InvokeAsync(args);
        if (args.IsCancelled) return;
        _previewColor = _currentColor;
        _isOpen = true;
        StateHasChanged();
    }

    public async Task Close()
    {
        if (!_isOpen) return;
        var args = new ColorPickerCloseEventArgs();
        await OnClose.InvokeAsync(args);
        if (args.IsCancelled) return;
        _isOpen = false;
        StateHasChanged();
    }

    public async Task FocusAsync()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("focusElement", _rootRef);
    }

    private async Task TogglePopupAsync()
    {
        if (!Enabled) return;
        if (_isOpen) await CloseWithoutApplyAsync();
        else await Open();
    }

    private async Task CloseWithoutApplyAsync()
    {
        var args = new ColorPickerCloseEventArgs();
        await OnClose.InvokeAsync(args);
        if (args.IsCancelled) return;
        _isOpen = false;
    }

    private async Task OnBackdropClickAsync()
    {
        // Apply-on-outside-click matches spec.
        await ApplyAsync();
    }

    // ── View switching ──────────────────────────────────────────────────
    private async Task SwitchViewAsync(ColorPickerView view)
    {
        if (_activeView == view) return;
        _activeView = view;
        await ViewChanged.InvokeAsync(view);
    }

    // ── Color selection ─────────────────────────────────────────────────
    private async Task SelectPaletteColorAsync(string color)
    {
        _previewColor = color;
        ParseColorToHsv(color);
        SyncTextInputs();
        if (!ShowButtons || FlatMode)
        {
            await CommitColorAsync(color);
        }
    }

    private async Task ApplyAsync()
    {
        var color = BuildOutputColor();
        await CommitColorAsync(color);
        if (!FlatMode) await CloseWithoutApplyAsync();
    }

    private async Task CancelAsync()
    {
        if (_currentColor is { Length: > 0 } c)
            ParseColorToHsv(c);
        else
        {
            _hue = 0; _sat = 0; _val = 1; _alpha = 1;
        }
        SyncTextInputs();
        _previewColor = null;
        if (!FlatMode) await CloseWithoutApplyAsync();
    }

    private async Task ClearColorAsync()
    {
        _previewColor = null;
        await CommitColorAsync(null);
        if (!FlatMode) await CloseWithoutApplyAsync();
    }

    private async Task CommitColorAsync(string? color)
    {
        _currentColor = color;
        Value = color;
        await ValueChanged.InvokeAsync(color);
        await OnChange.InvokeAsync(color);
    }

    // ── Sliders & inputs ────────────────────────────────────────────────
    private async Task OnHueInput(ChangeEventArgs e)
    {
        if (!Enabled) return;
        if (double.TryParse(e.Value?.ToString(), out var h))
        {
            _hue = h;
            SyncTextInputs();
            _previewColor = BuildOutputColor();
            if (_jsModule is not null)
                await _jsModule.InvokeVoidAsync("updateHue", _hue, _sat, _val);
        }
    }

    private void OnOpacityInput(ChangeEventArgs e)
    {
        if (!Enabled) return;
        if (double.TryParse(e.Value?.ToString(), out var pct))
        {
            _alpha = pct / 100.0;
            SyncTextInputs();
            _previewColor = BuildOutputColor();
        }
    }

    private void OnHexInputInput(ChangeEventArgs e)
    {
        _hexText = e.Value?.ToString() ?? "";
    }

    private void OnHexInputChange(ChangeEventArgs e)
    {
        if (!Enabled) return;
        var raw = (e.Value?.ToString() ?? "").Trim();
        if (!raw.StartsWith('#')) raw = "#" + raw;
        if (TryParseHex(raw, out var r, out var g, out var b, out var a))
        {
            _r = r; _g = g; _b = b; _alpha = a / 255.0;
            RgbToHsv(r, g, b, out _hue, out _sat, out _val);
            UpdateThumbFromHsv();
            _hexText = BuildHex();
            _previewColor = BuildOutputColor();
        }
    }

    private void OnRgbChannelChange(ChangeEventArgs e, int channel)
    {
        if (!Enabled) return;
        if (!int.TryParse(e.Value?.ToString(), out var v)) return;
        v = Math.Clamp(v, 0, channel == 3 ? 100 : 255);
        switch (channel)
        {
            case 0: _r = v; break;
            case 1: _g = v; break;
            case 2: _b = v; break;
            case 3: _alpha = v / 100.0; break;
        }
        if (channel < 3)
            RgbToHsv(_r, _g, _b, out _hue, out _sat, out _val);
        UpdateThumbFromHsv();
        _hexText = BuildHex();
        _previewColor = BuildOutputColor();
    }

    // ── JS invokable: canvas drag callback ──────────────────────────────
    [JSInvokable]
    public void OnCanvasPick(double saturation, double brightness, double thumbX, double thumbY)
    {
        if (!Enabled) return;
        _sat = saturation;
        _val = brightness;
        _thumbX = thumbX;
        _thumbY = thumbY;
        SyncTextInputs();
        _previewColor = BuildOutputColor();
        StateHasChanged();
    }

    private async Task OnCanvasKeyDown(KeyboardEventArgs e)
    {
        if (!Enabled) return;
        const double step = 0.02;
        switch (e.Key)
        {
            case "ArrowRight": _sat = Math.Min(1, _sat + step); break;
            case "ArrowLeft":  _sat = Math.Max(0, _sat - step); break;
            case "ArrowUp":    _val = Math.Min(1, _val + step); break;
            case "ArrowDown":  _val = Math.Max(0, _val - step); break;
            default: return;
        }
        UpdateThumbFromHsv();
        SyncTextInputs();
        _previewColor = BuildOutputColor();
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("updateHue", _hue, _sat, _val);
    }

    private async Task OnTriggerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await TogglePopupAsync();
        else if (e.Key == "Escape" && _isOpen)
            await CancelAsync();
    }

    private async Task OnPopupKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            await CancelAsync();
        else if (e.Key == "Enter" && ShowButtons)
            await ApplyAsync();
    }

    private void ToggleTextFormat()
    {
        _textFormat = _textFormat switch
        {
            ColorPickerFormat.Hex => ColorPickerFormat.Rgb,
            ColorPickerFormat.Rgb => ColorPickerFormat.Hsl,
            _ => ColorPickerFormat.Hex,
        };
    }

    // ── Body render fragment (shared between Flat and Popup layouts) ────
    private RenderFragment RenderPickerBody => builder =>
    {
        var seq = 0;

        // Header (view toggles + preview + clear)
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "sf-colorpicker__popup-header");

        var available = ResolveAvailableViews();
        if (available.Count > 1)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "sf-colorpicker__view-toggle");
            builder.AddAttribute(seq++, "role", "group");
            builder.AddAttribute(seq++, "aria-label", "Color picker view");

            foreach (var view in available)
            {
                var isActive = _activeView == view;
                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "type", "button");
                builder.AddAttribute(seq++, "class",
                    "sf-colorpicker__view-btn " + (isActive ? "mar-colorpicker__view-btn--active" : ""));
                builder.AddAttribute(seq++, "aria-pressed", isActive ? "true" : "false");
                var captured = view;
                builder.AddAttribute(seq++, "onclick",
                    EventCallback.Factory.Create(this, () => SwitchViewAsync(captured)));
                builder.AddContent(seq++, view switch
                {
                    ColorPickerView.Gradient        => "Gradient",
                    ColorPickerView.Palette         => "Palette",
                    ColorPickerView.GradientPalette => "Both",
                    _                               => view.ToString(),
                });
                builder.CloseElement();
            }
            builder.CloseElement();
        }

        if (Preview)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "sf-colorpicker__preview-container");
            builder.AddAttribute(seq++, "aria-label", "Color preview");

            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "sf-colorpicker__preview-new");
            builder.AddAttribute(seq++, "style",
                $"background-color: {_previewColor ?? _currentColor ?? "transparent"};");
            builder.AddAttribute(seq++, "title", "New color");
            builder.CloseElement();

            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "sf-colorpicker__preview-current");
            builder.AddAttribute(seq++, "style", $"background-color: {_currentColor ?? "transparent"};");
            builder.AddAttribute(seq++, "title", "Current color");
            builder.CloseElement();

            builder.CloseElement();
        }

        if (ClearButton && Enabled)
        {
            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "type", "button");
            builder.AddAttribute(seq++, "class", "sf-colorpicker__clear-btn");
            builder.AddAttribute(seq++, "aria-label", "Clear color");
            builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, ClearColorAsync));
            builder.AddMarkupContent(seq++, "&#x2715;");
            builder.CloseElement();
        }

        builder.CloseElement(); // header

        // Views container — may render gradient, palette, or both.
        var showGradient = (_activeView == ColorPickerView.Gradient
                            || _activeView == ColorPickerView.GradientPalette)
                           && _hasGradientView;
        var showPalette = (_activeView == ColorPickerView.Palette
                           || _activeView == ColorPickerView.GradientPalette)
                          && _hasPaletteView;

        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class",
            "sf-colorpicker__views "
            + (_activeView == ColorPickerView.GradientPalette ? "sf-colorpicker__views--split" : ""));

        if (showGradient)
        {
            builder.AddContent(seq++, RenderGradientView);
        }
        if (showPalette)
        {
            builder.AddContent(seq++, RenderPaletteView);
        }

        builder.CloseElement(); // views

        if (ContrastTool)
        {
            builder.AddContent(seq++, RenderContrastTool);
        }

        if (ShowButtons && !FlatMode)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "sf-colorpicker__actions");

            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "type", "button");
            builder.AddAttribute(seq++, "class", "sf-colorpicker__apply-btn");
            builder.AddAttribute(seq++, "aria-label", "Apply color");
            builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, ApplyAsync));
            builder.AddContent(seq++, "Apply");
            builder.CloseElement();

            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "type", "button");
            builder.AddAttribute(seq++, "class", "sf-colorpicker__cancel-btn");
            builder.AddAttribute(seq++, "aria-label", "Cancel");
            builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, CancelAsync));
            builder.AddContent(seq++, "Cancel");
            builder.CloseElement();

            builder.CloseElement();
        }
    };

    // ── Gradient sub-view (HSV canvas + hue + opacity + text inputs) ────
