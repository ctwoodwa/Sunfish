@inherits SunfishComponentBase

<div class="@CombineClasses(RatingCss)"
     style="@CombineStyles()"
     role="radiogroup"
     aria-label="@(Label ?? "Rating")"
     @attributes="AdditionalAttributes">
    @for (var i = 1; i <= Max; i++)
    {
        var starIndex = i;
        var isFilled = starIndex <= Value;
        var iconName = isFilled ? "star-filled" : "star";

        if (IsReadOnly || !Enabled)
        {
            <span class="sf-rating__star @(isFilled ? "mar-rating__star--filled" : "")"
                  aria-label="@starIndex of @Max stars">
                @IconProvider.GetIconMarkup(iconName, IconSize.Medium)
            </span>
        }
        else
        {
            <button class="sf-rating__star @(isFilled ? "mar-rating__star--filled" : "")"
                    type="button"
                    aria-label="@starIndex of @Max stars"
                    @onclick="() => SetRating(starIndex)">
                @IconProvider.GetIconMarkup(iconName, IconSize.Medium)
            </button>
        }
    }
</div>

@code {
    [Parameter] public int Value { get; set; }
    [Parameter] public EventCallback<int> ValueChanged { get; set; }
    [Parameter] public int Max { get; set; } = 5;
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;
    [Parameter] public string? Label { get; set; }

    private string RatingCss
    {
        get
        {
            var cls = CssProvider.RatingClass();
            if (IsReadOnly) cls += " mar-rating--readonly";
            if (!Enabled) cls += " mar-rating--disabled";
            return cls;
        }
    }

    private async Task SetRating(int rating)
    {
        Value = rating;
        await ValueChanged.InvokeAsync(Value);
    }
}
