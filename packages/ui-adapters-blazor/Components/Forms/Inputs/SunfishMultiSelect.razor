@inherits SunfishComponentBase
@typeparam TItem
@typeparam TValue
@implements IMultiSelectSettingsSink
@using Sunfish.UIAdapters.Blazor.Enums
@using FilterOperator = Sunfish.Foundation.Enums.FilterOperator

<div class="@CombineClasses(CssProvider.MultiSelectClass(_isOpen, !IsEnabled, IsInvalid))"
     style="@CombineStyles(_widthStyle)"
     @attributes="AdditionalAttributes"
     @onkeydown="OnKeyDown"
     @onfocusout="HandleBlur"
     @onclick:stopPropagation="true"
     tabindex="@(IsEnabled ? (TabIndex ?? 0) : -1)"
     id="@Id"
     role="combobox"
     aria-haspopup="listbox"
     aria-expanded="@_isOpen.ToString().ToLowerInvariant()"
     aria-disabled="@(!IsEnabled).ToString().ToLowerInvariant()"
     aria-multiselectable="true"
     aria-owns="@_listboxId"
     aria-activedescendant="@(_highlightedIndex >= 0 ? $"{_listboxId}-opt-{_highlightedIndex}" : null)">

    @* Input area: tags + filter input *@
    <div class="sf-multiselect__input-area" @onclick="OnInputAreaClick" @onclick:stopPropagation="true">

        @* Selected tags *@
        @if (_selectedItems.Count > 0)
        {
            @if (TagMode == TagMode.Single)
            {
                <span class="@CssProvider.MultiSelectTagClass() mar-multiselect-tag--summary">
                    @if (SummaryTagTemplate != null)
                    {
                        @SummaryTagTemplate(Value)
                    }
                    else
                    {
                        <span>@Value.Count items selected</span>
                    }
                </span>
            }
            else
            {
                var visibleCount = MaxVisibleTags ?? _selectedItems.Count;
                var overflow = _selectedItems.Count - visibleCount;

                @for (int ti = 0; ti < Math.Min(visibleCount, _selectedItems.Count); ti++)
                {
                    var tagItem = _selectedItems[ti];
                    <span class="@CssProvider.MultiSelectTagClass()">
                        @if (ChipTemplate != null)
                        {
                            @ChipTemplate(tagItem)
                        }
                        else if (TagTemplate != null)
                        {
                            @TagTemplate(tagItem)
                        }
                        else
                        {
                            @GetText(tagItem)
                        }
                        @if (IsEnabled && !ReadOnly)
                        {
                            <button type="button"
                                    class="sf-multiselect-tag__remove"
                                    tabindex="-1"
                                    aria-label="@($"Remove {GetText(tagItem)}")"
                                    @onclick="() => RemoveItem(tagItem)"
                                    @onclick:stopPropagation="true">
                                &times;
                            </button>
                        }
                    </span>
                }

                @if (overflow > 0)
                {
                    <span class="@CssProvider.MultiSelectTagClass() mar-multiselect-tag--overflow">
                        +@overflow more
                    </span>
                }
            }
        }

        @* Filter / search input *@
        <input type="text"
               class="sf-multiselect__filter-input"
               value="@_filterText"
               @oninput="OnFilterInput"
               placeholder="@(_selectedItems.Count == 0 ? Placeholder : null)"
               disabled="@(!IsEnabled)"
               readonly="@ReadOnly"
               aria-autocomplete="list"
               aria-controls="@_listboxId"
               tabindex="-1" />

        @* Clear button *@
        @if (ShowClearButton && IsEnabled && !ReadOnly && _selectedItems.Count > 0)
        {
            <button type="button"
                    class="sf-multiselect__clear-btn"
                    tabindex="-1"
                    aria-label="Clear all"
                    @onclick="ClearAll"
                    @onclick:stopPropagation="true">
                &times;
            </button>
        }

        @* Arrow toggle *@
        @if (ShowArrowButton)
        {
            <button type="button"
                    class="sf-multiselect__arrow"
                    tabindex="-1"
                    aria-label="@(_isOpen ? "Close list" : "Open list")"
                    @onclick="ToggleDropdown"
                    @onclick:stopPropagation="true">
                &#9660;
            </button>
        }
    </div>

    @* Dropdown popup *@
    @if (_isOpen)
    {
        <div class="@CssProvider.MultiSelectPopupClass() @EffectivePopupClass"
             id="@_listboxId"
             role="listbox"
             style="@(EffectivePopupWidth is not null ? $"width:{EffectivePopupWidth};" : null)"
             aria-multiselectable="true"
             aria-label="@(Placeholder ?? "Options")"
             @onclick:stopPropagation="true">

            @if (HeaderTemplate != null)
            {
                <div class="sf-multiselect__header">@HeaderTemplate</div>
            }

            @if (IsVirtual)
            {
                <div class="sf-multiselect__virtual-container" style="height:@(EffectivePopupHeight ?? "200px"); overflow-y:auto;">
                    <Microsoft.AspNetCore.Components.Web.Virtualization.Virtualize Items="@_filteredItems"
                                                                                    Context="item"
                                                                                    ItemSize="@EffectiveVirtualItemHeight"
                                                                                    OverscanCount="@PageSize">
                        @{
                            var idx = _filteredItems.IndexOf(item);
                            var isHighlighted = idx == _highlightedIndex;
                            var itemValue = GetValue(item);
                            var isSelected = itemValue is not null && _selectedValues.Contains(itemValue);
                            MultiSelectItemRenderEventArgs<TItem>? renderArgs = null;
                            if (item is not null) _itemRenderCache.TryGetValue(item, out renderArgs);
                            var extraClass = renderArgs?.CssClass;
                            var itemDisabled = renderArgs?.IsDisabled ?? false;
                        }
                        <div id="@(_listboxId)-opt-@idx"
                             class="@CssProvider.MultiSelectItemClass(isHighlighted, isSelected) @extraClass"
                             role="option"
                             aria-selected="@isSelected.ToString().ToLowerInvariant()"
                             aria-disabled="@itemDisabled.ToString().ToLowerInvariant()"
                             @onclick="() => ToggleItem(item)"
                             @onclick:stopPropagation="true"
                             @onmouseover="() => _highlightedIndex = idx">
                            <input type="checkbox"
                                   checked="@isSelected"
                                   tabindex="-1"
                                   aria-hidden="true"
                                   disabled="@itemDisabled"
                                   @onclick:stopPropagation="true"
                                   @onclick:preventDefault="true" />
                            @if (ItemTemplate is not null)
                            {
                                @ItemTemplate(item)
                            }
                            else
                            {
                                <span>@GetText(item)</span>
                            }
                        </div>
                    </Microsoft.AspNetCore.Components.Web.Virtualization.Virtualize>
                </div>
            }
            else
            {
                <div class="sf-multiselect__list-container" style="@(_popupMaxHeightStyle)">
                    @{
                        // When GroupField is set, sort filtered indices by group key first so
                        // a single linear pass can emit a sticky group header each time the
                        // group key changes. Indices stay tied to _filteredItems so
                        // _highlightedIndex / aria-activedescendant remain valid.
                        // Note: the virtualized path above ignores GroupField — sticky group
                        // headers under <Virtualize> need a separate overlay approach.
                        var grouped = !string.IsNullOrEmpty(GroupField);
                        var orderedIndices = grouped
                            ? Enumerable.Range(0, _filteredItems.Count)
                                .OrderBy(idx => GetGroupKey(_filteredItems[idx]) ?? string.Empty,
                                         StringComparer.CurrentCultureIgnoreCase)
                                .ToList()
                            : Enumerable.Range(0, _filteredItems.Count).ToList();
                        string? lastGroupKey = null;
                    }
                    @foreach (var index in orderedIndices)
                    {
                        var item = _filteredItems[index];
                        var isHighlighted = index == _highlightedIndex;
                        var itemValue = GetValue(item);
                        var isSelected = itemValue is not null && _selectedValues.Contains(itemValue);
                        MultiSelectItemRenderEventArgs<TItem>? renderArgs = null;
                        if (item is not null) _itemRenderCache.TryGetValue(item, out renderArgs);
                        var extraClass = renderArgs?.CssClass;
                        var itemDisabled = renderArgs?.IsDisabled ?? false;

                        @if (grouped)
                        {
                            var groupKey = GetGroupKey(item) ?? string.Empty;
                            if (groupKey != lastGroupKey)
                            {
                                lastGroupKey = groupKey;
                                if (!string.IsNullOrEmpty(groupKey))
                                {
                                    <div class="sf-multiselect__group-header"
                                         role="presentation"
                                         style="position:sticky;top:0;z-index:1;background:inherit;">
                                        @groupKey
                                    </div>
                                }
                            }
                        }

                        <div id="@(_listboxId)-opt-@index"
                             class="@CssProvider.MultiSelectItemClass(isHighlighted, isSelected) @extraClass"
                             role="option"
                             aria-selected="@isSelected.ToString().ToLowerInvariant()"
                             aria-disabled="@itemDisabled.ToString().ToLowerInvariant()"
                             @onclick="() => ToggleItem(item)"
                             @onclick:stopPropagation="true"
                             @onmouseover="() => _highlightedIndex = index">
                            <input type="checkbox"
                                   checked="@isSelected"
                                   tabindex="-1"
                                   aria-hidden="true"
                                   disabled="@itemDisabled"
                                   @onclick:stopPropagation="true"
                                   @onclick:preventDefault="true" />
                            @if (ItemTemplate is not null)
                            {
                                @ItemTemplate(item)
                            }
                            else
                            {
                                <span>@GetText(item)</span>
                            }
                        </div>
                    }

                    @if (AllowCustom && !string.IsNullOrEmpty(_filterText) && !_filteredItems.Any(i => GetText(i) == _filterText))
                    {
                        <div class="sf-multiselect__item mar-multiselect__item--custom"
                             role="option"
                             @onclick="HandleAddCustom">
                            <span>Create: @_filterText</span>
                        </div>
                    }

                    @if (_filteredItems.Count == 0 && !(AllowCustom && !string.IsNullOrEmpty(_filterText)))
                    {
                        @if (NoDataTemplate != null)
                        {
                            @NoDataTemplate
                        }
                        else
                        {
                            <div class="sf-multiselect__no-data">No items found</div>
                        }
                    }
                </div>
            }

            @if (FooterTemplate != null)
            {
                <div class="sf-multiselect__footer">@FooterTemplate</div>
            }
        </div>

        @* Click-away overlay *@
        <div class="sf-multiselect__overlay" @onclick="CloseDropdown"></div>
    }

    @* Settings child components: non-visible cascade region. MultiSelectSettings and
       MultiSelectPopupSettings register themselves through the IMultiSelectSettingsSink
       cascade and produce no DOM. Cast to interface so the generic TItem/TValue type
       parameters do not leak into the non-generic children. *@
    @if (ChildContent != null)
    {
        <CascadingValue Value="(IMultiSelectSettingsSink)this" IsFixed="true">
            @ChildContent
        </CascadingValue>
    }
</div>

@code {
    // ── Type parameters ──────────────────────────────────────────────────────

    // TItem = data model type, TValue = value field type

    // ── Parameters ──────────────────────────────────────────────────────────
    [Parameter] public IEnumerable<TItem> Data { get; set; } = Enumerable.Empty<TItem>();
    [Parameter] public string? TextField { get; set; }
    [Parameter] public string? ValueField { get; set; }

    /// <summary>Selected values — use @bind-Value for two-way binding.</summary>
    [Parameter] public List<TValue> Value { get; set; } = new();
    [Parameter] public EventCallback<List<TValue>> ValueChanged { get; set; }

    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool IsInvalid { get; set; }

    // Filtering
    [Parameter] public bool Filterable { get; set; }

    /// <summary>
    /// String filter operator used for client-side filtering and forwarded in
    /// <see cref="OnRead"/> args. Mirrors <see cref="SunfishComboBox{TItem, TValue}.FilterOperator"/>.
    /// </summary>
    [Parameter] public FilterOperator FilterOperator { get; set; } = FilterOperator.StartsWith;

    /// <summary>Minimum characters required before filtering kicks in.</summary>
    [Parameter] public int MinLength { get; set; } = 1;
    [Parameter] public bool PersistFilterOnSelect { get; set; }

    /// <summary>Debounce window (ms) applied to filter input. <c>0</c> fires synchronously.</summary>
    [Parameter] public int DebounceDelay { get; set; } = 150;

    // Behavior
    [Parameter] public bool AutoClose { get; set; } = true;

    /// <summary>
    /// Controls how selected items are rendered in the trigger: <see cref="Enums.TagMode.Single"/>
    /// shows a summary chip ("3 items"); <see cref="Enums.TagMode.Multiple"/> renders one chip
    /// per value (default).
    /// </summary>
    [Parameter] public TagMode TagMode { get; set; } = TagMode.Multiple;
    [Parameter] public int? MaxVisibleTags { get; set; }
    [Parameter] public bool ShowClearButton { get; set; }
    [Parameter] public bool ShowArrowButton { get; set; } = true;

    // Virtualization
    /// <summary>Enables virtualization of the dropdown list.</summary>
    [Parameter] public bool EnableVirtualization { get; set; }

    /// <summary>
    /// ComboBox-parity alias for <see cref="EnableVirtualization"/>. When either is <c>true</c>
    /// the list is virtualized.
    /// </summary>
    [Parameter] public bool Virtual { get; set; }

    /// <summary>
    /// ComboBox-parity alias for <see cref="ItemHeight"/>. When set (non-zero) it wins over
    /// <see cref="ItemHeight"/> as the pixel height of each virtualized row.
    /// </summary>
    [Parameter] public int VirtualItemHeight { get; set; }

    [Parameter] public string? PopupHeight { get; set; }
    [Parameter] public string? PopupMaxHeight { get; set; }

    private bool IsVirtual => EnableVirtualization || Virtual;
    private float EffectiveVirtualItemHeight => VirtualItemHeight > 0 ? VirtualItemHeight : ItemHeight;

    // Appearance
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public int? TabIndex { get; set; }
    [Parameter] public string? PopupClass { get; set; }

    /// <summary>Specifies the adaptive rendering mode for the popup on mobile devices.</summary>
    [Parameter] public AdaptiveMode AdaptiveMode { get; set; } = AdaptiveMode.None;

    // Templates
    [Parameter] public RenderFragment<TItem>? ItemTemplate { get; set; }

    /// <summary>
    /// Template for selected chips rendered in the trigger. Takes precedence over
    /// <see cref="TagTemplate"/> when both are supplied.
    /// </summary>
    [Parameter] public RenderFragment<TItem>? ChipTemplate { get; set; }

    /// <summary>Alias of <see cref="ChipTemplate"/> kept for existing consumers.</summary>
    [Parameter] public RenderFragment<TItem>? TagTemplate { get; set; }
    [Parameter] public RenderFragment<List<TValue>>? SummaryTagTemplate { get; set; }
    [Parameter] public RenderFragment? HeaderTemplate { get; set; }
    [Parameter] public RenderFragment? FooterTemplate { get; set; }
    [Parameter] public RenderFragment? NoDataTemplate { get; set; }

    /// <summary>
    /// Declarative child content for the Telerik-shaped settings API. Accepts
    /// <see cref="MultiSelectSettings"/> and <see cref="MultiSelectPopupSettings"/>
    /// child components which register via an internal cascade and override the
    /// corresponding top-level parameters. The cascade region produces no visible DOM.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // Custom entry
    [Parameter] public bool AllowCustom { get; set; }

    /// <summary>
    /// Property name on TItem used to group items in the dropdown. When set, items
    /// are grouped alphabetically by the property value and a sticky group header
    /// is rendered above each group. Ignored when EnableVirtualization is true.
    /// </summary>
    [Parameter] public string? GroupField { get; set; }

    // Events
    [Parameter] public EventCallback<string> OnFilter { get; set; }
    [Parameter] public EventCallback<PopupEventArgs> OnOpen { get; set; }
    [Parameter] public EventCallback<PopupEventArgs> OnClose { get; set; }
    [Parameter] public EventCallback OnBlur { get; set; }

    /// <summary>
    /// Server-side data callback. When bound, the component invokes this on Open,
    /// Filter changes, and Rebind() instead of paging the local Data parameter.
    /// The handler must set Data and Total on the args.
    /// </summary>
    [Parameter] public EventCallback<MultiSelectReadEventArgs<TItem>> OnRead { get; set; }

    /// <summary>
    /// Async resolver invoked when Value contains entries that are not present in the
    /// current Data window. Returns the matching TItems so the component can render
    /// the tag chips for pre-selected remote values.
    /// </summary>
    [Parameter] public Func<IEnumerable<TValue>, Task<IEnumerable<TItem>>>? ValueMapper { get; set; }

    /// <summary>
    /// Fires after the selected values change in response to a user-driven action
    /// (toggle, remove, clear, custom add). Receives the new value list. Does NOT
    /// fire when the consumer sets Value externally via parameter binding.
    /// </summary>
    [Parameter] public EventCallback<List<TValue>> OnChange { get; set; }

    /// <summary>
    /// Fires for each filtered item once per cache rebuild (i.e., when the filter
    /// or data window changes), allowing the consumer to modify per-item rendering
    /// attributes such as CSS class or disabled state.
    /// </summary>
    [Parameter] public EventCallback<MultiSelectItemRenderEventArgs<TItem>> OnItemRender { get; set; }

    // Virtualization configuration

    /// <summary>
    /// Pixel height of each virtualized item. Defaults to 32. Only used when
    /// EnableVirtualization is true.
    /// </summary>
    [Parameter] public int ItemHeight { get; set; } = 32;

    /// <summary>
    /// Number of items to render outside the visible viewport (overscan count)
    /// when virtualization is enabled. Defaults to 3. Maps to Blazor's
    /// Virtualize.OverscanCount.
    /// </summary>
    [Parameter] public int PageSize { get; set; } = 3;

    // ── Private state ────────────────────────────────────────────────────────
    private bool _isOpen;
    private int _highlightedIndex = -1;
    private string _filterText = string.Empty;
    private List<TItem> _allItems = new();
    private List<TItem> _filteredItems = new();
    private List<TItem> _selectedItems = new();
    private HashSet<TValue> _selectedValues = new();
    private CancellationTokenSource? _filterDebounce;
    private CancellationTokenSource? _readCts;
    private bool _initialReadDone;
#pragma warning disable CS8714 // TItem may be nullable but is constrained by caller
    private Dictionary<TItem, MultiSelectItemRenderEventArgs<TItem>> _itemRenderCache = new();
#pragma warning restore CS8714

    // Settings child component registrations (Telerik-shaped child API). Populated
    // via the IMultiSelectSettingsSink cascade from MultiSelectSettings /
    // MultiSelectPopupSettings child components in ChildContent.
    private MultiSelectSettings? _registeredSettings;
    private MultiSelectPopupSettings? _registeredPopupSettings;

    private readonly string _listboxId = $"ms-{Guid.NewGuid():N}";
    private string _widthStyle => Width is not null ? $"width:{Width}" : string.Empty;
    private string _popupMaxHeightStyle => (EffectivePopupMaxHeight ?? EffectivePopupHeight) is string mh ? $"max-height:{mh};overflow-y:auto;" : string.Empty;

    // Effective settings: child override (when a settings child component registered)
    // wins over the parent parameter; null child falls through to the parent value.

    /// <summary>
    /// Shipped as plumbing for the future Adaptive rendering work; this value is not currently
    /// consumed by the component template.
    /// </summary>
    internal AdaptiveMode EffectiveAdaptiveMode =>
        _registeredSettings?.AdaptiveMode ?? AdaptiveMode;

    internal string? EffectivePopupHeight =>
        _registeredPopupSettings?.Height ?? PopupHeight;

    internal string? EffectivePopupMaxHeight =>
        _registeredPopupSettings?.MaxHeight ?? PopupMaxHeight;

    internal string? EffectivePopupWidth =>
        _registeredPopupSettings?.Width;

    internal string? EffectivePopupClass =>
        _registeredPopupSettings?.Class ?? PopupClass;

    private bool IsEnabled => Enabled && !Disabled;

    // ── IMultiSelectSettingsSink ─────────────────────────────────────────────
    // Registration callbacks invoked by MultiSelectSettings / MultiSelectPopupSettings
    // via the cascading parameter. Use InvokeAsync(StateHasChanged) so register/
    // unregister from OnInitialized / Dispose is dispatcher-safe.

    void IMultiSelectSettingsSink.RegisterSettings(MultiSelectSettings s)
    {
        _registeredSettings = s;
        InvokeAsync(StateHasChanged);
    }

    void IMultiSelectSettingsSink.UnregisterSettings(MultiSelectSettings s)
    {
        if (ReferenceEquals(_registeredSettings, s)) _registeredSettings = null;
        InvokeAsync(StateHasChanged);
    }

    void IMultiSelectSettingsSink.RegisterPopupSettings(MultiSelectPopupSettings s)
    {
        _registeredPopupSettings = s;
        InvokeAsync(StateHasChanged);
    }

    void IMultiSelectSettingsSink.UnregisterPopupSettings(MultiSelectPopupSettings s)
    {
        if (ReferenceEquals(_registeredPopupSettings, s)) _registeredPopupSettings = null;
        InvokeAsync(StateHasChanged);
    }

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnParametersSetAsync()
    {
        _allItems = Data?.ToList() ?? new List<TItem>();
        _selectedValues = new HashSet<TValue>(Value ?? Enumerable.Empty<TValue>());
        _selectedItems = _allItems
            .Where(item => { var v = GetValue(item); return v is not null && _selectedValues.Contains(v); })
            .ToList();

        // ValueMapper resolution: any selected values not present in _allItems get
        // resolved via the consumer-provided async mapper. This is the remote-data
        // pre-selection path — Value contains TValues whose TItems live on the server.
        if (ValueMapper is not null && _selectedValues.Count > _selectedItems.Count)
        {
            var resolvedValues = new HashSet<TValue>(
                _selectedItems.Select(GetValue).Where(v => v is not null).Cast<TValue>());
            var unresolved = _selectedValues.Where(v => !resolvedValues.Contains(v)).ToList();
            if (unresolved.Count > 0)
            {
                var mapped = await ValueMapper(unresolved);
                if (mapped is not null)
                {
                    foreach (var item in mapped)
                    {
                        var v = GetValue(item);
                        if (v is not null && _selectedValues.Contains(v) && !resolvedValues.Contains(v))
                        {
                            _selectedItems.Add(item);
                            resolvedValues.Add(v);
                        }
                    }
                }
            }
        }

        ApplyFilter();
        await RebuildItemRenderCacheAsync();
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    private string? GetText(TItem item)
    {
        if (item is null) return null;
        if (string.IsNullOrEmpty(TextField)) return item.ToString();
        return typeof(TItem).GetProperty(TextField)?.GetValue(item)?.ToString();
    }

    private TValue? GetValue(TItem item)
    {
        if (item is null) return default;
        if (string.IsNullOrEmpty(ValueField)) return (TValue?)(object?)item;
        var propValue = typeof(TItem).GetProperty(ValueField)?.GetValue(item);
        if (propValue is null) return default;
        return (TValue?)Convert.ChangeType(propValue, typeof(TValue));
    }

    private string? GetGroupKey(TItem item)
    {
        if (item is null || string.IsNullOrEmpty(GroupField)) return null;
        return typeof(TItem).GetProperty(GroupField)?.GetValue(item)?.ToString();
    }

    private void ApplyFilter()
    {
        if (!Filterable || string.IsNullOrEmpty(_filterText) || _filterText.Length < MinLength)
        {
            _filteredItems = _allItems.ToList();
            return;
        }

        _filteredItems = _allItems
            .Where(item =>
            {
                var text = GetText(item);
                if (text is null) return false;
                return FilterOperator switch
                {
                    FilterOperator.Contains => text.Contains(_filterText, StringComparison.OrdinalIgnoreCase),
                    FilterOperator.StartsWith => text.StartsWith(_filterText, StringComparison.OrdinalIgnoreCase),
                    FilterOperator.EndsWith => text.EndsWith(_filterText, StringComparison.OrdinalIgnoreCase),
                    FilterOperator.Equals => text.Equals(_filterText, StringComparison.OrdinalIgnoreCase),
                    FilterOperator.NotEquals => !text.Equals(_filterText, StringComparison.OrdinalIgnoreCase),
                    _ => text.Contains(_filterText, StringComparison.OrdinalIgnoreCase)
                };
            })
            .ToList();
    }

    /// <summary>
    /// Rebuilds the per-item render cache by invoking <see cref="OnItemRender"/> once
    /// per filtered item. Mirrors the <c>_cellRenderCache</c> pattern in SunfishDateTimePicker.
    /// Cheap when OnItemRender is not bound (early-returns after clearing).
    /// </summary>
    private async Task RebuildItemRenderCacheAsync()
    {
        _itemRenderCache.Clear();
        if (!OnItemRender.HasDelegate) return;

        foreach (var item in _filteredItems)
        {
            if (item is null) continue;
            var args = new MultiSelectItemRenderEventArgs<TItem> { Item = item };
            await OnItemRender.InvokeAsync(args);
            _itemRenderCache[item] = args;
        }
    }

    // ── Dropdown control ─────────────────────────────────────────────────────
    private async Task OnInputAreaClick()
    {
        if (!IsEnabled || ReadOnly) return;
        if (!_isOpen) await OpenDropdown();
    }

    private async Task ToggleDropdown()
    {
        if (!IsEnabled || ReadOnly) return;
        if (_isOpen) await CloseDropdown();
        else await OpenDropdown();
    }

    private async Task OpenDropdown()
    {
        var args = new PopupEventArgs();
        await OnOpen.InvokeAsync(args);
        if (args.IsCancelled) return;

        _filterText = string.Empty;
        _highlightedIndex = -1;
        _isOpen = true;

        // Lazy initial server read on first open when OnRead is bound and no data yet.
        if (OnRead.HasDelegate && !_initialReadDone)
        {
            await LoadServerDataAsync();
            _initialReadDone = true;
        }
        else
        {
            ApplyFilter();
            await RebuildItemRenderCacheAsync();
        }
    }

    private async Task CloseDropdown()
    {
        var args = new PopupEventArgs();
        await OnClose.InvokeAsync(args);
        if (args.IsCancelled) return;

        _filterText = string.Empty;
        ApplyFilter();
        _isOpen = false;
    }

    // ── Item selection ───────────────────────────────────────────────────────
    private async Task ToggleItem(TItem item)
    {
        if (!IsEnabled || ReadOnly) return;

        // Guard against selecting items the consumer marked disabled via OnItemRender.
        if (_itemRenderCache.TryGetValue(item, out var renderArgs) && renderArgs.IsDisabled) return;

        var value = GetValue(item);
        if (value is null) return;

        if (_selectedValues.Contains(value))
        {
            _selectedValues.Remove(value);
            _selectedItems.RemoveAll(i => Equals(GetValue(i), value));
        }
        else
        {
            _selectedValues.Add(value);
            _selectedItems.Add(item);
        }

        if (AutoClose)
        {
            await CloseDropdown();
        }
        else if (!PersistFilterOnSelect)
        {
            _filterText = string.Empty;
            ApplyFilter();
        }

        await EmitValueChanged();
    }

    private async Task RemoveItem(TItem item)
    {
        if (!IsEnabled || ReadOnly) return;

        var value = GetValue(item);
        if (value is null) return;

        _selectedValues.Remove(value);
        _selectedItems.RemoveAll(i => Equals(GetValue(i), value));
        await EmitValueChanged();
    }

    private async Task ClearAll()
    {
        _selectedValues.Clear();
        _selectedItems.Clear();
        await EmitValueChanged();
    }

    private async Task EmitValueChanged()
    {
        var list = _selectedValues.ToList();
        Value = list;
        await ValueChanged.InvokeAsync(list);
        if (OnChange.HasDelegate)
            await OnChange.InvokeAsync(list);
    }

    // ── Custom entry ─────────────────────────────────────────────────────────
    private async Task HandleAddCustom()
    {
        if (string.IsNullOrEmpty(_filterText)) return;
        try
        {
            var customValue = (TValue)Convert.ChangeType(_filterText, typeof(TValue));
            var newValue = new List<TValue>(Value) { customValue };
            Value = newValue;
            await ValueChanged.InvokeAsync(Value);
            _filterText = "";
            if (AutoClose) await Close();
        }
        catch (InvalidCastException) { }
        catch (FormatException) { }
    }

    // ── Filtering ────────────────────────────────────────────────────────────
    private async Task OnFilterInput(ChangeEventArgs e)
    {
        if (!Filterable) return;

        _filterText = e.Value?.ToString() ?? string.Empty;

        // Debounce
        _filterDebounce?.Cancel();
        _filterDebounce = new CancellationTokenSource();
        var token = _filterDebounce.Token;

        try
        {
            await Task.Delay(DebounceDelay, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        // Remote-data path: invoke OnRead with the new filter text.
        // Local-data path: apply local filter against _allItems.
        if (OnRead.HasDelegate)
        {
            await LoadServerDataAsync();
        }
        else
        {
            ApplyFilter();
            await RebuildItemRenderCacheAsync();
        }
        _highlightedIndex = _filteredItems.Count > 0 ? 0 : -1;

        if (OnFilter.HasDelegate)
            await OnFilter.InvokeAsync(_filterText);

        if (!_isOpen && _filteredItems.Count > 0)
            await OpenDropdown();
    }

    // ── Server-side data loading ─────────────────────────────────────────────
    private async Task LoadServerDataAsync()
    {
        if (!OnRead.HasDelegate) return;

        // Cancel any in-flight read so handlers can abort cleanly.
        _readCts?.Cancel();
        _readCts = new CancellationTokenSource();

        var args = new MultiSelectReadEventArgs<TItem>
        {
            Filter = string.IsNullOrEmpty(_filterText) ? null : _filterText,
            FilterOperator = FilterOperator,
            Skip = 0,
            Take = 0,
            Sorts = Array.Empty<SortDescriptor>(),
            Values = _selectedValues
                .Select(v => (object?)v)
                .ToList(),
            CancellationToken = _readCts.Token
        };

        await OnRead.InvokeAsync(args);

        if (_readCts.IsCancellationRequested) return;

        _allItems = args.Data?.ToList() ?? new List<TItem>();
        // Total is informational for the consumer's handler — reserved for future
        // virtual-scroll page-fetch cycles. Not currently consumed by the component.
        _filteredItems = _allItems.ToList();
        await RebuildItemRenderCacheAsync();

        // Recompute selected items against the new server data window so tags
        // for selected items already in this window stay rendered.
        var fromWindow = _allItems
            .Where(item => { var v = GetValue(item); return v is not null && _selectedValues.Contains(v); })
            .ToList();
        // Preserve any tags resolved earlier (e.g., via ValueMapper) whose items
        // are not in the current window — they remain in _selectedItems.
        var existingValues = new HashSet<TValue>(
            _selectedItems.Select(GetValue).Where(v => v is not null).Cast<TValue>());
        foreach (var item in fromWindow)
        {
            var v = GetValue(item);
            if (v is not null && !existingValues.Contains(v))
            {
                _selectedItems.Add(item);
                existingValues.Add(v);
            }
        }
    }

    // ── Keyboard navigation ───────────────────────────────────────────────────
    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (!IsEnabled) return;

        switch (e.Key)
        {
            case "ArrowDown":
                if (!_isOpen)
                {
                    await OpenDropdown();
                    _highlightedIndex = 0;
                }
                else if (_filteredItems.Count > 0)
                {
                    _highlightedIndex = (_highlightedIndex + 1) % _filteredItems.Count;
                }
                break;

            case "ArrowUp":
                if (_isOpen && _filteredItems.Count > 0)
                {
                    _highlightedIndex = _highlightedIndex <= 0
                        ? _filteredItems.Count - 1
                        : _highlightedIndex - 1;
                }
                break;

            case "Enter":
            case " " when _isOpen:
                if (_isOpen && _highlightedIndex >= 0 && _highlightedIndex < _filteredItems.Count)
                {
                    await ToggleItem(_filteredItems[_highlightedIndex]);
                }
                else if (!_isOpen)
                {
                    await OpenDropdown();
                }
                break;

            case "Escape":
                await CloseDropdown();
                break;

            case "Backspace":
                if (string.IsNullOrEmpty(_filterText) && _selectedItems.Count > 0)
                {
                    await RemoveItem(_selectedItems[^1]);
                }
                break;

            case "a" when e.CtrlKey:
                // Ctrl+A: select all visible
                foreach (var item in _filteredItems)
                {
                    var v = GetValue(item);
                    if (v is not null && !_selectedValues.Contains(v))
                    {
                        _selectedValues.Add(v);
                        _selectedItems.Add(item);
                    }
                }
                await EmitValueChanged();
                break;
        }
    }

    // ── Blur handling ────────────────────────────────────────────────────────
    private async Task HandleBlur(FocusEventArgs e)
    {
        await OnBlur.InvokeAsync();
    }

    // ── Public methods ───────────────────────────────────────────────────────
    public Task Open() => OpenDropdown();
    public Task Close() => CloseDropdown();
    public void Refresh()
    {
        _allItems = Data?.ToList() ?? new List<TItem>();
        ApplyFilter();
        StateHasChanged();
    }

    /// <summary>
    /// Forces a fresh data read. When OnRead is bound, invokes the callback again
    /// with the current filter text. Otherwise re-syncs from the local Data parameter.
    /// </summary>
    public async Task Rebind()
    {
        if (OnRead.HasDelegate)
        {
            await LoadServerDataAsync();
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            Refresh();
        }
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing)
        {
            _filterDebounce?.Dispose();
            _readCts?.Dispose();
        }
        base.Dispose(disposing);
    }
}
