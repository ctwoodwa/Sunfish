@inherits SunfishComponentBase
@typeparam TItem
@typeparam TValue

<div class="@CombineClasses(CssProvider.DropDownListClass(_isOpen, Disabled, IsInvalid))"
     style="@CombineStyles()"
     @onclick="ToggleDropdown"
     @onclick:stopPropagation="true"
     @onkeydown="OnKeyDown"
     tabindex="0"
     role="listbox"
     aria-expanded="@_isOpen.ToString().ToLowerInvariant()"
     aria-disabled="@Disabled.ToString().ToLowerInvariant()"
     @attributes="AdditionalAttributes">

    <div class="sf-dropdownlist__value">
        @if (_selectedItem is not null && ValueTemplate is not null)
        {
            @ValueTemplate(_selectedItem)
        }
        else if (_selectedItem is not null)
        {
            @GetText(_selectedItem)
        }
        else
        {
            <span class="sf-dropdownlist__placeholder">@(DefaultText ?? Placeholder)</span>
        }
    </div>

    <DropdownPopup IsOpen="@_isOpen">
        <div class="@CssProvider.DropDownListPopupClass()">
            @if (Filterable)
            {
                <input type="text"
                       class="sf-dropdownlist__filter-input"
                       value="@_filterText"
                       @oninput="OnFilterInput"
                       @onclick:stopPropagation="true"
                       placeholder="Search..." />
            }
            <ul role="listbox">
                @if (!string.IsNullOrEmpty(GroupField))
                {
                    var groups = GetGroupedItems();
                    var flatIndex = 0;
                    @foreach (var group in groups)
                    {
                        <li class="sf-dropdownlist__group-header" role="presentation">@group.Key</li>
                        @foreach (var item in group.Items)
                        {
                            var index = flatIndex;
                            var isHighlighted = index == _highlightedIndex;
                            var isSelected = Equals(GetValue(item), Value);
                            <li id="ddl-option-@index"
                                class="@CssProvider.DropDownListItemClass(isHighlighted, isSelected)"
                                role="option"
                                aria-selected="@isSelected.ToString().ToLowerInvariant()"
                                @onclick="() => SelectItem(item)"
                                @onclick:stopPropagation="true"
                                @onmouseover="() => _highlightedIndex = index">
                                @if (ItemTemplate is not null)
                                {
                                    @ItemTemplate(item)
                                }
                                else
                                {
                                    @GetText(item)
                                }
                            </li>
                            flatIndex++;
                        }
                    }
                }
                else
                {
                    @for (var i = 0; i < _filteredItems.Count; i++)
                    {
                        var index = i;
                        var item = _filteredItems[i];
                        var isHighlighted = index == _highlightedIndex;
                        var isSelected = Equals(GetValue(item), Value);
                        <li id="ddl-option-@index"
                            class="@CssProvider.DropDownListItemClass(isHighlighted, isSelected)"
                            role="option"
                            aria-selected="@isSelected.ToString().ToLowerInvariant()"
                            @onclick="() => SelectItem(item)"
                            @onclick:stopPropagation="true"
                            @onmouseover="() => _highlightedIndex = index">
                            @if (ItemTemplate is not null)
                            {
                                @ItemTemplate(item)
                            }
                            else
                            {
                                @GetText(item)
                            }
                        </li>
                    }
                }
            </ul>
        </div>
    </DropdownPopup>
</div>

@code {
    [Parameter] public IEnumerable<TItem> Data { get; set; } = Enumerable.Empty<TItem>();
    [Parameter] public string? TextField { get; set; }
    [Parameter] public string? ValueField { get; set; }
    [Parameter] public string? GroupField { get; set; }
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? DefaultText { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool IsInvalid { get; set; }
    [Parameter] public bool Filterable { get; set; }
    [Parameter] public EventCallback<TValue?> OnChange { get; set; }
    [Parameter] public RenderFragment<TItem>? ItemTemplate { get; set; }
    [Parameter] public RenderFragment<TItem>? ValueTemplate { get; set; }

    private bool _isOpen;
    private int _highlightedIndex = -1;
    private string _filterText = string.Empty;
    private List<TItem> _filteredItems = new();
    private TItem? _selectedItem;

    protected override void OnParametersSet()
    {
        ApplyFilter();
        UpdateSelectedItem();
    }

    private void UpdateSelectedItem()
    {
        if (Value is null)
        {
            _selectedItem = default;
            return;
        }

        _selectedItem = Data.FirstOrDefault(item => Equals(GetValue(item), Value));
    }

    private string? GetText(TItem item)
    {
        if (item is null) return null;
        if (string.IsNullOrEmpty(TextField)) return item.ToString();
        return typeof(TItem).GetProperty(TextField)?.GetValue(item)?.ToString();
    }

    private TValue? GetValue(TItem item)
    {
        if (item is null) return default;
        if (string.IsNullOrEmpty(ValueField)) return (TValue?)(object?)item;
        var propValue = typeof(TItem).GetProperty(ValueField)?.GetValue(item);
        if (propValue is null) return default;
        var targetType = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);
        return (TValue?)Convert.ChangeType(propValue, targetType);
    }

    private string? GetGroup(TItem item)
    {
        if (item is null || string.IsNullOrEmpty(GroupField)) return null;
        return typeof(TItem).GetProperty(GroupField)?.GetValue(item)?.ToString();
    }

    private record GroupResult(string Key, List<TItem> Items);

    private List<GroupResult> GetGroupedItems()
    {
        return _filteredItems
            .GroupBy(item => GetGroup(item) ?? "")
            .Select(g => new GroupResult(g.Key, g.ToList()))
            .ToList();
    }

    private void ToggleDropdown()
    {
        if (Disabled) return;
        _isOpen = !_isOpen;
        if (_isOpen)
        {
            _filterText = string.Empty;
            ApplyFilter();
            _highlightedIndex = -1;
        }
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrEmpty(_filterText))
        {
            _filteredItems = Data.ToList();
        }
        else
        {
            _filteredItems = Data
                .Where(item =>
                {
                    var text = GetText(item);
                    return text is not null && text.Contains(_filterText, StringComparison.OrdinalIgnoreCase);
                })
                .ToList();
        }
    }

    private void OnFilterInput(ChangeEventArgs e)
    {
        _filterText = e.Value?.ToString() ?? string.Empty;
        ApplyFilter();
        _highlightedIndex = _filteredItems.Count > 0 ? 0 : -1;
    }

    private async Task SelectItem(TItem item)
    {
        var value = GetValue(item);
        Value = value;
        _selectedItem = item;
        _isOpen = false;
        await ValueChanged.InvokeAsync(value);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (Disabled) return;

        switch (e.Key)
        {
            case "ArrowDown":
                if (!_isOpen)
                {
                    _isOpen = true;
                    _filterText = string.Empty;
                    ApplyFilter();
                    _highlightedIndex = 0;
                }
                else if (_filteredItems.Count > 0)
                {
                    _highlightedIndex = (_highlightedIndex + 1) % _filteredItems.Count;
                }
                break;

            case "ArrowUp":
                if (_isOpen && _filteredItems.Count > 0)
                {
                    _highlightedIndex = _highlightedIndex <= 0
                        ? _filteredItems.Count - 1
                        : _highlightedIndex - 1;
                }
                break;

            case "Enter":
                if (_isOpen && _highlightedIndex >= 0 && _highlightedIndex < _filteredItems.Count)
                {
                    await SelectItem(_filteredItems[_highlightedIndex]);
                }
                break;

            case "Escape":
                _isOpen = false;
                break;
        }
    }
}
