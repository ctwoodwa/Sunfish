@inherits SunfishComponentBase

<div class="@CombineClasses(DropZoneCss())"
     style="@CombineStyles()"
     id="@Id"
     @ondragover="HandleDragOver"
     @ondragover:preventDefault="true"
     @ondragleave="HandleDragLeave"
     @ondrop="HandleDrop"
     @ondrop:preventDefault="true"
     @onclick="HandleClick"
     @attributes="AdditionalAttributes">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        <div class="sf-dropzone__content">
            <span class="sf-dropzone__icon" aria-hidden="true">&#128193;</span>
            <span class="sf-dropzone__message">Drag files here or click to browse</span>
            @if (!string.IsNullOrEmpty(Note))
            {
                <span class="sf-dropzone__note">@Note</span>
            }
        </div>
    }

    <input type="file"
           class="sf-dropzone__input"
           accept="@Accept"
           multiple="@Multiple"
           disabled="@(!Enabled)"
           @ref="_fileInput"
           @onchange="HandleFileInput"
           style="display:none" />
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<DropZoneEventArgs> OnDrop { get; set; }
    [Parameter] public string? Accept { get; set; }
    [Parameter] public bool Multiple { get; set; } = true;
    [Parameter] public long MaxFileSize { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;
    [Parameter] public string? Id { get; set; }
    [Parameter] public string? Note { get; set; }

    private bool _isDragOver;
    private ElementReference _fileInput;

    private string DropZoneCss()
    {
        var css = "mar-dropzone";
        if (_isDragOver) css += " mar-dropzone--dragover";
        if (!Enabled) css += " mar-dropzone--disabled";
        return css;
    }

    private void HandleDragOver(DragEventArgs e)
    {
        if (!Enabled) return;
        _isDragOver = true;
    }

    private void HandleDragLeave(DragEventArgs e)
    {
        _isDragOver = false;
    }

    private async Task HandleDrop(DragEventArgs e)
    {
        if (!Enabled) return;
        _isDragOver = false;
        // Actual file data from drag events requires JS interop;
        // for prototype, raise the event with empty data to signal drop occurred.
        await OnDrop.InvokeAsync(new DropZoneEventArgs());
    }

    private Task HandleClick()
    {
        if (!Enabled) return Task.CompletedTask;
        // Trigger the hidden file input (requires JS interop in production;
        // for prototype the input is rendered and clickable via label association).
        return Task.CompletedTask;
    }

    private async Task HandleFileInput(ChangeEventArgs e)
    {
        // File input changed — in prototype, raise OnDrop with minimal info.
        await OnDrop.InvokeAsync(new DropZoneEventArgs());
    }
}
