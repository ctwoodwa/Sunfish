@namespace Sunfish.UIAdapters.Blazor.Components.Scheduling
@typeparam TEvent where TEvent : class
@inherits SunfishComponentBase
@using Sunfish.UIAdapters.Blazor.Enums
@using SchedulerView = Sunfish.UIAdapters.Blazor.Enums.SchedulerView

@{
    var containerStyle = new System.Text.StringBuilder();
    if (!string.IsNullOrEmpty(Width))  containerStyle.Append($"width:{Width};");
    if (!string.IsNullOrEmpty(Height)) containerStyle.Append($"height:{Height};");

    var days = GetVisibleDays();
}

<div class="@CombineClasses("sf-scheduler", $"sf-scheduler--{View.ToString().ToLowerInvariant()}")"
     style="@CombineStyles(containerStyle.ToString())"
     role="grid"
     aria-label="Scheduler"
     @attributes="AdditionalAttributes">

    @* WCAG 4.1.3 Status Messages — polite live region for view-change, navigation, and event-activation announcements. *@
    <div class="sf-scheduler__sr-only" role="status" aria-live="polite" aria-atomic="true"
         style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">@_liveAnnouncement</div>

    <div class="sf-scheduler__toolbar">
        <div class="sf-scheduler__nav">
            <button type="button" class="sf-scheduler__nav-btn" style="min-width:24px;min-height:24px;" @onclick="NavigatePrevious" aria-label="@GetPreviousNavLabel()">‹</button>
            <div class="sf-scheduler__title" aria-live="polite">@GetHeaderTitle()</div>
            <button type="button" class="sf-scheduler__nav-btn" style="min-width:24px;min-height:24px;" @onclick="NavigateNext" aria-label="@GetNextNavLabel()">›</button>
        </div>
        <div class="sf-scheduler__views" role="tablist" aria-label="Scheduler view">
            @foreach (var v in Enum.GetValues<SchedulerView>())
            {
                var isActive = v == View;
                <button type="button"
                        role="tab"
                        aria-selected="@isActive.ToString().ToLowerInvariant()"
                        class="@CombineClasses("sf-scheduler__view-btn", isActive ? "sf-scheduler__view-btn--active" : null)"
                        style="min-width:24px;min-height:24px;"
                        @onclick="() => SwitchView(v)">
                    @v
                </button>
            }
        </div>
    </div>

    @switch (View)
    {
        case SchedulerView.Month:
            <div class="sf-scheduler__month">
                <div class="sf-scheduler__month-grid" role="rowgroup">
                    @for (int w = 0; w < 6; w++)
                    {
                        <div class="sf-scheduler__month-row" role="row">
                            @for (int d = 0; d < 7; d++)
                            {
                                var cellDay = days[w * 7 + d];
                                var dayEvents = GetEventsOnDay(cellDay);
                                var isOtherMonth = cellDay.Month != CurrentDate.Month;
                                <div class="@CombineClasses("sf-scheduler__month-cell", isOtherMonth ? "sf-scheduler__month-cell--other" : null)"
                                     role="gridcell">
                                    <div class="sf-scheduler__month-cell-date">@cellDay.Day</div>
                                    @foreach (var evt in dayEvents.Take(3))
                                    {
                                        var captured = evt;
                                        var color = GetColor(captured) ?? "#1976d2";
                                        var evtLabel = $"{GetTitle(captured)}, {(GetAllDay(captured) ? "all day" : GetStart(captured).ToString("h:mm tt"))}";
                                        <button type="button"
                                                class="sf-scheduler__month-event"
                                                style="background:@color;min-height:24px;"
                                                aria-label="@evtLabel"
                                                @onclick="() => InvokeEventClick(captured)">
                                            @GetTitle(captured)
                                        </button>
                                    }
                                    @if (dayEvents.Count > 3)
                                    {
                                        <div class="sf-scheduler__month-more" aria-label="@((dayEvents.Count - 3) + " more events on this day")">+@(dayEvents.Count - 3) more</div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            break;

        case SchedulerView.Agenda:
            <div class="sf-scheduler__agenda">
                @{
                    var agendaEvents = GetAgendaEvents();
                }
                @if (agendaEvents.Count == 0)
                {
                    <div class="sf-scheduler__agenda-empty">No upcoming events.</div>
                }
                else
                {
                    <ul class="sf-scheduler__agenda-list" role="list">
                        @foreach (var evt in agendaEvents)
                        {
                            var captured = evt;
                            var color = GetColor(captured) ?? "#1976d2";
                            var ariaLabel = $"{GetTitle(captured)}, {GetStart(captured):ddd MMM d, h:mm tt}";
                            <li class="sf-scheduler__agenda-item">
                                <button type="button"
                                        class="sf-scheduler__agenda-item-btn"
                                        style="display:flex;align-items:center;gap:0.5rem;background:none;border:0;padding:0;width:100%;text-align:start;cursor:pointer;min-height:24px;"
                                        aria-label="@ariaLabel"
                                        @onclick="() => InvokeEventClick(captured)">
                                    <span class="sf-scheduler__agenda-color" style="background:@color" aria-hidden="true"></span>
                                    <div class="sf-scheduler__agenda-when">
                                        @GetStart(captured).ToString("ddd MMM d, h:mm tt")
                                    </div>
                                    <div class="sf-scheduler__agenda-title">@GetTitle(captured)</div>
                                </button>
                            </li>
                        }
                    </ul>
                }
            </div>
            break;

        default: // Day / Week / WorkWeek — time grid
            <div class="sf-scheduler__time-grid">
                <div class="sf-scheduler__time-header" role="row">
                    <div class="sf-scheduler__time-gutter" style="width:@(TimeGutterWidth)px"></div>
                    @foreach (var day in days)
                    {
                        <div class="sf-scheduler__time-header-cell" role="columnheader">
                            <div class="sf-scheduler__time-header-dow">@day.ToString("ddd")</div>
                            <div class="sf-scheduler__time-header-date">@day.Day</div>
                        </div>
                    }
                </div>
                <div class="sf-scheduler__time-body" role="row">
                    <div class="sf-scheduler__time-gutter-col" style="width:@(TimeGutterWidth)px">
                        @for (int h = StartHour; h < EndHour; h++)
                        {
                            <div class="sf-scheduler__time-gutter-row" style="height:@(HourSlotHeight)px">
                                @h:00
                            </div>
                        }
                    </div>
                    @foreach (var day in days)
                    {
                        <div class="sf-scheduler__time-col" role="gridcell">
                            @for (int h = StartHour; h < EndHour; h++)
                            {
                                <div class="sf-scheduler__time-slot" style="height:@(HourSlotHeight)px"></div>
                            }
                            @foreach (var evt in GetEventsOnDay(day))
                            {
                                var captured = evt;
                                if (GetAllDay(captured)) continue;
                                var (top, height) = ComputeTimedGeometry(captured);
                                var color = GetColor(captured) ?? "#1976d2";
                                var evtLabel = $"{GetTitle(captured)}, {GetStart(captured):ddd MMM d HH:mm} to {GetEnd(captured):HH:mm}";
                                <button type="button"
                                        class="sf-scheduler__time-event"
                                        style="top:@(top)px;height:@(height)px;background:@color;min-height:24px;"
                                        aria-label="@evtLabel"
                                        @onclick="() => InvokeEventClick(captured)">
                                    <span class="sf-scheduler__time-event-title">@GetTitle(captured)</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
            break;
    }
</div>
