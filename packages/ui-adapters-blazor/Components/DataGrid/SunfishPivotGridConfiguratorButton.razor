@inherits SunfishComponentBase

<button class="@CombineClasses(ButtonClass())"
        type="button"
        @onclick="HandleClick"
        @attributes="AdditionalAttributes">
    @if (ChildContent != null)
    {
        @ChildContent
    }
    else
    {
        <span class="sf-pivotgrid-configurator-button__icon">&#9881;</span>
        <span class="sf-pivotgrid-configurator-button__text">Configure</span>
    }
</button>

@code {
    /// <summary>Whether the configurator is currently shown. Supports two-way binding.</summary>
    [Parameter] public bool IsOpen { get; set; }

    /// <summary>Callback when IsOpen changes.</summary>
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    /// <summary>Custom button content. When null, a default icon and text are rendered.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string ButtonClass()
    {
        var cls = "mar-pivotgrid-configurator-button";
        if (IsOpen)
            cls += " mar-pivotgrid-configurator-button--active";
        return cls;
    }

    private async Task HandleClick()
    {
        IsOpen = !IsOpen;
        await IsOpenChanged.InvokeAsync(IsOpen);
    }
}
