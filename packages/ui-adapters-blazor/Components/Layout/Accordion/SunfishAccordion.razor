@namespace Sunfish.UIAdapters.Blazor.Components.Layout
@inherits SunfishComponentBase

<div class="@CombineClasses(CssProvider.AccordionClass())"
     style="@CombineStyles()"
     role="region"
     @attributes="AdditionalAttributes">

    @if (IsDataDriven)
    {
        @* Data-driven mode — flat or hierarchical. Supports recursive children via ItemsField. *@
        @RenderItems(Data!, 0)
    }
    else
    {
        @* Declarative / ChildContent mode — one level of SunfishAccordionItem children coordinated via CascadingValue. *@
        <CascadingValue Value="this" IsFixed="true">
            @ChildContent
        </CascadingValue>
    }
</div>

@code {
    // ── Internal state ──────────────────────────────────────────────────

    private HashSet<object> _expandedItems = [];
    private readonly List<SunfishAccordionItem> _items = [];

    // ── Parameters: Data Binding ────────────────────────────────────────

    /// <summary>Data source for data-driven accordion items. Supports flat or hierarchical (via <see cref="ItemsField"/>) collections.</summary>
    [Parameter] public IEnumerable<object>? Data { get; set; }

    /// <summary>Property name for the item display text. Defaults to "Text".</summary>
    [Parameter] public string TextField { get; set; } = "Text";

    /// <summary>Property name for the item icon. Defaults to "Icon".</summary>
    [Parameter] public string IconField { get; set; } = "Icon";

    /// <summary>Property name for the item navigation URL. Defaults to "Url".</summary>
    [Parameter] public string UrlField { get; set; } = "Url";

    /// <summary>Property name for the item disabled flag. Defaults to "Disabled".</summary>
    [Parameter] public string DisabledField { get; set; } = "Disabled";

    /// <summary>Property name for per-item initial expanded flag. Defaults to "Expanded".</summary>
    [Parameter] public string ExpandedField { get; set; } = "Expanded";

    /// <summary>Property name on each item that contains nested child items. When set (e.g. "Items"), the accordion renders recursively. Defaults to "Items".</summary>
    [Parameter] public string ItemsField { get; set; } = "Items";

    // ── Parameters: Expansion ───────────────────────────────────────────

    /// <summary>How items expand — Single (one at a time) or Multiple. Defaults to Multiple.</summary>
    [Parameter] public AccordionExpandMode ExpandMode { get; set; } = AccordionExpandMode.Multiple;

    /// <summary>The currently expanded items. Supports two-way binding.</summary>
    [Parameter] public IEnumerable<object>? ExpandedItems { get; set; }

    /// <summary>Fires when the expanded items collection changes (after expand/collapse is committed).</summary>
    [Parameter] public EventCallback<IEnumerable<object>> ExpandedItemsChanged { get; set; }

    /// <summary>Fires before an item expands. Set <see cref="AccordionExpandEventArgs.IsCancelled"/> to cancel.</summary>
    [Parameter] public EventCallback<AccordionExpandEventArgs> OnExpand { get; set; }

    /// <summary>Fires before an item collapses. Set <see cref="AccordionCollapseEventArgs.IsCancelled"/> to cancel.</summary>
    [Parameter] public EventCallback<AccordionCollapseEventArgs> OnCollapse { get; set; }

    // ── Parameters: Templates & Content ─────────────────────────────────

    /// <summary>Custom header template for data-driven items.</summary>
    [Parameter] public RenderFragment<object>? HeaderTemplate { get; set; }

    /// <summary>Custom content template for data-driven leaf items (items without children).</summary>
    [Parameter] public RenderFragment<object>? ContentTemplate { get; set; }

    /// <summary>Manual child content (SunfishAccordionItem components) — used when <see cref="Data"/> is not provided.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // ── Computed ────────────────────────────────────────────────────────

    /// <summary>True when the accordion is rendering from a bound <see cref="Data"/> collection.</summary>
    private bool IsDataDriven => Data != null && Data.Any();

    // ── Lifecycle ───────────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        if (ExpandedItems != null)
            _expandedItems = new HashSet<object>(ExpandedItems);
        else if (IsDataDriven)
            SeedExpandedFromExpandedField(Data!);
    }

    private void SeedExpandedFromExpandedField(IEnumerable<object> items)
    {
        foreach (var item in items)
        {
            if (GetPropertyBool(item, ExpandedField))
                _expandedItems.Add(item);

            if (GetChildren(item) is { } kids)
                SeedExpandedFromExpandedField(kids);
        }
    }

    // ── Public API ──────────────────────────────────────────────────────

    /// <summary>Forces a re-render with the current data (e.g. after mutating the source collection in place).</summary>
    public void Rebind() => StateHasChanged();

    // ── Internal API for manual AccordionItem children ──────────────────

    internal void RegisterItem(SunfishAccordionItem item)
    {
        if (!_items.Contains(item)) _items.Add(item);
    }

    internal void UnregisterItem(SunfishAccordionItem item)
    {
        _items.Remove(item);
    }

    internal async Task NotifyItemExpanded(SunfishAccordionItem expandedItem)
    {
        if (ExpandMode == AccordionExpandMode.Single)
        {
            foreach (var item in _items)
            {
                if (item != expandedItem && item.IsExpanded)
                {
                    await item.CollapseAsync();
                }
            }
        }
    }

    // ── Recursive data-driven renderer ──────────────────────────────────

    private RenderFragment RenderItems(IEnumerable<object> items, int depth) => builder =>
    {
        int seq = 0;
        foreach (var item in items)
        {
            var isExpanded = _expandedItems.Contains(item);
            var text = GetPropertyString(item, TextField);
            var icon = GetPropertyString(item, IconField);
            var url = GetPropertyString(item, UrlField);
            var disabled = GetPropertyBool(item, DisabledField);
            var contentId = $"acc-{item.GetHashCode():X8}-{depth}";
            var children = GetChildren(item);
            var hasChildren = children != null && children.Any();

            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", CssProvider.AccordionItemClass(isExpanded) + (hasChildren ? " sf-accordion-item--has-children" : "") + $" sf-accordion-item--depth-{depth}");

            // Header button
            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "type", "button");
            builder.AddAttribute(seq++, "class", "sf-accordion-item__header");
            builder.AddAttribute(seq++, "style", "min-width:24px;min-height:24px;");
            builder.AddAttribute(seq++, "aria-expanded", isExpanded.ToString().ToLowerInvariant());
            builder.AddAttribute(seq++, "aria-controls", contentId);
            builder.AddAttribute(seq++, "disabled", disabled);
            var clickItem = item;
            builder.AddAttribute(seq++, "onclick",
                Microsoft.AspNetCore.Components.EventCallback.Factory.Create(this, () => HandleItemToggle(clickItem)));

            if (HeaderTemplate != null)
            {
                builder.AddContent(seq++, HeaderTemplate(item));
            }
            else
            {
                if (!string.IsNullOrEmpty(icon))
                {
                    builder.OpenElement(seq++, "span");
                    builder.AddAttribute(seq++, "class", "sf-accordion-item__icon");
                    builder.AddContent(seq++, IconProvider.GetIconMarkup(icon, Sunfish.Foundation.Enums.IconSize.Small));
                    builder.CloseElement();
                }
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "sf-accordion-item__text");
                builder.AddContent(seq++, text);
                builder.CloseElement();
            }

            builder.CloseElement(); // </button>

            // Expanded body
            if (isExpanded)
            {
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "id", contentId);
                builder.AddAttribute(seq++, "class", "sf-accordion-item__content");

                if (hasChildren)
                {
                    // Recurse into nested items
                    builder.AddContent(seq++, RenderItems(children!, depth + 1));
                }
                else if (ContentTemplate != null)
                {
                    builder.AddContent(seq++, ContentTemplate(item));
                }
                else if (!string.IsNullOrEmpty(url))
                {
                    builder.OpenElement(seq++, "a");
                    builder.AddAttribute(seq++, "href", url);
                    builder.AddContent(seq++, text);
                    builder.CloseElement();
                }

                builder.CloseElement(); // </div content>
            }

            builder.CloseElement(); // </div item>
        }
    };

    // ── Data-driven event handlers ──────────────────────────────────────

    private async Task HandleItemToggle(object item)
    {
        if (GetPropertyBool(item, DisabledField)) return;

        var wasExpanded = _expandedItems.Contains(item);

        if (wasExpanded)
        {
            // Fire cancellable OnCollapse first
            if (OnCollapse.HasDelegate)
            {
                var args = new AccordionCollapseEventArgs { Item = item };
                await OnCollapse.InvokeAsync(args);
                if (args.IsCancelled) return;
            }
            _expandedItems.Remove(item);
        }
        else
        {
            // Fire cancellable OnExpand first
            if (OnExpand.HasDelegate)
            {
                var args = new AccordionExpandEventArgs { Item = item };
                await OnExpand.InvokeAsync(args);
                if (args.IsCancelled) return;
            }

            if (ExpandMode == AccordionExpandMode.Single)
            {
                // Collapse only siblings at the same depth — find the parent and clear its peers.
                var siblings = FindSiblings(Data!, item);
                foreach (var sibling in siblings.ToList())
                {
                    if (sibling != item && _expandedItems.Contains(sibling))
                        _expandedItems.Remove(sibling);
                }
            }
            _expandedItems.Add(item);
        }

        await ExpandedItemsChanged.InvokeAsync(_expandedItems.ToList());
        StateHasChanged();
    }

    /// <summary>Returns the sibling collection (including <paramref name="item"/>) within the Data tree.</summary>
    private IEnumerable<object> FindSiblings(IEnumerable<object> items, object item)
    {
        if (items.Contains(item)) return items;
        foreach (var candidate in items)
        {
            var kids = GetChildren(candidate);
            if (kids == null) continue;
            var sibs = FindSiblings(kids, item);
            if (sibs.Any()) return sibs;
        }
        return [];
    }

    // ── Helpers ─────────────────────────────────────────────────────────

    private IEnumerable<object>? GetChildren(object item)
    {
        if (string.IsNullOrEmpty(ItemsField)) return null;
        var raw = item.GetType().GetProperty(ItemsField)?.GetValue(item);
        if (raw is System.Collections.IEnumerable enumerable and not string)
            return enumerable.Cast<object>();
        return null;
    }

    private static string? GetPropertyString(object? item, string propertyName)
    {
        if (item is null || string.IsNullOrEmpty(propertyName)) return null;
        return item.GetType().GetProperty(propertyName)?.GetValue(item)?.ToString();
    }

    private static bool GetPropertyBool(object? item, string propertyName)
    {
        if (item is null || string.IsNullOrEmpty(propertyName)) return false;
        var prop = item.GetType().GetProperty(propertyName);
        if (prop is null) return false;
        return prop.GetValue(item) is true;
    }
}
