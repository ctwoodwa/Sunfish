@namespace Sunfish.UIAdapters.Blazor.Components.Layout
@using Sunfish.UIAdapters.Blazor.Enums
@inherits SunfishComponentBase

<div class="@CombineClasses(RootCssClass)"
     style="@CombineStyles(RootStyle)"
     @attributes="AdditionalAttributes">

    @* Hidden container for step registration via CascadingValue *@
    <div style="display:none">
        <CascadingValue Value="this" IsFixed="true">
            @ChildContent
        </CascadingValue>
    </div>

    @* Step indicators *@
    <div class="sf-wizard__steps @StepperCssClass" role="tablist" @onkeydown="HandleStepperKeyDown">
        @for (var i = 0; i < _steps.Count; i++)
        {
            var stepIndex = i;
            var step = _steps[i];
            var isCurrent = stepIndex == Value;
            var isCompleted = stepIndex < Value;
            var isClickable = !Linear || isCurrent || isCompleted;
            <button type="button"
                    class="sf-wizard__step @(isCurrent ? "mar-wizard__step--active" : "") @(isCompleted ? "mar-wizard__step--completed" : "") @(step.Disabled ? "mar-wizard__step--disabled" : "")"
                    role="tab"
                    aria-selected="@isCurrent.ToString().ToLowerInvariant()"
                    aria-controls="@($"mar-wizard-panel-{_instanceId}")"
                    aria-current="@(isCurrent ? "step" : null)"
                    tabindex="@(stepIndex == _focusedIndex ? 0 : -1)"
                    disabled="@(!isClickable || step.Disabled)"
                    draggable="@(Draggable ? "true" : null)"
                    @onclick="() => GoToStep(stepIndex)">
                @if (step.StepTemplate != null)
                {
                    @step.StepTemplate
                }
                else
                {
                    @if (EffectiveStepType != WizardStepType.Text)
                    {
                        <span class="sf-wizard__step-indicator">
                            @if (step.Valid == true)
                            {
                                <span class="sf-wizard__step-icon mar-wizard__step-icon--valid">&#x2713;</span>
                            }
                            else if (step.Valid == false)
                            {
                                <span class="sf-wizard__step-icon mar-wizard__step-icon--invalid">&#x2717;</span>
                            }
                            else
                            {
                                <span class="sf-wizard__step-number">@(isCompleted ? "✓" : (step.Text ?? (stepIndex + 1).ToString()))</span>
                            }
                        </span>
                    }
                    @if (ShowStepTitle && EffectiveStepType != WizardStepType.Steps && !string.IsNullOrEmpty(step.Label))
                    {
                        <span class="sf-wizard__step-label">
                            @step.Label
                            @if (step.Optional)
                            {
                                <span class="sf-wizard__step-optional">(Optional)</span>
                            }
                        </span>
                    }
                }
            </button>
            @if (i < _steps.Count - 1)
            {
                <span class="sf-wizard__connector @(isCompleted ? "mar-wizard__connector--completed" : "")"></span>
            }
        }
    </div>

    @* Active step content *@
    <div class="sf-wizard__content"
         id="@($"mar-wizard-panel-{_instanceId}")"
         role="tabpanel"
         aria-label="@($"Step {Value + 1} of {_steps.Count}")"
         tabindex="0">
        @if (Value >= 0 && Value < _steps.Count)
        {
            @(_steps[Value].EffectiveContent)
        }
    </div>

    @* Navigation buttons *@
    @if (EffectiveButtonTemplate != null)
    {
        <div class="sf-wizard__actions">
            @EffectiveButtonTemplate(Value)
        </div>
    }
    else
    {
        <div class="sf-wizard__actions">
            @if (Value > 0)
            {
                var prevDisabled = _steps.Count > 0 && Value - 1 >= 0 && _steps[Value - 1].Disabled;
                <button type="button" class="sf-btn mar-btn--flat" disabled="@prevDisabled" @onclick="PreviousStep">
                    @(PreviousText ?? "Previous")
                </button>
            }
            <span class="sf-wizard__spacer"></span>
            @if (ShowPager)
            {
                <span class="sf-wizard__pager">Step @(Value + 1) of @_steps.Count</span>
            }
            @if (Value < _steps.Count - 1)
            {
                var nextDisabled = IsNextBlocked();
                <button type="button" class="sf-btn mar-btn--primary" disabled="@nextDisabled" @onclick="NextStep">
                    @(NextText ?? "Next")
                </button>
            }
            else
            {
                <button type="button" class="sf-btn mar-btn--primary" @onclick="HandleFinish">
                    @(FinishText ?? "Finish")
                </button>
            }
        </div>
    }
</div>

@code {
    private readonly List<SunfishWizardStep> _steps = new();
    private int _focusedIndex;
    private readonly string _instanceId = Guid.NewGuid().ToString("N")[..8];

    // ── Parameters: structure ──────────────────────────────────────────

    /// <summary>Wizard body — hosts <see cref="SunfishWizardStep"/> (or spec-style <c>WizardStep</c>) children.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Read-only view of the registered steps (ICollection, as required by the hierarchical spec).</summary>
    public ICollection<SunfishWizardStep> Steps => _steps;

    // ── Parameters: step index (dual-named for spec + Sunfish conventions) ──

    /// <summary>Zero-based index of the current step. Spec-compatible name. Supports two-way binding.</summary>
    [Parameter] public int Value { get; set; }

    /// <summary>Change callback for <see cref="Value"/>.</summary>
    [Parameter] public EventCallback<int> ValueChanged { get; set; }

    /// <summary>Sunfish-canonical alias for <see cref="Value"/>. Supports two-way binding.</summary>
    [Parameter]
    public int CurrentStepIndex
    {
        get => Value;
        set => Value = value;
    }

    /// <summary>Change callback for <see cref="CurrentStepIndex"/>.</summary>
    [Parameter] public EventCallback<int> CurrentStepIndexChanged { get; set; }

    // ── Parameters: layout / behaviour ─────────────────────────────────

    /// <summary>
    /// When <c>true</c> (default) the user cannot skip ahead past uncompleted steps
    /// and Next is blocked if the current step reports <c>Valid == false</c>.
    /// </summary>
    [Parameter] public bool Linear { get; set; } = true;

    /// <summary>Stepper orientation — <see cref="WizardOrientation.Horizontal"/> (default) or <see cref="WizardOrientation.Vertical"/>.</summary>
    [Parameter] public WizardOrientation? Orientation { get; set; }

    /// <summary>Legacy 4-way stepper position (Top/Bottom/Left/Right). Inferred from <see cref="Orientation"/> when not set.</summary>
    [Parameter] public WizardStepperPosition StepperPosition { get; set; } = WizardStepperPosition.Top;

    /// <summary>Controls what each step on the rail renders: label only, chip only, or both (default).</summary>
    [Parameter] public WizardStepType? StepType { get; set; }

    /// <summary>Whether to render the step label next to the chip on the rail. Default <c>true</c>.</summary>
    [Parameter] public bool ShowStepTitle { get; set; } = true;

    /// <summary>Whether steps can be dragged to reorder. Default <c>false</c> — a pure UX hint today; reorder plumbing lands in Wave 3.</summary>
    [Parameter] public bool Draggable { get; set; }

    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Height { get; set; }
    [Parameter] public bool ShowPager { get; set; }

    // ── Parameters: built-in button labels ─────────────────────────────

    [Parameter] public string? PreviousText { get; set; }
    [Parameter] public string? NextText { get; set; }
    [Parameter] public string? FinishText { get; set; }

    // ── Parameters: custom buttons + events ────────────────────────────

    /// <summary>Canonical custom-button slot. Receives the current step index.</summary>
    [Parameter] public RenderFragment<int>? ButtonTemplate { get; set; }

    /// <summary>Spec-compatible alias for <see cref="ButtonTemplate"/>.</summary>
    [Parameter] public RenderFragment<int>? WizardButtons { get; set; }

    private RenderFragment<int>? EffectiveButtonTemplate => ButtonTemplate ?? WizardButtons;

    /// <summary>
    /// Fires when the Finish button is pressed on the last step.
    /// Not raised by custom <see cref="ButtonTemplate"/>/<see cref="WizardButtons"/> output.
    /// </summary>
    [Parameter] public EventCallback OnFinish { get; set; }

    /// <summary>
    /// Fires on the wizard before any navigation. Set
    /// <see cref="WizardStepChangeEventArgs.IsCancelled"/> to veto the transition.
    /// Complements the per-step <see cref="SunfishWizardStep.OnChange"/>.
    /// </summary>
    [Parameter] public EventCallback<WizardStepChangeEventArgs> OnStepChange { get; set; }

    /// <summary>Fires after the active step changes; the argument is the new index.</summary>
    [Parameter] public EventCallback<int> OnActivate { get; set; }

    // ── Computed presentation ──────────────────────────────────────────

    private WizardStepperPosition EffectivePosition => Orientation switch
    {
        WizardOrientation.Vertical => WizardStepperPosition.Left,
        WizardOrientation.Horizontal => WizardStepperPosition.Top,
        _ => StepperPosition,
    };

    private WizardStepType EffectiveStepType => StepType ?? WizardStepType.Full;

    private string RootCssClass
    {
        get
        {
            var pos = EffectivePosition.ToString().ToLowerInvariant();
            return $"mar-wizard mar-wizard--stepper-{pos}";
        }
    }

    private string? RootStyle
    {
        get
        {
            var parts = new List<string>();
            if (Width != null) parts.Add($"width:{Width}");
            if (Height != null) parts.Add($"height:{Height}");
            return parts.Count > 0 ? string.Join(";", parts) : null;
        }
    }

    private string StepperCssClass => EffectivePosition is WizardStepperPosition.Left or WizardStepperPosition.Right
        ? "mar-wizard__steps--vertical"
        : "";

    // ── Step registration ──────────────────────────────────────────────

    internal void RegisterStep(SunfishWizardStep step)
    {
        if (!_steps.Contains(step))
        {
            _steps.Add(step);
            StateHasChanged();
        }
    }

    internal void UnregisterStep(SunfishWizardStep step)
    {
        _steps.Remove(step);
        StateHasChanged();
    }

    // ── Navigation ─────────────────────────────────────────────────────

    private bool IsNextBlocked()
    {
        if (Value < 0 || Value >= _steps.Count - 1) return false;
        var current = _steps[Value];
        if (Linear && current.Valid == false) return true;
        var next = _steps[Value + 1];
        return next.Disabled;
    }

    private async Task GoToStep(int index)
    {
        if (index < 0 || index >= _steps.Count || _steps[index].Disabled) return;
        if (index == Value) return;

        // Linear guard: invalid current step blocks forward movement
        if (Linear && index > Value && Value < _steps.Count && _steps[Value].Valid == false)
        {
            return;
        }

        // Fire wizard-level OnStepChange first (cancellable)
        if (OnStepChange.HasDelegate)
        {
            var wizardArgs = new WizardStepChangeEventArgs { TargetIndex = index };
            await OnStepChange.InvokeAsync(wizardArgs);
            if (wizardArgs.IsCancelled) return;
        }

        // Fire current step's OnChange (also cancellable)
        if (Value >= 0 && Value < _steps.Count)
        {
            var currentStep = _steps[Value];
            if (currentStep.OnChange.HasDelegate)
            {
                var args = new WizardStepChangeEventArgs { TargetIndex = index };
                await currentStep.OnChange.InvokeAsync(args);
                if (args.IsCancelled) return;
            }
        }

        Value = index;
        _focusedIndex = index;
        await ValueChanged.InvokeAsync(Value);
        await CurrentStepIndexChanged.InvokeAsync(Value);
        await OnActivate.InvokeAsync(Value);
        if (index >= 0 && index < _steps.Count && _steps[index].OnActivate.HasDelegate)
        {
            await _steps[index].OnActivate.InvokeAsync(index);
        }
    }

    private async Task NextStep()
    {
        if (Value < _steps.Count - 1 && !IsNextBlocked())
            await GoToStep(Value + 1);
    }

    private async Task PreviousStep()
    {
        if (Value > 0)
            await GoToStep(Value - 1);
    }

    private async Task HandleFinish()
    {
        await OnFinish.InvokeAsync();
    }

    // ── Keyboard navigation (WAI-ARIA tablist) ─────────────────────────

    private void HandleStepperKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (_steps.Count == 0) return;

        var isVertical = EffectivePosition is WizardStepperPosition.Left or WizardStepperPosition.Right;
        var nextKey = isVertical ? "ArrowDown" : "ArrowRight";
        var prevKey = isVertical ? "ArrowUp" : "ArrowLeft";

        switch (e.Key)
        {
            case var k when k == nextKey:
                _focusedIndex = (_focusedIndex + 1) % _steps.Count;
                break;
            case var k when k == prevKey:
                _focusedIndex = (_focusedIndex - 1 + _steps.Count) % _steps.Count;
                break;
            case "Home":
                _focusedIndex = 0;
                break;
            case "End":
                _focusedIndex = _steps.Count - 1;
                break;
        }
    }
}
