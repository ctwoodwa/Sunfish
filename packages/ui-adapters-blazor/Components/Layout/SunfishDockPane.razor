@implements IAsyncDisposable

@if (DockManager != null && DockManager.IsPaneActive(this))
{
    <div class="sf-dockpane">
        @ChildContent
    </div>
}

@code {
    /// <summary>Display title for the pane tab.</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Unique identifier for the pane.</summary>
    [Parameter] public string? Id { get; set; }

    /// <summary>Content rendered inside the pane.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Whether the pane can be closed by the user. Defaults to true.</summary>
    [Parameter] public bool Closable { get; set; } = true;

    /// <summary>Whether the pane starts in floating (overlay) mode. Defaults to false.</summary>
    [Parameter] public bool IsFloating { get; set; }

    /// <summary>Logical tab group this pane belongs to. Used for cross-pane tab moves. Defaults to "root".</summary>
    [Parameter] public string TabGroupId { get; set; } = "root";

    /// <summary>Internal setter for DockManager cross-pane moves (avoids BL0005 by not setting the parameter directly from outside).</summary>
    internal void SetTabGroupId(string groupId) => TabGroupId = groupId;

    /// <summary>Minimum width constraint (e.g. "100px"). Enforced during floating resize. Defaults to "100px".</summary>
    [Parameter] public string MinWidth { get; set; } = "100px";

    /// <summary>Minimum height constraint (e.g. "100px"). Enforced during floating resize. Defaults to "100px".</summary>
    [Parameter] public string MinHeight { get; set; } = "100px";

    /// <summary>CSS top offset when floating. Defaults to "50px".</summary>
    [Parameter] public string FloatingTop { get; set; } = "50px";

    /// <summary>CSS left offset when floating. Defaults to "50px".</summary>
    [Parameter] public string FloatingLeft { get; set; } = "50px";

    /// <summary>CSS width when floating. Defaults to "400px".</summary>
    [Parameter] public string FloatingWidth { get; set; } = "400px";

    /// <summary>CSS height when floating. Defaults to "300px".</summary>
    [Parameter] public string FloatingHeight { get; set; } = "300px";

    /// <summary>Parent dock manager provided via cascading value.</summary>
    [CascadingParameter] public SunfishDockManager? DockManager { get; set; }

    /// <summary>
    /// Runtime floating state. Initialized from <see cref="IsFloating"/> parameter
    /// and toggled programmatically by the dock manager.
    /// </summary>
    internal bool IsCurrentlyFloating { get; set; }

    /// <summary>Runtime top position, initialized from <see cref="FloatingTop"/>.</summary>
    internal string RuntimeTop { get; set; } = "50px";

    /// <summary>Runtime left position, initialized from <see cref="FloatingLeft"/>.</summary>
    internal string RuntimeLeft { get; set; } = "50px";

    /// <summary>Runtime width, initialized from <see cref="FloatingWidth"/>.</summary>
    internal string RuntimeWidth { get; set; } = "400px";

    /// <summary>Runtime height, initialized from <see cref="FloatingHeight"/>.</summary>
    internal string RuntimeHeight { get; set; } = "300px";

    private bool _previousIsFloating;
    private string? _prevTop, _prevLeft, _prevWidth, _prevHeight;

    protected override async Task OnInitializedAsync()
    {
        IsCurrentlyFloating = IsFloating;
        _previousIsFloating = IsFloating;
        SyncRuntimePositionFromParameters();
        if (DockManager != null) await DockManager.RegisterPane(this);
    }

    protected override void OnParametersSet()
    {
        // Only sync from parameter when the parameter itself changed
        // (not when parent re-renders after a programmatic toggle)
        if (IsFloating != _previousIsFloating)
        {
            IsCurrentlyFloating = IsFloating;
            _previousIsFloating = IsFloating;
        }
        SyncRuntimePositionFromParameters();
    }

    private void SyncRuntimePositionFromParameters()
    {
        if (FloatingTop != _prevTop) { RuntimeTop = FloatingTop; _prevTop = FloatingTop; }
        if (FloatingLeft != _prevLeft) { RuntimeLeft = FloatingLeft; _prevLeft = FloatingLeft; }
        if (FloatingWidth != _prevWidth) { RuntimeWidth = FloatingWidth; _prevWidth = FloatingWidth; }
        if (FloatingHeight != _prevHeight) { RuntimeHeight = FloatingHeight; _prevHeight = FloatingHeight; }
    }

    public async ValueTask DisposeAsync()
    {
        if (DockManager != null) await DockManager.UnregisterPane(this);
    }
}
