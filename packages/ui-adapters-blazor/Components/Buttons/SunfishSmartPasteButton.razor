@inherits SunfishComponentBase

<button type="button"
        class="@CombineClasses($"mar-button mar-button--smart-paste mar-button--{Variant.ToString().ToLowerInvariant()} mar-button--{Size.ToString().ToLowerInvariant()}")"
        style="@CombineStyles()"
        disabled="@(!Enabled)"
        @onclick="OnClick"
        @attributes="AdditionalAttributes">
    <span class="sf-button__icon">&#128203;</span>
    @if (ChildContent != null)
    {
        @ChildContent
    }
    else
    {
        <span>Smart Paste</span>
    }
</button>

@code {
    /// <summary>Custom button label content. Defaults to "Smart Paste" text.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Whether the button is enabled.</summary>
    [Parameter] public bool Enabled { get; set; } = true;

    /// <summary>Callback invoked when the button is clicked.</summary>
    [Parameter] public EventCallback OnClick { get; set; }

    /// <summary>Visual variant of the button.</summary>
    [Parameter] public ButtonVariant Variant { get; set; } = ButtonVariant.Secondary;

    /// <summary>Size of the button.</summary>
    [Parameter] public ButtonSize Size { get; set; } = ButtonSize.Medium;
}
