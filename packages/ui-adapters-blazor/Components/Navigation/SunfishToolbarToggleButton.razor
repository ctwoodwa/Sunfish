@inherits SunfishComponentBase

<button class="@CombineClasses(CssProvider.ToolbarToggleButtonClass(IsActive, Disabled))"
        style="@CombineStyles()"
        disabled="@Disabled"
        title="@Title"
        aria-pressed="@IsActive.ToString().ToLowerInvariant()"
        @onclick="HandleClick"
        @attributes="AdditionalAttributes">
    @ChildContent
</button>

@code {
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public EventCallback<bool> IsActiveChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private async Task HandleClick()
    {
        IsActive = !IsActive;
        await IsActiveChanged.InvokeAsync(IsActive);
    }
}
