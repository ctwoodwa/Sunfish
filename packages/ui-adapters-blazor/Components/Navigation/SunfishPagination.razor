@namespace Sunfish.UIAdapters.Blazor.Components.Navigation
@using Sunfish.UIAdapters.Blazor.Enums
@inherits SunfishComponentBase

@* Inline min-width/min-height on every pagination button satisfies WCAG 2.2 SC 2.5.8
   (target-size) without relying on theme CSS, which the bUnit-axe harness does not
   load. Themes can raise these values further but must not drop below 24px. Mirrors
   the SunfishGridColumnMenu fix from PR #123. *@
<nav class="@CombineClasses(CssProvider.PaginationClass())"
     style="@CombineStyles()"
     role="navigation"
     aria-label="@AriaLabel"
     tabindex="@(Navigatable ? "0" : null)"
     @onkeydown="OnKeyDown"
     @attributes="AdditionalAttributes">

    @if (ResolvedShowInfo)
    {
        <span class="sf-pagination__info">@GetInfoText()</span>
    }

    @if (FirstLast)
    {
        <button type="button"
                class="sf-pagination__first"
                style="min-width:24px;min-height:24px;"
                disabled="@(Page <= 1)"
                aria-label="First page"
                title="First page"
                @onclick="GoToFirst">
            &laquo;
        </button>
    }

    @if (PreviousNext)
    {
        <button type="button"
                class="sf-pagination__prev"
                style="min-width:24px;min-height:24px;"
                disabled="@(Page <= 1)"
                aria-label="Previous page"
                title="Previous page"
                @onclick="PreviousPage">
            &lsaquo;
        </button>
    }

    @if (InputType == PagerInputType.Dropdown)
    {
        <span class="sf-pagination__page-label">Page</span>
        <select class="sf-pagination__page-select"
                aria-label="Current page"
                value="@Page"
                @onchange="HandlePageSelectChange">
            @for (var p = 1; p <= ComputedTotalPages; p++)
            {
                var pageNum = p;
                <option value="@pageNum" selected="@(pageNum == Page)">@pageNum</option>
            }
        </select>
        <span class="sf-pagination__page-of">of @ComputedTotalPages</span>
    }
    else if (InputType == PagerInputType.Input)
    {
        <span class="sf-pagination__page-label">Page</span>
        <input type="number"
               class="sf-pagination__page-input"
               min="1"
               max="@ComputedTotalPages"
               value="@Page"
               aria-label="Current page"
               @onchange="HandlePageInputChange" />
        <span class="sf-pagination__page-of">of @ComputedTotalPages</span>
    }
    else
    {
        @foreach (var slot in GetButtonSlots())
        {
            if (slot.IsEllipsis)
            {
                <button type="button"
                        class="sf-pagination__ellipsis"
                        style="min-width:24px;min-height:24px;"
                        disabled
                        aria-hidden="true"
                        tabindex="-1">
                    &hellip;
                </button>
            }
            else
            {
                var p = slot.Page;
                var isCurrent = p == Page;
                <button type="button"
                        class="@CssProvider.PaginationItemClass(isCurrent)"
                        style="min-width:24px;min-height:24px;"
                        aria-current="@(isCurrent ? "page" : null)"
                        aria-label="@($"Page {p}")"
                        @onclick="() => GoToPage(p)">
                    @p
                </button>
            }
        }
    }

    @if (PreviousNext)
    {
        <button type="button"
                class="sf-pagination__next"
                style="min-width:24px;min-height:24px;"
                disabled="@(Page >= ComputedTotalPages)"
                aria-label="Next page"
                title="Next page"
                @onclick="NextPage">
            &rsaquo;
        </button>
    }

    @if (FirstLast)
    {
        <button type="button"
                class="sf-pagination__last"
                style="min-width:24px;min-height:24px;"
                disabled="@(Page >= ComputedTotalPages)"
                aria-label="Last page"
                title="Last page"
                @onclick="GoToLast">
            &raquo;
        </button>
    }

    @if (ResolvedPageSizes is { Count: > 0 })
    {
        <select class="sf-pagination__page-size"
                aria-label="Items per page"
                value="@PageSize"
                @onchange="HandlePageSizeChange">
            @foreach (var size in ResolvedPageSizes)
            {
                <option value="@size" selected="@(size == PageSize)">@size</option>
            }
        </select>
    }

    @if (RefreshButton)
    {
        <button type="button"
                class="sf-pagination__refresh"
                style="min-width:24px;min-height:24px;"
                aria-label="Refresh"
                title="Refresh"
                @onclick="HandleRefresh">
            &#x21bb;
        </button>
    }
</nav>
