@namespace Sunfish.UIAdapters.Blazor.Components.Navigation
@inherits SunfishComponentBase

<nav class="@CombineClasses(CssProvider.BreadcrumbClass())"
     style="@CombineStyles()"
     aria-label="breadcrumb"
     @attributes="AdditionalAttributes">
    <ol>
        @if (Data != null)
        {
            @foreach (var item in Data)
            {
                var text = GetPropertyValue(item, TextField);
                var url = GetPropertyValue(item, UrlField);
                var icon = GetPropertyValue(item, IconField);

                @* Inline min-width/min-height satisfies WCAG 2.2 SC 2.5.8 (target-size) for
                   raw <a>/<span> children that bypass the SunfishBreadcrumbItem wrapper.
                   PR #112 covered the canonical wrapper path; this extends the floor to
                   the data-driven path. The bUnit-axe harness does not load theme CSS so
                   the structural floor must travel with the markup itself. *@
                <li class="sf-breadcrumb__item">
                    @if (ItemTemplate != null)
                    {
                        @ItemTemplate(item)
                    }
                    else if (!string.IsNullOrEmpty(url))
                    {
                        <a href="@url" style="min-width:24px;min-height:24px;display:inline-flex;align-items:center;justify-content:center;padding:4px;">
                            @if (!string.IsNullOrEmpty(icon))
                            {
                                <span class="sf-breadcrumb__icon">@icon</span>
                            }
                            @text
                        </a>
                    }
                    else
                    {
                        <span style="min-width:24px;min-height:24px;display:inline-flex;align-items:center;justify-content:center;padding:4px;">
                            @if (!string.IsNullOrEmpty(icon))
                            {
                                <span class="sf-breadcrumb__icon">@icon</span>
                            }
                            @text
                        </span>
                    }
                </li>
            }
        }
        else
        {
            @ChildContent
        }
    </ol>
</nav>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Data source for breadcrumb items.</summary>
    [Parameter] public IEnumerable<object>? Data { get; set; }
    [Parameter] public string TextField { get; set; } = "Text";
    [Parameter] public string UrlField { get; set; } = "Url";
    [Parameter] public string IconField { get; set; } = "Icon";

    /// <summary>Custom template for rendering each breadcrumb item.</summary>
    [Parameter] public RenderFragment<object>? ItemTemplate { get; set; }

    private static string? GetPropertyValue(object item, string propertyName)
    {
        return item.GetType().GetProperty(propertyName)?.GetValue(item)?.ToString();
    }
}
