@namespace Sunfish.UIAdapters.Blazor.Components.AI
@inherits SunfishComponentBase

@*
    SunfishAIPrompt — MVP spec-aligned shell (Tier 3 W3-1).

    Prompt surface with:
      * textarea input bound to Value (two-way via ValueChanged)
      * cancellable OnPrompt event (AIPromptEventArgs)
      * Streaming output placeholder (pure UI; no LLM engine wired)
      * Optional model-picker driven by Models / SelectedModel
      * Right-rail history list

    Canonical API — matches apps/docs/component-specs/aiprompt. No external deps
    (no Microsoft.Extensions.AI / no commands / no toolbar) — those are layered
    in subsequent tiers. This file intentionally stays lean and self-contained.
*@

<div class="@CombineClasses("sf-aiprompt")"
     style="@CombineStyles()"
     @attributes="AdditionalAttributes">

    <div class="sf-aiprompt__main">
        @if (Models is { Count: > 0 })
        {
            <div class="sf-aiprompt__model-picker">
                <label class="sf-aiprompt__model-label" for="@_modelPickerId">Model</label>
                <select id="@_modelPickerId"
                        class="sf-aiprompt__model-select"
                        value="@SelectedModel"
                        disabled="@Disabled"
                        @onchange="HandleModelChanged">
                    @foreach (var model in Models)
                    {
                        <option value="@model">@model</option>
                    }
                </select>
            </div>
        }

        <textarea class="sf-aiprompt__input"
                  rows="3"
                  placeholder="@Placeholder"
                  disabled="@Disabled"
                  value="@Value"
                  @oninput="HandleInput"
                  @onkeydown="HandleKeyDown"></textarea>

        <div class="sf-aiprompt__actions">
            <button type="button"
                    class="sf-aiprompt__submit"
                    disabled="@(Disabled || Streaming || string.IsNullOrWhiteSpace(Value))"
                    @onclick="SubmitAsync">
                @if (Streaming)
                {
                    <span class="sf-aiprompt__spinner" aria-hidden="true">…</span>
                    <span>Streaming…</span>
                }
                else
                {
                    <span>Send</span>
                }
            </button>
        </div>

        @if (Streaming || !string.IsNullOrEmpty(StreamedOutput))
        {
            <div class="sf-aiprompt__output" aria-live="polite">
                @if (OutputTemplate is not null)
                {
                    @OutputTemplate(StreamedOutput ?? string.Empty)
                }
                else
                {
                    <pre class="sf-aiprompt__output-pre">@StreamedOutput</pre>
                }
                @if (Streaming)
                {
                    <span class="sf-aiprompt__caret" aria-hidden="true">▊</span>
                }
            </div>
        }
    </div>

    @if (History is { Count: > 0 })
    {
        <aside class="sf-aiprompt__history" aria-label="Prompt history">
            <h4 class="sf-aiprompt__history-title">History</h4>
            <ul class="sf-aiprompt__history-list">
                @foreach (var item in History)
                {
                    <li class="sf-aiprompt__history-item">
                        <button type="button"
                                class="sf-aiprompt__history-button"
                                disabled="@Disabled"
                                @onclick="() => ReplayAsync(item)">
                            @item
                        </button>
                    </li>
                }
            </ul>
        </aside>
    }
</div>

@code {
    private readonly string _modelPickerId = $"sf-aiprompt-model-{Guid.NewGuid():N}";

    /// <summary>The current prompt text. Supports two-way binding via <see cref="ValueChanged"/>.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Two-way binding callback for <see cref="Value"/>.</summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Fires when the user submits the prompt (Enter / Send click). Cancellable
    /// via <see cref="AIPromptEventArgs.IsCancelled"/>.
    /// </summary>
    [Parameter] public EventCallback<AIPromptEventArgs> OnPrompt { get; set; }

    /// <summary>
    /// Whether a response is currently streaming. When true the component renders
    /// the streaming caret and disables the submit button.
    /// </summary>
    [Parameter] public bool Streaming { get; set; }

    /// <summary>
    /// Incremental output to display while <see cref="Streaming"/> is true. The
    /// host is responsible for appending tokens to this string.
    /// </summary>
    [Parameter] public string? StreamedOutput { get; set; }

    /// <summary>
    /// Optional template for rendering <see cref="StreamedOutput"/>. Receives the
    /// current streamed text and is invoked once per render while streaming.
    /// </summary>
    [Parameter] public RenderFragment<string>? OutputTemplate { get; set; }

    /// <summary>Prompt-history items shown in the right-rail list.</summary>
    [Parameter] public IReadOnlyList<string>? History { get; set; }

    /// <summary>Available model ids rendered in the model-picker dropdown.</summary>
    [Parameter] public IReadOnlyList<string>? Models { get; set; }

    /// <summary>Currently-selected model id. Two-way bound via <see cref="SelectedModelChanged"/>.</summary>
    [Parameter] public string? SelectedModel { get; set; }

    /// <summary>Two-way binding callback for <see cref="SelectedModel"/>.</summary>
    [Parameter] public EventCallback<string?> SelectedModelChanged { get; set; }

    /// <summary>Whether the component is disabled (all inputs read-only).</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Placeholder shown in the textarea when empty.</summary>
    [Parameter] public string Placeholder { get; set; } = "Ask AI anything…";

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Ctrl/Meta + Enter submits; bare Enter inserts a newline.
        if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey))
        {
            await SubmitAsync();
        }
    }

    private async Task HandleModelChanged(ChangeEventArgs e)
    {
        SelectedModel = e.Value?.ToString();
        await SelectedModelChanged.InvokeAsync(SelectedModel);
    }

    private async Task SubmitAsync()
    {
        if (Disabled || Streaming || string.IsNullOrWhiteSpace(Value)) return;

        var args = new AIPromptEventArgs(Value, SelectedModel);
        if (OnPrompt.HasDelegate) await OnPrompt.InvokeAsync(args);

        if (!args.IsCancelled)
        {
            Value = string.Empty;
            await ValueChanged.InvokeAsync(Value);
        }
    }

    private async Task ReplayAsync(string prompt)
    {
        if (Disabled) return;
        Value = prompt;
        await ValueChanged.InvokeAsync(Value);
    }
}
