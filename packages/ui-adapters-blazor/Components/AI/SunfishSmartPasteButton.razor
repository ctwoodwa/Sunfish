@namespace Sunfish.UIAdapters.Blazor.Components.AI
@inherits SunfishComponentBase
@inject IJSRuntime JS

@*
    SunfishSmartPasteButton — MVP spec-aligned shell (Tier 3 W3-1).

    Clipboard-aware paste button. Reads text from the host clipboard via
    navigator.clipboard.readText() and dispatches the result on OnPaste. Hosts
    are responsible for parsing the payload (AI-assisted form-fill, structured
    extraction, etc.) — the MVP simply hands the raw text over.

    Status: implemented — the clipboard read happens via standard JS interop that
    does not require a bespoke module, so the MVP is functionally complete.
*@

<button type="button"
        class="@CombineClasses("sf-smart-paste-button")"
        style="@CombineStyles()"
        disabled="@Disabled"
        @onclick="HandleClickAsync"
        @attributes="AdditionalAttributes">
    <span class="sf-smart-paste-button__icon" aria-hidden="true">📋</span>
    <span class="sf-smart-paste-button__label">@Label</span>
</button>

@code {
    /// <summary>Fires with the clipboard text after a successful read.</summary>
    [Parameter] public EventCallback<string> OnPaste { get; set; }

    /// <summary>Whether the button is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Visible button label.</summary>
    [Parameter] public string Label { get; set; } = "Smart Paste";

    private async Task HandleClickAsync()
    {
        if (Disabled) return;

        string? text = null;
        try
        {
            // Standard browser API — no custom JS module required.
            text = await JS.InvokeAsync<string>("navigator.clipboard.readText");
        }
        catch
        {
            // Permission denied / non-browser host / pre-rendering — swallow and
            // fire OnPaste with empty string so hosts can surface their own UX.
        }

        if (OnPaste.HasDelegate) await OnPaste.InvokeAsync(text ?? string.Empty);
    }
}
