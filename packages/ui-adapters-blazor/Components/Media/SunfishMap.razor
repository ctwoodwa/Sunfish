@namespace Sunfish.UIAdapters.Blazor.Components.Media
@inherits SunfishComponentBase
@implements IAsyncDisposable

<div class="@CombineClasses("sf-map")"
     style="@CombineStyles($"width:{Width};height:{Height};display:block;position:relative;")"
     @attributes="AdditionalAttributes">

    @* Preview fallback: shown until the JS engine boots (or always, if the JS module is not wired up). *@
    <div @ref="_containerRef" id="@_containerId" class="sf-map__canvas"
         style="width:100%;height:100%;background:#e8eef5;border:1px solid #c5d2e0;border-radius:4px;overflow:hidden;position:relative;">

        @if (!_jsInitialized)
        {
            <div class="sf-map__preview"
                 style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;color:#3a557a;font-family:system-ui,sans-serif;">
                <div style="font-size:28px;">🗺</div>
                <div style="font-weight:600;">Map preview</div>
                <div style="font-size:12px;opacity:.75;">
                    center (@Latitude.ToString("0.###"), @Longitude.ToString("0.###")) · zoom @Zoom
                </div>
                @if (Markers is { Count: > 0 })
                {
                    <div style="font-size:11px;opacity:.65;">@Markers.Count marker@(Markers.Count == 1 ? "" : "s")</div>
                }
                <div style="font-size:10px;opacity:.5;margin-top:6px;text-align:center;max-width:80%;">
                    JS engine (@JsModulePath) will replace this preview at runtime.
                </div>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Attribution))
    {
        <div class="sf-map__attribution"
             style="position:absolute;inset-inline-end:4px;bottom:4px;background:rgba(255,255,255,0.7);padding:2px 6px;border-radius:3px;font-size:10px;color:#333;">
            @((MarkupString)Attribution)
        </div>
    }
</div>
