@namespace Sunfish.UIAdapters.Blazor.Components.Feedback
@inherits SunfishComponentBase

<div role="alert"
     class="@CombineClasses(CssProvider.AlertClass(Severity))"
     style="@CombineStyles()"
     aria-label="@AriaLabel"
     @attributes="AdditionalAttributes">
    @if (Icon != null)
    {
        <span class="sf-alert__icon">@Icon</span>
    }
    <div class="sf-alert__content">
        @ChildContent
    </div>
    @if (IsDismissible)
    {
        <button type="button" class="sf-alert__dismiss" aria-label="Dismiss alert" @onclick="OnDismiss">&times;</button>
    }
</div>

@code {
    [Parameter] public AlertSeverity Severity { get; set; } = AlertSeverity.Info;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnDismiss { get; set; }
    [Parameter] public bool IsDismissible { get; set; }

    /// <summary>Custom icon content to display before the alert message.</summary>
    [Parameter] public RenderFragment? Icon { get; set; }

    /// <summary>Accessible label for the alert.</summary>
    [Parameter] public string? AriaLabel { get; set; }
}
