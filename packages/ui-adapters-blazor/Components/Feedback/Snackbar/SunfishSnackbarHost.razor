@namespace Sunfish.Components.Blazor.Components.Feedback
@using Sunfish.Foundation.Enums
@using Sunfish.Foundation.Models
@using Sunfish.Foundation.Services
@inherits SunfishComponentBase

@{
    var notifications = GetVisibleNotifications();
    var hostClass = CssProvider.SnackbarClass(VerticalPosition, HorizontalPosition)
        + (notifications.Count == 0 ? " mar-snackbar--empty" : "");
}

<div class="@CombineClasses(hostClass)"
     style="@CombineStyles()"
     @attributes="AdditionalAttributes">
    @foreach (var notification in notifications)
    {
        var id = notification.Id;
        var animClass = GetAnimationClass(notification);
        var themeStyle = GetThemeColorStyle(notification);
        <div class="@GetNotificationClass(notification) @animClass" role="status" aria-live="polite"
             style="@(GetAnimationStyle() + themeStyle)">
            <span class="sf-snackbar__message">@notification.Message</span>
            @if (notification.Closeable)
            {
                <button class="sf-snackbar__dismiss"
                        @onclick="() => DismissNotification(id)"
                        aria-label="Dismiss">&#x2715;</button>
            }
        </div>
    }
</div>

@code {
    [Inject] private ISunfishNotificationService NotificationService { get; set; } = default!;

    /// <summary>Vertical position of the notification host.</summary>
    [Parameter] public NotificationVerticalPosition VerticalPosition { get; set; } = NotificationVerticalPosition.Bottom;

    /// <summary>Horizontal position of the notification host.</summary>
    [Parameter] public NotificationHorizontalPosition HorizontalPosition { get; set; } = NotificationHorizontalPosition.Right;

    /// <summary>Maximum number of simultaneously visible notifications.</summary>
    [Parameter] public int MaxCount { get; set; } = 5;

    /// <summary>Animation type for notification entry. Supports Fade, SlideIn, or None.</summary>
    [Parameter] public NotificationAnimation AnimationType { get; set; } = NotificationAnimation.Fade;

    /// <summary>Animation duration in milliseconds.</summary>
    [Parameter] public int AnimationDurationMs { get; set; } = 300;

    private readonly Dictionary<string, System.Timers.Timer> _timers = new();

    protected override void OnInitialized()
    {
        NotificationService.OnChange += HandleNotificationsChanged;
    }

    private void HandleNotificationsChanged()
    {
        InvokeAsync(() =>
        {
            EnsureTimers();
            StateHasChanged();
        });
    }

    private IReadOnlyList<NotificationModel> GetVisibleNotifications()
    {
        var all = NotificationService.GetNotifications();
        return all.Count <= MaxCount ? all : all.TakeLast(MaxCount).ToList().AsReadOnly();
    }

    private void EnsureTimers()
    {
        var notifications = NotificationService.GetNotifications();
        foreach (var n in notifications)
        {
            if (n.CloseAfterMs > 0 && !_timers.ContainsKey(n.Id))
            {
                var id = n.Id;
                var timer = new System.Timers.Timer(n.CloseAfterMs);
                timer.AutoReset = false;
                timer.Elapsed += async (_, _) => await InvokeAsync(() =>
                {
                    NotificationService.Hide(id);
                    CleanupTimer(id);
                });
                _timers[id] = timer;
                timer.Start();
            }
        }

        // Cleanup timers for notifications that no longer exist
        var activeIds = notifications.Select(n => n.Id).ToHashSet();
        var staleIds = _timers.Keys.Where(k => !activeIds.Contains(k)).ToList();
        foreach (var id in staleIds)
        {
            CleanupTimer(id);
        }
    }

    private void DismissNotification(string id)
    {
        NotificationService.Hide(id);
        CleanupTimer(id);
    }

    private void CleanupTimer(string id)
    {
        if (_timers.Remove(id, out var timer))
        {
            timer.Stop();
            timer.Dispose();
        }
    }

    private string GetAnimationClass(NotificationModel notification)
    {
        return AnimationType switch
        {
            NotificationAnimation.Fade => "mar-snackbar--anim-fade",
            NotificationAnimation.SlideIn => "mar-snackbar--anim-slide",
            _ => ""
        };
    }

    private string GetAnimationStyle()
    {
        if (AnimationType == NotificationAnimation.None) return "";
        return $"animation-duration: {AnimationDurationMs}ms;";
    }

    private static string GetThemeColorStyle(NotificationModel notification)
    {
        if (string.IsNullOrEmpty(notification.ThemeColor)) return "";
        return $"background-color: {notification.ThemeColor};";
    }

    private string GetNotificationClass(NotificationModel notification)
    {
        return $"mar-snackbar-item {CssProvider.ToastClass(notification.Severity)}";
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing)
        {
            NotificationService.OnChange -= HandleNotificationsChanged;
            foreach (var timer in _timers.Values)
            {
                timer.Stop();
                timer.Dispose();
            }
            _timers.Clear();
        }
        base.Dispose(disposing);
    }
}
