@namespace Sunfish.Components.Blazor.Components.Feedback
@inherits SunfishComponentBase

<div class="@CombineClasses(CssProvider.ToastClass(Severity))"
     style="@CombineStyles()"
     role="alert"
     aria-live="polite"
     @attributes="AdditionalAttributes">
    @if (Icon != null)
    {
        <span class="sf-toast__icon">@Icon</span>
    }
    <div class="sf-toast__content">
        @if (!string.IsNullOrEmpty(Title))
        {
            <div class="sf-toast__title">@Title</div>
        }
        <div class="sf-toast__message">@Message</div>
    </div>
    @if (ShowCloseButton)
    {
        <button type="button" class="sf-toast__dismiss" aria-label="Dismiss" @onclick="OnDismiss">&times;</button>
    }
</div>

@code {
    [Parameter] public ToastSeverity Severity { get; set; } = ToastSeverity.Info;
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public string? Title { get; set; }
    [Parameter] public EventCallback OnDismiss { get; set; }
    [Parameter] public bool ShowCloseButton { get; set; } = true;
    [Parameter] public RenderFragment? Icon { get; set; }
}
