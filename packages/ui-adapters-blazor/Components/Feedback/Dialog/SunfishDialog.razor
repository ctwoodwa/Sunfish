@namespace Sunfish.UIAdapters.Blazor.Components.Feedback
@inherits SunfishComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

@if (Visible)
{
    @if (Modal)
    {
        <div class="@CombineClasses(CssProvider.DialogOverlayClass())" @onclick="HandleOverlayClick">
            @RenderDialogContent()
        </div>
    }
    else
    {
        @RenderDialogContent()
    }
}

@code {
    /// <summary>
    /// Whether the dialog is visible. Supports two-way binding via @bind-Visible.
    /// </summary>
    [Parameter] public bool Visible { get; set; }

    /// <summary>
    /// Callback fired when Visible changes. Enables two-way binding.
    /// </summary>
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    /// <summary>
    /// The dialog title displayed in the header.
    /// </summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>
    /// The main content of the dialog. Can also use ChildContent for simple scenarios.
    /// </summary>
    [Parameter] public RenderFragment? DialogContent { get; set; }

    /// <summary>
    /// Custom buttons render fragment for the dialog footer. Overrides the Buttons enum.
    /// </summary>
    [Parameter] public RenderFragment? DialogActions { get; set; }

    /// <summary>
    /// Simple child content (used when DialogContent is not set).
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Fired when the dialog is closed (via close button, overlay click, Esc, or Cancel/No button).
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Height { get; set; }
    [Parameter] public bool Draggable { get; set; }
    [Parameter] public bool Modal { get; set; } = true;

    /// <summary>
    /// Whether to show a close button in the title bar. Default is true.
    /// </summary>
    [Parameter] public bool ShowCloseButton { get; set; } = true;

    /// <summary>
    /// Whether clicking the modal overlay closes the dialog. Default is true.
    /// </summary>
    [Parameter] public bool CloseOnOverlayClick { get; set; } = true;

    /// <summary>
    /// Whether pressing Escape closes the dialog. Default is true. WCAG 2.1.2 pattern.
    /// </summary>
    [Parameter] public bool CloseOnEsc { get; set; } = true;

    /// <summary>
    /// Predefined button set for the dialog footer. Ignored when DialogActions is set.
    /// </summary>
    [Parameter] public DialogButtons Buttons { get; set; } = DialogButtons.None;

    /// <summary>
    /// Fired when a predefined button is clicked.
    /// </summary>
    [Parameter] public EventCallback<DialogResult> OnButtonClick { get; set; }

    // ── A11y interop state ──────────────────────────────────────────────

    private readonly string _dialogId = $"sf-dialog-{Guid.NewGuid():N}";
    private readonly string _titleId = $"sf-dialog-title-{Guid.NewGuid():N}";
    private ElementReference _dialogRef;
    private IJSObjectReference? _a11yModule;
    private DotNetObjectReference<SunfishDialog>? _dotNetRef;
    private bool _a11yAttached;
    private bool _wasVisible;

    private const string A11yModulePath = "./_content/Sunfish.UIAdapters.Blazor/js/sunfish-dialog-a11y.js";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_wasVisible)
        {
            await AttachA11yAsync();
            _wasVisible = true;
        }
        else if (!Visible && _wasVisible)
        {
            await DetachA11yAsync();
            _wasVisible = false;
        }
    }

    private async Task AttachA11yAsync()
    {
        if (_a11yAttached) return;
        try
        {
            _a11yModule ??= await JS.InvokeAsync<IJSObjectReference>("import", A11yModulePath);
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await _a11yModule.InvokeVoidAsync(
                "attach",
                _dialogId,
                _dialogRef,
                _dotNetRef,
                new { closeOnEsc = CloseOnEsc, escMethod = nameof(OnEscFromJs) });
            _a11yAttached = true;
        }
        catch (JSException) { /* JS module not shipped / prerendering race */ }
        catch (InvalidOperationException) { /* prerender */ }
    }

    private async Task DetachA11yAsync()
    {
        if (!_a11yAttached || _a11yModule is null) return;
        try
        {
            await _a11yModule.InvokeVoidAsync("detach", _dialogId);
        }
        catch (JSException) { }
        catch (InvalidOperationException) { }
        _a11yAttached = false;
    }

    /// <summary>
    /// Invoked by the JS a11y module when the user presses Escape.
    /// </summary>
    [JSInvokable]
    public async Task OnEscFromJs()
    {
        if (!CloseOnEsc || !Visible) return;
        await CloseAsync();
    }

    private RenderFragment RenderDialogContent() => __builder =>
    {
        var dimensionStyle = new StyleBuilder()
            .AddStyle("width", Width!, !string.IsNullOrEmpty(Width))
            .AddStyle("height", Height!, !string.IsNullOrEmpty(Height))
            .AddStyle(Style)
            .Build();

        @* ADR 0023 — dialog root emits the outer `DialogClass()` shell
           (BS5: `.modal`; Fluent/Material: `.sf-dialog`). Inside we nest
           `DialogDialogClass()` (BS5: `.modal-dialog` sizing wrapper) and
           `DialogContentClass()` (BS5: `.modal-content` surface). For
           Fluent/Material the wrapper and content both resolve to BEM
           descendants of `.sf-dialog`, so the extra nesting is visually
           transparent. Draggable is a modifier class on the root. *@
        var rootClass = new CssClassBuilder()
            .AddClass(CssProvider.DialogClass())
            .AddClass("sf-dialog--draggable", Draggable)
            .Build();

        <div id="@_dialogId"
             class="@rootClass"
             style="@dimensionStyle"
             role="dialog"
             aria-modal="@Modal.ToString().ToLower()"
             aria-labelledby="@(!string.IsNullOrEmpty(Title) ? _titleId : null)"
             aria-label="@(string.IsNullOrEmpty(Title) ? "Dialog" : null)"
             tabindex="-1"
             @ref="_dialogRef"
             @onclick:stopPropagation="true"
             @attributes="AdditionalAttributes">
            <div class="@CssProvider.DialogDialogClass()">
                <div class="@CssProvider.DialogContentClass()">
                    @if (!string.IsNullOrEmpty(Title) || ShowCloseButton)
                    {
                        <div class="@CssProvider.DialogHeaderClass()">
                            <span id="@_titleId" class="@CssProvider.DialogTitleClass()">@Title</span>
                            @if (ShowCloseButton)
                            {
                                @* Theme 9 (Phase 2B) — close glyph is provider-driven.
                                   Bootstrap returns empty markup because `.btn-close` draws
                                   its own SVG via CSS; Fluent returns an inline dismiss SVG;
                                   Material returns a Material Symbols <span>. The shared
                                   `sf-dialog__close` class is kept for existing SCSS hooks
                                   (drag, focus-visible, forced-colors/reduced-motion). *@
                                <button type="button"
                                        class="@($"sf-dialog__close {CssProvider.DialogCloseButtonClass()}".Trim())"
                                        aria-label="Close"
                                        @onclick="CloseAsync">@((MarkupString)CssProvider.DialogCloseMarkup())</button>
                            }
                        </div>
                    }
                    <div class="@CssProvider.DialogBodyClass()">
                        @(DialogContent ?? ChildContent)
                    </div>
                    @if (DialogActions != null)
                    {
                        <div class="@CssProvider.DialogFooterClass()">
                            @DialogActions
                        </div>
                    }
                    else if (Buttons != DialogButtons.None)
                    {
                        <div class="@CssProvider.DialogFooterClass()">
                            @switch (Buttons)
                            {
                                case DialogButtons.Ok:
                                    <button class="sf-btn mar-btn--primary" @onclick="() => HandleButtonClick(DialogResult.Ok)">OK</button>
                                    break;
                                case DialogButtons.OkCancel:
                                    <button class="sf-btn mar-btn--flat" @onclick="() => HandleButtonClick(DialogResult.Cancel)">Cancel</button>
                                    <button class="sf-btn mar-btn--primary" @onclick="() => HandleButtonClick(DialogResult.Ok)">OK</button>
                                    break;
                                case DialogButtons.YesNo:
                                    <button class="sf-btn mar-btn--flat" @onclick="() => HandleButtonClick(DialogResult.No)">No</button>
                                    <button class="sf-btn mar-btn--primary" @onclick="() => HandleButtonClick(DialogResult.Yes)">Yes</button>
                                    break;
                                case DialogButtons.YesNoCancel:
                                    <button class="sf-btn mar-btn--flat" @onclick="() => HandleButtonClick(DialogResult.Cancel)">Cancel</button>
                                    <button class="sf-btn mar-btn--flat" @onclick="() => HandleButtonClick(DialogResult.No)">No</button>
                                    <button class="sf-btn mar-btn--primary" @onclick="() => HandleButtonClick(DialogResult.Yes)">Yes</button>
                                    break;
                                case DialogButtons.RetryCancel:
                                    <button class="sf-btn mar-btn--flat" @onclick="() => HandleButtonClick(DialogResult.Cancel)">Cancel</button>
                                    <button class="sf-btn mar-btn--primary" @onclick="() => HandleButtonClick(DialogResult.Retry)">Retry</button>
                                    break;
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    };

    private async Task HandleButtonClick(DialogResult result)
    {
        await OnButtonClick.InvokeAsync(result);
        if (result is DialogResult.Cancel or DialogResult.No)
        {
            await CloseAsync();
        }
    }

    private async Task HandleOverlayClick()
    {
        if (CloseOnOverlayClick)
        {
            await CloseAsync();
        }
    }

    private async Task CloseAsync()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
        await OnClose.InvokeAsync();
    }

    /// <summary>
    /// Triggers a re-render of the dialog content.
    /// </summary>
    public void Refresh() => StateHasChanged();

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        try
        {
            await DetachA11yAsync();
            if (_a11yModule is not null) await _a11yModule.DisposeAsync();
        }
        catch (JSDisconnectedException) { }
        catch (JSException) { }
        _dotNetRef?.Dispose();
    }
}
