@namespace Sunfish.UIAdapters.Blazor.Components.Overlays
@* WindowFooter — semantic child component for SunfishWindow footer content. *@

@ChildContent

@code {
    [CascadingParameter] internal SunfishWindow? ParentWindow { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        if (ParentWindow is null)
            throw new InvalidOperationException("WindowFooter must be placed inside a SunfishWindow.");
        ParentWindow.SetFooterFragment(ChildContent);
    }
}
