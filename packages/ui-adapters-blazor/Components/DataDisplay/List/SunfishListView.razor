@namespace Sunfish.Components.Blazor.Components.DataDisplay
@inherits SunfishComponentBase
@typeparam TItem

<div class="@CombineClasses(CssProvider.ListViewClass())"
     style="@CombineStyles(SizeStyle)"
     @attributes="AdditionalAttributes">

    @if (HeaderTemplate != null)
    {
        <div class="sf-listview__header">@HeaderTemplate</div>
    }

    <div class="sf-listview__items">
        @if (_pagedItems != null)
        {
            @foreach (var item in _pagedItems)
            {
                var isSelected = _selectedItems.Contains(item);
                <div class="@CssProvider.ListViewItemClass(isSelected)"
                     @onclick="() => HandleItemClick(item)">
                    @if (_editingItem != null && EqualityComparer<TItem>.Default.Equals(_editingItem, item) && EditTemplate != null)
                    {
                        @EditTemplate(item)
                    }
                    else
                    {
                        @ItemTemplate(item)
                    }
                </div>
            }
        }
    </div>

    @if (FooterTemplate != null)
    {
        <div class="sf-listview__footer">@FooterTemplate</div>
    }

    @if (Pageable && _totalCount > PageSize)
    {
        <div class="sf-listview__pager">
            <button type="button"
                    class="sf-listview__pager-btn"
                    disabled="@(_currentPage <= 0)"
                    @onclick="PreviousPage">
                Previous
            </button>
            <span class="sf-listview__pager-info">
                Page @(_currentPage + 1) of @TotalPages
            </span>
            <button type="button"
                    class="sf-listview__pager-btn"
                    disabled="@(_currentPage >= TotalPages - 1)"
                    @onclick="NextPage">
                Next
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public IEnumerable<TItem>? Data { get; set; }
    [Parameter] public EventCallback<DataRequest> OnRead { get; set; }
    [Parameter, EditorRequired] public RenderFragment<TItem> ItemTemplate { get; set; } = default!;
    [Parameter] public bool Pageable { get; set; }
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public GridSelectionMode SelectionMode { get; set; } = GridSelectionMode.None;
    [Parameter] public IEnumerable<TItem>? SelectedItems { get; set; }
    [Parameter] public EventCallback<IEnumerable<TItem>> SelectedItemsChanged { get; set; }
    [Parameter] public RenderFragment<TItem>? EditTemplate { get; set; }
    [Parameter] public EventCallback<TItem> OnCreate { get; set; }
    [Parameter] public EventCallback<TItem> OnUpdate { get; set; }
    [Parameter] public EventCallback<TItem> OnDelete { get; set; }
    [Parameter] public RenderFragment? HeaderTemplate { get; set; }
    [Parameter] public RenderFragment? FooterTemplate { get; set; }
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Height { get; set; }
    [Parameter] public int Page { get; set; }
    [Parameter] public EventCallback<int> PageChanged { get; set; }

    private string? SizeStyle
    {
        get
        {
            var parts = new List<string>();
            if (Width != null) parts.Add($"width:{Width};");
            if (Height != null) parts.Add($"height:{Height};overflow:auto;");
            return parts.Count > 0 ? string.Join("", parts) : null;
        }
    }

    /// <summary>Forces the list view to re-read its data source.</summary>
    public async Task Rebind()
    {
        if (OnRead.HasDelegate) await LoadServerData();
        else if (Data != null) { _allItems = Data.ToList(); _totalCount = _allItems.Count; ApplyPaging(); }
        StateHasChanged();
    }

    private List<TItem> _allItems = [];
    private IEnumerable<TItem>? _pagedItems;
    private HashSet<TItem> _selectedItems = new();
    private TItem? _editingItem = default;
    private int _currentPage;
    private int _totalCount;

    private int TotalPages => _totalCount > 0 ? (int)Math.Ceiling((double)_totalCount / PageSize) : 1;

    protected override async Task OnParametersSetAsync()
    {
        if (SelectedItems != null)
        {
            _selectedItems = new HashSet<TItem>(SelectedItems);
        }

        if (OnRead.HasDelegate)
        {
            await LoadServerData();
        }
        else if (Data != null)
        {
            _allItems = Data.ToList();
            _totalCount = _allItems.Count;
            ApplyPaging();
        }
    }

    private async Task LoadServerData()
    {
        var request = new Sunfish.Foundation.Data.DataRequest
        {
            Paging = new Sunfish.Foundation.Data.PageState
            {
                PageIndex = _currentPage,
                PageSize = PageSize
            }
        };
        await OnRead.InvokeAsync(request);
    }

    private void ApplyPaging()
    {
        if (Pageable)
        {
            _pagedItems = _allItems.Skip(_currentPage * PageSize).Take(PageSize);
        }
        else
        {
            _pagedItems = _allItems;
        }
    }

    private async Task HandleItemClick(TItem item)
    {
        if (SelectionMode == GridSelectionMode.None) return;

        if (SelectionMode == GridSelectionMode.Single)
        {
            _selectedItems.Clear();
            _selectedItems.Add(item);
        }
        else
        {
            if (!_selectedItems.Remove(item))
            {
                _selectedItems.Add(item);
            }
        }

        await SelectedItemsChanged.InvokeAsync(_selectedItems);
    }

    private async Task PreviousPage()
    {
        if (_currentPage > 0)
        {
            _currentPage--;
            if (OnRead.HasDelegate)
                await LoadServerData();
            else
                ApplyPaging();
        }
    }

    private async Task NextPage()
    {
        if (_currentPage < TotalPages - 1)
        {
            _currentPage++;
            if (OnRead.HasDelegate)
                await LoadServerData();
            else
                ApplyPaging();
        }
    }
}
