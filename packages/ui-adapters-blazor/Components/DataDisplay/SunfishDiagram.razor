@inherits SunfishComponentBase

<div class="@CombineClasses("mar-diagram")"
     style="@CombineStyles($"width:{Width};height:{Height};position:relative;overflow:hidden")"
     aria-label="@AriaLabel"
     @attributes="AdditionalAttributes">

    <svg class="sf-diagram__canvas"
         width="100%" height="100%"
         role="img"
         aria-label="@(AriaLabel ?? "Diagram")"
         style="position:absolute;top:0;left:0">

        <defs>
            <marker id="mar-diagram-arrow"
                    viewBox="0 0 10 10"
                    refX="10" refY="5"
                    markerWidth="8" markerHeight="8"
                    orient="auto-start-reverse">
                <path d="M 0 0 L 10 5 L 0 10 z" fill="#666" />
            </marker>
        </defs>

        @* ── Connections ────────────────────────────────────────── *@
        @if (Connections != null && Shapes != null)
        {
            @foreach (var conn in Connections)
            {
                var fromShape = FindShape(conn.FromShapeId);
                var toShape = FindShape(conn.ToShapeId);
                if (fromShape != null && toShape != null)
                {
                    var x1 = fromShape.X + fromShape.Width / 2;
                    var y1 = fromShape.Y + fromShape.Height / 2;
                    var x2 = toShape.X + toShape.Width / 2;
                    var y2 = toShape.Y + toShape.Height / 2;

                    <line class="@ConnectionCssClass(conn)"
                          x1="@x1" y1="@y1" x2="@x2" y2="@y2"
                          stroke="#666" stroke-width="2"
                          marker-end="url(#mar-diagram-arrow)"
                          style="cursor:pointer" />

                    @if (!string.IsNullOrEmpty(conn.Text))
                    {
                        <g>
                            <text x="@((x1 + x2) / 2)" y="@((y1 + y2) / 2 - 8)"
                                  text-anchor="middle"
                                  fill="#666" font-size="12"
                                  class="sf-diagram__connection-label">@conn.Text</text>
                        </g>
                    }
                }
            }
        }

        @* ── Shapes ─────────────────────────────────────────────── *@
        @if (Shapes != null)
        {
            @foreach (var shape in Shapes)
            {
                var cx = shape.X + shape.Width / 2;
                var cy = shape.Y + shape.Height / 2;

                <g class="sf-diagram__shape-group"
                   role="button"
                   tabindex="0"
                   aria-label="@(shape.Text ?? shape.Id)"
                   @onclick="() => HandleShapeClick(shape)"
                   @onkeydown="(e) => HandleShapeKeyDown(e, shape)">

                    @switch (shape.Type)
                    {
                        case DiagramShapeType.Ellipse:
                            <ellipse class="@ShapeCssClass(shape)"
                                     cx="@cx" cy="@cy"
                                     rx="@(shape.Width / 2)" ry="@(shape.Height / 2)"
                                     fill="#e3f2fd" stroke="#1976d2" stroke-width="2" />
                            break;

                        case DiagramShapeType.Circle:
                            var r = Math.Min(shape.Width, shape.Height) / 2;
                            <circle class="@ShapeCssClass(shape)"
                                    cx="@cx" cy="@cy" r="@r"
                                    fill="#e3f2fd" stroke="#1976d2" stroke-width="2" />
                            break;

                        case DiagramShapeType.Diamond:
                            var dPoints = $"{cx},{shape.Y} {shape.X + shape.Width},{cy} {cx},{shape.Y + shape.Height} {shape.X},{cy}";
                            <polygon class="@ShapeCssClass(shape)"
                                     points="@dPoints"
                                     fill="#e3f2fd" stroke="#1976d2" stroke-width="2" />
                            break;

                        case DiagramShapeType.Triangle:
                            var tPoints = $"{cx},{shape.Y} {shape.X + shape.Width},{shape.Y + shape.Height} {shape.X},{shape.Y + shape.Height}";
                            <polygon class="@ShapeCssClass(shape)"
                                     points="@tPoints"
                                     fill="#e3f2fd" stroke="#1976d2" stroke-width="2" />
                            break;

                        default: @* Rectangle *@
                            <rect class="@ShapeCssClass(shape)"
                                  x="@shape.X" y="@shape.Y"
                                  width="@shape.Width" height="@shape.Height"
                                  rx="4" ry="4"
                                  fill="#e3f2fd" stroke="#1976d2" stroke-width="2" />
                            break;
                    }

                    @if (!string.IsNullOrEmpty(shape.TooltipText))
                    {
                        <title>@shape.TooltipText</title>
                    }

                    @if (!string.IsNullOrEmpty(shape.Text))
                    {
                        @((MarkupString)$"""<text x="{cx}" y="{cy + 5}" text-anchor="middle" fill="#333" font-size="14" class="sf-diagram__shape-label" style="pointer-events:none">{System.Net.WebUtility.HtmlEncode(shape.Text)}</text>""")
                    }
                </g>
            }
        }
    </svg>
</div>

@code {
    /// <summary>Shapes displayed in the diagram.</summary>
    [Parameter] public IReadOnlyList<DiagramShapeDescriptor>? Shapes { get; set; }

    /// <summary>Connections between shapes.</summary>
    [Parameter] public IReadOnlyList<DiagramConnectionDescriptor>? Connections { get; set; }

    /// <summary>CSS width of the diagram container.</summary>
    [Parameter] public string? Width { get; set; } = "100%";

    /// <summary>CSS height of the diagram container.</summary>
    [Parameter] public string? Height { get; set; } = "500px";

    /// <summary>Accessible label for the diagram container and SVG element.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    /// <summary>Callback invoked when a shape is clicked.</summary>
    [Parameter] public EventCallback<DiagramShapeClickEventArgs> OnShapeClick { get; set; }

    private Dictionary<string, DiagramShapeDescriptor>? _shapeIndex;
    private IReadOnlyList<DiagramShapeDescriptor>? _lastShapes;

    private DiagramShapeDescriptor? FindShape(string? id)
    {
        if (string.IsNullOrEmpty(id) || Shapes == null) return null;

        // Rebuild index when Shapes reference changes
        if (!ReferenceEquals(Shapes, _lastShapes))
        {
            _shapeIndex = new Dictionary<string, DiagramShapeDescriptor>(StringComparer.Ordinal);
            foreach (var s in Shapes)
            {
                if (!string.IsNullOrEmpty(s.Id))
                    _shapeIndex.TryAdd(s.Id, s);
            }
            _lastShapes = Shapes;
        }

        return _shapeIndex!.GetValueOrDefault(id);
    }

    private async Task HandleShapeClick(DiagramShapeDescriptor shape)
    {
        await OnShapeClick.InvokeAsync(new DiagramShapeClickEventArgs { Shape = shape });
    }

    private async Task HandleShapeKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, DiagramShapeDescriptor shape)
    {
        if (e.Key is "Enter" or " ")
        {
            await HandleShapeClick(shape);
        }
    }

    private static string ShapeCssClass(DiagramShapeDescriptor shape)
    {
        var baseClass = "mar-diagram__shape";
        return string.IsNullOrEmpty(shape.CssClass) ? baseClass : $"{baseClass} {shape.CssClass}";
    }

    private static string ConnectionCssClass(DiagramConnectionDescriptor conn)
    {
        var baseClass = "mar-diagram__connection";
        return string.IsNullOrEmpty(conn.CssClass) ? baseClass : $"{baseClass} {conn.CssClass}";
    }
}
