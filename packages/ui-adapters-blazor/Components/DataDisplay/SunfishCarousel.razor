@inherits SunfishComponentBase

<div class="@CombineClasses(CssProvider.CarouselClass())" style="@CombineStyles(SizeStyle)" @attributes="AdditionalAttributes">
    <div class="sf-carousel__track">
        @if (Data != null && ItemTemplate != null)
        {
            @* Data-driven mode *@
            var dataList = Data.ToList();
            @if (ActiveIndex >= 0 && ActiveIndex < dataList.Count)
            {
                <div class="sf-carousel__slide">
                    @ItemTemplate(dataList[ActiveIndex])
                </div>
            }
        }
        else
        {
            @ChildContent
        }
    </div>
    @if (ShowArrows)
    {
        <button class="sf-carousel__prev" @onclick="Previous" aria-label="Previous">
            @IconProvider.GetIcon("chevron-left", IconSize.Medium)
        </button>
        <button class="sf-carousel__next" @onclick="Next" aria-label="Next">
            @IconProvider.GetIcon("chevron-right", IconSize.Medium)
        </button>
    }
    <div class="sf-carousel__dots">
        @for (var i = 0; i < EffectiveItemCount; i++)
        {
            var idx = i;
            <button class="sf-carousel__dot @(idx == ActiveIndex ? "mar-carousel__dot--active" : "")"
                    @onclick="() => GoTo(idx)" aria-label="Go to slide @(idx + 1)"></button>
        }
    </div>
</div>

@code {
    [Parameter] public int ActiveIndex { get; set; }
    [Parameter] public EventCallback<int> ActiveIndexChanged { get; set; }
    [Parameter] public int ItemCount { get; set; } = 1;

    private int EffectiveItemCount => Data != null ? Data.Count() : ItemCount;
    [Parameter] public bool AutoPlay { get; set; }
    [Parameter] public int IntervalMs { get; set; } = 5000;
    [Parameter] public bool ShowArrows { get; set; } = true;
    [Parameter] public bool Pageable { get; set; } = true;
    [Parameter] public bool LoopPages { get; set; } = true;
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Height { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Data source for data-driven carousel. When set with ItemTemplate, renders slides from data.</summary>
    [Parameter] public IEnumerable<object>? Data { get; set; }

    /// <summary>Template for rendering each data item as a slide.</summary>
    [Parameter] public RenderFragment<object>? ItemTemplate { get; set; }

    private string? SizeStyle
    {
        get
        {
            var parts = new List<string>();
            if (Width != null) parts.Add($"width:{Width};");
            if (Height != null) parts.Add($"height:{Height};");
            return parts.Count > 0 ? string.Join("", parts) : null;
        }
    }

    private System.Timers.Timer? _timer;

    protected override void OnInitialized()
    {
        if (AutoPlay)
        {
            _timer = new System.Timers.Timer(IntervalMs);
            _timer.Elapsed += async (_, _) => await InvokeAsync(async () =>
            {
                await Next();
                StateHasChanged();
            });
            _timer.Start();
        }
    }

    private async Task Previous()
    {
        if (LoopPages)
            ActiveIndex = (ActiveIndex - 1 + EffectiveItemCount) % EffectiveItemCount;
        else if (ActiveIndex > 0)
            ActiveIndex--;
        await ActiveIndexChanged.InvokeAsync(ActiveIndex);
    }

    private async Task Next()
    {
        if (LoopPages)
            ActiveIndex = (ActiveIndex + 1) % EffectiveItemCount;
        else if (ActiveIndex < EffectiveItemCount - 1)
            ActiveIndex++;
        await ActiveIndexChanged.InvokeAsync(ActiveIndex);
    }

    private async Task GoTo(int index)
    {
        ActiveIndex = index;
        await ActiveIndexChanged.InvokeAsync(ActiveIndex);
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing)
        {
            _timer?.Stop();
            _timer?.Dispose();
        }
        base.Dispose(disposing);
    }
}
