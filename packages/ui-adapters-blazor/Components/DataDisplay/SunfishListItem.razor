@inherits SunfishComponentBase

<li class="@CombineClasses(ItemClass)"
    style="@CombineStyles()"
    role="option"
    aria-selected="@Selected"
    aria-disabled="@(Disabled ? "true" : null)"
    @onclick="HandleClick"
    @attributes="AdditionalAttributes">
    @ChildContent
</li>

@code {
    /// <summary>Whether this item is selected.</summary>
    [Parameter] public bool Selected { get; set; }

    /// <summary>Whether this item is disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Fires when the item is clicked.</summary>
    [Parameter] public EventCallback OnClick { get; set; }

    /// <summary>Item content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string ItemClass
    {
        get
        {
            var cls = CssProvider.ListItemClass();
            if (Selected) cls += " mar-list__item--selected";
            if (Disabled) cls += " mar-list__item--disabled";
            return cls;
        }
    }

    private async Task HandleClick()
    {
        if (!Disabled && OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }
}
