@inherits SunfishComponentBase

@switch (Variant)
{
    case TypographyVariant.H1:
        <h1 class="@CombineClasses(CssProvider.TypographyClass(Variant))" style="@CombineStyles()" @attributes="AdditionalAttributes">@ChildContent</h1>
        break;
    case TypographyVariant.H2:
        <h2 class="@CombineClasses(CssProvider.TypographyClass(Variant))" style="@CombineStyles()" @attributes="AdditionalAttributes">@ChildContent</h2>
        break;
    case TypographyVariant.H3:
        <h3 class="@CombineClasses(CssProvider.TypographyClass(Variant))" style="@CombineStyles()" @attributes="AdditionalAttributes">@ChildContent</h3>
        break;
    case TypographyVariant.H4:
        <h4 class="@CombineClasses(CssProvider.TypographyClass(Variant))" style="@CombineStyles()" @attributes="AdditionalAttributes">@ChildContent</h4>
        break;
    case TypographyVariant.H5:
        <h5 class="@CombineClasses(CssProvider.TypographyClass(Variant))" style="@CombineStyles()" @attributes="AdditionalAttributes">@ChildContent</h5>
        break;
    case TypographyVariant.H6:
        <h6 class="@CombineClasses(CssProvider.TypographyClass(Variant))" style="@CombineStyles()" @attributes="AdditionalAttributes">@ChildContent</h6>
        break;
    case TypographyVariant.Caption:
    case TypographyVariant.Overline:
        <span class="@CombineClasses(CssProvider.TypographyClass(Variant))" style="@CombineStyles()" @attributes="AdditionalAttributes">@ChildContent</span>
        break;
    default:
        <p class="@CombineClasses(CssProvider.TypographyClass(Variant))" style="@CombineStyles()" @attributes="AdditionalAttributes">@ChildContent</p>
        break;
}

@code {
    [Parameter] public TypographyVariant Variant { get; set; } = TypographyVariant.Body1;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
