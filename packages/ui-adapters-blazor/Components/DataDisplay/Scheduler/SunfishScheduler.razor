@namespace Sunfish.UIAdapters.Blazor.Components.DataDisplay
@using Sunfish.UIAdapters.Blazor.Components.DataDisplay.Scheduler
@inherits SunfishComponentBase
@implements ISchedulerViewHost
<CascadingValue Value="(ISchedulerViewHost)this" IsFixed="true">
    @ChildContent
</CascadingValue>

<div class="@CombineClasses("mar-scheduler")" style="@CombineStyles(SizeStyle)" role="application" aria-roledescription="Scheduler" aria-label="Scheduler" @attributes="AdditionalAttributes">

    @* WCAG 4.1.3 Status Messages — polite live region for view, navigation, and CRUD announcements. *@
    <div class="sf-scheduler__sr-only" role="status" aria-live="polite" aria-atomic="true"
         style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">@_liveAnnouncement</div>

    <div class="sf-scheduler__header">
        <button type="button" class="sf-btn mar-btn--flat" style="min-width:24px;min-height:24px;" aria-label="@GetPreviousNavLabel()" @onclick="NavigatePrevious">&#9664;</button>
        <span class="sf-scheduler__title">@GetHeaderTitle()</span>
        <button type="button" class="sf-btn mar-btn--flat" style="min-width:24px;min-height:24px;" aria-label="@GetNextNavLabel()" @onclick="NavigateNext">&#9654;</button>
        <span class="sf-scheduler__spacer"></span>
        <div class="sf-scheduler__view-switcher" role="tablist" aria-label="Scheduler view">
            @foreach (var viewType in AvailableViews)
            {
                var vt = viewType;
                var label = GetViewLabel(vt);
                var isActive = View == vt;
                <button type="button"
                        class="sf-btn mar-btn--flat @(isActive ? "mar-btn--primary" : "")"
                        style="min-width:24px;min-height:24px;"
                        role="tab"
                        aria-selected="@(isActive ? "true" : "false")"
                        @onclick="() => SetView(vt)">@label</button>
            }
        </div>
    </div>

    @if (View == SchedulerView.Month)
    {
        @if (IsResourceGrouped)
        {
            <div class="sf-scheduler__month">
                @foreach (var resource in ResourceList)
                {
                    var res = resource;
                    <div class="sf-scheduler__resource-group">
                        <div class="sf-scheduler__resource-label">@res.Text</div>
                        <div class="sf-scheduler__resource-group-content">
                            <div class="sf-scheduler__weekday-headers">
                                @foreach (var day in GetDayNames()) { <span class="sf-scheduler__weekday">@day</span> }
                            </div>
                            <div class="sf-scheduler__month-grid">
                                @foreach (var day in GetMonthDays())
                                {
                                    var d = day;
                                    var isToday = d == DateOnly.FromDateTime(DateTime.Today);
                                    var isCurrentMonth = d.Month == CurrentDate.Month;
                                    <div class="sf-scheduler__day-cell @(isToday ? "mar-scheduler__day-cell--today" : "") @(!isCurrentMonth ? "mar-scheduler__day-cell--outside" : "")" tabindex="0" role="gridcell" aria-label="@GetDayCellAriaLabel(d)" @onclick="() => OnDateClick.InvokeAsync(d.ToDateTime(TimeOnly.MinValue))" @onkeydown="(e) => HandleDayCellKeyDown(d, e)">
                                        <span class="sf-scheduler__day-number">@d.Day</span>
                                        @foreach (var appt in GetAppointmentsForDateAndResource(d, res.Id).Where(aa => !aa.IsAllDay))
                                        {
                                            var a = appt;
                                            <div class="sf-scheduler__appointment @GetRenderCssClass(a)" tabindex="0" role="button" aria-label="@GetAppointmentAriaLabel(a)" style="@(GetAppointmentColor(a) is string clr && clr.Length > 0 ? $"background-color:{clr};" : "") @GetRenderStyle(a)" @onclick:stopPropagation="true" @onclick="() => OnAppointmentClick.InvokeAsync(a)" @ondblclick:stopPropagation="true" @ondblclick="() => HandleAppointmentDoubleClick(a)" @onkeydown="(e) => HandleAppointmentKeyDown(a, e)">
                                                @if (AppointmentTemplate != null) { @AppointmentTemplate(a) } else { @a.Title }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="sf-scheduler__month">
                <div class="sf-scheduler__weekday-headers">
                    @foreach (var day in GetDayNames()) { <span class="sf-scheduler__weekday">@day</span> }
                </div>
                @if (HasAllDayAppointments())
                {
                    <div class="sf-scheduler__allday-row">
                        @foreach (var appt in GetAllDayAppointments())
                        {
                            var a = appt;
                            <div class="sf-scheduler__appointment mar-scheduler__appointment--allday @GetRenderCssClass(a)" tabindex="0" role="button" aria-label="@GetAppointmentAriaLabel(a)" style="@(GetAppointmentColor(a) is string clr && clr.Length > 0 ? $"background-color:{clr};" : "") @GetRenderStyle(a)" @onclick:stopPropagation="true" @onclick="() => OnAppointmentClick.InvokeAsync(a)" @ondblclick:stopPropagation="true" @ondblclick="() => HandleAppointmentDoubleClick(a)" @onkeydown="(e) => HandleAppointmentKeyDown(a, e)">
                                @if (AppointmentTemplate != null) { @AppointmentTemplate(a) } else { @a.Title }
                            </div>
                        }
                    </div>
                }
                <div class="sf-scheduler__month-grid">
                    @foreach (var day in GetMonthDays())
                    {
                        var d = day;
                        var isToday = d == DateOnly.FromDateTime(DateTime.Today);
                        var isCurrentMonth = d.Month == CurrentDate.Month;
                        <div class="sf-scheduler__day-cell @(isToday ? "mar-scheduler__day-cell--today" : "") @(!isCurrentMonth ? "mar-scheduler__day-cell--outside" : "")" tabindex="0" role="gridcell" aria-label="@GetDayCellAriaLabel(d)" @onclick="() => OnDateClick.InvokeAsync(d.ToDateTime(TimeOnly.MinValue))" @onkeydown="(e) => HandleDayCellKeyDown(d, e)">
                            <span class="sf-scheduler__day-number">@d.Day</span>
                            @foreach (var appt in GetTimedAppointmentsForDate(d))
                            {
                                var a = appt;
                                <div class="sf-scheduler__appointment @GetRenderCssClass(a)" tabindex="0" role="button" aria-label="@GetAppointmentAriaLabel(a)" style="@(GetAppointmentColor(a) is string clr && clr.Length > 0 ? $"background-color:{clr};" : "") @GetRenderStyle(a)" @onclick:stopPropagation="true" @onclick="() => OnAppointmentClick.InvokeAsync(a)" @ondblclick:stopPropagation="true" @ondblclick="() => HandleAppointmentDoubleClick(a)" @onkeydown="(e) => HandleAppointmentKeyDown(a, e)">
                                    @if (AppointmentTemplate != null) { @AppointmentTemplate(a) } else { @a.Title }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
    else if (View == SchedulerView.Week || View == SchedulerView.Day || View == SchedulerView.MultiDay)
    {
        var days = View == SchedulerView.Week ? GetWeekDays() : View == SchedulerView.MultiDay ? GetMultiDayDays() : new List<DateOnly> { DateOnly.FromDateTime(CurrentDate) };
        var effectiveStartHour = GetEffectiveStartHour();
        var effectiveEndHour = GetEffectiveEndHour();

        @if (IsResourceGrouped)
        {
            @if (View == SchedulerView.Day)
            {
                <div class="sf-scheduler__time-grid">
                    <div class="sf-scheduler__time-labels">
                        @for (var h = effectiveStartHour; h <= effectiveEndHour; h++) { <div class="sf-scheduler__time-label">@($"{h:D2}:00")</div> }
                    </div>
                    @foreach (var resource in ResourceList)
                    {
                        var res = resource;
                        var d = DateOnly.FromDateTime(CurrentDate);
                        <div class="sf-scheduler__day-column">
                            <div class="sf-scheduler__resource-header">@res.Text</div>
                            <div class="sf-scheduler__day-slots" style="position: relative;">
                                @for (var h = effectiveStartHour; h <= effectiveEndHour; h++) { var slotDate = d;
                            var slotHour = h;
                            var isDragSelecting = _isDragCreating && IsSlotInDragRange(slotDate, slotHour);
                            var isDropTarget = _isDragRescheduling && _dropTargetSlot.HasValue
                                && _dropTargetSlot.Value.Date == slotDate && _dropTargetSlot.Value.Hour == slotHour;
                            <div class="sf-scheduler__time-slot @(isDragSelecting ? "mar-scheduler__slot--drag-selecting" : "") @(isDropTarget ? "mar-scheduler__slot--drop-target" : "")"
                                 tabindex="@(Editable ? "0" : "-1")"
                                 role="gridcell"
                                 aria-label="@GetSlotAriaLabel(slotDate, slotHour)"
                                 @onmousedown="() => HandleSlotMouseDown(slotDate, slotHour)"
                                 @onmousemove="() => HandleSlotMouseMove(slotDate, slotHour)"
                                 @onmouseup="() => HandleSlotMouseUp(slotDate, slotHour)"
                                 @onkeydown="(e) => HandleSlotKeyDown(slotDate, slotHour, e)"
                                 @ondragover="() => HandleSlotDragOver(slotDate, slotHour)"
                                 @ondragover:preventDefault="true"
                                 @ondrop="() => HandleSlotDrop(slotDate, slotHour)">
                            </div> }
                                @foreach (var appt in GetTimedAppointmentsForDateAndResource(d, res.Id))
                                {
                                    var a = appt;
                                    var top = (a.Start.Hour - effectiveStartHour + a.Start.Minute / 60.0) * 48;
                                    var height = (a.End - a.Start).TotalHours * 48;
                                    <div class="sf-scheduler__appointment mar-scheduler__appointment--timed @(_draggingAppointment?.Id == a.Id ? "mar-scheduler__appointment--dragging" : "") @GetRenderCssClass(a)" tabindex="0" role="button" aria-label="@GetAppointmentAriaLabel(a)" aria-grabbed="@((_draggingAppointment?.Id == a.Id) ? "true" : "false")" draggable="@(Editable ? "true" : "false")" @ondragstart="() => HandleAppointmentDragStart(a)" @ondragend="HandleAppointmentDragEnd" style="top: @(top)px; height: @(height)px; @(GetAppointmentColor(a) is string clr && clr.Length > 0 ? $"background-color:{clr};" : "") @GetRenderStyle(a)" @onclick="() => OnAppointmentClick.InvokeAsync(a)" @ondblclick:stopPropagation="true" @ondblclick="() => HandleAppointmentDoubleClick(a)" @onkeydown="(e) => HandleAppointmentKeyDown(a, e)">
                                        @if (AppointmentTemplate != null) { @AppointmentTemplate(a) } else { @a.Title }
                                        @if (Editable) { <div class="sf-scheduler__appointment-resize-handle" @onmousedown="() => HandleResizeMouseDown(a)" @onmousedown:stopPropagation="true"></div> }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                @foreach (var resource in ResourceList)
                {
                    var res = resource;
                    <div class="sf-scheduler__resource-group">
                        <div class="sf-scheduler__resource-label">@res.Text</div>
                        <div class="sf-scheduler__resource-group-content">
                            <div class="sf-scheduler__time-grid">
                                <div class="sf-scheduler__time-labels">
                                    @for (var h = effectiveStartHour; h <= effectiveEndHour; h++) { <div class="sf-scheduler__time-label">@($"{h:D2}:00")</div> }
                                </div>
                                @foreach (var day in days)
                                {
                                    var d = day;
                                    <div class="sf-scheduler__day-column">
                                        <div class="sf-scheduler__day-column-header">@d.ToString("ddd M/d")</div>
                                        <div class="sf-scheduler__day-slots" style="position: relative;">
                                            @for (var h = effectiveStartHour; h <= effectiveEndHour; h++)
                        {
                            var slotDate = d;
                            var slotHour = h;
                            var isDragSelecting = _isDragCreating && IsSlotInDragRange(slotDate, slotHour);
                            var isDropTarget = _isDragRescheduling && _dropTargetSlot.HasValue
                                && _dropTargetSlot.Value.Date == slotDate && _dropTargetSlot.Value.Hour == slotHour;
                            <div class="sf-scheduler__time-slot @(isDragSelecting ? "mar-scheduler__slot--drag-selecting" : "") @(isDropTarget ? "mar-scheduler__slot--drop-target" : "")"
                                 tabindex="@(Editable ? "0" : "-1")"
                                 role="gridcell"
                                 aria-label="@GetSlotAriaLabel(slotDate, slotHour)"
                                 @onmousedown="() => HandleSlotMouseDown(slotDate, slotHour)"
                                 @onmousemove="() => HandleSlotMouseMove(slotDate, slotHour)"
                                 @onmouseup="() => HandleSlotMouseUp(slotDate, slotHour)"
                                 @onkeydown="(e) => HandleSlotKeyDown(slotDate, slotHour, e)"
                                 @ondragover="() => HandleSlotDragOver(slotDate, slotHour)"
                                 @ondragover:preventDefault="true"
                                 @ondrop="() => HandleSlotDrop(slotDate, slotHour)">
                            </div>
                        }
                                            @foreach (var appt in GetTimedAppointmentsForDateAndResource(d, res.Id))
                                            {
                                                var a = appt;
                                                var top = (a.Start.Hour - effectiveStartHour + a.Start.Minute / 60.0) * 48;
                                                var height = (a.End - a.Start).TotalHours * 48;
                                                <div class="sf-scheduler__appointment mar-scheduler__appointment--timed @(_draggingAppointment?.Id == a.Id ? "mar-scheduler__appointment--dragging" : "") @GetRenderCssClass(a)" tabindex="0" role="button" aria-label="@GetAppointmentAriaLabel(a)" aria-grabbed="@((_draggingAppointment?.Id == a.Id) ? "true" : "false")" draggable="@(Editable ? "true" : "false")" @ondragstart="() => HandleAppointmentDragStart(a)" @ondragend="HandleAppointmentDragEnd" style="top: @(top)px; height: @(height)px; @(GetAppointmentColor(a) is string clr && clr.Length > 0 ? $"background-color:{clr};" : "") @GetRenderStyle(a)" @onclick="() => OnAppointmentClick.InvokeAsync(a)" @ondblclick:stopPropagation="true" @ondblclick="() => HandleAppointmentDoubleClick(a)" @onkeydown="(e) => HandleAppointmentKeyDown(a, e)">
                                                    @if (AppointmentTemplate != null) { @AppointmentTemplate(a) } else { @a.Title }
                                                    @if (Editable) { <div class="sf-scheduler__appointment-resize-handle" @onmousedown="() => HandleResizeMouseDown(a)" @onmousedown:stopPropagation="true"></div> }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        }
        else
        {
            @if (HasAllDayAppointmentsForDays(days))
            {
                <div class="sf-scheduler__allday-row">
                    @foreach (var day in days)
                    {
                        var d = day;
                        <div class="sf-scheduler__allday-cell"
                         @ondragover="() => HandleAllDayDragOver(d)"
                         @ondragover:preventDefault="true"
                         @ondrop="() => HandleAllDayDrop(d)">
                            @foreach (var appt in GetAllDayAppointmentsForDate(d))
                            {
                                var a = appt;
                                <div class="sf-scheduler__appointment mar-scheduler__appointment--allday @GetRenderCssClass(a)" tabindex="0" role="button" aria-label="@GetAppointmentAriaLabel(a)" style="@(GetAppointmentColor(a) is string clr && clr.Length > 0 ? $"background-color:{clr};" : "") @GetRenderStyle(a)" draggable="@(Editable ? "true" : "false")"
                                 @ondragstart="() => HandleAppointmentDragStart(a)"
                                 @ondragend="HandleAppointmentDragEnd"
                                 @onclick:stopPropagation="true" @onclick="() => OnAppointmentClick.InvokeAsync(a)" @ondblclick:stopPropagation="true" @ondblclick="() => HandleAppointmentDoubleClick(a)" @onkeydown="(e) => HandleAppointmentKeyDown(a, e)">
                                    @if (AppointmentTemplate != null) { @AppointmentTemplate(a) } else { @a.Title }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            <div class="sf-scheduler__time-grid">
                <div class="sf-scheduler__time-labels">
                    @for (var h = effectiveStartHour; h <= effectiveEndHour; h++) { <div class="sf-scheduler__time-label">@($"{h:D2}:00")</div> }
                </div>
                @foreach (var day in days)
                {
                    var d = day;
                    <div class="sf-scheduler__day-column">
                        <div class="sf-scheduler__day-column-header">@d.ToString("ddd M/d")</div>
                        <div class="sf-scheduler__day-slots" style="position: relative;">
                            @for (var h = effectiveStartHour; h <= effectiveEndHour; h++)
                        {
                            var slotDate = d;
                            var slotHour = h;
                            var isDragSelecting = _isDragCreating && IsSlotInDragRange(slotDate, slotHour);
                            var isDropTarget = _isDragRescheduling && _dropTargetSlot.HasValue
                                && _dropTargetSlot.Value.Date == slotDate && _dropTargetSlot.Value.Hour == slotHour;
                            <div class="sf-scheduler__time-slot @(isDragSelecting ? "mar-scheduler__slot--drag-selecting" : "") @(isDropTarget ? "mar-scheduler__slot--drop-target" : "")"
                                 tabindex="@(Editable ? "0" : "-1")"
                                 role="gridcell"
                                 aria-label="@GetSlotAriaLabel(slotDate, slotHour)"
                                 @onmousedown="() => HandleSlotMouseDown(slotDate, slotHour)"
                                 @onmousemove="() => HandleSlotMouseMove(slotDate, slotHour)"
                                 @onmouseup="() => HandleSlotMouseUp(slotDate, slotHour)"
                                 @onkeydown="(e) => HandleSlotKeyDown(slotDate, slotHour, e)"
                                 @ondragover="() => HandleSlotDragOver(slotDate, slotHour)"
                                 @ondragover:preventDefault="true"
                                 @ondrop="() => HandleSlotDrop(slotDate, slotHour)">
                            </div>
                        }
                            @foreach (var appt in GetTimedAppointmentsForDate(d))
                            {
                                var a = appt;
                                var top = (a.Start.Hour - effectiveStartHour + a.Start.Minute / 60.0) * 48;
                                var height = (a.End - a.Start).TotalHours * 48;
                                <div class="sf-scheduler__appointment mar-scheduler__appointment--timed @(_draggingAppointment?.Id == a.Id ? "mar-scheduler__appointment--dragging" : "") @GetRenderCssClass(a)" tabindex="0" role="button" aria-label="@GetAppointmentAriaLabel(a)" aria-grabbed="@((_draggingAppointment?.Id == a.Id) ? "true" : "false")" draggable="@(Editable ? "true" : "false")" @ondragstart="() => HandleAppointmentDragStart(a)" @ondragend="HandleAppointmentDragEnd" style="top: @(top)px; height: @(height)px; @(GetAppointmentColor(a) is string clr && clr.Length > 0 ? $"background-color:{clr};" : "") @GetRenderStyle(a)" @onclick="() => OnAppointmentClick.InvokeAsync(a)" @ondblclick:stopPropagation="true" @ondblclick="() => HandleAppointmentDoubleClick(a)" @onkeydown="(e) => HandleAppointmentKeyDown(a, e)">
                                    @if (AppointmentTemplate != null) { @AppointmentTemplate(a) } else { @a.Title }
                                    @if (Editable) { <div class="sf-scheduler__appointment-resize-handle" @onmousedown="() => HandleResizeMouseDown(a)" @onmousedown:stopPropagation="true"></div> }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

    else if (View == SchedulerView.Timeline)
    {
        var tlStartHour = GetEffectiveStartHour();
        var tlEndHour = GetEffectiveEndHour();
        var tlSlotMin = GetEffectiveTimelineSlotMinutes();
        var tlDays = GetTimelineDays();
        var tlTotalSlots = GetTimelineTotalSlots(tlStartHour, tlEndHour, tlSlotMin);
        <div class="sf-scheduler__timeline">
            <div class="sf-scheduler__timeline-header">
                <div class="sf-scheduler__timeline-header-label"></div>
                @for (var s = 0; s < tlTotalSlots; s++) { var mins = tlStartHour * 60 + s * tlSlotMin; <div class="sf-scheduler__timeline-slot">@($"{mins / 60:D2}:{mins % 60:D2}")</div> }
            </div>
            @foreach (var day in tlDays)
            {
                var d = day;
                <div class="sf-scheduler__timeline-row">
                    <div class="sf-scheduler__timeline-row-label">@d.ToString("ddd M/d")</div>
                    <div class="sf-scheduler__timeline-row-slots" style="position: relative;">
                        @for (var s = 0; s < tlTotalSlots; s++) { <div class="sf-scheduler__timeline-slot"></div> }
                        @foreach (var appt in GetTimedAppointmentsForDate(d))
                        {
                            var a = appt;
                            var sw = 100.0 / tlTotalSlots;
                            var sm = (a.Start.Hour * 60 + a.Start.Minute) - tlStartHour * 60;
                            var em = (a.End.Hour * 60 + a.End.Minute) - tlStartHour * 60;
                            var lp = (sm / (double)tlSlotMin) * sw;
                            var wp = ((em - sm) / (double)tlSlotMin) * sw;
                            <div class="sf-scheduler__timeline-appointment @GetRenderCssClass(a)" tabindex="0" role="button" aria-label="@GetAppointmentAriaLabel(a)" style="left: @(lp)%; width: @(wp)%; @(!string.IsNullOrEmpty(a.Color) ? $"background-color:{a.Color};" : "") @GetRenderStyle(a)" @onclick="() => OnAppointmentClick.InvokeAsync(a)" @ondblclick:stopPropagation="true" @ondblclick="() => HandleAppointmentDoubleClick(a)" @onkeydown="(e) => HandleAppointmentKeyDown(a, e)">
                                @if (AppointmentTemplate != null) { @AppointmentTemplate(a) } else { @a.Title }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else if (View == SchedulerView.Agenda)
    {
        var agDays = GetAgendaDays();
        <div class="sf-scheduler__agenda">
            @foreach (var day in agDays)
            {
                var d = day;
                var dayAppts = GetAppointmentsForDate(d).OrderBy(a => a.Start).ToList();
                @if (dayAppts.Count > 0)
                {
                    <div class="sf-scheduler__agenda-date">@d.ToString("dddd, MMM d, yyyy")</div>
                    @foreach (var appt in dayAppts)
                    {
                        var a = appt;
                        <div class="sf-scheduler__agenda-item @GetRenderCssClass(a)" tabindex="0" role="button" aria-label="@GetAppointmentAriaLabel(a)" style="@(!string.IsNullOrEmpty(a.Color) ? $"border-inline-start-color:{a.Color};" : "") @GetRenderStyle(a)" @onclick="() => OnAppointmentClick.InvokeAsync(a)" @ondblclick:stopPropagation="true" @ondblclick="() => HandleAppointmentDoubleClick(a)" @onkeydown="(e) => HandleAppointmentKeyDown(a, e)">
                            <span class="sf-scheduler__agenda-item-time">@(a.IsAllDay ? "All Day" : $"{a.Start:HH:mm} - {a.End:HH:mm}")</span>
                            <span class="sf-scheduler__agenda-item-title">@if (AppointmentTemplate != null) { @AppointmentTemplate(a) } else { @a.Title }</span>
                        </div>
                    }
                }
            }
        </div>
    }

    @if (Editable && _editingAppointment != null && EditMode == SchedulerEditMode.Inline)
    {
        <div class="sf-scheduler__edit-form" role="dialog" aria-modal="false" aria-label="Edit appointment" tabindex="-1" @onkeydown="HandleEditDialogKeyDown">
            <div class="sf-scheduler__edit-form-header">
                <span>Edit Appointment</span>
                <button type="button" class="sf-btn mar-btn--flat mar-scheduler__edit-form-close" style="min-width:24px;min-height:24px;" aria-label="Close" @onclick="CancelEdit">&times;</button>
            </div>
            <div class="sf-scheduler__edit-form-body">
                <label class="sf-scheduler__edit-form-label">Title <input type="text" class="sf-scheduler__edit-form-input" value="@_editTitle" @oninput="OnEditTitleChanged" /></label>
                <label class="sf-scheduler__edit-form-label">Start <input type="datetime-local" class="sf-scheduler__edit-form-input" value="@_editStart.ToString("yyyy-MM-ddTHH:mm")" @onchange="OnEditStartChanged" /></label>
                <label class="sf-scheduler__edit-form-label">End <input type="datetime-local" class="sf-scheduler__edit-form-input" value="@_editEnd.ToString("yyyy-MM-ddTHH:mm")" @onchange="OnEditEndChanged" /></label>
            </div>
            <div class="sf-scheduler__edit-form-actions">
                <button type="button" class="sf-btn mar-btn--primary" @onclick="SaveEdit">Save</button>
                <button type="button" class="sf-btn mar-btn--danger" @onclick="DeleteAppointment">Delete</button>
                <button type="button" class="sf-btn mar-btn--flat" @onclick="CancelEdit">Cancel</button>
            </div>
        </div>
    }

    @if (Editable && _editingAppointment != null && EditMode == SchedulerEditMode.Popup)
    {
        <div class="sf-scheduler__edit-backdrop" @onclick="CancelEdit"></div>
        <div class="sf-scheduler__edit-popup" role="dialog" aria-modal="true" aria-label="Edit appointment" tabindex="-1" @onkeydown="HandleEditDialogKeyDown">
            <div class="sf-scheduler__edit-popup-header">
