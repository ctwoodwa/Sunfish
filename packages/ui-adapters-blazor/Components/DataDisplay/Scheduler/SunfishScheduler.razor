    private DayOfWeek GetEffectiveFirstDayOfWeek() { if (View == SchedulerView.Week) { var v = GetRegisteredView<SchedulerWeekView>(); if (v != null) return v.FirstDayOfWeek; } else if (View == SchedulerView.Month) { var v = GetRegisteredView<SchedulerMonthView>(); if (v != null) return v.FirstDayOfWeek; } return DayOfWeek.Sunday; }
