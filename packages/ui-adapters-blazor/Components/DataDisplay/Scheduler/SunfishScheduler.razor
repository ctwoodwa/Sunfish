    private async Task SetView(SchedulerView view) { View = view; await ViewChanged.InvokeAsync(view); AnnounceViewChange(view); }
    private async Task NavigatePrevious() { CurrentDate = View switch { SchedulerView.Month => CurrentDate.AddMonths(-1), SchedulerView.Week => CurrentDate.AddDays(-7), SchedulerView.Day => CurrentDate.AddDays(-1), SchedulerView.MultiDay => CurrentDate.AddDays(-GetEffectiveNumberOfDays()), SchedulerView.Timeline => CurrentDate.AddDays(-1), SchedulerView.Agenda => CurrentDate.AddDays(-GetEffectiveAgendaDays()), _ => CurrentDate.AddMonths(-1) }; await CurrentDateChanged.InvokeAsync(CurrentDate); AnnounceNavigation(); }
    private async Task NavigateNext() { CurrentDate = View switch { SchedulerView.Month => CurrentDate.AddMonths(1), SchedulerView.Week => CurrentDate.AddDays(7), SchedulerView.Day => CurrentDate.AddDays(1), SchedulerView.MultiDay => CurrentDate.AddDays(GetEffectiveNumberOfDays()), SchedulerView.Timeline => CurrentDate.AddDays(1), SchedulerView.Agenda => CurrentDate.AddDays(GetEffectiveAgendaDays()), _ => CurrentDate.AddMonths(1) }; await CurrentDateChanged.InvokeAsync(CurrentDate); AnnounceNavigation(); }
    private DateTime GetWeekStart() { var firstDay = GetEffectiveFirstDayOfWeek(); var diff = ((int)CurrentDate.DayOfWeek - (int)firstDay + 7) % 7; return CurrentDate.AddDays(-diff); }
    private List<DateOnly> GetMonthDays() { var firstDay = GetEffectiveFirstDayOfWeek(); var days = new List<DateOnly>(); var first = new DateOnly(CurrentDate.Year, CurrentDate.Month, 1); var startOffset = ((int)first.DayOfWeek - (int)firstDay + 7) % 7; for (var i = startOffset - 1; i >= 0; i--) days.Add(first.AddDays(-(i + 1))); var daysInMonth = DateTime.DaysInMonth(CurrentDate.Year, CurrentDate.Month); for (var d = 1; d <= daysInMonth; d++) days.Add(new DateOnly(CurrentDate.Year, CurrentDate.Month, d)); while (days.Count % 7 != 0) days.Add(days[^1].AddDays(1)); return days; }
