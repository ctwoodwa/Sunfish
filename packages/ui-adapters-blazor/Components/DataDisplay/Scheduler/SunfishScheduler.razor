    private string[] GetDayNames() { var firstDay = GetEffectiveFirstDayOfWeek(); if (firstDay == DayOfWeek.Sunday) return _defaultDayNames; var offset = (int)firstDay; var names = new string[7]; for (var i = 0; i < 7; i++) names[i] = _defaultDayNames[(i + offset) % 7]; return names; }
