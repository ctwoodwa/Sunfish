    // -- Drag-to-create handlers --

    private void HandleSlotMouseDown(DateOnly date, int hour)
    {
        if (!Editable) return;
        _isDragCreating = true;
        _dragStartSlot = (date, hour);
        _dragEndSlot = (date, hour);
    }

    private void HandleSlotMouseMove(DateOnly date, int hour)
    {
        if (!_isDragCreating || !Editable) return;
        if (_dragStartSlot.HasValue && _dragStartSlot.Value.Date == date)
            _dragEndSlot = (date, hour);
    }

    private async Task HandleSlotMouseUp(DateOnly date, int hour)
    {
        if (!_isDragCreating || !Editable) return;
        _isDragCreating = false;
        if (_dragStartSlot.HasValue)
        {
            var startSlot = _dragStartSlot.Value;
            var endSlot = _dragEndSlot ?? (date, hour);
            var startHour = Math.Min(startSlot.Hour, endSlot.Hour);
            var endHour = Math.Max(startSlot.Hour, endSlot.Hour) + 1;
            var newAppt = new SchedulerAppointment
            {
                Title = "New Appointment",
                Start = startSlot.Date.ToDateTime(new TimeOnly(startHour, 0)),
                End = startSlot.Date.ToDateTime(new TimeOnly(endHour, 0))
            };
            _dragStartSlot = null;
            _dragEndSlot = null;
            await OnAppointmentCreate.InvokeAsync(newAppt);
        }
    }

    private bool IsSlotInDragRange(DateOnly date, int hour)
    {
        if (!_dragStartSlot.HasValue || !_dragEndSlot.HasValue) return false;
        if (date != _dragStartSlot.Value.Date) return false;
        var minHour = Math.Min(_dragStartSlot.Value.Hour, _dragEndSlot.Value.Hour);
        var maxHour = Math.Max(_dragStartSlot.Value.Hour, _dragEndSlot.Value.Hour);
        return hour >= minHour && hour <= maxHour;
    }

    // -- Drag-to-reschedule handlers --

    private void HandleAppointmentDragStart(SchedulerAppointment appt)
    {
        if (!Editable) return;
        _isDragRescheduling = true;
        _draggingAppointment = appt;
    }

    private void HandleAppointmentDragEnd()
    {
        _isDragRescheduling = false;
        _draggingAppointment = null;
        _dropTargetSlot = null;
    }

    private void HandleSlotDragOver(DateOnly date, int hour)
    {
        if (!_isDragRescheduling || _draggingAppointment == null) return;
        if (_draggingAppointment.IsAllDay) return;
        _dropTargetSlot = (date, hour);
    }

    private async Task HandleSlotDrop(DateOnly date, int hour)
    {
        if (!_isDragRescheduling || _draggingAppointment == null || !Editable) return;
        if (_draggingAppointment.IsAllDay) { HandleAppointmentDragEnd(); return; }
        var appt = _draggingAppointment;
        var duration = appt.End - appt.Start;
        var newStart = date.ToDateTime(new TimeOnly(hour, 0));
        var newEnd = newStart + duration;
        var updated = new SchedulerAppointment
        {
            Id = appt.Id, Title = appt.Title, Start = newStart, End = newEnd,
            Description = appt.Description, IsAllDay = false,
            Color = appt.Color, RecurrenceRule = appt.RecurrenceRule
        };
        HandleAppointmentDragEnd();
        await OnUpdate.InvokeAsync(updated);
    }

    private void HandleAllDayDragOver(DateOnly date)
    {
        if (!_isDragRescheduling || _draggingAppointment == null) return;
        if (!_draggingAppointment.IsAllDay) return;
        _dropTargetSlot = (date, 0);
    }

    private async Task HandleAllDayDrop(DateOnly date)
    {
        if (!_isDragRescheduling || _draggingAppointment == null || !Editable) return;
        if (!_draggingAppointment.IsAllDay) { HandleAppointmentDragEnd(); return; }
        var appt = _draggingAppointment;
        var duration = appt.End - appt.Start;
        var newStart = date.ToDateTime(TimeOnly.MinValue);
        var newEnd = newStart + duration;
        var updated = new SchedulerAppointment
        {
            Id = appt.Id, Title = appt.Title, Start = newStart, End = newEnd,
            Description = appt.Description, IsAllDay = true,
            Color = appt.Color, RecurrenceRule = appt.RecurrenceRule
        };
        HandleAppointmentDragEnd();
        await OnUpdate.InvokeAsync(updated);
    }

    // -- Drag-resize handlers --
    private void HandleResizeMouseDown(SchedulerAppointment appt)
    {
        if (!Editable) return;
        _isResizingAppointment = true;
        _resizingAppointment = appt;
        _resizeOriginalEnd = appt.End;
    }

    private void HandleResizeMouseMove(DateOnly date, int hour)
    {
        if (!_isResizingAppointment || _resizingAppointment == null) return;
        // Only allow resize on the same day
        if (DateOnly.FromDateTime(_resizingAppointment.Start) != date) return;
        var newEnd = date.ToDateTime(new TimeOnly(Math.Max(hour + 1, _resizingAppointment.Start.Hour + 1), 0));
        _resizingAppointment = new SchedulerAppointment
        {
            Id = _resizingAppointment.Id, Title = _resizingAppointment.Title,
            Start = _resizingAppointment.Start, End = newEnd,
            Description = _resizingAppointment.Description, IsAllDay = _resizingAppointment.IsAllDay,
            Color = _resizingAppointment.Color, RecurrenceRule = _resizingAppointment.RecurrenceRule
        };
    }

    private async Task HandleResizeMouseUp()
    {
        if (!_isResizingAppointment || _resizingAppointment == null) return;
        var updated = _resizingAppointment;
        _isResizingAppointment = false;
        _resizingAppointment = null;
        if (updated.End != _resizeOriginalEnd)
            await OnUpdate.InvokeAsync(updated);
    }

    // -- OnAppointmentRender cache --
    protected override async Task OnParametersSetAsync()
    {
        if (!ReferenceEquals(Appointments, _lastAppointmentsRef))
        {
            _lastAppointmentsRef = Appointments;
            await RebuildRenderArgsCache();
        }
    }

    private async Task RebuildRenderArgsCache()
    {
        _renderArgsCache.Clear();
        if (!OnAppointmentRender.HasDelegate) return;
        foreach (var appt in Appointments)
        {
            var args = new SchedulerAppointmentRenderEventArgs { Appointment = appt };
            await OnAppointmentRender.InvokeAsync(args);
            _renderArgsCache[appt.Id] = args;
        }
    }

    private string GetRenderCssClass(SchedulerAppointment appt) =>
        _renderArgsCache.TryGetValue(appt.Id, out var args) ? args.CssClass ?? string.Empty : string.Empty;

    private string GetRenderStyle(SchedulerAppointment appt) =>
        _renderArgsCache.TryGetValue(appt.Id, out var args) ? args.Style ?? string.Empty : string.Empty;

    protected override void Dispose(bool disposing) { if (disposing) { _registeredViews.Clear(); } base.Dispose(disposing); }
