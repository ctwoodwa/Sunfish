@namespace Sunfish.Components.Blazor.Components.DataDisplay
@typeparam TItem where TItem : class
@inherits SunfishComponentBase

@{
    var accessor = _accessor!;
    var visible = _flatVisible;

    var containerStyle = new System.Text.StringBuilder();
    if (!string.IsNullOrEmpty(Width)) containerStyle.Append($"width:{Width};");
    if (!string.IsNullOrEmpty(Height)) containerStyle.Append($"height:{Height};");

    var cols = VisibleColumns;
    var useColumns = cols.Count > 0;
}

@* Column definitions (hidden, just registers via CascadingValue) *@
<CascadingValue Value="this" IsFixed="true">
    @GanttColumns
</CascadingValue>

@* View definitions (hidden, registers via IGanttViewHost cascade) *@
<CascadingValue Value="(IGanttViewHost)this" IsFixed="true">
    @GanttViews
</CascadingValue>

@* Dependency definitions (hidden, registers via SunfishGantt cascade) *@
<CascadingValue Value="this" IsFixed="true">
    @GanttDependenciesSlot
</CascadingValue>

<div @ref="_containerRef"
     class="@CombineClasses("mar-gantt")"
     style="@CombineStyles(containerStyle.ToString())"
     @attributes="AdditionalAttributes"
     @onclick="HandleGanttClick">
    <div class="sf-gantt__announcer" aria-live="polite" aria-atomic="true" role="status">@_announcement</div>
    <a href="#mar-gantt-tasklist-@_instanceId" class="sf-gantt__skip-link">Skip to task list</a>
    <a href="#mar-gantt-timeline-@_instanceId" class="sf-gantt__skip-link">Skip to timeline</a>
    @if (ShowToolbar)
    {
        <div class="sf-gantt__toolbar">
            @if (_views.Count > 1)
            {
                <div class="sf-gantt__view-selector">
                    @foreach (var v in _views)
                    {
                        <button class="sf-gantt__view-btn @(v.ViewType == View ? "mar-gantt__view-btn--active" : "")"
                                @onclick="() => SwitchView(v.ViewType)">
                            @v.ViewType
                        </button>
                    }
                </div>
            }
            @GanttToolBarTemplate
            @if (ShowColumnChooser)
            {
                <button type="button"
                        id="mar-gantt-column-chooser-btn"
                        class="sf-gantt__column-chooser-btn"
                        title="Column Chooser"
                        @onclick="() => _columnChooserOpen = !_columnChooserOpen"
                        @onclick:stopPropagation="true">
                    &#x2630;
                </button>
            }
        </div>
    }
    <div class="sf-gantt__container">
        @* Task list *@
        <div class="sf-gantt__tasklist"
             id="mar-gantt-tasklist-@_instanceId"
             style="width: @(TaskListWidth)px;"
             role="treegrid"
             aria-label="Task list"
             tabindex="0"
             @onkeydown="HandleKeyDown"
             @onkeydown:preventDefault="true">
            <div class="sf-gantt__tasklist-header" role="row">
                @if (useColumns)
                {
                    @foreach (var col in cols)
                    {
                        var c = col;
                        var headerStyle = "";
                        if (!string.IsNullOrEmpty(c.Width)) headerStyle += $"width:{c.Width};";
                        var isSorted = _sortField is not null && _sortField == c.Field;
                        var headerCssClass = "mar-gantt__header-cell"
                            + (c.Sortable ? " mar-gantt__header--sortable" : "")
                            + (isSorted ? " mar-gantt__header--sorted" : "")
                            + (!string.IsNullOrEmpty(c.HeaderClass) ? $" {c.HeaderClass}" : "");
                        <div class="@headerCssClass"
                             style="@headerStyle"
                             role="columnheader"
                             aria-sort="@(isSorted ? (_sortAscending ? "ascending" : "descending") : (c.Sortable ? "none" : null))"
                             @onclick="async () => { if (c.Sortable) await SortBy(c.Field); }">
                            @if (c.HeaderTemplate is not null)
                            {
                                @c.HeaderTemplate
                            }
                            else
                            {
                                <span>@c.DisplayTitle</span>
                                @if (isSorted)
                                {
                                    <span class="sf-gantt__sort-indicator">@(_sortAscending ? "▲" : "▼")</span>
                                }
                            }
                            @if (FilterMode == GanttFilterMode.FilterMenu && c.Filterable && !string.IsNullOrEmpty(c.Field))
                            {
                                var isActive = _filterValues.ContainsKey(c.Field);
                                var filterField = c.Field;

                                @if (c.FilterType == GanttColumnFilterType.CheckboxList)
                                {
                                    <button type="button"
                                            id="mar-gantt-filter-@filterField"
                                            class="sf-gantt__filter-btn @(isActive ? "mar-gantt__filter-btn--active" : "")"
                                            title="Filter"
                                            @onclick="() => OpenCheckboxFilter(filterField)"
                                            @onclick:stopPropagation="true">
                                        &#x25BC;
                                    </button>
                                }
                                else
                                {
                                    var isOpen = _filterMenuField == c.Field;

                                    <button type="button"
                                            class="sf-gantt__filter-btn @(isActive ? "mar-gantt__filter-btn--active" : "")"
                                            title="Filter"
                                            @onclick="() => ToggleFilterMenu(filterField)"
                                            @onclick:stopPropagation="true">
                                        &#x25BC;@* Funnel-like down arrow *@
                                    </button>

                                    @if (isOpen)
                                    {
                                        <div class="sf-gantt__filter-menu" @onclick:stopPropagation="true">
                                            <input type="text"
                                                   class="sf-gantt__filter-menu-input"
                                                   placeholder="Filter..."
                                                   value="@_filterMenuValue"
                                                   @oninput="(e) => _filterMenuValue = e.Value?.ToString() ?? string.Empty" />
                                            <div class="sf-gantt__filter-menu-actions">
                                                <button type="button" class="sf-gantt__filter-menu-btn" @onclick="ApplyFilterMenu">Filter</button>
                                                <button type="button" class="sf-gantt__filter-menu-btn" @onclick="ClearFilterMenu">Clear</button>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    }
                }
                else
                {
                    <span role="columnheader">Task</span>
                }
                @if (HasCommandColumn)
                {
                    var cmdCol = _commandColumn!;
                    var cmdHeaderStyle = !string.IsNullOrEmpty(cmdCol.Width) ? $"width:{cmdCol.Width};" : "";
                    <div class="sf-gantt__header-cell mar-gantt__command-header" style="@cmdHeaderStyle" role="columnheader">
                        @if (cmdCol.ShowAddButton)
                        {
                            <button type="button" class="sf-gantt__cmd-btn mar-gantt__cmd-btn--add"
                                    title="Add" @onclick="HandleCommandAdd" @onclick:stopPropagation="true">&#x2795;</button>
                        }
                        else
                        {
                            @(cmdCol.Title ?? "")
                        }
                    </div>
                }
            </div>
            @if (useColumns && cols.Any(c => c.Filterable) && FilterMode == GanttFilterMode.FilterRow)
            {
                <div class="sf-gantt__filter-row">
                    @foreach (var col in cols)
                    {
                        var c = col;
                        var cellStyle = "";
                        if (!string.IsNullOrEmpty(c.Width)) cellStyle += $"width:{c.Width};";
                        <div class="sf-gantt__task-cell" style="@cellStyle">
                            @if (c.Filterable && !string.IsNullOrEmpty(c.Field))
                            {
                                _filterValues.TryGetValue(c.Field, out var currentVal);
                                var field = c.Field;
                                <input type="text"
                                       class="sf-gantt__filter-input"
                                       placeholder="Filter..."
                                       value="@(currentVal ?? "")"
                                       @oninput="@(async e => await OnFilterInput(field, e.Value?.ToString() ?? ""))" />
                            }
                        </div>
                    }
                    @if (HasCommandColumn)
                    {
                        var cmdFilterStyle = !string.IsNullOrEmpty(_commandColumn!.Width) ? $"width:{_commandColumn.Width};" : "";
                        <div class="sf-gantt__task-cell mar-gantt__command-cell" style="@cmdFilterStyle"></div>
                    }
                </div>
            }
            @for (var idx = 0; idx < visible.Count; idx++)
            {
                var n = visible[idx];
                var rowIdx = idx;
                var hasChildren = n.Children.Count > 0 || (!string.IsNullOrEmpty(HasChildrenField) && _accessor!.GetHasChildren(n.Item));
                var expanded = IsExpanded(n);
                var isFocused = rowIdx == _focusedIndex;
                var siblingCount = GetSiblingCount(n);
                var posInSiblings = GetPositionInSiblings(n);
                var rowClass = "mar-gantt__task-row" + (isFocused ? " mar-gantt__task-row--focused" : "");

                @if (useColumns)
                {
                    var isIncell = TreeListEditMode == GanttTreeListEditMode.Incell;
                    var isPopup = TreeListEditMode == GanttTreeListEditMode.Popup;
                    var isEditing = _editingRowIndex == rowIdx;
                    var editRowClass = rowClass + (isEditing ? " mar-gantt__task-row--editing" : "");
                    var capturedRowIdx = rowIdx;

                    <div class="@editRowClass"
                         role="row"
                         aria-level="@(n.Depth + 1)"
                         aria-setsize="@siblingCount"
                         aria-posinset="@posInSiblings"
                         aria-expanded="@(hasChildren ? (expanded ? "true" : "false") : null)"
                         tabindex="@(isFocused ? 0 : -1)"
                         @onclick="async () => { await HandleTaskSelect(n.Item); await OnTaskClick.InvokeAsync(n.Item); }"
                         @ondblclick="() => { if (!isIncell && !isPopup) _ = BeginEdit(capturedRowIdx); }"
                         @ondblclick:stopPropagation="true">
                        @foreach (var col in cols)
                        {
                            var cellStyle = "";
                            if (!string.IsNullOrEmpty(col.Width)) cellStyle += $"width:{col.Width};";
                            if (!string.IsNullOrEmpty(col.TextAlign)) cellStyle += $"text-align:{col.TextAlign};";

                            @* Determine whether this specific cell is in edit mode *@
                            var isEditingThisCell = isIncell
                                ? (_editingRowIndex == rowIdx && _editingField == col.Field)
                                : isEditing;

                            @if (isEditingThisCell && col.Editable && !string.IsNullOrEmpty(col.Field))
                            {
                                @* Incell / Inline editing mode: render input *@
                                var editField = col.Field;
                                var inputType = GetInputType(editField, col);
                                if (col.Expandable)
                                {
                                    var pad = (int)(n.Depth * 16 + (hasChildren ? 0 : 16));
                                    <div class="sf-gantt__task-cell" role="gridcell" style="@cellStyle">
                                        <span style="padding-left: @(pad)px; display: inline-flex; align-items: center;">
                                            @if (hasChildren)
                                            {
                                                <button type="button"
                                                        class="sf-gantt__chevron"
                                                        aria-expanded="@(expanded ? "true" : "false")"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => ToggleExpanded(n)">
                                                    @(expanded ? "▼" : "▶")
                                                </button>
                                            }
                                            <input type="@inputType"
                                                   value="@FormatEditValue(editField, _editValues.GetValueOrDefault(editField))"
                                                   @onchange="(e) => _editValues[editField] = ParseValue(editField, e.Value?.ToString())"
                                                   @onclick:stopPropagation="true"
                                                   @onkeydown="HandleCellKeyDown"
                                                   @onkeydown:preventDefault="@isIncell"
                                                   class="sf-gantt__edit-input" />
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <div class="sf-gantt__task-cell" role="gridcell" style="@cellStyle">
                                        <input type="@inputType"
                                               value="@FormatEditValue(editField, _editValues.GetValueOrDefault(editField))"
                                               @onchange="(e) => _editValues[editField] = ParseValue(editField, e.Value?.ToString())"
                                               @onclick:stopPropagation="true"
                                               @onkeydown="HandleCellKeyDown"
                                               @onkeydown:preventDefault="@isIncell"
                                               class="sf-gantt__edit-input" />
                                    </div>
                                }
                            }
                            else if (isIncell && col.Editable && !string.IsNullOrEmpty(col.Field))
                            {
                                @* Incell mode: non-editing editable cell — clickable to start editing *@
                                var incellField = col.Field;
                                if (col.Expandable)
                                {
                                    var pad = (int)(n.Depth * 16 + (hasChildren ? 0 : 16));
                                    <div class="sf-gantt__task-cell mar-gantt__task-cell--editable" role="gridcell" style="@cellStyle"
                                         @onclick="() => BeginCellEdit(rowIdx, incellField)"
                                         @onclick:stopPropagation="true">
                                        <span style="padding-left: @(pad)px; display: inline-flex; align-items: center;">
                                            @if (hasChildren)
                                            {
                                                <button type="button"
                                                        class="sf-gantt__chevron"
                                                        aria-expanded="@(expanded ? "true" : "false")"
                                                        aria-label="@(expanded ? $"Collapse {accessor.GetTitle(n.Item)}" : $"Expand {accessor.GetTitle(n.Item)}")"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => ToggleExpanded(n)">
                                                    @(expanded ? "▼" : "▶")
                                                </button>
                                            }
                                            @if (col.Template is not null)
                                            {
                                                @col.Template(n.Item)
                                            }
                                            else
                                            {
                                                @col.GetDisplayValue(n.Item)
                                            }
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <div class="sf-gantt__task-cell mar-gantt__task-cell--editable" role="gridcell" style="@cellStyle"
                                         @onclick="() => BeginCellEdit(rowIdx, incellField)"
                                         @onclick:stopPropagation="true">
                                        @if (col.Template is not null)
                                        {
                                            @col.Template(n.Item)
                                        }
                                        else
                                        {
                                            @col.GetDisplayValue(n.Item)
                                        }
                                    </div>
                                }
                            }
                            else if (isPopup && col.Editable && !string.IsNullOrEmpty(col.Field))
                            {
                                @* Popup mode: editable cell — clicking opens popup form *@
                                var popupField = col.Field;
                                var cellAnchorId = $"mar-gantt-cell-{rowIdx}-{popupField}";
                                if (col.Expandable)
                                {
                                    var pad = (int)(n.Depth * 16 + (hasChildren ? 0 : 16));
                                    <div id="@cellAnchorId" class="sf-gantt__task-cell mar-gantt__task-cell--editable" role="gridcell" style="@cellStyle"
                                         @onclick="() => BeginPopupEdit(rowIdx, popupField)"
                                         @onclick:stopPropagation="true">
                                        <span style="padding-left: @(pad)px; display: inline-flex; align-items: center;">
                                            @if (hasChildren)
                                            {
                                                <button type="button"
                                                        class="sf-gantt__chevron"
                                                        aria-expanded="@(expanded ? "true" : "false")"
                                                        aria-label="@(expanded ? $"Collapse {accessor.GetTitle(n.Item)}" : $"Expand {accessor.GetTitle(n.Item)}")"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => ToggleExpanded(n)">
                                                    @(expanded ? "▼" : "▶")
                                                </button>
                                            }
                                            @if (col.Template is not null)
                                            {
                                                @col.Template(n.Item)
                                            }
                                            else
                                            {
                                                @col.GetDisplayValue(n.Item)
                                            }
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <div id="@cellAnchorId" class="sf-gantt__task-cell mar-gantt__task-cell--editable" role="gridcell" style="@cellStyle"
                                         @onclick="() => BeginPopupEdit(rowIdx, popupField)"
                                         @onclick:stopPropagation="true">
                                        @if (col.Template is not null)
                                        {
                                            @col.Template(n.Item)
                                        }
                                        else
                                        {
                                            @col.GetDisplayValue(n.Item)
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="sf-gantt__task-cell" role="gridcell" style="@cellStyle">
                                    @if (col.Expandable)
                                    {
                                        var pad = (int)(n.Depth * 16 + (hasChildren ? 0 : 16));
                                        <span style="padding-left: @(pad)px; display: inline-flex; align-items: center;">
                                            @if (hasChildren)
                                            {
                                                <button type="button"
                                                        class="sf-gantt__chevron"
                                                        aria-expanded="@(expanded ? "true" : "false")"
                                                        aria-label="@(expanded ? $"Collapse {accessor.GetTitle(n.Item)}" : $"Expand {accessor.GetTitle(n.Item)}")"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => ToggleExpanded(n)">
                                                    @(expanded ? "▼" : "▶")
                                                </button>
                                            }
                                            @if (col.Template is not null)
                                            {
                                                @col.Template(n.Item)
                                            }
                                            else
                                            {
                                                @col.GetDisplayValue(n.Item)
                                            }
                                        </span>
                                    }
                                    else
                                    {
                                        @if (col.Template is not null)
                                        {
                                            @col.Template(n.Item)
                                        }
                                        else
                                        {
                                            @col.GetDisplayValue(n.Item)
                                        }
                                    }
                                </div>
                            }
                        }
                        @if (HasCommandColumn)
                        {
                            var cmdCol = _commandColumn!;
                            var cmdStyle = !string.IsNullOrEmpty(cmdCol.Width) ? $"width:{cmdCol.Width};" : "";
                            <div class="sf-gantt__task-cell mar-gantt__command-cell" role="gridcell" style="@cmdStyle">
                                @if (isEditing && !isIncell)
                                {
                                    <button type="button" class="sf-gantt__cmd-btn mar-gantt__cmd-btn--save"
                                            title="Save" @onclick="CommitEdit" @onclick:stopPropagation="true">&#x2713;</button>
                                    <button type="button" class="sf-gantt__cmd-btn mar-gantt__cmd-btn--cancel"
                                            title="Cancel" @onclick="() => CancelEdit()" @onclick:stopPropagation="true">&#x2717;</button>
                                }
                                else if (!isIncell)
                                {
                                    <button type="button" class="sf-gantt__cmd-btn mar-gantt__cmd-btn--edit"
                                            title="Edit" @onclick="() => BeginEdit(rowIdx)" @onclick:stopPropagation="true">&#x270E;</button>
                                    <button type="button" class="sf-gantt__cmd-btn mar-gantt__cmd-btn--delete"
                                            title="Delete" @onclick="() => HandleCommandDelete(n.Item)" @onclick:stopPropagation="true">&#x2716;</button>
                                }
                                else
                                {
                                    <button type="button" class="sf-gantt__cmd-btn mar-gantt__cmd-btn--delete"
                                            title="Delete" @onclick="() => HandleCommandDelete(n.Item)" @onclick:stopPropagation="true">&#x2716;</button>
                                }
                            </div>
                        }
                        else if (isEditing && !isIncell)
                        {
                            <div class="sf-gantt__edit-actions">
                                <button type="button"
                                        class="sf-gantt__edit-btn mar-gantt__edit-btn--save"
                                        title="Save"
                                        @onclick="CommitEdit"
                                        @onclick:stopPropagation="true">&#x2713;</button>
                                <button type="button"
                                        class="sf-gantt__edit-btn mar-gantt__edit-btn--cancel"
                                        title="Cancel"
                                        @onclick="() => CancelEdit()"
                                        @onclick:stopPropagation="true">&#x2717;</button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    var pad = (int)(n.Depth * 16 + (hasChildren ? 0 : 16));
                    <div class="@rowClass"
                         role="row"
                         aria-level="@(n.Depth + 1)"
                         aria-setsize="@siblingCount"
                         aria-posinset="@posInSiblings"
                         aria-expanded="@(hasChildren ? (expanded ? "true" : "false") : null)"
                         tabindex="@(isFocused ? 0 : -1)"
                         style="padding-left: @(pad)px;"
                         @onclick="async () => { await HandleTaskSelect(n.Item); await OnTaskClick.InvokeAsync(n.Item); }">
                        @if (hasChildren)
                        {
                            <button type="button"
                                    class="sf-gantt__chevron"
                                    aria-expanded="@(expanded ? "true" : "false")"
                                    aria-label="@(expanded ? $"Collapse {accessor.GetTitle(n.Item)}" : $"Expand {accessor.GetTitle(n.Item)}")"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => ToggleExpanded(n)">
                                @(expanded ? "▼" : "▶")
                            </button>
                        }
                        @accessor.GetTitle(n.Item)
                    </div>
                }
            }
        </div>

        @* Timeline *@
        <div class="sf-gantt__timeline"
             id="mar-gantt-timeline-@_instanceId"
             style="overflow-x: auto;">
            @if (UseViewEngine && _slots.Count > 0)
            {
                @* View-driven timeline with main + secondary headers *@
                <div class="sf-gantt__timeline-headers" style="width: @((int)_totalTimelineWidth)px;">
                    <div class="sf-gantt__timeline-header mar-gantt__timeline-header--main">
                        @foreach (var header in _mainHeaders)
                        {
                            var hw = (int)(header.SpanSlots * ActiveView!.SlotWidth);
                            <span class="sf-gantt__date-label mar-gantt__date-label--main" style="width: @(hw)px;">
                                @if (ActiveView?.MainHeaderTemplate is { } mainTpl)
                                {
                                    @mainTpl(header.Start)
                                }
                                else
                                {
                                    @(ActiveView?.MainHeaderDateFormat is { } fmt ? header.Start.ToString(fmt) : header.Label)
                                }
                            </span>
                        }
                    </div>
                    <div class="sf-gantt__timeline-header mar-gantt__timeline-header--secondary">
                        @foreach (var slot in _slots)
                        {
                            var sw = (int)ActiveView!.SlotWidth;
                            <span class="sf-gantt__date-label" style="width: @(sw)px;">
                                @if (ActiveView?.SubHeaderTemplate is { } subTpl)
                                {
                                    @subTpl(slot.Start)
                                }
                                else
                                {
                                    @(ActiveView?.SubHeaderDateFormat is { } fmt ? slot.Start.ToString(fmt) : slot.Label)
                                }
                            </span>
                        }
                    </div>
                </div>

                <div class="sf-gantt__bars" style="width: @((int)_totalTimelineWidth)px; position: relative;">
                    @for (var bi = 0; bi < visible.Count; bi++)
                    {
                        var n = visible[bi];
                        var barIdx = bi;
                        var taskStart = accessor.GetStart(n.Item);
                        var taskEnd = accessor.GetEnd(n.Item);
                        var isMilestone = taskStart == taskEnd;
                        var isSummary = n.Children.Count > 0;

                        var barStart = isSummary && n.ComputedStart.HasValue ? n.ComputedStart.Value : taskStart;
                        var barEnd = isSummary && n.ComputedEnd.HasValue ? n.ComputedEnd.Value : taskEnd;
                        var pctValue = accessor.GetPercentComplete(n.Item);
                        var barPct = isSummary && n.ComputedPercentComplete.HasValue ? n.ComputedPercentComplete.Value : pctValue;

                        var startOffset = GetPixelOffset(barStart);
                        var barWidth = GetBarWidth(barStart, barEnd);
                        var barTitle = accessor.GetTitle(n.Item);
                        var pctWidth = Math.Clamp(barPct, 0, 100);
                        var barClass = "mar-gantt__bar" + (isSummary ? " mar-gantt__bar--summary" : "") + (ReferenceEquals(n.Item, SelectedTask) ? " mar-gantt__bar--selected" : "");

                        <div class="sf-gantt__bar-row">
                            @if (isMilestone)
                            {
                                var milestoneOffset = GetPixelOffset(taskStart);
                                <div class="sf-gantt__milestone"
                                     style="left: @((int)milestoneOffset)px; top: @(bi * RowHeight + RowHeight / 2 - 6)px;"
                                     role="img"
                                     aria-label="@($"Milestone: {barTitle}: {taskStart:M/d/yyyy}")"
                                     @onclick="async () => { await HandleTaskSelect(n.Item); await OnTaskClick.InvokeAsync(n.Item); }"
                                     @onclick:stopPropagation="true">
                                    <span class="sf-gantt__milestone-diamond">&#x25C6;</span>
                                </div>
                            }
                            else
                            {
                                <div class="@barClass"
                                     data-index="@barIdx"
                                     role="img"
                                     aria-label="@($"{barTitle}: {barStart:M/d/yyyy} – {barEnd:M/d/yyyy}")"
                                     style="left: @((int)startOffset)px; width: @((int)barWidth)px;"
                                     @onclick="async () => { await HandleTaskSelect(n.Item); await OnTaskClick.InvokeAsync(n.Item); }">
                                    <div class="sf-gantt__bar-resize mar-gantt__bar-resize--left"></div>
                                    <div class="sf-gantt__bar-progress" style="width: @(pctWidth)%;"></div>
                                    @if (TaskTemplate is not null)
                                    {
                                        @TaskTemplate(n.Item)
                                    }
                                    <button type="button"
                                            class="sf-gantt__bar-delete"
                                            title="Delete"
                                            @onclick="() => OnDelete.InvokeAsync(new GanttDeleteEventArgs { Item = n.Item })"
                                            @onclick:stopPropagation="true">&#x2716;</button>
                                    <div class="sf-gantt__bar-resize mar-gantt__bar-resize--right"></div>
                                </div>
                            }
                            @if (TooltipTemplate is not null)
                            {
                                <div class="sf-gantt__tooltip" style="left: @((int)startOffset)px;">
                                    @TooltipTemplate(n.Item)
                                </div>
                            }
                            else
                            {
                                <div class="sf-gantt__tooltip" style="left: @((int)startOffset)px;">
                                    <strong>@accessor.GetTitle(n.Item)</strong><br />
                                    @barStart.ToString("M/d/yyyy") &ndash; @barEnd.ToString("M/d/yyyy")
                                </div>
                            }
                        </div>
                    }
                    @if (_dependencyLines.Count > 0)
                    {
                        <svg class="sf-gantt__dependency-svg" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;">
                            <defs>
                                <marker id="@($"gantt-arrow-{_instanceId}")" class="sf-gantt__dependency-marker" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto">
                                    <path d="M0,0 L10,4 L0,8 Z" />
                                </marker>
                            </defs>
                            @foreach (var dep in _dependencyLines)
                            {
                                <line x1="@dep.X1.ToString("F1")" y1="@dep.Y1.ToString("F1")"
                                      x2="@dep.X2.ToString("F1")" y2="@dep.Y2.ToString("F1")"
                                      class="sf-gantt__dependency"
                                      marker-end="@($"url(#gantt-arrow-{_instanceId})")" />
                            }
                        </svg>
                    }
                </div>
            }
            else
            {
                @* Legacy DayWidth-based fallback *@
                <div class="sf-gantt__timeline-header" style="width: @((int)_totalTimelineWidth)px;">
                    @{
                        var d = _rangeStart;
                        while (d <= _rangeEnd)
                        {
                            <span class="sf-gantt__date-label" style="width: @(DayWidth)px;">
                                @d.ToString("M/d")
                            </span>
                            d = d.AddDays(1);
                        }
                    }
                </div>

                <div class="sf-gantt__bars" style="width: @((int)_totalTimelineWidth)px; position: relative;">
                    @for (var bi = 0; bi < visible.Count; bi++)
                    {
                        var n = visible[bi];
                        var barIdx = bi;
                        var taskStart = accessor.GetStart(n.Item);
                        var taskEnd = accessor.GetEnd(n.Item);
                        var isMilestone = taskStart == taskEnd;
                        var isSummary = n.Children.Count > 0;

                        var barStart = isSummary && n.ComputedStart.HasValue ? n.ComputedStart.Value : taskStart;
                        var barEnd = isSummary && n.ComputedEnd.HasValue ? n.ComputedEnd.Value : taskEnd;
                        var pctValue = accessor.GetPercentComplete(n.Item);
                        var barPct = isSummary && n.ComputedPercentComplete.HasValue ? n.ComputedPercentComplete.Value : pctValue;

                        var startOffset = GetPixelOffset(barStart);
                        var barWidth = GetBarWidth(barStart, barEnd);
                        var barTitle = accessor.GetTitle(n.Item);
                        var pctWidth = Math.Clamp(barPct, 0, 100);
                        var barClass = "mar-gantt__bar" + (isSummary ? " mar-gantt__bar--summary" : "") + (ReferenceEquals(n.Item, SelectedTask) ? " mar-gantt__bar--selected" : "");

                        <div class="sf-gantt__bar-row">
                            @if (isMilestone)
                            {
                                var milestoneOffset = GetPixelOffset(taskStart);
                                <div class="sf-gantt__milestone"
                                     style="left: @((int)milestoneOffset)px; top: @(bi * RowHeight + RowHeight / 2 - 6)px;"
                                     role="img"
                                     aria-label="@($"Milestone: {barTitle}: {taskStart:M/d/yyyy}")"
                                     @onclick="async () => { await HandleTaskSelect(n.Item); await OnTaskClick.InvokeAsync(n.Item); }"
                                     @onclick:stopPropagation="true">
                                    <span class="sf-gantt__milestone-diamond">&#x25C6;</span>
                                </div>
                            }
                            else
                            {
                                <div class="@barClass"
                                     data-index="@barIdx"
                                     role="img"
                                     aria-label="@($"{barTitle}: {barStart:M/d/yyyy} – {barEnd:M/d/yyyy}")"
                                     style="left: @((int)startOffset)px; width: @((int)barWidth)px;"
                                     @onclick="async () => { await HandleTaskSelect(n.Item); await OnTaskClick.InvokeAsync(n.Item); }">
                                    <div class="sf-gantt__bar-resize mar-gantt__bar-resize--left"></div>
                                    <div class="sf-gantt__bar-progress" style="width: @(pctWidth)%;"></div>
                                    @if (TaskTemplate is not null)
                                    {
                                        @TaskTemplate(n.Item)
                                    }
                                    <button type="button"
                                            class="sf-gantt__bar-delete"
                                            title="Delete"
                                            @onclick="() => OnDelete.InvokeAsync(new GanttDeleteEventArgs { Item = n.Item })"
                                            @onclick:stopPropagation="true">&#x2716;</button>
                                    <div class="sf-gantt__bar-resize mar-gantt__bar-resize--right"></div>
                                </div>
                            }
                            @if (TooltipTemplate is not null)
                            {
                                <div class="sf-gantt__tooltip" style="left: @((int)startOffset)px;">
                                    @TooltipTemplate(n.Item)
                                </div>
                            }
                            else
                            {
                                <div class="sf-gantt__tooltip" style="left: @((int)startOffset)px;">
                                    <strong>@accessor.GetTitle(n.Item)</strong><br />
                                    @barStart.ToString("M/d/yyyy") &ndash; @barEnd.ToString("M/d/yyyy")
                                </div>
                            }
                        </div>
                    }
                    @if (_dependencyLines.Count > 0)
                    {
                        <svg class="sf-gantt__dependency-svg" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;">
                            <defs>
                                <marker id="@($"gantt-arrow-{_instanceId}")" class="sf-gantt__dependency-marker" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto">
                                    <path d="M0,0 L10,4 L0,8 Z" />
                                </marker>
                            </defs>
                            @foreach (var dep in _dependencyLines)
                            {
                                <line x1="@dep.X1.ToString("F1")" y1="@dep.Y1.ToString("F1")"
                                      x2="@dep.X2.ToString("F1")" y2="@dep.Y2.ToString("F1")"
                                      class="sf-gantt__dependency"
                                      marker-end="@($"url(#gantt-arrow-{_instanceId})")" />
                            }
                        </svg>
                    }
                </div>
            }
        </div>
    </div>
    @if (_columnChooserOpen)
    {
        <SunfishPopup IsOpen="true"
                     AnchorId="mar-gantt-column-chooser-btn"
                     Placement="PopupPlacement.Bottom"
                     CloseOnEscape="true"
                     OnOutsideClick="() => { _columnChooserOpen = false; }">
            <div class="sf-gantt__column-chooser">
                <h3 class="sf-gantt__column-chooser-title">Columns</h3>
                @foreach (var col in _columns)
                {
                    var c = col;
                    <label class="sf-gantt__column-chooser-item">
                        <input type="checkbox"
                               checked="@c.Visible"
                               @onchange="async () => await ToggleColumnVisibility(c)" />
                        @(c.DisplayTitle ?? c.Field ?? "Column")
                    </label>
                }
            </div>
        </SunfishPopup>
    }
</div>

@if (_checkboxFilterField is not null)
{
    @if (FilterPopupMode == GanttFilterPopupMode.Popup)
    {
        <SunfishPopup IsOpen="true"
                     AnchorId="@($"mar-gantt-filter-{_checkboxFilterField}")"
                     Placement="PopupPlacement.Bottom"
                     CloseOnEscape="true"
                     OnOutsideClick="EventCallback.Factory.Create(this, () => { _checkboxFilterField = null; StateHasChanged(); })">
            <div class="sf-gantt__checkbox-filter">
                <h3 class="sf-gantt__checkbox-filter-title">Filter: @(_columns.FirstOrDefault(col => col.Field == _checkboxFilterField)?.DisplayTitle ?? _checkboxFilterField)</h3>
                <div class="sf-gantt__checkbox-filter-list">
                    @foreach (var option in _checkboxFilterOptions)
                    {
                        var opt = option;
                        <label class="sf-gantt__checkbox-filter-item">
                            <input type="checkbox"
                                   checked="@_checkboxFilterSelected.Contains(opt)"
                                   @onchange="() => ToggleCheckboxOption(opt)" />
                            @opt
                        </label>
                    }
                </div>
                <div class="sf-gantt__checkbox-filter-actions">
                    <button type="button" class="sf-gantt__filter-menu-btn" @onclick="ApplyCheckboxFilter">Apply</button>
                    <button type="button" class="sf-gantt__filter-menu-btn" @onclick="ClearCheckboxFilter">Clear</button>
                </div>
            </div>
        </SunfishPopup>
    }
    else
    {
        <SunfishDrawer Expanded="true"
                      Position="DrawerPosition.Right"
                      Width="300px"
                      OnClose="EventCallback.Factory.Create(this, () => { _checkboxFilterField = null; StateHasChanged(); })">
            <div class="sf-gantt__checkbox-filter">
                <h3 class="sf-gantt__checkbox-filter-title">Filter: @(_columns.FirstOrDefault(col => col.Field == _checkboxFilterField)?.DisplayTitle ?? _checkboxFilterField)</h3>
                <div class="sf-gantt__checkbox-filter-list">
                    @foreach (var option in _checkboxFilterOptions)
                    {
                        var opt = option;
                        <label class="sf-gantt__checkbox-filter-item">
                            <input type="checkbox"
                                   checked="@_checkboxFilterSelected.Contains(opt)"
                                   @onchange="() => ToggleCheckboxOption(opt)" />
                            @opt
                        </label>
                    }
                </div>
                <div class="sf-gantt__checkbox-filter-actions">
                    <button type="button" class="sf-gantt__filter-menu-btn" @onclick="ApplyCheckboxFilter">Apply</button>
                    <button type="button" class="sf-gantt__filter-menu-btn" @onclick="ClearCheckboxFilter">Clear</button>
                </div>
            </div>
        </SunfishDrawer>
    }
}

@if (TreeListEditMode == GanttTreeListEditMode.Popup && _popupEditOpen && _editingRowIndex >= 0)
{
    <SunfishPopup IsOpen="@_popupEditOpen"
                 AnchorId="@_popupEditAnchorId"
                 Placement="PopupPlacement.Bottom"
                 FocusTrap="true"
                 CloseOnEscape="true"
                 OnOutsideClick="() => CancelPopupEdit()">
        <div class="sf-gantt__popup-edit">
            <h3 class="sf-gantt__popup-edit-title">Edit Task</h3>
            @foreach (var col in VisibleColumns.Where(c => c.Editable && !string.IsNullOrEmpty(c.Field)))
            {
                var editField = col.Field;
                var inputType = GetInputType(editField!, col);
                <div class="sf-gantt__popup-edit-field">
                    <label>@col.DisplayTitle</label>
                    <input type="@inputType"
                           value="@FormatEditValue(editField!, _editValues.GetValueOrDefault(editField!))"
                           @onchange="(e) => _editValues[editField!] = ParseValue(editField!, e.Value?.ToString())"
                           class="sf-gantt__edit-input" />
                </div>
            }
            <div class="sf-gantt__popup-edit-actions">
                <button type="button" class="sf-gantt__edit-btn mar-gantt__edit-btn--save" @onclick="CommitPopupEdit">Save</button>
                <button type="button" class="sf-gantt__edit-btn mar-gantt__edit-btn--cancel" @onclick="CancelPopupEdit">Cancel</button>
            </div>
        </div>
    </SunfishPopup>
}
