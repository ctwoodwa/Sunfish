@namespace Sunfish.UIAdapters.Blazor.Components.DataDisplay
@inherits SunfishComponentBase

<div class="@CombineClasses("mar-pivotgrid")"
     style="@CombineStyles(SizeStyle())"
     aria-label="@(AriaLabel ?? "Pivot Grid")"
     @attributes="AdditionalAttributes">

    @* Field definitions (hidden, registers via CascadingValue) *@
    <CascadingValue Value="(IPivotGridFieldHost)this" IsFixed="true">
        @ChildContent
    </CascadingValue>

    @if (_effectiveColumnKeys.Count == 0 && _effectiveRowKeys.Count == 0)
    {
        <div class="sf-pivotgrid__empty" role="status">
            <p>Configure row, column, and measure fields to display pivot data.</p>
        </div>
    }
    else
    {
        <div class="sf-pivotgrid__scroll" style="overflow:auto;max-height:@(Height ?? "100%")">
            <table class="sf-pivotgrid__table" role="grid">
                <thead>
                    <tr>
                        <th class="sf-pivotgrid__corner" scope="col" role="columnheader">
                            @foreach (var rf in GetEffectiveRowFields())
                            {
                                <span>@(rf.Title ?? rf.Name)</span>
                            }
                        </th>
                        @foreach (var colKey in _effectiveColumnKeys)
                        {
                            <th class="sf-pivotgrid__col-header"
                                scope="col"
                                role="columnheader"
                                aria-sort="@(Sortable ? "none" : null)">
                                @if (ColumnHeaderTemplate != null)
                                {
                                    @ColumnHeaderTemplate(colKey)
                                }
                                else
                                {
                                    @colKey
                                }
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rowKey in _effectiveRowKeys)
                    {
                        <tr>
                            <th class="sf-pivotgrid__row-header" scope="row" role="rowheader">
                                @if (RowHeaderTemplate != null)
                                {
                                    @RowHeaderTemplate(rowKey)
                                }
                                else
                                {
                                    @rowKey
                                }
                            </th>
                            @foreach (var colKey in _effectiveColumnKeys)
                            {
                                var key = (rowKey, colKey);
                                var hasValue = _aggregates.ContainsKey(key);
                                @if (CellTemplate != null)
                                {
                                    var cellContext = BuildCellContext(rowKey, colKey, hasValue ? _aggregates[key] : null);
                                    <td class="sf-pivotgrid__cell" role="gridcell">@CellTemplate(cellContext)</td>
                                }
                                else
                                {
                                    var val = hasValue ? FormatValue(_aggregates[key]) : "-";
                                    <td class="sf-pivotgrid__cell" role="gridcell">@val</td>
                                }
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
