@namespace Sunfish.UIAdapters.Blazor.Components.DataDisplay
@typeparam TItem

@* Inline min-width/min-height satisfies WCAG 2.2 SC 2.5.8 (target-size) without
   relying on theme CSS, which the bUnit-axe harness does not load. Themes can
   raise these values further but must not drop below 24px. *@
@if (IsOpen)
{
    <div class="sf-datagrid__column-menu" @ref="_menuRef" role="menu" aria-label="Column options">
        @if (ShowSort)
        {
            <button type="button" class="sf-datagrid__column-menu-item" role="menuitem"
                    style="min-width:24px;min-height:24px;"
                    @onclick="HandleSortAsc">Sort ascending</button>
            <button type="button" class="sf-datagrid__column-menu-item" role="menuitem"
                    style="min-width:24px;min-height:24px;"
                    @onclick="HandleSortDesc">Sort descending</button>
            <button type="button" class="sf-datagrid__column-menu-item" role="menuitem"
                    style="min-width:24px;min-height:24px;"
                    @onclick="HandleClearSort"
                    disabled="@(!HasSort)">Clear sort</button>
            <div class="sf-datagrid__column-menu-divider" role="separator"></div>
        }
        @if (ShowFilter)
        {
            <button type="button" class="sf-datagrid__column-menu-item" role="menuitem"
                    style="min-width:24px;min-height:24px;"
                    @onclick="HandleFilter">Filter&#x2026;</button>
            <div class="sf-datagrid__column-menu-divider" role="separator"></div>
        }
        @if (ShowLock)
        {
            <button type="button" class="sf-datagrid__column-menu-item" role="menuitem"
                    style="min-width:24px;min-height:24px;"
                    @onclick="HandleToggleLock">
                @(IsLocked ? "Unlock column" : "Lock column")
            </button>
        }
    </div>
}

@code {
    /// <summary>Whether the menu is open.</summary>
    [Parameter] public bool IsOpen { get; set; }

    /// <summary>Whether sort items are shown. Typically tied to column.Sortable.</summary>
    [Parameter] public bool ShowSort { get; set; } = true;

    /// <summary>Whether the Filter item is shown. Typically tied to column.Filterable.</summary>
    [Parameter] public bool ShowFilter { get; set; } = true;

    /// <summary>Whether the Lock/Unlock item is shown. Typically tied to column.Lockable.</summary>
    [Parameter] public bool ShowLock { get; set; } = true;

    /// <summary>Whether the column is currently locked (frozen). Controls the label text.</summary>
    [Parameter] public bool IsLocked { get; set; }

    /// <summary>Whether there is an active sort on this column. Controls whether Clear sort is enabled.</summary>
    [Parameter] public bool HasSort { get; set; }

    /// <summary>Raised when the user clicks Sort ascending.</summary>
    [Parameter] public EventCallback OnSortAscending { get; set; }

    /// <summary>Raised when the user clicks Sort descending.</summary>
    [Parameter] public EventCallback OnSortDescending { get; set; }

    /// <summary>Raised when the user clicks Clear sort.</summary>
    [Parameter] public EventCallback OnClearSort { get; set; }

    /// <summary>Raised when the user clicks Filter.</summary>
    [Parameter] public EventCallback OnFilter { get; set; }

    /// <summary>Raised when the user clicks Lock / Unlock column.</summary>
    [Parameter] public EventCallback OnToggleLock { get; set; }

    /// <summary>Raised by item handlers after invoking their action, to tell the grid to close the menu.</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    private ElementReference _menuRef;

    private async Task HandleSortAsc()
    {
        await OnSortAscending.InvokeAsync();
        await OnClose.InvokeAsync();
    }

    private async Task HandleSortDesc()
    {
        await OnSortDescending.InvokeAsync();
        await OnClose.InvokeAsync();
    }

    private async Task HandleClearSort()
    {
        await OnClearSort.InvokeAsync();
        await OnClose.InvokeAsync();
    }

    private async Task HandleFilter()
    {
        await OnFilter.InvokeAsync();
        await OnClose.InvokeAsync();
    }

    private async Task HandleToggleLock()
    {
        await OnToggleLock.InvokeAsync();
        await OnClose.InvokeAsync();
    }
}
