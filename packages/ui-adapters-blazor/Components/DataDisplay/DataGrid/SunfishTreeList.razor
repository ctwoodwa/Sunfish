@namespace Sunfish.UIAdapters.Blazor.Components.DataDisplay
@typeparam TItem
@inherits SunfishComponentBase
@implements IColumnHost

<div class="@CombineClasses("mar-treelist")"
     style="@CombineStyles()"
     @attributes="AdditionalAttributes">

    <CascadingValue Value="(IColumnHost)this" IsFixed="true">
        <CascadingValue Value="(ITreeListEditController)this" IsFixed="true">
            @ChildContent
        </CascadingValue>
    </CascadingValue>

    <table class="sf-treelist__table" role="treegrid"
           tabindex="@(Navigable ? 0 : -1)"
           @onkeydown="HandleKeyDown"
           @onkeydown:preventDefault="Navigable"
           @onmousemove="OnResizeMouseMove"
           @onmouseup="OnResizeMouseUp"
           @onmousemove:preventDefault="_isResizing">
        <thead>
            <tr>
                @{ var orderedCols = OrderedColumns; }
                @for (var colIdx = 0; colIdx < orderedCols.Count; colIdx++)
                {
                    var col = orderedCols[colIdx];
                    var idx = colIdx;
                    var isSortable = IsColumnSortable(col);
                    var isSorted = _sortField == col.Field && _sortDirection is not null;
                    var sortCss = isSorted
                        ? (_sortDirection == Sunfish.Foundation.Enums.SortDirection.Ascending
                            ? "mar-treelist__sort-asc"
                            : "mar-treelist__sort-desc")
                        : "";
                    var dragOverCss = Reorderable && _dragOverIndex == idx && _dragSourceIndex != idx ? " mar-treelist__th--drag-over" : "";
                    var thClass = $"mar-treelist__th{(isSortable ? " mar-treelist__th--sortable" : "")}{(isSorted ? $" {sortCss}" : "")}{dragOverCss}";

                    <th class="@thClass"
                        role="columnheader"
                        aria-sort="@(isSorted ? (_sortDirection == Sunfish.Foundation.Enums.SortDirection.Ascending ? "ascending" : "descending") : "none")"
                        style="@GetColumnWidthStyle(col)"
                        draggable="@(Reorderable ? "true" : "false")"
                        @onclick="() => HandleHeaderClick(col)"
                        @ondragstart="(e) => OnDragStart(e, idx)"
                        @ondragover="(e) => OnDragOver(e, idx)"
                        @ondragover:preventDefault
                        @ondrop="(e) => OnDrop(e, idx)"
                        @ondragend="OnDragEnd">
                        @{
                            var headerTemplate = (col as SunfishTreeListColumn)?.HeaderTemplate;
                        }
                        @if (headerTemplate is not null)
                        {
                            @headerTemplate
                        }
                        else
                        {
                            @col.DisplayTitle
                        }
                        @if (isSorted)
                        {
                            <span class="sf-treelist__sort-indicator">@(_sortDirection == Sunfish.Foundation.Enums.SortDirection.Ascending ? "\u25B2" : "\u25BC")</span>
                        }
                        @if (Resizable)
                        {
                            <span class="sf-treelist__resize-handle"
                                  @onmousedown="(e) => OnResizeMouseDown(e, col)"
                                  @onmousedown:stopPropagation></span>
                        }
                    </th>
                }
                @if (EditMode == Sunfish.Foundation.Enums.TreeListEditMode.Inline)
                {
                    <th class="sf-treelist__th mar-treelist__th--commands" role="columnheader">Commands</th>
                }
            </tr>
            @if (FilterMode == Sunfish.Foundation.Enums.TreeListFilterMode.FilterRow)
            {
                <tr class="sf-treelist__filter-row">
                    @foreach (var col in orderedCols)
                    {
                        <td class="sf-treelist__filter-cell">
                            @if (IsColumnFilterable(col))
                            {
                                var fieldName = col.Field;
                                <input type="text"
                                       class="sf-treelist__filter-input"
                                       placeholder="Filter..."
                                       value="@(_filterValues.TryGetValue(fieldName, out var fv) ? fv : "")"
                                       @oninput="@(e => HandleFilterInput(fieldName, e.Value?.ToString() ?? ""))" />
                            }
                        </td>
                    }
                    @if (EditMode == Sunfish.Foundation.Enums.TreeListEditMode.Inline)
                    {
                        <td class="sf-treelist__filter-cell"></td>
                    }
                </tr>
            }
        </thead>
        <tbody>
            @{ _currentRenderRowIndex = 0; }
            @if (_isNewItem && _editingItem is not null)
            {
                @RenderEditRow(_editingItem, 0)
            }
            @if (EnableVirtualization)
            {
                <Virtualize Items="FlattenedVisibleRows" ItemSize="@((float)ItemHeight)" Context="entry">
                    @RenderSingleRow(entry.Node, entry.Depth)
                </Virtualize>
            }
            else
            {
                @RenderRows(_rootItems, 0)
            }
        </tbody>
    </table>

    @if (Pageable && TotalPages > 0)
    {
        <nav class="sf-treelist__pager" role="navigation" aria-label="TreeList pagination">
            <button type="button"
                    class="sf-treelist__pager-btn mar-treelist__pager-btn--prev"
                    disabled="@(Page <= 1)"
                    @onclick="GoToPreviousPageAsync">
                &laquo; Prev
            </button>
            @for (var p = 1; p <= TotalPages; p++)
            {
                var pageNum = p;
                <button type="button"
                        class="@($"mar-treelist__pager-btn{(pageNum == Page ? " mar-treelist__pager-btn--active" : "")}")"
                        @onclick="() => GoToPageAsync(pageNum)">
                    @pageNum
                </button>
            }
            <button type="button"
                    class="sf-treelist__pager-btn mar-treelist__pager-btn--next"
                    disabled="@(Page >= TotalPages)"
                    @onclick="GoToNextPageAsync">
                Next &raquo;
            </button>
        </nav>
    }
</div>
