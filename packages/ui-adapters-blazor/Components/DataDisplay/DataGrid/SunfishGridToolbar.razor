@namespace Sunfish.Components.Blazor.Components.DataDisplay
@inherits SunfishComponentBase

<div class="@CombineClasses(CssProvider.DataGridToolbarClass())"
     style="@CombineStyles()"
     role="toolbar"
     aria-label="Grid toolbar"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    /// <summary>Toolbar content. Can include command buttons or any custom content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
