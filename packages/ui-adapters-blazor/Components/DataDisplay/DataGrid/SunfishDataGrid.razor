@namespace Sunfish.Components.Blazor.Components.DataDisplay
@using Sunfish.Components.Blazor.Components.Navigation
@using Sunfish.Foundation.Data
@using Microsoft.AspNetCore.Components.Forms
@typeparam TItem
@inherits SunfishComponentBase

<div id="@_gridId"
     class="@CombineClasses(CssProvider.DataGridClass(), SizeClass)"
     style="@CombineStyles(RootStyle)"
     role="grid"
     aria-rowcount="@_displayedItems.Count"
     aria-colcount="@_visibleColumns.Count"
     aria-busy="@(IsLoading ? "true" : null)"
     @attributes="AdditionalAttributes">

    @* Toolbar area *@
    @if (ToolbarTemplate != null)
    {
        <CascadingValue Value="this" IsFixed="true">
            @ToolbarTemplate
        </CascadingValue>
    }

    @* Search box *@
    @if (ShowSearchBox)
    {
        <div class="sf-datagrid-searchbox" role="search">
            <input type="text"
                   class="sf-datagrid-searchbox-input"
                   placeholder="@SearchBoxPlaceholder"
                   value="@_searchText"
                   aria-label="Search grid"
                   @oninput="OnSearchChanged" />
        </div>
    }

    @* Column definitions (hidden, just registers via CascadingValue) *@
    <CascadingValue Value="this" IsFixed="true">
        @ChildContent
    </CascadingValue>

    @* Loading overlay *@
    @if (IsLoading)
    {
        <div class="sf-datagrid-loading-overlay" aria-live="polite">
            <div class="sf-datagrid-loading-spinner" role="status">
                <span class="sf-datagrid-loading-text">Loading…</span>
            </div>
        </div>
    }

    <div class="sf-datagrid-content" style="@ContentContainerStyle">
        <table style="width:100%;table-layout:fixed;">
            <colgroup>
                @if (RowDraggable)
                {
                    <col style="width:40px;" />
                }
                @if (DetailTemplate != null)
                {
                    <col style="width:40px;" />
                }
                @if (ShowCheckboxColumn)
                {
                    <col style="width:40px;" />
                }
                @foreach (var column in _visibleColumns)
                {
                    <col data-column-id="@column.EffectiveId" style="@GetColumnWidthStyle(column)" />
                }
                @if (EditMode != GridEditMode.None && EditMode != GridEditMode.InCell)
                {
                    <col style="width:120px;" />
                }
            </colgroup>

            @* Header row *@
            <thead>
                <tr class="@CssProvider.DataGridHeaderClass()" role="row">
                    @if (RowDraggable)
                    {
                        <th class="sf-datagrid-drag-header" role="columnheader" style="width:40px;"></th>
                    }
                    @if (DetailTemplate != null)
                    {
                        <th class="sf-datagrid-detail-cell" role="columnheader" style="width:40px;"></th>
                    }
                    @if (ShowCheckboxColumn)
                    {
                        <th class="sf-datagrid-checkbox-cell" role="columnheader" style="width:40px;">
                            @if (SelectionMode == GridSelectionMode.Multiple)
                            {
                                <input type="checkbox"
                                       checked="@(_selectedItems.Count > 0 && _selectedItems.Count == _displayedItems.Count)"
                                       aria-label="Select all rows"
                                       @onchange="OnSelectAllChanged" />
                            }
                        </th>
                    }
                    @foreach (var column in _visibleColumns)
                    {
                        var isSortable = Sortable && column.Sortable;
                        var isSorted = _state.SortDescriptors.Any(s => s.Field == column.Field);
                        var sortDir = _state.SortDescriptors.FirstOrDefault(s => s.Field == column.Field);
                        var headerCellClass = CssProvider.DataGridHeaderCellClass(isSortable, isSorted);
                        if (column.Locked) headerCellClass = $"{headerCellClass} mar-datagrid-col--locked";
                        if (!string.IsNullOrEmpty(column.HeaderClass)) headerCellClass = string.IsNullOrEmpty(headerCellClass) ? column.HeaderClass : $"{headerCellClass} {column.HeaderClass}";
                        var frozenHeaderStyle = GetFrozenCellStyle(column, isHeader: true);
                        // B2.4: header must be position:relative so the absolutely-positioned handle aligns.
                        var resizePositionStyle = column.IsResizable(AllowColumnResize || Resizable) ? "position:relative;" : null;
                        var combinedStyle = GetColumnCellStyle(column, string.IsNullOrEmpty(frozenHeaderStyle)
                            ? resizePositionStyle
                            : resizePositionStyle is not null ? $"{frozenHeaderStyle}{resizePositionStyle}" : frozenHeaderStyle);

                        <th class="@headerCellClass"
                            role="columnheader"
                            style="@(string.IsNullOrEmpty(combinedStyle) ? null : combinedStyle)"
                            aria-sort="@GetAriaSortValue(sortDir)"
                            data-column-index="@_visibleColumns.IndexOf(column)"
                            data-column-id="@column.EffectiveId"
                            draggable="@(column.IsReorderable(AllowColumnReorder || Reorderable) ? "true" : "false")"
                            @onclick="(e) => OnHeaderClick(column, isSortable, e)">
                            @if (column.HeaderTemplate != null)
                            {
                                @column.HeaderTemplate
                            }
                            else
                            {
                                @column.DisplayTitle
                            }
                            @if (isSorted && sortDir != null)
                            {
                                var sortOrder = _state.SortDescriptors.IndexOf(sortDir) + 1;
                                <span class="sf-datagrid-sort-indicator" aria-hidden="true">
                                    @(sortDir.Direction == SortDirection.Ascending ? "\u25B2" : "\u25BC")
                                    @if (_state.SortDescriptors.Count > 1)
                                    {
                                        <sub class="sf-datagrid-sort-order">@sortOrder</sub>
                                    }
                                </span>
                            }
                            @if (FilterMode == GridFilterMode.FilterMenu && column.Filterable)
                            {
                                var col = column;
                                var isFilterMenuOpen = _filterMenuField == col.Field;
                                <button type="button"
                                        class="sf-datagrid-filter-menu-btn @(_state.FilterDescriptors.Any(f => f.Field == col.Field) ? "mar-datagrid-filter-menu-btn--active" : "")"
                                        aria-label="@($"Filter {column.DisplayTitle}")"
                                        aria-expanded="@(isFilterMenuOpen ? "true" : "false")"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => ToggleFilterMenu(col.Field)">
                                    <svg class="sf-datagrid-filter-menu-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                        <path fill="currentColor" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h9A1.5 1.5 0 0 1 14 3.5a1.5 1.5 0 0 1-.33.94L10 9v3.25c0 .29-.16.56-.42.7l-2 1A.75.75 0 0 1 6.5 13.3V9L2.33 4.44A1.5 1.5 0 0 1 2 3.5Z" />
                                    </svg>
                                </button>

                                @if (isFilterMenuOpen)
                                {
                                    <div class="sf-datagrid-filter-popup" @onclick:stopPropagation="true">
                                        @RenderFilterMenu()
                                    </div>
                                }
                            }
                            @if (FilterMode == GridFilterMode.CheckBoxList && column.Filterable)
                            {
                                var col = column;
                                var isCheckBoxFilterOpen = _checkBoxFilterField == col.Field;
                                var hasActiveCheckBoxFilter = _state.CompositeFilterDescriptors.Any(c => c.Filters.Count > 0 && c.Filters[0].Field == col.Field);
                                <button type="button"
                                        class="sf-datagrid-filter-menu-btn @(hasActiveCheckBoxFilter ? "mar-datagrid-filter-menu-btn--active" : "")"
                                        aria-label="@($"Filter {column.DisplayTitle}")"
                                        aria-expanded="@(isCheckBoxFilterOpen ? "true" : "false")"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => ToggleCheckBoxFilter(col.Field)">
                                    <svg class="sf-datagrid-filter-menu-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                        <path fill="currentColor" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h9A1.5 1.5 0 0 1 14 3.5a1.5 1.5 0 0 1-.33.94L10 9v3.25c0 .29-.16.56-.42.7l-2 1A.75.75 0 0 1 6.5 13.3V9L2.33 4.44A1.5 1.5 0 0 1 2 3.5Z" />
                                    </svg>
                                </button>

                                @if (isCheckBoxFilterOpen)
                                {
                                    <div class="sf-datagrid-filter-popup" @onclick:stopPropagation="true">
                                        @RenderCheckBoxFilterMenu()
                                    </div>
                                }
                            }
                            @* B2.4: column resize drag handle — rendered only when both grid and column allow resizing. *@
                            @if (column.IsResizable(AllowColumnResize || Resizable))
                            {
                                <div class="mar-datagrid-col-resize-handle"
                                     data-column-index="@_visibleColumns.IndexOf(column)"
                                     data-column-id="@column.EffectiveId"
                                     data-min-width="@column.MinResizableWidth"
                                     data-max-width="@column.MaxResizableWidth"
                                     role="separator"
                                     aria-orientation="vertical"
                                     aria-label="@($"Resize column {column.DisplayTitle}")"
                                     @onclick:stopPropagation="true"></div>
                            }
                        </th>
                    }
                    @if (EditMode != GridEditMode.None && EditMode != GridEditMode.InCell)
                    {
                        <th class="sf-datagrid-command-header" role="columnheader">Commands</th>
                    }
                </tr>

                @* Filter row *@
                @if (FilterMode == GridFilterMode.FilterRow)
                {
                    <tr class="@CssProvider.DataGridFilterRowClass()" role="row">
                        @if (RowDraggable)
                        {
                            <td class="@CssProvider.DataGridFilterCellClass()" role="gridcell"></td>
                        }
                        @if (DetailTemplate != null)
                        {
                            <td class="@CssProvider.DataGridFilterCellClass()" role="gridcell"></td>
                        }
                        @if (ShowCheckboxColumn)
                        {
                            <td class="@CssProvider.DataGridFilterCellClass()" role="gridcell"></td>
                        }
                        @foreach (var column in _visibleColumns)
                        {
                            var frozenFilterStyle = GetFrozenCellStyle(column);
                            var filterCellCombinedStyle = GetColumnCellStyle(column, frozenFilterStyle);
                                <td class="@CssProvider.DataGridFilterCellClass()" role="gridcell" style="@(string.IsNullOrEmpty(filterCellCombinedStyle) ? null : filterCellCombinedStyle)">
                                @if (column.Filterable)
                                {
                                    var currentFilter = _state.FilterDescriptors.FirstOrDefault(f => f.Field == column.Field);
                                    <input type="text"
                                           value="@(currentFilter?.Value?.ToString() ?? "")"
                                           placeholder="Filter..."
                                           aria-label="@($"Filter {column.DisplayTitle}")"
                                           @onchange="(e) => OnFilterChanged(column.Field, e)" />
                                }
                            </td>
                        }
                        @if (EditMode != GridEditMode.None && EditMode != GridEditMode.InCell)
                        {
                            <td class="@CssProvider.DataGridFilterCellClass()" role="gridcell"></td>
                        }
                    </tr>
                }
            </thead>

            @* Data rows *@
            <tbody>
                @if (_isCreating && EditMode == GridEditMode.Inline && _editingItem != null)
                {
                    @RenderEditRow(_editingItem)
                }

                @if (_displayedItems.Count == 0 && _groupedRows.Count == 0 && !_isCreating && !IsLoading)
                {
                    <tr role="row">
                        <td colspan="@TotalColumnCount" role="gridcell" class="sf-datagrid-empty">
                            @if (NoDataTemplate != null)
                            {
                                @NoDataTemplate
                            }
                            else
                            {
                                <text>No data available.</text>
                            }
                        </td>
                    </tr>
                }
                else if (_groupedRows.Count > 0)
                {
                    @RenderGroupRows(_groupedRows)
                }
                else if (EnableVirtualization)
                {
                    <Virtualize Items="@_displayedItems" Context="item" OverscanCount="@VirtualizeOverscanCount">
                        @{ RenderDataRow(item, _displayedItems.IndexOf(item)); }
                    </Virtualize>
                }
                else
                {
                    @for (var i = 0; i < _displayedItems.Count; i++)
                    {
                        var item = _displayedItems[i];
                        @RenderDataRow(item, i)

                        @* Detail row (master-detail) *@
                        @if (DetailTemplate != null && _expandedDetailItems.Contains(item))
                        {
                            <tr class="sf-datagrid-detail-row" role="row">
                                <td colspan="@TotalColumnCount" role="gridcell">
                                    @DetailTemplate(item)
                                </td>
                            </tr>
                        }
                    }
                }
            </tbody>

            @* Footer row (aggregates) *@
            @if (_visibleColumns.Any(c => c.FooterTemplate != null))
            {
                <tfoot>
                    <tr class="sf-datagrid-footer-row" role="row">
                        @if (RowDraggable)
                        {
                            <td role="gridcell"></td>
                        }
                        @if (DetailTemplate != null)
                        {
                            <td role="gridcell"></td>
                        }
                        @if (ShowCheckboxColumn)
                        {
                            <td role="gridcell"></td>
                        }
                        @foreach (var column in _visibleColumns)
                        {
                            var frozenFooterStyle = GetFrozenCellStyle(column);
                            var footerCombinedStyle = GetColumnCellStyle(column, frozenFooterStyle);
                                <td class="sf-datagrid-footer-cell" role="gridcell"
                                        style="@(string.IsNullOrEmpty(footerCombinedStyle) ? null : footerCombinedStyle)">
                                @if (column.FooterTemplate != null)
                                {
                                    @column.FooterTemplate
                                }
                            </td>
                        }
                        @if (EditMode != GridEditMode.None && EditMode != GridEditMode.InCell)
                        {
                            <td role="gridcell"></td>
                        }
                    </tr>
                </tfoot>
            }
        </table>
    </div>

    @* Popup edit dialog *@
    @if (EditMode == GridEditMode.Popup && _editingItem != null)
    {
        <div class="sf-datagrid-popup-overlay" @onclick="CancelEdit">
            <div class="sf-datagrid-popup-dialog" role="dialog" aria-label="@(_isCreating ? "Add item" : "Edit item")" @onclick:stopPropagation="true">
                <div class="sf-datagrid-popup-header">
                    <h3>@(_isCreating ? "Add New Item" : "Edit Item")</h3>
                </div>
                <EditForm Model="_editingItem" OnValidSubmit="SaveEdit">
                    <DataAnnotationsValidator />
                    <div class="sf-datagrid-popup-body">
                        <ValidationSummary class="sf-datagrid-validation-summary" />
                        @foreach (var column in _visibleColumns)
                        {
                            <div class="sf-datagrid-popup-field">
                                <label>@column.DisplayTitle</label>
                                @if (column.Editable && column.EditorTemplate != null)
                                {
                                    @column.EditorTemplate(_editingItem)
                                }
                                else
                                {
                                    <input type="text" value="@column.GetDisplayValue(_editingItem)" disabled />
                                }
                            </div>
                        }
                    </div>
                    <div class="sf-datagrid-popup-actions">
                        <button type="submit" class="sf-datagrid-cmd-btn">Save</button>
                        <button type="button" class="sf-datagrid-cmd-btn" @onclick="CancelEdit">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* Pager *@
    @if (Pageable)
    {
        var totalPages = TotalPages;

        <div class="@CssProvider.DataGridPagerClass()">
            <SunfishPagination Page="@_state.CurrentPage"
                              PageChanged="GoToPage"
                              Total="@_state.TotalCount"
                              PageSize="@_state.PageSize"
                              PageSizeChanged="OnPaginationPageSizeChanged"
                              PageSizes="@(PageSizes?.ToList())"
                              ButtonCount="@PagerButtonCount"
                              AriaLabel="Pagination" />

            <span class="sf-datagrid-pager-info">
                Page @_state.CurrentPage of @totalPages
            </span>
        </div>
    }
</div>
