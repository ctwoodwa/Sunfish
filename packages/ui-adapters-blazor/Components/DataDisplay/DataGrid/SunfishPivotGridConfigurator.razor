@namespace Sunfish.UIAdapters.Blazor.Components.DataDisplay
@inherits SunfishComponentBase

<div class="@CombineClasses("sf-pivotgrid-configurator")"
     @attributes="AdditionalAttributes">
    <div class="sf-pivotgrid-configurator__section">
        <h4 class="sf-pivotgrid-configurator__section-title">Rows</h4>
        @if (RowFields?.Any() == true)
        {
            <ul class="sf-pivotgrid-configurator__field-list">
                @foreach (var field in RowFields)
                {
                    <li class="sf-pivotgrid-configurator__field-item sf-pivotgrid-configurator__field-item--row">
                        @(field.Title ?? field.Name)
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="sf-pivotgrid-configurator__empty-hint">No row fields</p>
        }
    </div>

    <div class="sf-pivotgrid-configurator__section">
        <h4 class="sf-pivotgrid-configurator__section-title">Columns</h4>
        @if (ColumnFields?.Any() == true)
        {
            <ul class="sf-pivotgrid-configurator__field-list">
                @foreach (var field in ColumnFields)
                {
                    <li class="sf-pivotgrid-configurator__field-item sf-pivotgrid-configurator__field-item--column">
                        @(field.Title ?? field.Name)
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="sf-pivotgrid-configurator__empty-hint">No column fields</p>
        }
    </div>

    <div class="sf-pivotgrid-configurator__section">
        <h4 class="sf-pivotgrid-configurator__section-title">Measures</h4>
        @if (MeasureFields?.Any() == true)
        {
            <ul class="sf-pivotgrid-configurator__field-list">
                @foreach (var field in MeasureFields)
                {
                    <li class="sf-pivotgrid-configurator__field-item sf-pivotgrid-configurator__field-item--measure">
                        @(field.Title ?? field.Name)
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="sf-pivotgrid-configurator__empty-hint">No measure fields</p>
        }
    </div>
</div>

@code {
    /// <summary>Row field definitions to display in the configurator.</summary>
    [Parameter] public IReadOnlyList<PivotGridField>? RowFields { get; set; }

    /// <summary>Column field definitions to display in the configurator.</summary>
    [Parameter] public IReadOnlyList<PivotGridField>? ColumnFields { get; set; }

    /// <summary>Measure field definitions to display in the configurator.</summary>
    [Parameter] public IReadOnlyList<PivotGridField>? MeasureFields { get; set; }
}
