@namespace Sunfish.Components.Blazor.Components.DataDisplay
@using Sunfish.Foundation.Enums
@using Sunfish.Foundation.Models.DataSheet
@typeparam TItem
@inherits SunfishComponentBase

<div id="@_gridId"
     class="@CombineClasses(CssProvider.DataSheetClass(IsLoading))"
     tabindex="0"
     style="@CombineStyles(_rootStyle)"
     role="grid"
     aria-label="@AriaLabel"
     aria-rowcount="@_displayRows.Count"
     aria-colcount="@_columns.Count"
     aria-busy="@((IsLoading || IsSaving) ? "true" : null)"
     @attributes="AdditionalAttributes">

    @* Toolbar *@
    <div class="@CssProvider.DataSheetToolbarClass()" role="toolbar" aria-label="Grid actions">
        @if (AllowAddRow)
        {
            <button type="button"
                    class="@CssProvider.DataSheetAddButtonClass()"
                    aria-label="Add row"
                    @onclick="AddRowAsync">
                + Add Row
            </button>
        }

        @if (_dirtyRows.Count > 0)
        {
            <span class="@CssProvider.DataSheetDirtyBadgeClass()" aria-live="polite">
                @_dirtyRows.Count(kv => !kv.Value.IsDeleted && kv.Value.DirtyFields.Count > 0) unsaved changes
            </span>
        }

        <button type="button"
                class="@CssProvider.DataSheetSaveButtonClass()"
                disabled="@(IsSaving || _dirtyRows.Count == 0)"
                aria-label="Save all changes"
                @onclick="SaveAllAsync">
            @if (IsSaving)
            {
                <span class="@CssProvider.DataSheetSpinnerClass()" role="status" aria-label="Saving"></span>
            }
            Save All
        </button>

        <button type="button"
                class="@CssProvider.DataSheetResetButtonClass()"
                disabled="@(_dirtyRows.Count == 0)"
                aria-label="Reset all changes"
                @onclick="ResetAsync">
            Reset
        </button>

        @if (ToolbarTemplate != null)
        {
            @ToolbarTemplate
        }
    </div>

    @* Bulk action bar *@
    @if (AllowDeleteRow && _selectedRows.Count > 0)
    {
        <div class="@CssProvider.DataSheetBulkBarClass(true)" role="toolbar" aria-label="Bulk actions">
            <span>@_selectedRows.Count selected</span>
            <button type="button" @onclick="BulkDeleteAsync" aria-label="Delete selected rows">Delete Selected</button>
            <button type="button" @onclick="BulkResetAsync" aria-label="Reset selected rows">Reset Selected</button>
        </div>
    }

    @* Column definitions (hidden, registers via CascadingValue) *@
    <CascadingValue Value="this" IsFixed="true">
        @ChildContent
    </CascadingValue>

    @* Loading skeleton *@
    @if (IsLoading)
    {
        <div class="@CssProvider.DataSheetSkeletonClass()" aria-live="polite" role="status">
            @for (var s = 0; s < 5; s++)
            {
                <div class="@CssProvider.DataSheetSkeletonRowClass()" aria-hidden="true">
                    @for (var sc = 0; sc < Math.Max(_columns.Count, 3); sc++)
                    {
                        <div class="@CssProvider.DataSheetSkeletonCellClass()"></div>
                    }
                </div>
            }
            <span class="@CssProvider.DataSheetLoadingTextClass()">Loading…</span>
        </div>
    }
    else
    {
        <div class="@CssProvider.DataSheetContentClass()" style="@_contentStyle">
            <table>
                @* Header *@
                <thead>
                    @{
                        var headerColIndex = 1;
                    }
                    <tr role="row" aria-rowindex="1">
                        @if (AllowDeleteRow)
                        {
                            <th class="@CssProvider.DataSheetSelectHeaderClass()"
                                role="columnheader"
                                aria-colindex="@(headerColIndex++)"
                                style="width:40px;">
                                <input type="checkbox"
                                       checked="@(_selectedRows.Count > 0 && _selectedRows.Count == _displayRows.Count)"
                                       aria-label="Select all rows"
                                       @onchange="OnSelectAllChanged" />
                            </th>
                        }
                        @foreach (var column in _columns)
                        {
                            var colStyle = column.Width != null ? $"width:{column.Width};" :
                                           column.MinWidth.HasValue ? $"min-width:{column.MinWidth}px;" : null;
                            <th class="@CssProvider.DataSheetHeaderCellClass(false)"
                                role="columnheader"
                                aria-colindex="@(headerColIndex++)"
                                style="@colStyle"
                                aria-label="@column.DisplayTitle">
                                @column.DisplayTitle
                            </th>
                        }
                        @if (AllowDeleteRow)
                        {
                            <th class="@CssProvider.DataSheetActionsHeaderClass()"
                                role="columnheader"
                                aria-colindex="@(headerColIndex++)"
                                style="width:60px;"></th>
                        }
                    </tr>
                </thead>

                @* Body *@
                <tbody>
                    @if (_displayRows.Count == 0)
                    {
                        <tr role="row">
                            <td colspan="@_totalColumnCount" role="gridcell" class="@CssProvider.DataSheetEmptyClass()">
                                @EmptyStateMessage
                            </td>
                        </tr>
                    }
                    else if (EnableVirtualization)
                    {
                        <Virtualize Items="@_displayRows" Context="row" OverscanCount="5">
                            @RenderRow(row)
                        </Virtualize>
                    }
                    else
                    {
                        @foreach (var row in _displayRows)
                        {
                            @RenderRow(row)
                        }
                    }
                </tbody>
            </table>
        </div>
    }

    @* Save footer *@
    <div class="@CssProvider.DataSheetSaveFooterClass(_dirtyRows.Count)" role="status">
        @if (_dirtyRows.Count > 0)
        {
            <span>@_dirtyRows.Count(kv => !kv.Value.IsDeleted && kv.Value.DirtyFields.Count > 0) unsaved changes</span>
        }
    </div>

    @* Aria-live region for announcements *@
    <div aria-live="polite" role="status" class="@CssProvider.DataSheetAriaLiveClass()">
        @_ariaAnnouncement
    </div>
</div>
