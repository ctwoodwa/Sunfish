@namespace Sunfish.Components.Blazor.Components.DataDisplay
@typeparam TItem
@inherits SunfishComponentBase

@code {
    [CascadingParameter] private SunfishDataGrid<TItem>? ParentGrid { get; set; }

    /// <summary>The property name on TItem to bind to this column.</summary>
    [Parameter] public string Field { get; set; } = "";

    /// <summary>Header text. Defaults to Field if not set.</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>CSS width for the column (e.g. "200px", "25%").</summary>
    [Parameter] public string? Width { get; set; }

    /// <summary>Runtime width set by column resize interop. Takes precedence over the Width parameter.</summary>
    internal string? RuntimeWidth { get; set; }

    /// <summary>Gets the effective width (runtime override or parameter value).</summary>
    internal string? EffectiveWidth => RuntimeWidth ?? Width;

    /// <summary>Whether this column is sortable. Defaults to true.</summary>
    [Parameter] public bool Sortable { get; set; } = true;

    /// <summary>Whether this column is filterable. Defaults to true.</summary>
    [Parameter] public bool Filterable { get; set; } = true;

    /// <summary>Whether this column is visible. Defaults to true.</summary>
    [Parameter] public bool Visible { get; set; } = true;

    /// <summary>Custom cell template. Receives the row item as context.</summary>
    [Parameter] public RenderFragment<TItem>? Template { get; set; }

    /// <summary>Custom header template.</summary>
    [Parameter] public RenderFragment? HeaderTemplate { get; set; }

    /// <summary>Custom editor template for inline/popup editing. Receives the row item as context.</summary>
    [Parameter] public RenderFragment<TItem>? EditorTemplate { get; set; }

    /// <summary>Custom footer template for column aggregates.</summary>
    [Parameter] public RenderFragment? FooterTemplate { get; set; }

    /// <summary>Text alignment for the column (e.g. "left", "center", "right").</summary>
    [Parameter] public string? TextAlign { get; set; }

    /// <summary>Format string for displaying the cell value (e.g. "C2", "yyyy-MM-dd").</summary>
    [Parameter] public string? Format { get; set; }

    /// <summary>Callback for per-cell render customization (CSS classes, styles).</summary>
    [Parameter] public Action<GridCellRenderEventArgs<TItem>>? OnCellRender { get; set; }

    /// <summary>Whether this column is editable in edit mode. Defaults to true.</summary>
    [Parameter] public bool Editable { get; set; } = true;

    /// <summary>Additional CSS class applied to the header cell (&lt;th&gt;) for this column.
    /// Appended (space-separated) to any existing header classes; does not replace them.</summary>
    [Parameter] public string? HeaderClass { get; set; }

    /// <summary>Stable column identifier, independent of <see cref="Field"/>.
    /// Useful when the field name may vary but a consistent column key is required
    /// (e.g. for state persistence, column chooser, or column menus).
    /// When not set, falls back to <see cref="Field"/>, then to an index-based key.</summary>
    [Parameter] public string? Id { get; set; }

    /// <summary>
    /// When <c>true</c>, a column-menu trigger will be rendered in the header once a column-menu
    /// host is available in the grid.
    /// <para><b>Note:</b> The column-menu host UI is not yet shipped (Phase C tracker item C3).
    /// Setting this parameter now ensures the column participates when menus land.</para>
    /// </summary>
    [Parameter] public bool ShowColumnMenu { get; set; }

    /// <summary>
    /// Whether this column appears in the column chooser UI. Defaults to <c>true</c>.
    /// Set to <c>false</c> to permanently hide a column from the chooser.
    /// <para><b>Note:</b> The column chooser UI is not yet shipped (Phase C tracker item C4).
    /// Setting this parameter now ensures the column is excluded when the chooser lands.</para>
    /// </summary>
    [Parameter] public bool VisibleInColumnChooser { get; set; } = true;

    /// <summary>Gets the effective column identifier.
    /// Returns <see cref="Id"/> if set; otherwise <see cref="Field"/> when non-empty;
    /// otherwise a positional key of the form <c>"column-{index}"</c>.</summary>
    internal string EffectiveId => Id ?? (string.IsNullOrEmpty(Field) ? $"column-{_columnIndex}" : Field);

    /// <summary>Zero-based position of this column in the parent grid's column list.
    /// Set by the parent grid (<see cref="SunfishDataGrid{TItem}.RegisterColumn"/>) on registration.</summary>
    internal int _columnIndex;

    /// <summary>
    /// Whether this column can be resized by the user when the grid's <c>AllowColumnResize</c> is <c>true</c>.
    /// Defaults to <c>true</c>; set to <c>false</c> to opt a specific column out of resizing.
    /// </summary>
    [Parameter] public bool Resizable { get; set; } = true;

    /// <summary>
    /// Minimum column width enforced during resize (CSS length string, e.g. <c>"40px"</c>).
    /// When not set, the JS layer defaults to 40 px.
    /// </summary>
    [Parameter] public string? MinResizableWidth { get; set; }

    /// <summary>
    /// Maximum column width enforced during resize (CSS length string, e.g. <c>"600px"</c>).
    /// When not set, there is no upper limit.
    /// </summary>
    [Parameter] public string? MaxResizableWidth { get; set; }

    /// <summary>
    /// Returns <c>true</c> when this column should show a resize handle.
    /// A column is resizable only when the grid opts in via <paramref name="gridAllows"/>
    /// AND the column's own <see cref="Resizable"/> is <c>true</c>.
    /// </summary>
    internal bool IsResizable(bool gridAllows) => gridAllows && Resizable;

    /// <summary>
    /// Whether this column can be dragged to a new position when the grid's
    /// <c>AllowColumnReorder</c> is <c>true</c>. Defaults to <c>true</c>; set to <c>false</c>
    /// to opt a specific column out of reordering.
    /// </summary>
    [Parameter] public bool Reorderable { get; set; } = true;

    /// <summary>
    /// Optional initial display order index. When set on one or more columns, the grid sorts
    /// <c>_columns</c> by <c>(OrderIndex ?? declarationIndex)</c> before first render so that
    /// columns appear in the specified order regardless of declaration sequence.
    /// After a drag-reorder, the grid calls <see cref="SetOrderIndex"/> to keep this in sync.
    /// </summary>
    [Parameter] public int? OrderIndex { get; set; }

    /// <summary>Updates <see cref="OrderIndex"/> after a drag-reorder.</summary>
    internal void SetOrderIndex(int idx) => OrderIndex = idx;

    /// <summary>
    /// Returns <c>true</c> when this column participates in HTML5 drag-reorder.
    /// A column is reorderable only when the grid opts in via <paramref name="gridAllows"/>
    /// AND the column's own <see cref="Reorderable"/> is <c>true</c>.
    /// </summary>
    internal bool IsReorderable(bool gridAllows) => gridAllows && Reorderable;

    /// <summary>Whether this column can be used for grouping. Defaults to true.</summary>
    [Parameter] public bool Groupable { get; set; } = true;

    /// <summary>When true, the column is frozen and sticks during horizontal scroll.</summary>
    [Parameter] public bool Locked { get; set; }

    /// <summary>
    /// Programmatically toggles <see cref="Locked"/> at runtime (e.g. via the column menu).
    /// Using a method bypasses the Blazor BL0005 warning that fires when a parameter property
    /// is set from outside the component's own render tree.
    /// </summary>
    internal void SetLocked(bool locked) => Locked = locked;

    /// <summary>When Locked=true, the side to pin to. Default: Start (left in LTR).</summary>
    [Parameter] public GridColumnFrozenPosition FrozenPosition { get; set; } = GridColumnFrozenPosition.Start;

    /// <summary>
    /// Whether this column can be locked/unlocked at runtime via the column menu.
    /// Defaults to <c>true</c>. Set to <c>false</c> to prevent the user from toggling
    /// the frozen state through the column menu (future C3 column-menu feature).
    /// <para><b>Note:</b> This parameter gates runtime UI toggling only. Setting
    /// <see cref="Locked"/> directly always works regardless of this value.</para>
    /// </summary>
    [Parameter] public bool Lockable { get; set; } = true;

    /// <summary>Composite format string for display (e.g. "{0:C2}"). Takes precedence over Format.</summary>
    [Parameter] public string? DisplayFormat { get; set; }

    /// <summary>Gets the display title for the column header.</summary>
    internal string DisplayTitle => Title ?? Field;

    /// <summary>Gets the value of this column's field from the given item.</summary>
    internal object? GetValue(TItem item)
    {
        if (item is null || string.IsNullOrEmpty(Field)) return null;
        return typeof(TItem).GetProperty(Field)?.GetValue(item);
    }

    /// <summary>Gets the formatted display string for the given item.</summary>
    internal string GetDisplayValue(TItem item)
    {
        var value = GetValue(item);
        if (value is null) return string.Empty;
        if (!string.IsNullOrEmpty(DisplayFormat) && value is IFormattable)
            return string.Format(null, DisplayFormat, value);
        if (!string.IsNullOrEmpty(Format) && value is IFormattable formattable)
            return formattable.ToString(Format, null);
        return value.ToString() ?? string.Empty;
    }

    protected override void OnInitialized()
    {
        ParentGrid?.RegisterColumn(this);
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing) ParentGrid?.UnregisterColumn(this);
        base.Dispose(disposing);
    }
}
