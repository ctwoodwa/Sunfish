@namespace Sunfish.UIAdapters.Blazor.Components.DataDisplay
@inherits SunfishComponentBase

<img class="@CombineClasses(CssProvider.CardImageClass())" style="@CombineStyles()" src="@Src" alt="@Alt" @attributes="AdditionalAttributes" />

@code {
    /// <summary>The image source URL.</summary>
    [Parameter] public string? Src { get; set; }

    /// <summary>The alternative text for the image.</summary>
    [Parameter] public string? Alt { get; set; }
}
