@namespace Sunfish.UIAdapters.Blazor.Shell
@inherits ComponentBase

<div class="sf-notifbell @Class" style="@Style">
    @if (Open)
    {
        <div class="sf-notifbell__scrim" @onclick="CloseAsync" aria-hidden="true"></div>
    }

    <div class="sf-notifbell__panel @(Open ? "is-open" : "")"
         role="dialog"
         aria-modal="false"
         aria-hidden="@(Open ? "false" : "true")"
         aria-label="Notifications">

        <header class="sf-notifbell__header">
            <span class="sf-notifbell__title">Notifications</span>
            <div class="sf-notifbell__header-actions">
                @if (UnreadCount > 0)
                {
                    <button type="button" class="sf-notifbell__mark-read" @onclick="HandleMarkAllRead">
                        Mark all read
                    </button>
                }
                <div class="sf-notifbell__more-wrap">
                    <button type="button"
                            class="sf-notifbell__more"
                            title="More options"
                            aria-label="More options"
                            aria-haspopup="menu"
                            aria-expanded="@_moreOpen.ToString().ToLowerInvariant()"
                            @onclick="ToggleMore"
                            @onclick:stopPropagation="true">
                        <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                            <circle cx="3" cy="8" r="1.4" fill="currentColor"/>
                            <circle cx="8" cy="8" r="1.4" fill="currentColor"/>
                            <circle cx="13" cy="8" r="1.4" fill="currentColor"/>
                        </svg>
                    </button>
                    @if (_moreOpen)
                    {
                        <div class="sf-notifbell__more-menu" role="menu">
                            <button type="button" class="sf-notifbell__more-item" role="menuitem" @onclick="HandleSettings">
                                <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true">
                                    <circle cx="10" cy="10" r="2.4" fill="none" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.5 4.5l1.4 1.4M14.1 14.1l1.4 1.4M4.5 15.5l1.4-1.4M14.1 5.9l1.4-1.4"
                                          stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                </svg>
                                <span>Settings</span>
                            </button>
                            <button type="button" class="sf-notifbell__more-item" role="menuitem" @onclick="HandleDeleteAllRead">
                                <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true">
                                    <path d="M4 6h12M8 6V4h4v2M6 6l1 11h6l1-11"
                                          fill="none" stroke="currentColor" stroke-width="1.5"
                                          stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span>Delete all read</span>
                            </button>
                        </div>
                    }
                </div>
            </div>
        </header>

        <div class="sf-notifbell__list">
            @if (Items is null || Items.Count == 0)
            {
                <div class="sf-notifbell__empty">No notifications</div>
            }
            else
            {
                @foreach (var item in Items)
                {
                    <button type="button"
                            class="sf-notifbell__item @(item.IsRead ? "" : "is-unread")"
                            @onclick="() => HandleClick(item)">
                        @if (!string.IsNullOrEmpty(item.Icon))
                        {
                            <span class="sf-notifbell__item-icon">@((MarkupString)item.Icon)</span>
                        }
                        else
                        {
                            <span class="sf-notifbell__item-dot" aria-hidden="true"></span>
                        }
                        <div class="sf-notifbell__item-body">
                            @if (!string.IsNullOrEmpty(item.Title))
                            {
                                <div class="sf-notifbell__item-title">@item.Title</div>
                            }
                            <div class="sf-notifbell__item-message">@item.Message</div>
                            <div class="sf-notifbell__item-time">@FormatTime(item.Timestamp)</div>
                        </div>
                    </button>
                }
            }
        </div>

        @if (Footer is not null)
        {
            <div class="sf-notifbell__footer">@Footer</div>
        }
    </div>
</div>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public List<NotificationItem>? Items { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public EventCallback OnMarkAllRead { get; set; }
    [Parameter] public EventCallback<NotificationItem> OnItemClick { get; set; }
    [Parameter] public EventCallback OnSettingsClick { get; set; }
    [Parameter] public EventCallback OnDeleteAllRead { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    private int UnreadCount => Items?.Count(i => !i.IsRead) ?? 0;
    private bool _moreOpen;

    private void ToggleMore() => _moreOpen = !_moreOpen;

    private async Task CloseAsync()
    {
        _moreOpen = false;
        Open = false;
        await OpenChanged.InvokeAsync(false);
    }

    private async Task HandleSettings()
    {
        _moreOpen = false;
        await OnSettingsClick.InvokeAsync();
        await CloseAsync();
    }

    private async Task HandleDeleteAllRead()
    {
        // The bell is presentation-only; the parent owns the underlying store and is
        // responsible for actually removing read items in response to this event.
        _moreOpen = false;
        await OnDeleteAllRead.InvokeAsync();
    }

    private async Task HandleMarkAllRead()
    {
        if (Items is not null)
        {
            foreach (var i in Items) i.IsRead = true;
        }
        await OnMarkAllRead.InvokeAsync();
    }

    private async Task HandleClick(NotificationItem item)
    {
        item.IsRead = true;
        item.OnClick?.Invoke();
        await OnItemClick.InvokeAsync(item);
    }

    private static string FormatTime(DateTimeOffset ts)
    {
        var delta = DateTimeOffset.Now - ts;
        if (delta.TotalSeconds < 60) return "just now";
        if (delta.TotalMinutes < 60) return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalHours < 24) return $"{(int)delta.TotalHours}h ago";
        if (delta.TotalDays < 7) return $"{(int)delta.TotalDays}d ago";
        return ts.LocalDateTime.ToString("MMM d");
    }
}
