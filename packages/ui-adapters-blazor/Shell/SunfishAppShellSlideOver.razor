@namespace Sunfish.UIAdapters.Blazor.Shell
@inherits ComponentBase

@if (Open)
{
    <div class="sf-appshell-slideover__scrim" @onclick="HandleClose" aria-hidden="true"></div>
}
<aside class="sf-appshell-slideover @(Open ? "is-open" : "")"
       role="dialog"
       aria-modal="true"
       aria-hidden="@(Open ? "false" : "true")"
       aria-label="@Title">
    <header class="sf-appshell-slideover__header">
        <span>@Title</span>
        <button type="button" class="sf-appshell-slideover__close" aria-label="Close" @onclick="HandleClose">
            <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
        </button>
    </header>
    <div class="sf-appshell-slideover__body">
        @ChildContent
    </div>
</aside>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private async Task HandleClose()
    {
        Open = false;
        await OpenChanged.InvokeAsync(false);
    }
}
