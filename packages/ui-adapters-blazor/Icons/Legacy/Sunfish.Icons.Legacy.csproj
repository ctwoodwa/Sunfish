<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Icons.Legacy</PackageId>
    <RootNamespace>Sunfish.Icons.Legacy</RootNamespace>
    <AssemblyName>Sunfish.Icons.Legacy</AssemblyName>
    <Description>Legacy Sunfish icon set (obsolete). Prefer Sunfish.Icons.Tabler for new projects.</Description>
    <PackageTags>blazor;icons;legacy;obsolete;svg;ui-framework;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Icons.Legacy.Tests" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\..\..\ui-core\Sunfish.UICore.csproj" />
  </ItemGroup>
</Project>
