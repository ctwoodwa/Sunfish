<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Kernel.Ledger</PackageId>
    <RootNamespace>Sunfish.Kernel.Ledger</RootNamespace>
    <Description>Sunfish kernel §12 event-sourced double-entry ledger subsystem. Posting engine with lease-coordinated idempotency, CQRS balance/statement projections, and period closing with adjustment-account routing. The log is the source of truth; projections are rebuilt from the event stream.</Description>
    <PackageTags>sunfish;kernel;ledger;double-entry;event-sourced;cqrs</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Kernel.Ledger.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
    <ProjectReference Include="..\kernel\Sunfish.Kernel.csproj" />
    <ProjectReference Include="..\kernel-event-bus\Sunfish.Kernel.EventBus.csproj" />
    <ProjectReference Include="..\kernel-lease\Sunfish.Kernel.Lease.csproj" />
  </ItemGroup>
</Project>
