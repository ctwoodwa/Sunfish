<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Kernel.SchemaRegistry</PackageId>
    <Description>Sunfish kernel §3.4 Schema Registry — JSON Schema draft 2020-12 via JsonSchema.Net, content-addressed via IBlobStore, in-memory default backend. Validation path shipped; migration path (jsonata) is a follow-up.</Description>
    <PackageTags>sunfish;kernel;schema;json-schema;registry</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Kernel.SchemaRegistry.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="JsonSchema.Net" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\kernel\Sunfish.Kernel.csproj" />
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\kernel-event-bus\Sunfish.Kernel.EventBus.csproj" />
  </ItemGroup>
</Project>
