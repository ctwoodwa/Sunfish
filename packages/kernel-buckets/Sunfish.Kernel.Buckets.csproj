<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Kernel.Buckets</PackageId>
    <RootNamespace>Sunfish.Kernel.Buckets</RootNamespace>
    <Description>Declarative sync-bucket engine for the Sunfish local-node architecture (paper §10.2, §10.3). Parses YAML bucket definitions, evaluates eligibility from role attestations at capability negotiation, and models lazy-fetch stubs with an LRU storage-budget manager.</Description>
    <PackageTags>sunfish;kernel;buckets;sync;yaml</PackageTags>
    <!-- Stub interfaces and XML-doc gaps will be filled during review hardening.
         CS1591 kept noisy-but-off until the first stable release, matching the
         Foundation and Kernel facade packages. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="YamlDotNet" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
    <ProjectReference Include="..\kernel\Sunfish.Kernel.csproj" />
    <ProjectReference Include="..\kernel-event-bus\Sunfish.Kernel.EventBus.csproj" />
    <ProjectReference Include="..\kernel-security\Sunfish.Kernel.Security.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Exclude the sibling test project from library compilation. -->
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Kernel.Buckets.Tests" />
  </ItemGroup>
</Project>
