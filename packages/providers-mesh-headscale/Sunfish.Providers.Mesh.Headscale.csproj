<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Providers.Mesh.Headscale</PackageId>
    <RootNamespace>Sunfish.Providers.Mesh.Headscale</RootNamespace>
    <Description>Headscale (BSD-3) IMeshVpnAdapter implementation for the Sunfish three-tier peer transport (ADR 0061 Phase 2.1). Wraps the Headscale v0.x REST API over HttpClient — no Headscale-Sharp / Tailscale-SDK dependency. First Tier-2 mesh-VPN adapter in the providers-mesh-* family per ADR 0013 provider neutrality.</Description>
    <PackageTags>sunfish;providers;mesh-vpn;headscale;wireguard;adr-0061;adr-0013</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation-transport\Sunfish.Foundation.Transport.csproj" />
    <ProjectReference Include="..\federation-common\Sunfish.Federation.Common.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Providers.Mesh.Headscale.Tests" />
  </ItemGroup>
</Project>
