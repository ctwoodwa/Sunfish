<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.TaxReporting</PackageId>
    <Description>Tax-reporting entities (Schedule E, 1099-NEC, state personal property), in-memory service, canonical-JSON signed-hash export, and text renderer for Sunfish — first pass, Option B (templates + signed-hash export only). Defers: per-jurisdiction state forms, PDF rendering, e-filing, automatic JE rollup.</Description>
    <PackageTags>tax;reporting;schedule-e;1099-nec;personal-property;blocks;domain;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- TODO(SUNFISH_I18N_002): Path A temporary suppression. blocks-tax-reporting's
         SharedResource bundle (default + ar-SA) defines 8 cascade keys that aren't yet
         consumed by any .cs / .razor in this package — scaffolded ahead of consumer wiring.
         Remove this suppression once consumers wire the keys via IStringLocalizer indexer or
         GetString. -->
    <NoWarn>CS1591;SUNFISH_I18N_002</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.TaxReporting.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
  </ItemGroup>
</Project>
