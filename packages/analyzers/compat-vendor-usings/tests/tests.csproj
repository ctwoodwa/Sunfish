<!--
    Tests for Sunfish.Analyzers.CompatVendorUsings.

    Uses the Microsoft.CodeAnalysis.*.Testing.XUnit harness, which provides
    CSharpAnalyzerTest/CSharpCodeFixTest classes for snapshot-style analyzer and
    code-fix tests.

    This project targets net8.0 rather than net11.0 because:
      - Microsoft.CodeAnalysis.*.Testing pins to LTS runtime metadata bundles,
      - and the analyzer itself is netstandard2.0 so the test host only needs to
        load the analyzer, not reference the repo's preview runtime pins.

    Opts out of Central Package Management because the analyzer-testing packages
    aren't pinned in Directory.Packages.props.
-->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <AssemblyName>Sunfish.Analyzers.CompatVendorUsings.Tests</AssemblyName>
    <RootNamespace>Sunfish.Analyzers.CompatVendorUsings.Tests</RootNamespace>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <IsRoslynComponent>false</IsRoslynComponent>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <!-- The .XUnit-named flavor is obsolete and binary-incompatible with xUnit 2.5+.
         Use the framework-neutral testing base package and DefaultVerifier (shipped
         in Microsoft.CodeAnalysis.Analyzer.Testing) instead — it's the forward-compat
         story recommended by the Roslyn team. -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Analyzer.Testing" Version="1.1.3" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.CodeFix.Testing" Version="1.1.3" />
    <!-- The testing.XUnit packages transitively pin Microsoft.CodeAnalysis.* 1.0.1
         (a 2015-era floor). We reference Sunfish.Analyzers.CompatVendorUsings, which
         links against Microsoft.CodeAnalysis 4.8.0. Without these overrides CSC
         fails with CS1705 (version skew). Explicit pins here satisfy both graphs. -->
    <PackageReference Include="Microsoft.CodeAnalysis.Common" Version="4.8.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.Common" Version="4.8.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.8.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Sunfish.Analyzers.CompatVendorUsings.csproj" />
  </ItemGroup>

</Project>
