<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.PropertyLeasingPipeline</PackageId>
    <RootNamespace>Sunfish.Blocks.PropertyLeasingPipeline</RootNamespace>
    <Description>Leasing pipeline (Inquiry → Prospect → Application → BackgroundCheck → AdverseAction | LeaseOffer) for property blocks. W#22 Phase 1 ships the entity substrate + FHA-defense layout per ADR 0057: Application's protected-class fields are quarantined to DemographicProfile; decisioning interfaces accept only DecisioningFacts. State machine + capability promotion + FCRA workflow ship in subsequent phases.</Description>
    <PackageTags>sunfish;blocks;leasing;property;fha;fcra;adr-0057</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.PropertyLeasingPipeline.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-integrations\Sunfish.Foundation.Integrations.csproj" />
    <ProjectReference Include="..\blocks-public-listings\Sunfish.Blocks.PublicListings.csproj" />
  </ItemGroup>
</Project>
