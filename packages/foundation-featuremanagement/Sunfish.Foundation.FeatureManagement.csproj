<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Foundation.FeatureManagement</PackageId>
    <Description>Feature-evaluation surface with a catalog + OpenFeature-style provider seam + entitlement + edition resolvers. Composes into a single evaluator. No vendor dependency. See ADR 0009.</Description>
    <PackageTags>sunfish;foundation;features;feature-flags;entitlements;openfeature</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Foundation.FeatureManagement.Tests" />
  </ItemGroup>
</Project>
