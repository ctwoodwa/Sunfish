@namespace Sunfish.Compat.Telerik
@using Microsoft.AspNetCore.Components
@using Sunfish.UIAdapters.Blazor.Components.Utility
@using Sunfish.Compat.Telerik.Internal

<SunfishIcon Name="@_nameFromIcon"
             Icon="_iconFragment"
             AriaLabel="AriaLabel"
             @attributes="AdditionalAttributes" />

@code {
    /// <summary>Telerik-shaped Icon parameter. Accepts a string (font-icon name), RenderFragment, or object.</summary>
    [Parameter] public object? Icon { get; set; }

    /// <summary>Telerik's Size parameter — a string like "sm", "md", "lg". Forwarded via inline style.</summary>
    [Parameter] public string? Size { get; set; }

    /// <summary>Accessible label for the icon. Optional.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? AdditionalAttributes { get; set; }

    private string? _nameFromIcon;
    private RenderFragment? _iconFragment;

    protected override void OnParametersSet()
    {
        // Carry over the Size parameter as an inline style if no other style already set.
        if (!string.IsNullOrEmpty(Size))
        {
            AdditionalAttributes ??= new Dictionary<string, object>();
            if (!AdditionalAttributes.ContainsKey("style"))
            {
                var px = Size switch
                {
                    "sm" => "16px",
                    "md" => "20px",
                    "lg" => "24px",
                    _ => null
                };
                if (px is not null)
                {
                    AdditionalAttributes["style"] = $"font-size: {px}";
                }
            }
        }

        switch (Icon)
        {
            case null:
                _nameFromIcon = null;
                _iconFragment = null;
                break;
            case string s:
                _nameFromIcon = s;
                _iconFragment = null;
                break;
            case RenderFragment rf:
                _nameFromIcon = null;
                _iconFragment = rf;
                break;
            default:
                _nameFromIcon = null;
                _iconFragment = SvgIconAdapter.ToRenderFragment(Icon);
                break;
        }
    }
}
