@namespace Sunfish.Compat.Telerik
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Logging
@using Sunfish.UIAdapters.Blazor.Components.Forms.Inputs
@inject ILogger<TelerikDatePicker> Logger

@*
    Divergence: Telerik's DatePicker works with DateTime?; Sunfish's SunfishDatePicker
    uses DateOnly?. The wrapper converts between them so existing Telerik-shaped consumer
    code (DateTime?) keeps compiling.
*@
<SunfishDatePicker Value="_valueDateOnly"
                   ValueChanged="OnSunfishValueChanged"
                   Min="_minDateOnly"
                   Max="_maxDateOnly"
                   Format="Format"
                   Enabled="Enabled"
                   @attributes="AdditionalAttributes" />

@code {
    [Parameter] public DateTime? Value { get; set; }
    [Parameter] public EventCallback<DateTime?> ValueChanged { get; set; }
    [Parameter] public DateTime? Min { get; set; }
    [Parameter] public DateTime? Max { get; set; }
    [Parameter] public string Format { get; set; } = "yyyy-MM-dd";
    [Parameter] public bool Enabled { get; set; } = true;

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private DateOnly? _valueDateOnly;
    private DateOnly? _minDateOnly;
    private DateOnly? _maxDateOnly;

    protected override void OnParametersSet()
    {
        _valueDateOnly = Value is { } v ? DateOnly.FromDateTime(v) : null;
        _minDateOnly = Min is { } mi ? DateOnly.FromDateTime(mi) : null;
        _maxDateOnly = Max is { } ma ? DateOnly.FromDateTime(ma) : null;
    }

    private async Task OnSunfishValueChanged(DateOnly? d)
    {
        Value = d?.ToDateTime(TimeOnly.MinValue);
        await ValueChanged.InvokeAsync(Value);
    }
}
