@namespace Sunfish.Compat.Telerik
@typeparam TValue
@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components
@using Sunfish.UIAdapters.Blazor.Components.Forms.Containers

@*
    Telerik-shaped per-field validation-message child. Wraps <SunfishValidationMessage>.

    Telerik shape: <TelerikValidationMessage For="() => Model.FieldName" />
    Sunfish shape: <SunfishValidationMessage For="() => Model.FieldName" />

    The For-expression surface is identical — simple passthrough.
*@
<SunfishValidationMessage TValue="TValue"
                          For="For"
                          Template="Template"
                          @attributes="AdditionalAttributes" />

@code {
    /// <summary>Expression identifying the model property to display validation messages for.</summary>
    [Parameter] public Expression<Func<TValue>>? For { get; set; }

    /// <summary>Custom template. Shape matches Sunfish's <c>SunfishValidationMessage.Template</c>.</summary>
    [Parameter] public RenderFragment<IEnumerable<string>>? Template { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
}
