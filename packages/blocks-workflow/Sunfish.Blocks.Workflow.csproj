<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.Workflow</PackageId>
    <Description>Generic state-machine workflow primitives for Sunfish — declarative definition, fluent builder, and an in-memory runtime. Defers durable execution, Temporal/Elsa/Dapr, BPMN, and event-bus integration to slice 2.</Description>
    <PackageTags>workflow;state-machine;blocks;domain;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- TODO(SUNFISH_I18N_002): Path A temporary suppression. blocks-workflow's SharedResource
         bundle (default + ar-SA) defines 8 cascade keys that aren't yet consumed by any .cs /
         .razor in this package — scaffolded ahead of consumer wiring. Remove this suppression
         once consumers wire the keys via IStringLocalizer indexer or GetString. -->
    <NoWarn>CS1591;SUNFISH_I18N_002</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.Workflow.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
  </ItemGroup>
</Project>
