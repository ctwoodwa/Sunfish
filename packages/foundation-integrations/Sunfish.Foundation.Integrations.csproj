<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Foundation.Integrations</PackageId>
    <Description>Runtime contracts for external provider integrations: provider registry, credentials references, webhook event envelopes + dispatcher, sync cursors, health checks. See ADR 0013.</Description>
    <PackageTags>sunfish;foundation;integrations;webhooks;providers</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\foundation-catalog\Sunfish.Foundation.Catalog.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Foundation.Integrations.Tests" />
  </ItemGroup>
</Project>
