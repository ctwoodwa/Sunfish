<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Blocks.Accounting</PackageId>
    <Description>Accounting entities (GL accounts, journal entries, depreciation schedules), in-memory service, and QuickBooks IIF exporter for Sunfish — first pass, export-only (Option B). Defers: ledger UI, Xero export, automatic JE generation, depreciation computation.</Description>
    <PackageTags>accounting;general-ledger;journal-entries;quickbooks;iif;blocks;domain;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- TODO(SUNFISH_I18N_002): Path A temporary suppression. blocks-accounting's SharedResource
         bundle (default + ar-SA) defines 8 cascade keys that aren't yet consumed by any .cs /
         .razor in this package — scaffolded ahead of consumer wiring. Remove this suppression
         once consumers wire the keys via IStringLocalizer indexer or GetString. -->
    <NoWarn>CS1591;SUNFISH_I18N_002</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Blocks.Accounting.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
  </ItemGroup>
</Project>
