<!--
    POLICY-GATED PACKAGE.
    All changes require explicit reviewer sign-off per packages/compat-infragistics/POLICY.md.
    This package MUST NOT reference IgniteUI.Blazor or any Infragistics NuGet.
    IgbGrid additions BEYOND shape-parity require explicit BDFL sign-off (commercial license).
-->
<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Compat.Infragistics</PackageId>
    <Description>Infragistics Ignite UI Blazor API-shaped compatibility surface over Sunfish components. Migration off-ramp for Ignite UI for Blazor consumers. Policy-gated.</Description>
    <PackageTags>blazor;compat;infragistics;igniteui;migration;sunfish</PackageTags>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Sunfish.Compat.Infragistics</RootNamespace>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Compat.Infragistics.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\compat-shared\Sunfish.Compat.Shared.csproj" />
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
    <ProjectReference Include="..\ui-core\Sunfish.UICore.csproj" />
    <ProjectReference Include="..\ui-adapters-blazor\Sunfish.UIAdapters.Blazor.csproj" />
  </ItemGroup>
</Project>
