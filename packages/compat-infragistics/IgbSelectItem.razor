@namespace Sunfish.Compat.Infragistics
@typeparam TValue
@using Microsoft.AspNetCore.Components
@using Sunfish.Compat.Shared
@inherits CompatChildComponent<IgbSelect<TValue>>

@*
    Child-component shim for IgbSelect. Ignite UI's real IgbSelectItem is rendered
    inside the select's shadow DOM; compat-infragistics buffers the shim into an
    in-memory option list and the parent IgbSelect binds the collection to
    SunfishDropDownList's Data source.

    If ChildContent is set, it is used as the display text. Otherwise the option's
    Value.ToString() is used.
*@

@code {
    /// <summary>The option's value.</summary>
    [Parameter] public TValue? Value { get; set; }

    /// <summary>The option's display text (optional — defaults to ChildContent text or Value.ToString()).</summary>
    [Parameter] public string? Text { get; set; }

    /// <summary>Marks the option as selected.</summary>
    [Parameter] public bool Selected { get; set; }

    /// <summary>Marks the option as disabled.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Disable the ripple animation — cosmetic-dropped.</summary>
    [Parameter] public bool DisableRipple { get; set; }

    /// <summary>Child text content — used as the display text when <see cref="Text"/> is null.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override string ShimName => "IgbSelectItem";
    protected override string ParentName => "IgbSelect";

    protected override void OnParametersSet()
    {
        // Register into the parent's buffered option list.
        var parent = RequireParent();
        var text = Text ?? ExtractText();
        parent.RegisterItem(Value, text, Selected, Disabled);
    }

    private string? ExtractText()
    {
        // We cannot execute a RenderFragment here synchronously in a useful way; fall back
        // to Value.ToString() for the display text. Consumers should pass `Text=` explicitly
        // when the child content is not a plain string.
        return Value?.ToString();
    }
}
