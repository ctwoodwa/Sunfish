<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Ingestion.Satellite</PackageId>
    <Description>Satellite imagery ingestion for Sunfish — ISatelliteImageryProvider contract, NoOp default, orchestration pipeline (spec §7.6).</Description>
    <PackageTags>sunfish;ingestion;satellite;imagery;remote-sensing</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
    <Content Remove="tests/**/*" />
    <None Remove="tests/**/*" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Ingestion.Satellite.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ingestion-core\Sunfish.Ingestion.Core.csproj" />
    <ProjectReference Include="..\foundation\Sunfish.Foundation.csproj" />
  </ItemGroup>
</Project>
