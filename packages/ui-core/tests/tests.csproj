    <ProjectReference Include="..\..\ui-adapters-blazor\Providers\Bootstrap\Sunfish.Providers.Bootstrap.csproj" />
    <ProjectReference Include="..\..\ui-adapters-blazor\Providers\FluentUI\Sunfish.Providers.FluentUI.csproj" />
