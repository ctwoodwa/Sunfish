{
  "name": "@sunfish/ui-adapters-react",
  "version": "0.1.0-alpha",
  "description": "React adapter for Sunfish UI-core contracts. Parity target for @sunfish/ui-adapters-blazor. See ADR 0014 (Adapter Parity Policy) and ADR 0030 (React Adapter Scaffolding).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^8.4.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "sunfish",
    "react",
    "ui",
    "adapter",
    "bootstrap",
    "fluent",
    "material"
  ],
  "license": "MIT"
}
