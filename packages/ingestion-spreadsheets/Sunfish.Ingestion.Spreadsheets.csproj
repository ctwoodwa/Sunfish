<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Sunfish.Ingestion.Spreadsheets</PackageId>
    <Description>CSV and XLSX ingestion for Sunfish — per-row entity minting with explicit column mapping and type coercion (spec §7.2).</Description>
    <PackageTags>sunfish;ingestion;csv;xlsx;spreadsheet</PackageTags>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
    <Content Remove="tests/**/*" />
    <None Remove="tests/**/*" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Sunfish.Ingestion.Spreadsheets.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="CsvHelper" />
    <PackageReference Include="ClosedXML" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ingestion-core\Sunfish.Ingestion.Core.csproj" />
  </ItemGroup>
</Project>
