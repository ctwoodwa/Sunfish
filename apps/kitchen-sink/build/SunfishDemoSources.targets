<!--
  SunfishDemoSources.targets — per-demo Sources.g.cs generator (ADR 0022, Phase 3).

  Scans Pages/Components/**/Demo.razor, gathers companion files in the same
  folder (*.razor, *.razor.cs, *.cs, *.md, *.css), and emits a partial-class
  file that exposes the demo's source files as a static SunfishSourceFile[]
  list. The Razor page can then reference Demo.GeneratedSources instead of
  hand-wiring _sources.

  Runs inline via RoslynCodeTaskFactory — no external tool, no package adds.
  The generated files land in $(IntermediateOutputPath)SunfishDemoSources and
  are added to @(Compile) before CoreCompile runs.
-->
<Project>

  <UsingTask TaskName="SunfishGenerateDemoSources"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <ProjectDirectory ParameterType="System.String" Required="true" />
      <PagesRoot        ParameterType="System.String" Required="true" />
      <RootNamespace    ParameterType="System.String" Required="true" />
      <OutputDirectory  ParameterType="System.String" Required="true" />
      <GeneratedCount   ParameterType="System.Int32"  Output="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Using Namespace="System.Text" />
      <Using Namespace="System.Collections.Generic" />
      <Code Type="Fragment" Language="cs">
        <![CDATA[
        GeneratedCount = 0;

        if (!Directory.Exists(PagesRoot))
        {
            Log.LogMessage(MessageImportance.Low, "Sunfish: pages root not found: " + PagesRoot);
            return true;
        }

        Directory.CreateDirectory(OutputDirectory);

        // Clear stale generated files so that deleting a demo folder removes its sources.
        foreach (var old in Directory.EnumerateFiles(OutputDirectory, "*.g.cs"))
        {
            try { File.Delete(old); } catch { /* best-effort */ }
        }

        var projectRoot = ProjectDirectory.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);

        var demoFiles = Directory.EnumerateFiles(PagesRoot, "Demo.razor", SearchOption.AllDirectories);
        var extensions = new[] { ".razor", ".cs", ".md", ".css" };

        foreach (var demo in demoFiles)
        {
            var folder = Path.GetDirectoryName(demo);
            if (folder == null) continue;

            var rel = folder.Substring(projectRoot.Length)
                .TrimStart(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);

            var nsSegments = rel
                .Split(new[] { Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar }, StringSplitOptions.RemoveEmptyEntries);
            var ns = RootNamespace + "." + string.Join(".", nsSegments);

            var companions = Directory.EnumerateFiles(folder)
                .Where(f =>
                {
                    var fn = Path.GetFileName(f);
                    if (fn.EndsWith(".g.cs", StringComparison.OrdinalIgnoreCase)) return false;
                    return extensions.Any(e => fn.EndsWith(e, StringComparison.OrdinalIgnoreCase));
                })
                .OrderBy(f =>
                {
                    var fn = Path.GetFileName(f);
                    if (fn.Equals("Demo.razor",    StringComparison.OrdinalIgnoreCase)) return "0_" + fn;
                    if (fn.Equals("Demo.razor.cs", StringComparison.OrdinalIgnoreCase)) return "1_" + fn;
                    if (fn.Equals("Narrative.md",  StringComparison.OrdinalIgnoreCase)) return "2_" + fn;
                    return "3_" + fn;
                }, StringComparer.Ordinal)
                .ToList();

            if (companions.Count == 0) continue;

            var sb = new StringBuilder();
            sb.AppendLine("// <auto-generated/>");
            sb.AppendLine("// Generated by SunfishDemoSources.targets — do not edit.");
            sb.AppendLine("#nullable enable");
            sb.AppendLine("using System.Collections.Generic;");
            sb.AppendLine("using Sunfish.UIAdapters.Blazor.Components.Showcase;");
            sb.AppendLine();
            sb.Append("namespace ").Append(ns).AppendLine(";");
            sb.AppendLine();
            sb.AppendLine("public partial class Demo");
            sb.AppendLine("{");
            sb.AppendLine("    public static readonly IReadOnlyList<SunfishSourceFile> GeneratedSources = new SunfishSourceFile[]");
            sb.AppendLine("    {");
            foreach (var file in companions)
            {
                var name = Path.GetFileName(file);
                var content = File.ReadAllText(file);
                var escaped = content.Replace("\"", "\"\"");
                sb.Append("        new SunfishSourceFile(\"").Append(name).AppendLine("\", @\"");
                sb.Append(escaped);
                sb.AppendLine("\"),");
            }
            sb.AppendLine("    };");
            sb.AppendLine("}");

            var safeName = string.Join("_", nsSegments);
            var outPath = Path.Combine(OutputDirectory, safeName + ".Sources.g.cs");
            File.WriteAllText(outPath, sb.ToString());
            GeneratedCount++;
        }

        Log.LogMessage(MessageImportance.Normal,
            "Sunfish: generated " + GeneratedCount + " demo-source file(s) into " + OutputDirectory);
        return true;
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <Target Name="SunfishGenerateDemoSourcesTarget"
          BeforeTargets="BeforeCompile;CoreCompile">
    <PropertyGroup>
      <SunfishDemoSourcesOutputDir>$(MSBuildProjectDirectory)\$(IntermediateOutputPath)SunfishDemoSources\</SunfishDemoSourcesOutputDir>
      <SunfishDemoSourcesPagesRoot>$(MSBuildProjectDirectory)\Pages\Components</SunfishDemoSourcesPagesRoot>
    </PropertyGroup>
    <SunfishGenerateDemoSources
        ProjectDirectory="$(MSBuildProjectDirectory)"
        PagesRoot="$(SunfishDemoSourcesPagesRoot)"
        RootNamespace="$(RootNamespace)"
        OutputDirectory="$(SunfishDemoSourcesOutputDir)" />
    <ItemGroup>
      <Compile Include="$(SunfishDemoSourcesOutputDir)*.g.cs"
               Exclude="@(Compile)" />
    </ItemGroup>
  </Target>

</Project>
