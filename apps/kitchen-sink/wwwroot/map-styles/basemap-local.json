{
  "version": 8,
  "name": "Sunfish Local Basemap",
  "metadata": {
    "sunfish:description": "Locally-served basemap from Natural Earth + OSM data, generated by Planetiler.",
    "sunfish:attribution": "Natural Earth (public domain), OpenStreetMap contributors (ODbL)"
  },
  "sources": {
    "natural-earth": {
      "type": "vector",
      "url": "pmtiles:///map-data/natural-earth.pmtiles",
      "attribution": "&copy; Natural Earth"
    },
    "osm-region": {
      "type": "vector",
      "url": "pmtiles:///map-data/osm-region.pmtiles",
      "attribution": "&copy; <a href='https://www.openstreetmap.org/copyright'>OpenStreetMap</a> contributors"
    }
  },
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#d8e8c8"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "osm-region",
      "source-layer": "water",
      "paint": {
        "fill-color": "#a0c8f0"
      }
    },
    {
      "id": "water-ne",
      "type": "fill",
      "source": "natural-earth",
      "source-layer": "water",
      "maxzoom": 6,
      "paint": {
        "fill-color": "#a0c8f0"
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "osm-region",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": {
        "fill-color": "#c8e6aa",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "osm-region",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": {
        "fill-color": "#a0d08c",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "osm-region",
      "source-layer": "landuse",
      "filter": ["==", "class", "park"],
      "paint": {
        "fill-color": "#c8e6c0",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "boundary-country",
      "type": "line",
      "source": "natural-earth",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 2],
      "paint": {
        "line-color": "#8a8a8a",
        "line-width": 1.2,
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "boundary-state",
      "type": "line",
      "source": "natural-earth",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 4],
      "maxzoom": 8,
      "paint": {
        "line-color": "#aaaaaa",
        "line-width": 0.8,
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "osm-region",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#d9d0c9",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "road-highway",
      "type": "line",
      "source": "osm-region",
      "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#e88040",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 14, 4]
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "osm-region",
      "source-layer": "transportation",
      "filter": ["==", "class", "trunk"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f0a050",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 3]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "osm-region",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f0c078",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.3, 14, 2.5]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "osm-region",
      "source-layer": "transportation",
      "filter": ["==", "class", "secondary"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f8e8b0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.3, 14, 2]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "osm-region",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "tertiary"],
      "minzoom": 12,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 14, 1.5]
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "osm-region",
      "source-layer": "place",
      "filter": ["==", "class", "city"],
      "layout": {
        "text-field": "{name}",
        "text-size": 14,
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "osm-region",
      "source-layer": "place",
      "minzoom": 8,
      "filter": ["==", "class", "town"],
      "layout": {
        "text-field": "{name}",
        "text-size": 12,
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.2
      }
    }
  ]
}
