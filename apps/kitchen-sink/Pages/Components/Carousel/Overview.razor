@page "/components/carousel"
@page "/components/carousel/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="Carousel cycles through a set of content slides." Code="@_basicCode">
        <div class="demo-row">
            <SunfishCarousel Style="height:200px;width:400px;">
                <div style="background:#e3f2fd;height:100%;display:flex;align-items:center;justify-content:center;">Slide 1</div>
                <div style="background:#f3e5f5;height:100%;display:flex;align-items:center;justify-content:center;">Slide 2</div>
                <div style="background:#e8f5e9;height:100%;display:flex;align-items:center;justify-content:center;">Slide 3</div>
            </SunfishCarousel>
        </div>
    </DemoSection>
</PageSection>

@code {
    private const string _basicCode =
        "<SunfishCarousel Style=\"height:200px;width:400px;\">\n" +
        "    <div>Slide 1</div>\n" +
        "    <div>Slide 2</div>\n" +
        "    <div>Slide 3</div>\n" +
        "</SunfishCarousel>";
}
