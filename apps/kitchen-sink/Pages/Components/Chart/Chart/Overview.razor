@page "/components/Chart"
@page "/components/Chart/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Line Chart" Description="A line chart with two series showing monthly revenue and profit." Code="@_lineCode">
        <SunfishChart Title="Monthly Revenue" Height="350px">
            <SunfishChartSeries Name="Revenue"
                               Data="_salesData"
                               Field="Revenue"
                               CategoryField="Month"
                               Type="ChartSeriesType.Line"
                               Color="#4e79a7" />
            <SunfishChartSeries Name="Profit"
                               Data="_salesData"
                               Field="Profit"
                               CategoryField="Month"
                               Type="ChartSeriesType.Line"
                               Color="#e15759" />
        </SunfishChart>
    </DemoSection>

    <DemoSection Title="Column Chart" Description="A column chart comparing revenue across months with two series side by side." Code="@_columnCode">
        <SunfishChart Title="Revenue vs Profit" Height="350px">
            <SunfishChartSeries Name="Revenue"
                               Data="_salesData"
                               Field="Revenue"
                               CategoryField="Month"
                               Type="ChartSeriesType.Column"
                               Color="#4e79a7" />
            <SunfishChartSeries Name="Profit"
                               Data="_salesData"
                               Field="Profit"
                               CategoryField="Month"
                               Type="ChartSeriesType.Column"
                               Color="#59a14f" />
        </SunfishChart>
    </DemoSection>
</PageSection>

<PageSection Title="Chart Types">
    <DemoSection Title="Area Chart" Description="An area chart with filled regions beneath the lines." Code="@_areaCode">
        <SunfishChart Title="Sales Trend" Height="300px">
            <SunfishChartSeries Name="Revenue"
                               Data="_salesData"
                               Field="Revenue"
                               CategoryField="Month"
                               Type="ChartSeriesType.Area"
                               Color="#76b7b2" />
        </SunfishChart>
    </DemoSection>

    <DemoSection Title="Bar Chart" Description="A horizontal bar chart — same data as Column but rotated." Code="@_barCode">
        <SunfishChart Title="Revenue by Month" Height="350px">
            <SunfishChartSeries Name="Revenue"
                               Data="_salesData"
                               Field="Revenue"
                               CategoryField="Month"
                               Type="ChartSeriesType.Bar"
                               Color="#b07aa1" />
        </SunfishChart>
    </DemoSection>

    <DemoSection Title="Pie Chart" Description="A pie chart showing revenue distribution across months." Code="@_pieCode">
        <SunfishChart Title="Revenue Distribution" Height="350px">
            <SunfishChartSeries Name="Revenue"
                               Data="_salesData"
                               Field="Revenue"
                               CategoryField="Month"
                               Type="ChartSeriesType.Pie" />
        </SunfishChart>
    </DemoSection>

    <DemoSection Title="Donut Chart" Description="A donut chart with a hole in the center." Code="@_donutCode">
        <SunfishChart Title="Profit Distribution" Height="350px">
            <SunfishChartSeries Name="Profit"
                               Data="_salesData"
                               Field="Profit"
                               CategoryField="Month"
                               Type="ChartSeriesType.Donut" />
        </SunfishChart>
    </DemoSection>

    <DemoSection Title="Scatter Chart" Description="A scatter plot using X/Y field bindings for correlation analysis." Code="@_scatterCode">
        <SunfishChart Title="Revenue vs Profit Correlation" Height="350px">
            <SunfishChartSeries Name="Months"
                               Data="_salesData"
                               XField="Revenue"
                               YField="Profit"
                               Type="ChartSeriesType.Scatter"
                               Color="#ff9da7" />
        </SunfishChart>
    </DemoSection>

    <DemoSection Title="Scatter Line Chart" Description="A scatter plot with connecting lines for trend analysis." Code="@_scatterLineCode">
        <SunfishChart Title="Revenue vs Profit Trend" Height="350px">
            <SunfishChartSeries Name="Months"
                               Data="_salesData"
                               XField="Revenue"
                               YField="Profit"
                               Type="ChartSeriesType.ScatterLine"
                               Color="#edc948" />
        </SunfishChart>
    </DemoSection>

    <DemoSection Title="Bubble Chart" Description="A bubble chart where size encodes a third dimension." Code="@_bubbleCode">
        <SunfishChart Title="Market Analysis" Height="350px">
            <SunfishChartSeries Name="Products"
                               Data="_bubbleData"
                               XField="Price"
                               YField="Sales"
                               SizeField="MarketShare"
                               Type="ChartSeriesType.Bubble"
                               Color="#86bcb6" />
        </SunfishChart>
    </DemoSection>
</PageSection>

<PageSection Title="Configuration">
    <DemoSection Title="Title & Subtitle" Description="Charts support a main title and subtitle using child components." Code="@_titleSubtitleCode">
        <SunfishChart Height="300px">
            <ChartTitle Text="Quarterly Performance">
                <ChartSubtitle Text="January through June 2026" />
            </ChartTitle>
            <SunfishChartSeries Name="Revenue"
                               Data="_salesData"
                               Field="Revenue"
                               CategoryField="Month"
                               Type="ChartSeriesType.Column"
                               Color="#4e79a7" />
        </SunfishChart>
    </DemoSection>

    <DemoSection Title="Legend & Tooltips" Description="Toggle legend visibility and tooltip display. Hover over data points to see tooltips." Code="@_legendTooltipsCode">
        <div class="demo-controls">
            <label><input type="checkbox" @bind="_showLegend" /> Show Legend</label>
            <label style="margin-left:16px;"><input type="checkbox" @bind="_showTooltips" /> Show Tooltips</label>
        </div>
        <SunfishChart Title="Interactive Chart" Height="350px"
                     ShowLegend="@_showLegend"
                     ShowTooltips="@_showTooltips">
            <SunfishChartSeries Name="Revenue"
                               Data="_salesData"
                               Field="Revenue"
                               CategoryField="Month"
                               Type="ChartSeriesType.Line"
                               Color="#4e79a7" />
            <SunfishChartSeries Name="Profit"
                               Data="_salesData"
                               Field="Profit"
                               CategoryField="Month"
                               Type="ChartSeriesType.Line"
                               Color="#e15759" />
        </SunfishChart>
    </DemoSection>

    <DemoSection Title="Series Visibility" Description="Toggle individual series on and off using the Visible parameter." Code="@_visibilityCode">
        <div class="demo-controls">
            <label><input type="checkbox" @bind="_showRevenue" /> Revenue</label>
            <label style="margin-left:16px;"><input type="checkbox" @bind="_showProfit" /> Profit</label>
        </div>
        <SunfishChart Title="Toggle Series" Height="300px">
            <SunfishChartSeries Name="Revenue"
                               Data="_salesData"
                               Field="Revenue"
                               CategoryField="Month"
                               Type="ChartSeriesType.Column"
                               Visible="@_showRevenue"
                               Color="#4e79a7" />
            <SunfishChartSeries Name="Profit"
                               Data="_salesData"
                               Field="Profit"
                               CategoryField="Month"
                               Type="ChartSeriesType.Column"
                               Visible="@_showProfit"
                               Color="#59a14f" />
        </SunfishChart>
    </DemoSection>
</PageSection>

<PageSection Title="Events">
    <DemoSection Title="Click Events" Description="Click on a data point to see the event details." Code="@_clickCode">
        <SunfishChart Title="Click a Data Point" Height="300px"
                     OnSeriesClick="@OnChartClick">
            <SunfishChartSeries Name="Revenue"
                               Data="_salesData"
                               Field="Revenue"
                               CategoryField="Month"
                               Type="ChartSeriesType.Column"
                               Color="#4e79a7" />
        </SunfishChart>
        <p class="demo-info">Last click: <strong>@(_lastClickInfo ?? "(none)")</strong></p>
    </DemoSection>
</PageSection>

