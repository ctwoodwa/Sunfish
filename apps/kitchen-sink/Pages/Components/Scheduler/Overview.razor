@page "/components/scheduler"
@page "/components/scheduler/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Month View with Appointments"
                 Description="The default Scheduler view is Month. Pass appointment data via the Appointments parameter."
                 Code="@_monthCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             Style="height:500px;" />
        </div>
    </DemoSection>

    <DemoSection Title="Week View"
                 Description="Switch to Week view to see hourly time slots across 7 days. Appointments render as timed blocks positioned by Start/End time."
                 Code="@_weekCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Week"
                             StartHour="7"
                             EndHour="20"
                             Style="height:500px;" />
        </div>
    </DemoSection>

    <DemoSection Title="Day View"
                 Description="Day view shows a single day with hourly slots. Use StartHour and EndHour to control the visible time range."
                 Code="@_dayCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Day"
                             StartHour="8"
                             EndHour="18"
                             Style="height:500px;" />
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Interaction">
    <DemoSection Title="View Switching"
                 Description="Use two-way binding on View to track and control which view is active. The built-in toolbar buttons switch between Day, Week, and Month."
                 Code="@_viewSwitchCode">
        <div class="demo-row">
            <p><strong>Current view:</strong> @_boundView</p>
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             @bind-View="@_boundView"
                             Style="height:500px;" />
        </div>
    </DemoSection>

    <DemoSection Title="Event Handling"
                 Description="Handle OnAppointmentClick and OnDateClick to respond to user interactions."
                 Code="@_eventsCode">
        <div class="demo-row">
            <p><strong>Last action:</strong> @_lastAction</p>
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Month"
                             OnAppointmentClick="@HandleAppointmentClick"
                             OnDateClick="@HandleDateClick"
                             Style="height:500px;" />
        </div>
    </DemoSection>

    <DemoSection Title="Date Navigation"
                 Description="Use two-way binding on CurrentDate to track navigation. The Previous/Next buttons change the date based on the active view."
                 Code="@_navCode">
        <div class="demo-row">
            <p><strong>Current date:</strong> @_boundDate.ToString("yyyy-MM-dd")</p>
            <SunfishScheduler Appointments="@_sampleAppointments"
                             @bind-CurrentDate="@_boundDate"
                             View="SchedulerView.Month"
                             Style="height:500px;" />
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Composable Views">
    <DemoSection Title="Child View Components"
                 Description="Use SchedulerDayView, SchedulerWeekView, and SchedulerMonthView as child components to configure each view independently. Only registered views appear in the toolbar."
                 Code="@_childViewCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Week"
                             Height="500px">
                <SchedulerDayView StartTime="TimeSpan.FromHours(7)"
                                  EndTime="TimeSpan.FromHours(20)"
                                  SlotDuration="TimeSpan.FromMinutes(30)" />
                <SchedulerWeekView StartTime="TimeSpan.FromHours(8)"
                                   EndTime="TimeSpan.FromHours(18)"
                                   FirstDayOfWeek="DayOfWeek.Monday" />
                <SchedulerMonthView FirstDayOfWeek="DayOfWeek.Monday" />
            </SunfishScheduler>
        </div>
    </DemoSection>

    <DemoSection Title="Selective Views with Custom Labels"
                 Description="Register only the views you need. Use the Label parameter to customize toolbar button text."
                 Code="@_selectiveViewCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Day"
                             Height="500px">
                <SchedulerDayView Label="Today"
                                  StartTime="TimeSpan.FromHours(9)"
                                  EndTime="TimeSpan.FromHours(17)" />
                <SchedulerWeekView Label="This Week"
                                   FirstDayOfWeek="DayOfWeek.Monday" />
            </SunfishScheduler>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Resources">
    <DemoSection Title="Grouped Day View with Resources"
                 Description="Set GroupByResource=true with a Resources collection and ResourceIdField to group appointments into per-resource columns. Each resource gets its own column in Day view."
                 Code="@_resourceDayCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_resourceAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Day"
                             StartHour="8"
                             EndHour="18"
                             Resources="@_resources"
                             ResourceIdField="ResourceId"
                             GroupByResource="true"
                             Style="height:500px;" />
        </div>
    </DemoSection>

    <DemoSection Title="Grouped Week View with Resources"
                 Description="In Week view, GroupByResource renders each resource as a separate row-band with its own 7-day time grid."
                 Code="@_resourceWeekCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_resourceAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Week"
                             StartHour="8"
                             EndHour="18"
                             Resources="@_resources"
                             ResourceIdField="ResourceId"
                             GroupByResource="true"
                             Style="height:600px;" />
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Multi-Day, Timeline, and Agenda Views">
    <DemoSection Title="Multi-Day View"
                 Description="The MultiDay view shows a configurable number of day columns with hourly time slots. Set NumberOfDays to control how many days are visible. Navigation moves by that number of days."
                 Code="@_multiDayCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.MultiDay"
                             Height="500px">
                <SchedulerMultiDayView NumberOfDays="4"
                                       StartTime="TimeSpan.FromHours(7)"
                                       EndTime="TimeSpan.FromHours(20)" />
            </SunfishScheduler>
        </div>
    </DemoSection>

    <DemoSection Title="Timeline View"
                 Description="The Timeline view renders time horizontally. Each row is a day. Appointments appear as horizontal bars spanning their time range. Configure SlotDuration to control granularity."
                 Code="@_timelineCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Timeline"
                             Height="300px">
                <SchedulerTimelineView StartTime="TimeSpan.FromHours(8)"
                                       EndTime="TimeSpan.FromHours(18)"
                                       SlotDuration="TimeSpan.FromMinutes(30)"
                                       NumberOfDays="3" />
            </SunfishScheduler>
        </div>
    </DemoSection>

    <DemoSection Title="Agenda View"
                 Description="The Agenda view shows a flat chronological list of appointments grouped by date. Set NumberOfDays to control the range."
                 Code="@_agendaCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Agenda"
                             Height="400px">
                <SchedulerAgendaView NumberOfDays="14" />
            </SunfishScheduler>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Editing">
    <DemoSection Title="Popup Edit (Default)"
                 Description="Double-click an appointment to open a modal popup with Title, Start, End, All Day, Description, and Resource fields. EditMode defaults to Popup."
                 Code="@_editPopupCode">
        <div class="demo-row">
            <p><strong>Last edit action:</strong> @_editAction</p>
            <SunfishScheduler Appointments="@_editableAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Month"
                             Editable="true"
                             EditMode="SchedulerEditMode.Popup"
                             OnUpdate="@HandleUpdate"
                             OnDelete="@HandleDelete"
                             OnCancel="@HandleCancel"
                             Style="height:500px;" />
        </div>
    </DemoSection>

    <DemoSection Title="Inline Edit"
                 Description="Set EditMode to Inline to use the compact inline edit form at the bottom of the scheduler."
                 Code="@_editCode">
        <div class="demo-row">
            <p><strong>Last edit action:</strong> @_editAction</p>
            <SunfishScheduler Appointments="@_editableAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Month"
                             Editable="true"
                             EditMode="SchedulerEditMode.Inline"
                             OnUpdate="@HandleUpdate"
                             OnDelete="@HandleDelete"
                             Style="height:500px;" />
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Templates">
    <DemoSection Title="Appointment Template"
                 Description="Use AppointmentTemplate to customize how appointments render. The template receives the SchedulerAppointment as context."
                 Code="@_templateCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Month"
                             Style="height:500px;">
                <AppointmentTemplate Context="appt">
                    <div style="display:flex;align-items:center;gap:4px;">
                        <span style="font-size:10px;">&#9679;</span>
                        <span style="font-weight:600;">@appt.Title</span>
                        @if (!string.IsNullOrEmpty(appt.Description))
                        {
                            <span style="opacity:0.7;font-size:10px;">(@appt.Description)</span>
                        }
                    </div>
                </AppointmentTemplate>
            </SunfishScheduler>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Accessibility">
    <DemoSection Title="Custom CSS Class and Sizing"
                 Description="Use Class to add custom CSS classes and Height/Width for sizing. The root element is a semantic div with class mar-scheduler. Toolbar buttons are native button elements accessible via keyboard Tab/Enter."
                 Code="@_a11yCode">
        <div class="demo-row">
            <SunfishScheduler Appointments="@_sampleAppointments"
                             CurrentDate="@_currentDate"
                             View="SchedulerView.Month"
                             Class="my-scheduler-custom"
                             Height="400px"
                             Width="100%" />
        </div>
    </DemoSection>
</PageSection>

@code {
