    private static readonly List<SchedulerAppointment> _resourceAppointments = new()
    {
        new ResourcedSchedulerAppointment { Title = "Sprint Planning", Start = new DateTime(2026, 4, 13, 9, 0, 0), End = new DateTime(2026, 4, 13, 11, 0, 0), ResourceId = "room-a" },
        new ResourcedSchedulerAppointment { Title = "Design Review", Start = new DateTime(2026, 4, 14, 14, 0, 0), End = new DateTime(2026, 4, 14, 15, 30, 0), ResourceId = "room-b" },
        new ResourcedSchedulerAppointment { Title = "Team Standup", Start = new DateTime(2026, 4, 13, 9, 30, 0), End = new DateTime(2026, 4, 13, 9, 45, 0), ResourceId = "room-c" },
        new ResourcedSchedulerAppointment { Title = "Client Demo", Start = new DateTime(2026, 4, 15, 13, 0, 0), End = new DateTime(2026, 4, 15, 14, 0, 0), ResourceId = "room-a" },
        new ResourcedSchedulerAppointment { Title = "1:1 Meeting", Start = new DateTime(2026, 4, 13, 14, 0, 0), End = new DateTime(2026, 4, 13, 14, 30, 0), ResourceId = "room-b" }
    };

    private class ResourcedSchedulerAppointment : SchedulerAppointment
    {
        public string ResourceId { get; set; } = string.Empty;
    }

    private void HandleAppointmentClick(SchedulerAppointment appt)
    {
        _lastAction = $"Clicked appointment: {appt.Title} ({appt.Start:HH:mm} - {appt.End:HH:mm})";
    }

    private void HandleDateClick(DateTime date)
    {
        _lastAction = $"Clicked date: {date:yyyy-MM-dd}";
    }

    private List<SchedulerAppointment> _editableAppointments = new()
    {
        new SchedulerAppointment
        {
            Title = "Sprint Planning",
            Start = new DateTime(2026, 4, 13, 9, 0, 0),
            End = new DateTime(2026, 4, 13, 11, 0, 0),
            Color = "#0078d4"
        },
        new SchedulerAppointment
        {
            Title = "Design Review",
            Start = new DateTime(2026, 4, 14, 14, 0, 0),
            End = new DateTime(2026, 4, 14, 15, 30, 0),
            Color = "#107c10"
        }
    };

    private void HandleUpdate(SchedulerAppointment updated)
    {
        var idx = _editableAppointments.FindIndex(a => a.Id == updated.Id);
        if (idx >= 0) _editableAppointments[idx] = updated;
        _editAction = $"Updated: {updated.Title}";
    }

    private void HandleDelete(SchedulerAppointment deleted)
    {
        _editableAppointments.RemoveAll(a => a.Id == deleted.Id);
        _editAction = $"Deleted: {deleted.Title}";
    }

    private void HandleCancel()
    {
        _editAction = "Edit cancelled";
    }

    private const string _monthCode = @"<SunfishScheduler Appointments=""@_appointments""
                 CurrentDate=""@(new DateTime(2026, 4, 12))""
                 Style=""height:500px;"" />";

