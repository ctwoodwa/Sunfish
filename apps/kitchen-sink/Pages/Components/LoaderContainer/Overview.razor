@page "/components/loadercontainer"
@page "/components/loadercontainer/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="A loader container wraps content and shows a loading overlay when the Loading parameter is true." Code="@_basicCode">
        <SunfishLoaderContainer Loading="@_loading">
            <div style="padding: 24px; border: 1px solid #e0e0e0; border-radius: 4px;">
                <p><strong>Data Panel</strong></p>
                <p>Row 1 - John Doe - Engineering</p>
                <p>Row 2 - Jane Smith - Marketing</p>
                <p>Row 3 - Bob Wilson - Sales</p>
            </div>
        </SunfishLoaderContainer>
        <div class="demo-row" style="margin-top: 8px;">
            <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _loading = !_loading)">
                @(_loading ? "Stop" : "Start") Loading
            </SunfishButton>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Custom Text" Description="Customize the loading message displayed below the spinner." Code="@_textCode">
        <SunfishLoaderContainer Loading="true" Text="Fetching records...">
            <div style="padding: 24px; border: 1px solid #e0e0e0; border-radius: 4px;">
                <p>Content is visible but overlaid by the loading state.</p>
            </div>
        </SunfishLoaderContainer>
    </DemoSection>

    <DemoSection Title="Spinner Sizes" Description="Choose a spinner size for the loading overlay." Code="@_sizesCode">
        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            <SunfishLoaderContainer Loading="true" Size="SpinnerSize.Small" Text="Small">
                <div style="padding: 16px; border: 1px solid #e0e0e0; border-radius: 4px; min-height: 80px; min-width: 120px;">
                    <p>Small</p>
                </div>
            </SunfishLoaderContainer>
            <SunfishLoaderContainer Loading="true" Size="SpinnerSize.Medium" Text="Medium">
                <div style="padding: 16px; border: 1px solid #e0e0e0; border-radius: 4px; min-height: 80px; min-width: 120px;">
                    <p>Medium</p>
                </div>
            </SunfishLoaderContainer>
            <SunfishLoaderContainer Loading="true" Size="SpinnerSize.Large" Text="Large">
                <div style="padding: 16px; border: 1px solid #e0e0e0; border-radius: 4px; min-height: 80px; min-width: 120px;">
                    <p>Large</p>
                </div>
            </SunfishLoaderContainer>
        </div>
    </DemoSection>

    <DemoSection Title="Custom Loader Template" Description="Replace the default spinner with a custom loading template." Code="@_templateCode">
        <SunfishLoaderContainer Loading="@_customLoading">
            <LoaderTemplate>
                <div style="text-align: center; padding: 16px;">
                    <div style="font-size: 2em;">&#9203;</div>
                    <p style="margin-top: 8px; font-weight: 600;">Please wait...</p>
                    <p style="font-size: 0.875em; color: #666;">Processing your request</p>
                </div>
            </LoaderTemplate>
            <ChildContent>
                <div style="padding: 24px; border: 1px solid #e0e0e0; border-radius: 4px;">
                    <p>Content with a custom loader template overlay.</p>
                </div>
            </ChildContent>
        </SunfishLoaderContainer>
        <div class="demo-row" style="margin-top: 8px;">
            <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _customLoading = !_customLoading)">
                Toggle Custom Loader
            </SunfishButton>
        </div>
    </DemoSection>
</PageSection>

@code {
    private bool _loading = true;
    private bool _customLoading = true;

    private const string _basicCode =
        "<SunfishLoaderContainer Loading=\"@_loading\">\n" +
        "    <div style=\"padding: 24px;\">\n" +
        "        <p>Row 1 - John Doe - Engineering</p>\n" +
        "        <p>Row 2 - Jane Smith - Marketing</p>\n" +
        "    </div>\n" +
        "</SunfishLoaderContainer>\n\n" +
        "<SunfishButton OnClick=\"@(() => _loading = !_loading)\">Toggle Loading</SunfishButton>\n\n" +
        "@code { private bool _loading = true; }";

    private const string _textCode =
        "<SunfishLoaderContainer Loading=\"true\" Text=\"Fetching records...\">\n" +
        "    <div style=\"padding: 24px;\">\n" +
        "        <p>Content is visible but overlaid.</p>\n" +
        "    </div>\n" +
        "</SunfishLoaderContainer>";

    private const string _sizesCode =
        "<SunfishLoaderContainer Loading=\"true\" Size=\"SpinnerSize.Small\" Text=\"Small\">\n" +
        "    <div>Content</div>\n" +
        "</SunfishLoaderContainer>\n\n" +
        "<SunfishLoaderContainer Loading=\"true\" Size=\"SpinnerSize.Large\" Text=\"Large\">\n" +
        "    <div>Content</div>\n" +
        "</SunfishLoaderContainer>";

    private const string _templateCode =
        "<SunfishLoaderContainer Loading=\"@_loading\">\n" +
        "    <LoaderTemplate>\n" +
        "        <div style=\"text-align: center; padding: 16px;\">\n" +
        "            <p style=\"font-weight: 600;\">Please wait...</p>\n" +
        "        </div>\n" +
        "    </LoaderTemplate>\n" +
        "    <ChildContent>\n" +
        "        <div>Your content here</div>\n" +
        "    </ChildContent>\n" +
        "</SunfishLoaderContainer>";
}
