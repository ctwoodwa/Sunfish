@page "/components/navigation/menu/events"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Menu / Events · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Menu / Events"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Navigation/Menu/Events/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishMenu</code> emits events through three surfaces. The two menus below are
            wired up to all of them; every invocation appends a line to the log.
        </p>
        <ul>
            <li><code>IsOpenChanged</code> — fires whenever the open state flips. This includes
                clicking the trigger, pressing <kbd>Escape</kbd>, clicking outside, or (when
                <code>CloseOnClick</code> is true) after an item click. Supports
                <code>@@bind-IsOpen</code>.</li>
            <li><code>OnClick</code> (on <code>SunfishMenu</code>, when data-bound) — fires with
                the underlying data item that was clicked. Used by containers that want to react
                generically.</li>
            <li><code>OnClick</code> (on <code>SunfishMenuItem</code>) — fires when that specific
                item is activated. Use this for per-item handlers in declarative menus.</li>
        </ul>
        <p>
            The <code>CloseOnClick</code> toggle below shows how selecting an item either closes
            the menu (default) or leaves it open (useful for multi-step interactions).
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; gap:1.25rem; flex-wrap:wrap;">
            <div style="flex:1 1 340px; min-width:300px; display:flex; flex-direction:column; gap:1rem;">

                <section>
                    <h4 style="margin:0 0 .5rem 0; font-size:.85rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Declarative (per-item OnClick)</h4>
                    <div class="demo-row">
                        <SunfishButton OnClick="() => _declOpen = !_declOpen">Toggle menu</SunfishButton>
                        <SunfishMenu IsOpen="@_declOpen"
                                     IsOpenChanged="@HandleDeclOpenChanged"
                                     CloseOnClick="@_closeOnClick">
                            <SunfishMenuItem Text="Edit" OnClick="@(() => HandleItemClick("Edit"))" />
                            <SunfishMenuItem Text="Duplicate" OnClick="@(() => HandleItemClick("Duplicate"))" />
                            <SunfishMenuItem Text="Archive" OnClick="@(() => HandleItemClick("Archive"))" />
                            <SunfishMenuDivider />
                            <SunfishMenuItem Text="Delete" OnClick="@(() => HandleItemClick("Delete"))" />
                        </SunfishMenu>
                    </div>
                    <label style="display:inline-flex; gap:.35rem; align-items:center; font-size:.9rem; margin-top:.5rem;">
                        <input type="checkbox" checked="@_closeOnClick"
                               @onchange="@((ChangeEventArgs e) => _closeOnClick = (bool)(e.Value ?? true))" />
                        CloseOnClick
                    </label>
                </section>

                <section>
                    <h4 style="margin:0 0 .5rem 0; font-size:.85rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Data-bound (menu-level OnClick)</h4>
                    <div class="demo-row">
                        <SunfishButton OnClick="() => _dataOpen = !_dataOpen">Toggle menu</SunfishButton>
                        <SunfishMenu IsOpen="@_dataOpen"
                                     IsOpenChanged="@HandleDataOpenChanged"
                                     Data="_items"
                                     TextField="Text"
                                     IconField="Icon"
                                     OnClick="@HandleMenuOnClick" />
                    </div>
                </section>

            </div>

            <div style="flex:1 1 280px; min-width:260px;">
                <h4 style="margin:0 0 .25rem 0; font-size:.85rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Event log</h4>
                <SunfishButton Variant="ButtonVariant.Secondary" OnClick="ClearLog">Clear log</SunfishButton>
                <pre style="background:var(--sunfish-surface-muted, #f3f4f6); padding:.75rem; border-radius:.375rem; font-size:.8rem; max-height:340px; overflow:auto; margin:.5rem 0 0 0;">@(_log.Count == 0 ? "(no events yet — open a menu and pick an item)" : string.Join("\n", _log))</pre>
            </div>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Navigation", "Menu", "Events"];

    private bool _declOpen;
    private bool _dataOpen;
    private bool _closeOnClick = true;

    private record MenuVm(string Text, string? Icon = null);

    private readonly List<MenuVm> _items = new()
    {
        new("New", "plus"),
        new("Open", "folder"),
        new("Save", "save"),
        new("Share", "share"),
    };

    private readonly List<string> _log = new();

    private void HandleDeclOpenChanged(bool isOpen)
    {
        _declOpen = isOpen;
        Append($"[declarative] IsOpenChanged → {isOpen}");
    }

    private void HandleDataOpenChanged(bool isOpen)
    {
        _dataOpen = isOpen;
        Append($"[data-bound] IsOpenChanged → {isOpen}");
    }

    private void HandleItemClick(string label)
    {
        Append($"[declarative] SunfishMenuItem.OnClick → {label}");
    }

    private void HandleMenuOnClick(object item)
    {
        var name = item is MenuVm vm ? vm.Text : item.ToString();
        Append($"[data-bound] SunfishMenu.OnClick → {name}");
    }

    private void ClearLog() => _log.Clear();

    private void Append(string entry)
    {
        var stamp = DateTime.Now.ToString("HH:mm:ss.fff");
        _log.Insert(0, $"[{stamp}] {entry}");
        if (_log.Count > 60) _log.RemoveAt(_log.Count - 1);
    }
}
