@page "/components/navigation/breadcrumb/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Breadcrumb / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Breadcrumb / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Navigation/Breadcrumb/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishBreadcrumb</code> shows the current page's location within a navigational
            hierarchy. It accepts either declarative <code>SunfishBreadcrumbItem</code> children or
            data binding via the <code>Data</code> collection together with <code>TextField</code>,
            <code>UrlField</code>, and <code>IconField</code>. The active crumb is marked with
            <code>IsActive="true"</code>, and <code>Separator</code> customises the glyph between items.
        </p>
        <p>
            Sibling demos cover
            <a href="/components/navigation/breadcrumb/items">items</a>,
            <a href="/components/navigation/breadcrumb/icons">icons</a>,
            <a href="/components/navigation/breadcrumb/events">events</a>,
            <a href="/components/navigation/breadcrumb/templates">templates</a>,
            <a href="/components/navigation/breadcrumb/keyboard-navigation">keyboard navigation</a>,
            and <a href="/components/navigation/breadcrumb/rtl">RTL</a>.
        </p>
    </Narrative>

    <Example>
        <SunfishBreadcrumb>
            <SunfishBreadcrumbItem Href="/">Home</SunfishBreadcrumbItem>
            <SunfishBreadcrumbItem Href="/components">Components</SunfishBreadcrumbItem>
            <SunfishBreadcrumbItem IsActive="true">Breadcrumb</SunfishBreadcrumbItem>
        </SunfishBreadcrumb>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Navigation", "Breadcrumb", "Overview"];
}
