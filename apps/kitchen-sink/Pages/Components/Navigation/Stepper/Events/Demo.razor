@page "/components/layout/stepper/events"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Layout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.Foundation.Enums

<PageTitle>Stepper / Events · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Stepper / Events"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Navigation/Stepper/Events/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishStepper</code> surfaces three navigation callbacks, plus a per-step
            <code>OnChange</code> on <code>SunfishStepperStep</code>:
        </p>
        <ul>
            <li><code>OnStepChange</code> — fires on the stepper <em>before</em> navigation.
                Receives <code>StepperStepChangeEventArgs</code>; set <code>IsCancelled = true</code>
                to veto the transition.</li>
            <li><code>OnActivate</code> — fires <em>after</em> the active step changes; receives
                the new index.</li>
            <li><code>ValueChanged</code> / <code>ActiveStepChanged</code> — two-way binding
                callbacks; fire after navigation commits.</li>
            <li><code>SunfishStepperStep.OnChange</code> — fires on the step being <em>left</em>
                before the stepper-level callback; also cancellable.</li>
        </ul>
        <p>
            This demo is a <em>linear</em> stepper with three-state validity. Step 1 requires an
            email containing <code>@@</code>; step 2 requires a non-empty name. The per-step
            <code>OnChange</code> on step 2 also vetoes the first forward attempt as a gate demo.
        </p>
    </Narrative>

    <Example>
        <div style="display:grid; grid-template-columns:minmax(0, 1fr) minmax(0, 360px); gap:1.25rem;">

            <div>
                <h4 style="margin:0 0 .5rem;">Linear stepper with validation</h4>
                <SunfishStepper @ref="_stepper"
                                @bind-Value="_active"
                                Linear="true"
                                OnStepChange="HandleStepChange"
                                OnActivate="HandleActivate">
                    <SunfishStepperStep Label="Account" Valid="@IsAccountValid">
                        <div style="display:flex; flex-direction:column; gap:.5rem; padding:16px;">
                            <strong>1 · Account</strong>
                            <label>Email
                                <input type="email" value="@_email"
                                       @oninput="e => _email = e.Value?.ToString() ?? string.Empty"
                                       placeholder="user@example.com"
                                       style="width:260px;" />
                            </label>
                            <small style="opacity:.7;">Required — must contain <code>@@</code>.</small>
                        </div>
                    </SunfishStepperStep>
                    <SunfishStepperStep Label="Profile" Valid="@IsProfileValid" OnChange="HandleStep2Change">
                        <div style="display:flex; flex-direction:column; gap:.5rem; padding:16px;">
                            <strong>2 · Profile</strong>
                            <label>Full name
                                <input type="text" value="@_name"
                                       @oninput="e => _name = e.Value?.ToString() ?? string.Empty"
                                       placeholder="Ada Lovelace"
                                       style="width:260px;" />
                            </label>
                            <small style="opacity:.7;">Required — at least 2 characters. First forward attempt is vetoed.</small>
                        </div>
                    </SunfishStepperStep>
                    <SunfishStepperStep Label="Review" Successful="@_reviewed">
                        <div style="padding:16px;">
                            <strong>3 · Review</strong>
                            <div>Email: <code>@(_email.Length > 0 ? _email : "(not set)")</code></div>
                            <div>Name: <code>@(_name.Length > 0 ? _name : "(not set)")</code></div>
                            <div style="margin-top:.5rem;">
                                <SunfishButton Variant="ButtonVariant.Primary"
                                               OnClick="() => _reviewed = true">
                                    Mark as reviewed
                                </SunfishButton>
                            </div>
                        </div>
                    </SunfishStepperStep>
                </SunfishStepper>

                <div style="display:flex; gap:.5rem; margin-top:.75rem; flex-wrap:wrap;">
                    <SunfishButton Variant="ButtonVariant.Secondary" OnClick="InvokePrevious">Previous (API)</SunfishButton>
                    <SunfishButton Variant="ButtonVariant.Secondary" OnClick="InvokeNext">Next (API)</SunfishButton>
                    <SunfishButton Variant="ButtonVariant.Secondary" OnClick="GoToLast">GoToStepAsync(2)</SunfishButton>
                    <SunfishButton Variant="ButtonVariant.Primary" OnClick="ResetDemo">Reset</SunfishButton>
                </div>

                <p style="margin:.5rem 0 0; font-size:.85rem; opacity:.75;">
                    Value: <strong>@_active</strong> · Step2Vetoed: <strong>@_step2Vetoed</strong>
                </p>
            </div>

            <div>
                <h4 style="margin:0 0 .5rem;">Event log</h4>
                <div style="border:1px solid var(--sunfish-border, #d0d0d0); border-radius:8px; background:var(--sunfish-surface-2, #fafafa); padding:.75rem; height:320px; overflow:auto; font-family:ui-monospace, SFMono-Regular, Menlo, monospace; font-size:.78rem;">
                    @if (_log.Count == 0)
                    {
                        <em style="opacity:.6;">No events yet — click a step indicator or a button.</em>
                    }
                    else
                    {
                        @foreach (var entry in _log)
                        {
                            <div>@entry</div>
                        }
                    }
                </div>
                <button type="button" class="sf-btn" style="margin-top:.5rem;"
                        @onclick="ClearLog">
                    Clear log
                </button>
            </div>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Layout", "Stepper", "Events"];

    private SunfishStepper? _stepper;
    private int _active;
    private string _email = "";
    private string _name = "";
    private bool _reviewed;
    private bool _step2Vetoed;

    private readonly List<string> _log = new();

    private bool? IsAccountValid
        => _email.Length == 0 ? null : _email.Contains('@');

    private bool? IsProfileValid
        => _name.Length == 0 ? null : _name.Trim().Length >= 2;

    private void Log(string message)
    {
        var ts = DateTime.Now.ToString("HH:mm:ss.fff");
        _log.Insert(0, $"[{ts}] {message}");
        if (_log.Count > 100) _log.RemoveRange(100, _log.Count - 100);
    }

    private void ClearLog() => _log.Clear();

    private void ResetDemo()
    {
        _active = 0;
        _email = string.Empty;
        _name = string.Empty;
        _reviewed = false;
        _step2Vetoed = false;
        _log.Clear();
    }

    private Task HandleStepChange(StepperStepChangeEventArgs args)
    {
        Log($"stepper OnStepChange: {args.PreviousStep} -> {args.CurrentStep} (cancelled={args.IsCancelled})");
        return Task.CompletedTask;
    }

    private void HandleActivate(int index)
    {
        Log($"stepper OnActivate -> index={index}");
    }

    private Task HandleStep2Change(StepperStepChangeEventArgs args)
    {
        if (args.CurrentStep > args.PreviousStep && !_step2Vetoed)
        {
            _step2Vetoed = true;
            args.IsCancelled = true;
            Log("step[1] OnChange -> vetoed forward navigation (first attempt)");
        }
        else
        {
            Log($"step[1] OnChange -> {args.PreviousStep} -> {args.CurrentStep}");
        }
        return Task.CompletedTask;
    }

    private async Task InvokeNext()
    {
        if (_stepper is not null)
        {
            await _stepper.NextAsync();
            Log("Invoked NextAsync()");
        }
    }

    private async Task InvokePrevious()
    {
        if (_stepper is not null)
        {
            await _stepper.PreviousAsync();
            Log("Invoked PreviousAsync()");
        }
    }

    private async Task GoToLast()
    {
        if (_stepper is not null)
        {
            await _stepper.GoToStepAsync(2);
            Log("Invoked GoToStepAsync(2)");
        }
    }
}
