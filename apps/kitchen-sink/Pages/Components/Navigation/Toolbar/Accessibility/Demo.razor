@page "/components/navigation/toolbar/accessibility"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Toolbar / Accessibility · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Toolbar / Accessibility"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Navigation/Toolbar/Accessibility/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishToolbar</code> follows the
            <a href="https://www.w3.org/WAI/ARIA/apg/patterns/toolbar/" target="_blank" rel="noopener">WAI-ARIA
            Toolbar pattern</a>. The root <code>&lt;div&gt;</code> is rendered with
            <code>role="toolbar"</code> and <code>aria-label="Toolbar"</code>; every child control
            is a native <code>&lt;button&gt;</code>, so keyboard and screen-reader behaviour builds
            on the browser's built-in semantics for buttons.
        </p>
        <p>
            <code>SunfishToolbarGroup</code> renders with <code>role="group"</code>, and
            <code>SunfishToolbarSeparator</code> uses <code>role="separator"</code> so AT users
            can tell command clusters apart. Toggle buttons expose their pressed state via
            <code>aria-pressed</code>, which screen readers announce alongside the label
            ("Bold, toggle button, pressed").
        </p>
        <p>
            Because each button is natively focusable, the toolbar naturally participates in the
            page's tab sequence — <kbd>Tab</kbd> enters the toolbar, and subsequent
            <kbd>Tab</kbd> presses visit each enabled button. Disabled items are skipped in the
            tab ring, and titles passed via the <code>Title</code> parameter become native
            browser tooltips.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.5rem;">

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Try it with keyboard &amp; screen reader</h3>
                <p style="margin:.25rem 0 .75rem 0; font-size:.9rem;">
                    Tab into the toolbar. Toggle buttons announce their pressed state;
                    the Delete action is disabled and will be skipped by the tab ring.
                    Hover (or focus + native tooltip) on icon-only buttons to see their
                    <code>Title</code> descriptions.
                </p>
                <SunfishToolbar>
                    <SunfishToolbarGroup>
                        <SunfishToolbarToggleButton IsActive="@_bold" IsActiveChanged="@((bool v) => _bold = v)" Title="Bold">
                            <strong>B</strong>
                        </SunfishToolbarToggleButton>
                        <SunfishToolbarToggleButton IsActive="@_italic" IsActiveChanged="@((bool v) => _italic = v)" Title="Italic">
                            <em>I</em>
                        </SunfishToolbarToggleButton>
                    </SunfishToolbarGroup>
                    <SunfishToolbarSeparator />
                    <SunfishToolbarGroup>
                        <SunfishToolbarButton Icon="plus" Title="Insert" />
                        <SunfishToolbarButton Icon="trash" Title="Delete" Disabled="true" />
                    </SunfishToolbarGroup>
                </SunfishToolbar>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">ARIA &amp; semantic contract</h3>
                <dl style="display:grid; grid-template-columns: max-content 1fr; column-gap:1rem; row-gap:.35rem; margin:0;">
                    <dt><code>role="toolbar"</code> + <code>aria-label="Toolbar"</code></dt>
                    <dd>Root container — announces the region as a toolbar.</dd>
                    <dt><code>role="group"</code></dt>
                    <dd>Applied to <code>SunfishToolbarGroup</code> — lets AT users recognise command clusters.</dd>
                    <dt><code>role="separator"</code></dt>
                    <dd>Applied to <code>SunfishToolbarSeparator</code> — clarifies visual dividers.</dd>
                    <dt><code>aria-pressed="true" / "false"</code></dt>
                    <dd>Rendered on every <code>SunfishToolbarToggleButton</code>.</dd>
                    <dt><code>disabled</code></dt>
                    <dd>Toolbar buttons honour the <code>Disabled</code> parameter; the whole toolbar can be disabled via <code>Enabled="false"</code> on the root.</dd>
                    <dt><code>title="..."</code></dt>
                    <dd>When <code>Title</code> is set, the native browser tooltip is exposed to AT as the accessible description — especially important for icon-only buttons.</dd>
                </dl>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Keyboard shortcuts</h3>
                <table style="border-collapse:collapse; font-size:.9rem;">
                    <thead>
                        <tr>
                            <th style="text-align:left; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Keys</th>
                            <th style="text-align:left; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Effect</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="padding:.35rem .75rem;"><kbd>Tab</kbd></td>
                            <td style="padding:.35rem .75rem;">Move focus to the next enabled toolbar button.</td>
                        </tr>
                        <tr>
                            <td style="padding:.35rem .75rem;"><kbd>Shift</kbd>+<kbd>Tab</kbd></td>
                            <td style="padding:.35rem .75rem;">Move focus to the previous enabled toolbar button.</td>
                        </tr>
                        <tr>
                            <td style="padding:.35rem .75rem;"><kbd>Enter</kbd> or <kbd>Space</kbd></td>
                            <td style="padding:.35rem .75rem;">Activate a regular toolbar button.</td>
                        </tr>
                        <tr>
                            <td style="padding:.35rem .75rem;"><kbd>Enter</kbd> or <kbd>Space</kbd></td>
                            <td style="padding:.35rem .75rem;">Toggle the <code>IsActive</code> state of a toolbar toggle button.</td>
                        </tr>
                    </tbody>
                </table>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Screen-reader output (expected)</h3>
                <pre style="background:var(--sunfish-surface-muted, #f3f4f6); padding:.75rem; border-radius:.375rem; font-size:.85rem; overflow:auto;"><code>Toolbar, toolbar
  group
    B, toggle button, pressed
    I, toggle button, not pressed
  separator
  group
    Insert, button
    Delete, button, dimmed</code></pre>
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Navigation", "Toolbar", "Accessibility"];

    private bool _bold = true;
    private bool _italic;
}
