@page "/components/navigation/toolbar/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Toolbar / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Toolbar / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Navigation/Toolbar/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishToolbar</code> groups related actions and controls in a horizontal bar.
            Compose children from <code>SunfishToolbarButton</code>,
            <code>SunfishToolbarToggleButton</code> (with <code>IsSelected</code> /
            <code>IsSelectedChanged</code>), <code>SunfishToolbarGroup</code> for logical clusters,
            and <code>SunfishToolbarSeparator</code> for dividers. Switch layout with
            <code>Orientation</code> and sizing with the <code>Size</code> parameter.
        </p>
        <p>
            Sibling demos cover
            <a href="/components/navigation/toolbar/templates">templates</a>,
            <a href="/components/navigation/toolbar/overflow">overflow</a>,
            <a href="/components/navigation/toolbar/events">events</a>,
            <a href="/components/navigation/toolbar/keyboard-navigation">keyboard navigation</a>,
            and <a href="/components/navigation/toolbar/rtl">RTL</a>.
        </p>
    </Narrative>

    <Example>
        <SunfishToolbar>
            <SunfishToolbarGroup>
                <SunfishToolbarToggleButton IsSelected="@_bold" IsSelectedChanged="@((bool v) => _bold = v)">Bold</SunfishToolbarToggleButton>
                <SunfishToolbarToggleButton IsSelected="@_italic" IsSelectedChanged="@((bool v) => _italic = v)">Italic</SunfishToolbarToggleButton>
                <SunfishToolbarToggleButton IsSelected="@_underline" IsSelectedChanged="@((bool v) => _underline = v)">Underline</SunfishToolbarToggleButton>
            </SunfishToolbarGroup>
            <SunfishToolbarSeparator />
            <SunfishToolbarGroup>
                <SunfishToolbarButton>Cut</SunfishToolbarButton>
                <SunfishToolbarButton>Copy</SunfishToolbarButton>
                <SunfishToolbarButton>Paste</SunfishToolbarButton>
            </SunfishToolbarGroup>
            <SunfishToolbarSeparator />
            <SunfishToolbarButton Disabled="true">Undo</SunfishToolbarButton>
        </SunfishToolbar>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Navigation", "Toolbar", "Overview"];

    private bool _bold;
    private bool _italic;
    private bool _underline;
}
