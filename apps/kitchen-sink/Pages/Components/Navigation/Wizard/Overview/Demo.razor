@page "/components/layout/wizard/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Wizard / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Wizard / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Navigation/Wizard/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishWizard</code> guides users through a multi-step flow with integrated
            back/next navigation. Bind the zero-based step with <code>@("@bind-Value")</code>, list
            panels via <code>WizardStep</code> (<code>Label</code>, optional <code>Icon</code>,
            <code>Optional</code>, <code>Disabled</code>, <code>Valid</code>), and subscribe to
            <code>OnStepChange</code> / <code>OnFinish</code> for workflow hooks. Set
            <code>Linear="false"</code> to allow clicking any step directly.
        </p>
        <p>
            Sibling demos cover
            <a href="/components/navigation/wizard/form">form</a>,
            <a href="/components/navigation/wizard/configuration">configuration</a>,
            <a href="/components/navigation/wizard/buttons">buttons</a>,
            <a href="/components/navigation/wizard/events">events</a>,
            <a href="/components/navigation/wizard/localization">localization</a>,
            <a href="/components/navigation/wizard/stepper-template">stepper template</a>,
            <a href="/components/navigation/wizard/keyboard-navigation">keyboard navigation</a>,
            and <a href="/components/navigation/wizard/rtl">RTL</a>.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1rem;">
            <SunfishWizard @bind-Value="_basicStep">
                <WizardStep Label="Account">
                    <div style="padding:16px;">
                        <p>Enter your account information.</p>
                        <label>Email: <input type="email" placeholder="user@example.com" style="width:250px;" /></label>
                    </div>
                </WizardStep>
                <WizardStep Label="Profile">
                    <div style="padding:16px;">
                        <p>Set up your profile.</p>
                        <label>Name: <input type="text" placeholder="Your name" style="width:250px;" /></label>
                    </div>
                </WizardStep>
                <WizardStep Label="Confirm">
                    <div style="padding:16px;">
                        <p>Review your information and click Finish.</p>
                    </div>
                </WizardStep>
            </SunfishWizard>
            <p>Current step: <strong>@(_basicStep + 1) of 3</strong></p>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Layout", "Wizard", "Overview"];

    private int _basicStep;
}
