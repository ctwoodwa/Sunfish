@page "/components/navigation/pagination/events"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Enums

<PageTitle>Pagination / Events · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Pagination / Events"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Navigation/Pagination/Events/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishPagination</code> exposes three callbacks that together cover every user
            interaction. The live component below is wired to all three; every invocation is
            appended to the log.
        </p>
        <ul>
            <li><code>PageChanged</code> — fires when the current page changes from the arrows, a
                numeric button, the page dropdown / input, or after a page-size change (which
                resets to page 1). Supports two-way binding via <code>@@bind-Page</code>.</li>
            <li><code>PageSizeChanged</code> — fires when the user selects a new entry from the
                <code>PageSizes</code> dropdown. Supports two-way binding via
                <code>@@bind-PageSize</code>.</li>
            <li><code>OnRefresh</code> — fires when the refresh button is clicked (requires
                <code>RefreshButton="true"</code>). After <code>OnRefresh</code>,
                <code>PageChanged</code> is re-fired with the current page so consumers can re-run
                their query.</li>
        </ul>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1rem;">

            <div style="display:flex; gap:1.25rem; flex-wrap:wrap; align-items:flex-start;">
                <div style="flex:1 1 480px; min-width:360px;">
                    <SunfishPagination Page="@_page"
                                       PageChanged="@HandlePageChanged"
                                       PageSize="@_pageSize"
                                       PageSizeChanged="@HandlePageSizeChanged"
                                       OnRefresh="@HandleRefresh"
                                       Total="@_total"
                                       PageSizes="@(new List<int> { 5, 10, 25, 50 })"
                                       Info="true"
                                       RefreshButton="true" />

                    <p style="margin:.75rem 0 0 0; font-size:.9rem;">
                        Current: page <strong>@_page</strong>, pageSize <strong>@_pageSize</strong>,
                        total <strong>@_total</strong>.
                    </p>

                    <div style="margin-top:.75rem;">
                        <SunfishButton Variant="ButtonVariant.Secondary" OnClick="ClearLog">Clear log</SunfishButton>
                    </div>
                </div>

                <div style="flex:1 1 260px; min-width:260px;">
                    <h4 style="margin:0 0 .5rem 0; font-size:.85rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Event log</h4>
                    <pre style="background:var(--sunfish-surface-muted, #f3f4f6); padding:.75rem; border-radius:.375rem; font-size:.8rem; max-height:280px; overflow:auto; margin:0;">@(_log.Count == 0 ? "(no events yet — interact above)" : string.Join("\n", _log))</pre>
                </div>
            </div>

            <section>
                <h4 style="margin:.75rem 0 .5rem 0; font-size:.85rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Applied items (current page slice)</h4>
                <ul style="margin:0; padding-inline-start:1.2rem; font-size:.9rem;">
                    @foreach (var item in CurrentPageItems())
                    {
                        <li>@item</li>
                    }
                </ul>
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Navigation", "Pagination", "Events"];

    private int _page = 1;
    private int _pageSize = 10;
    private int _total = 57;
    private int _refreshCount;
    private readonly List<string> _log = new();

    private void HandlePageChanged(int newPage)
    {
        _page = newPage;
        Append($"PageChanged -> {newPage}");
    }

    private void HandlePageSizeChanged(int newSize)
    {
        _pageSize = newSize;
        Append($"PageSizeChanged -> {newSize}");
    }

    private void HandleRefresh()
    {
        _refreshCount++;
        Append($"OnRefresh (#{_refreshCount})");
    }

    private void ClearLog()
    {
        _log.Clear();
    }

    private void Append(string entry)
    {
        var stamp = DateTime.Now.ToString("HH:mm:ss.fff");
        _log.Insert(0, $"[{stamp}] {entry}");
        if (_log.Count > 50) _log.RemoveAt(_log.Count - 1);
    }

    private IEnumerable<string> CurrentPageItems()
    {
        var start = (_page - 1) * _pageSize + 1;
        var end = Math.Min(_page * _pageSize, _total);
        for (var i = start; i <= end; i++)
            yield return $"Item #{i}";
    }
}
