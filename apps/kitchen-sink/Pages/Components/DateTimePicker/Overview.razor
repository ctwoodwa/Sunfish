@page "/components/datetimepicker"
@page "/components/datetimepicker/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="DateTimePicker combines date and time selection in one control." Code="@_basicCode">
        <div class="demo-row">
            <SunfishDateTimePicker @bind-Value="_value" />
            <span>Selected: @_value?.ToString("g")</span>
        </div>
    </DemoSection>
</PageSection>

@code {
    private DateTime? _value = DateTime.Now;

    private const string _basicCode =
        "<SunfishDateTimePicker @bind-Value=\"_value\" />";
}
