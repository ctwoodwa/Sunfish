@page "/components/spreadsheet"
@page "/components/spreadsheet/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="Spreadsheet provides an Excel-like grid with lettered column headers and numbered rows. Click a cell to edit." Code="@_basicCode">
        <SunfishSpreadsheet RowCount="10"
                           ColumnCount="6"
                           Height="300px"
                           OnCellEdit="HandleCellEdit" />
    </DemoSection>
</PageSection>

<PageSection Title="Features">
    <DemoSection Title="Read-Only Mode" Description="Set ReadOnly to prevent cell editing." Code="@_readonlyCode">
        <SunfishSpreadsheet RowCount="5"
                           ColumnCount="4"
                           Height="200px"
                           ReadOnly="true" />
    </DemoSection>

    <DemoSection Title="Custom Toolbar" Description="Add a toolbar above the spreadsheet for formatting actions or custom controls." Code="@_toolbarCode">
        <SunfishSpreadsheet RowCount="8"
                           ColumnCount="5"
                           Height="300px"
                           OnCellEdit="HandleCellEdit">
            <ToolbarTemplate>
                <div style="display:flex;gap:8px;align-items:center;">
                    <button style="padding:2px 8px;border:1px solid #ccc;border-radius:3px;background:white;cursor:pointer;font-weight:bold;">B</button>
                    <button style="padding:2px 8px;border:1px solid #ccc;border-radius:3px;background:white;cursor:pointer;font-style:italic;">I</button>
                    <button style="padding:2px 8px;border:1px solid #ccc;border-radius:3px;background:white;cursor:pointer;text-decoration:underline;">U</button>
                    <span style="width:1px;height:20px;background:#ccc;"></span>
                    <span style="font-size:12px;color:#666;">Formatting toolbar (prototype)</span>
                </div>
            </ToolbarTemplate>
        </SunfishSpreadsheet>
    </DemoSection>

    <DemoSection Title="Wider Grid" Description="Adjust ColumnCount and RowCount for different grid sizes." Code="@_wideCode">
        <SunfishSpreadsheet RowCount="15"
                           ColumnCount="10"
                           Height="350px"
                           Width="100%" />
    </DemoSection>
</PageSection>

@if (_lastEdit != null)
{
    <div style="margin-top:12px;padding:8px;background:#e3f2fd;border-radius:4px;font-size:13px;">
        Last edit: Cell (@(_lastEdit.Row + 1), @GetColumnLabel(_lastEdit.Column)) changed from "@(_lastEdit.OldValue ?? "")" to "@(_lastEdit.NewValue ?? "")"
    </div>
}

@code {
    private SpreadsheetCellEditEventArgs? _lastEdit;

    private Task HandleCellEdit(SpreadsheetCellEditEventArgs args)
    {
        _lastEdit = args;
        return Task.CompletedTask;
    }

    private static string GetColumnLabel(int index)
    {
        var label = "";
        var i = index;
        do
        {
            label = (char)('A' + i % 26) + label;
            i = i / 26 - 1;
        } while (i >= 0);
        return label;
    }

    private const string _basicCode =
        "<SunfishSpreadsheet RowCount=\"10\"\n" +
        "                   ColumnCount=\"6\"\n" +
        "                   Height=\"300px\"\n" +
        "                   OnCellEdit=\"HandleCellEdit\" />";

    private const string _readonlyCode =
        "<SunfishSpreadsheet RowCount=\"5\"\n" +
        "                   ColumnCount=\"4\"\n" +
        "                   Height=\"200px\"\n" +
        "                   ReadOnly=\"true\" />";

    private const string _toolbarCode =
        "<SunfishSpreadsheet RowCount=\"8\" ColumnCount=\"5\" Height=\"300px\">\n" +
        "    <ToolbarTemplate>\n" +
        "        <button>B</button> <button>I</button> <button>U</button>\n" +
        "    </ToolbarTemplate>\n" +
        "</SunfishSpreadsheet>";

    private const string _wideCode =
        "<SunfishSpreadsheet RowCount=\"15\"\n" +
        "                   ColumnCount=\"10\"\n" +
        "                   Height=\"350px\"\n" +
        "                   Width=\"100%\" />";
}
