@page "/components/Switch"
@page "/components/Switch/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Code="@_basicCode">
        <SunfishField>
            <SunfishSwitch @bind-Value="_switchOn" Label="Enable notifications" />
        </SunfishField>
        <p><strong>Switch is on:</strong> @_switchOn</p>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="On and Off Labels" Description="Use OnLabel and OffLabel to display contextual text next to the switch thumb." Code="@_onOffLabelCode">
        <SunfishField>
            <SunfishSwitch @bind-Value="_darkMode" Label="Dark mode" OnLabel="On" OffLabel="Off" />
        </SunfishField>
        <SunfishField>
            <SunfishSwitch @bind-Value="_autoSave" Label="Auto-save" OnLabel="Enabled" OffLabel="Disabled" />
        </SunfishField>
    </DemoSection>

    <DemoSection Title="Disabled" Description="A disabled switch prevents user interaction." Code="@_disabledCode">
        <SunfishField>
            <SunfishSwitch Value="true" Enabled="false" Label="On and disabled" />
        </SunfishField>
        <SunfishField>
            <SunfishSwitch Value="false" Enabled="false" Label="Off and disabled" />
        </SunfishField>
    </DemoSection>
</PageSection>

<PageSection Title="Events">
    <DemoSection Title="ValueChanged" Description="Handle switch state changes with the ValueChanged callback or use two-way binding." Code="@_interactiveCode">
        <SunfishField>
            <SunfishSwitch Value="@_evSwitchOn" ValueChanged="@(v => _evSwitchOn = v)" Label="Toggle me" />
        </SunfishField>
        <p><strong>Switch is on:</strong> @_evSwitchOn</p>
    </DemoSection>
</PageSection>

<PageSection Title="Accessibility">
    <AccessibilityInfo
        KeyboardInteractions="@_keyboard"
        AriaAttributes="@_aria"
        ScreenReaderNotes="@_screenReader" />
</PageSection>

@code {
    private bool _switchOn;
    private bool _darkMode;
    private bool _autoSave = true;
    private bool _evSwitchOn;

    private const string _basicCode =
        "<SunfishSwitch @bind-Value=\"_switchOn\" Label=\"Enable notifications\" />\n\n" +
        "@code { private bool _switchOn; }";

    private const string _onOffLabelCode =
        "<SunfishSwitch @bind-Value=\"_darkMode\" Label=\"Dark mode\" OnLabel=\"On\" OffLabel=\"Off\" />\n" +
        "<SunfishSwitch @bind-Value=\"_autoSave\" Label=\"Auto-save\" OnLabel=\"Enabled\" OffLabel=\"Disabled\" />";

    private const string _disabledCode =
        "<SunfishSwitch Value=\"true\" Enabled=\"false\" Label=\"On and disabled\" />\n" +
        "<SunfishSwitch Value=\"false\" Enabled=\"false\" Label=\"Off and disabled\" />";

    private const string _interactiveCode =
        "<SunfishSwitch Value=\"@_switchOn\" ValueChanged=\"@(v => _switchOn = v)\" Label=\"Toggle me\" />\n" +
        "<p><strong>Switch is on:</strong> @_switchOn</p>\n\n" +
        "@code {\n" +
        "    private bool _switchOn;\n" +
        "}";

    private static readonly (string Key, string Action)[] _keyboard =
    [
        ("Tab", "Moves focus to the switch"),
        ("Shift + Tab", "Moves focus to the previous focusable element"),
        ("Space", "Toggles the switch on or off"),
    ];

    private static readonly (string Attribute, string Description)[] _aria =
    [
        ("role=\"switch\"", "Identifies the element as a switch"),
        ("aria-checked", "Reflects the current on/off state of the switch"),
        ("aria-disabled=\"true\"", "Applied when Enabled is false"),
        ("aria-label", "Provided by the Label parameter"),
    ];

    private static readonly string[] _screenReader =
    [
        "Switches are announced with their label, on/off state, and the \"switch\" role.",
        "Toggling the switch announces the new state (\"on\" or \"off\").",
        "Disabled switches are announced as \"dimmed\" or \"unavailable\" depending on the screen reader.",
    ];
}
