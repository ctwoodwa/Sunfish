@page "/components/maskedtextbox"
@page "/components/maskedtextbox/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <SunfishAlert Severity="AlertSeverity.Info" style="margin-bottom:16px;">
        The MaskedTextBox is provided by the <strong>SunfishMaskedInput</strong> component, which enforces input formatting through mask patterns.
    </SunfishAlert>

    <DemoSection Title="Phone Number Mask" Description="Use the Mask parameter to define the expected input pattern. The placeholder shows the mask format when no custom Placeholder is set." Code="@_phoneCode">
        <SunfishMaskedInput @bind-Value="_phoneValue"
                           Mask="(000) 000-0000"
                           Prompt="@('_')"
                           AriaLabel="Phone number" />
        <p style="margin-top:8px;">Value: <strong>@_phoneValue</strong></p>
    </DemoSection>

    <DemoSection Title="Date Mask" Description="Apply a date mask pattern to guide date entry." Code="@_dateCode">
        <SunfishMaskedInput @bind-Value="_dateValue"
                           Mask="00/00/0000"
                           Placeholder="MM/DD/YYYY"
                           AriaLabel="Date" />
        <p style="margin-top:8px;">Value: <strong>@_dateValue</strong></p>
    </DemoSection>

    <DemoSection Title="Custom Mask with Literals" Description="When IncludeLiterals is true, literal characters from the mask (such as dashes) are included in the bound value." Code="@_ssnCode">
        <SunfishMaskedInput @bind-Value="_ssnValue"
                           Mask="000-00-0000"
                           IncludeLiterals="true"
                           Prompt="@('_')"
                           AriaLabel="SSN" />
        <p style="margin-top:8px;">Value (with literals): <strong>@_ssnValue</strong></p>
    </DemoSection>

    <DemoSection Title="Disabled and Read-Only" Description="Set Enabled to false or ReadOnly to true to prevent editing." Code="@_disabledCode">
        <div style="display:flex; gap:12px; flex-direction:column; max-width:300px;">
            <SunfishMaskedInput Value="(555) 123-4567" Mask="(000) 000-0000" Enabled="false" AriaLabel="Disabled phone" />
            <SunfishMaskedInput Value="12/25/2026" Mask="00/00/0000" ReadOnly="true" AriaLabel="Read-only date" />
        </div>
    </DemoSection>
</PageSection>

@code {
    private string _phoneValue = "";
    private string _dateValue = "";
    private string _ssnValue = "";

    private const string _phoneCode =
        "<SunfishMaskedInput @bind-Value=\"_phone\"\n" +
        "                   Mask=\"(000) 000-0000\"\n" +
        "                   Prompt='_'\n" +
        "                   AriaLabel=\"Phone number\" />";

    private const string _dateCode =
        "<SunfishMaskedInput @bind-Value=\"_date\"\n" +
        "                   Mask=\"00/00/0000\"\n" +
        "                   Placeholder=\"MM/DD/YYYY\"\n" +
        "                   AriaLabel=\"Date\" />";

    private const string _ssnCode =
        "<SunfishMaskedInput @bind-Value=\"_ssn\"\n" +
        "                   Mask=\"000-00-0000\"\n" +
        "                   IncludeLiterals=\"true\"\n" +
        "                   Prompt='_'\n" +
        "                   AriaLabel=\"SSN\" />";

    private const string _disabledCode =
        "<SunfishMaskedInput Value=\"(555) 123-4567\"\n" +
        "                   Mask=\"(000) 000-0000\"\n" +
        "                   Enabled=\"false\" />\n\n" +
        "<SunfishMaskedInput Value=\"12/25/2026\"\n" +
        "                   Mask=\"00/00/0000\"\n" +
        "                   ReadOnly=\"true\" />";
}
