@page "/components/DataGrid"
@page "/components/DataGrid/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Code="@_basicCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="HireDate" Title="Hire Date" Format="yyyy-MM-dd" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="Auto-Generated Columns"
                 Description="Set AutoGenerateColumns to true to generate columns from the model's public properties."
                 Code="@_autoGenCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" AutoGenerateColumns="true" />
    </DemoSection>
</PageSection>

<PageSection Title="Paging">
    <DemoSection Title="Basic Paging" Description="Enable paging with the Pageable parameter." Code="@_pagingCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" Pageable="true" PageSize="3">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="HireDate" Title="Hire Date" Format="yyyy-MM-dd" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="Page Size Selector" Description="Add a page size dropdown with the PageSizes parameter." Code="@_pageSizesCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" Pageable="true" PageSize="3" PageSizes="@(new[] { 3, 5, 10 })">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
    </DemoSection>
</PageSection>

<PageSection Title="Sorting">
    <DemoSection Title="Single-Column Sorting"
                 Description="Click column headers to sort. Sorting is enabled by default. Click again to reverse, click a third time to clear."
                 Code="@_sortingCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" Sortable="true" Striped="true">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="Multi-Column Sorting"
                 Description="Hold Ctrl/Cmd and click additional column headers to sort by multiple columns."
                 Code="@_multiSortCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" Sortable="true">
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
            <SunfishGridColumn TItem="Employee" Field="HireDate" Title="Hire Date" Format="yyyy-MM-dd" />
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="Disable Sorting Per Column"
                 Description="Set Sortable=false on individual columns to prevent sorting."
                 Code="@_disableSortCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" Sortable="true">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" Sortable="false" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
    </DemoSection>
</PageSection>

<PageSection Title="Filtering">
    <DemoSection Title="Filter Row"
                 Description="Show a filter row below the header with FilterMode.FilterRow."
                 Code="@_filterRowCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" FilterMode="GridFilterMode.FilterRow">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" Filterable="false" />
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="Filter Menu"
                 Description="Use FilterMode.FilterMenu to show a popup filter with operator selection."
                 Code="@_filterMenuCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" FilterMode="GridFilterMode.FilterMenu">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="Search Box"
                 Description="Enable the built-in search box to filter across all visible columns."
                 Code="@_searchBoxCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" ShowSearchBox="true" SearchBoxPlaceholder="Search employees...">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="HireDate" Title="Hire Date" Format="yyyy-MM-dd" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
    </DemoSection>
</PageSection>

<PageSection Title="Selection">
    <DemoSection Title="Single Selection"
                 Description="Enable row selection with the SelectionMode parameter. Click a row to select it."
                 Code="@_selectionCode">
        <SunfishDataGrid TItem="Employee"
                        Data="@_employees"
                        SelectionMode="GridSelectionMode.Single"
                        SelectedItems="@_selected"
                        SelectedItemsChanged="@OnSelectionChanged"
                        Striped="true">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
        </SunfishDataGrid>
        <p>Selected: @string.Join(", ", _selected.Select(e => e.Name))</p>
    </DemoSection>

    <DemoSection Title="Multiple Selection with Checkboxes"
                 Description="Use SelectionMode.Multiple with ShowCheckboxColumn for multi-select with a Select All header."
                 Code="@_multiSelectCode">
        <SunfishDataGrid TItem="Employee"
                        Data="@_employees"
                        SelectionMode="GridSelectionMode.Multiple"
                        ShowCheckboxColumn="true"
                        SelectedItems="@_multiSelected"
                        SelectedItemsChanged="@OnMultiSelectionChanged">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
        <p>Selected (@_multiSelected.Count): @string.Join(", ", _multiSelected.Select(e => e.Name))</p>
    </DemoSection>
</PageSection>

<PageSection Title="Grouping">
    <DemoSection Title="Basic Grouping"
                 Description="Enable Groupable and use the GroupBy API to group data by a field. Click the group header to expand or collapse."
                 Code="@_groupingCode">
        <SunfishDataGrid @ref="_groupGrid" TItem="Employee" Data="@_employees" Groupable="true">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
        <button @onclick="GroupByDepartment">Group by Department</button>
        <button @onclick="ClearGroups">Clear Groups</button>
    </DemoSection>

    <DemoSection Title="Custom Group Header & Footer"
                 Description="Use GroupHeaderTemplate and GroupFooterTemplate to customize group rendering."
                 Code="@_groupTemplateCode">
        <SunfishDataGrid @ref="_groupTemplateGrid" TItem="Employee" Data="@_employees" Groupable="true">
            <GroupHeaderTemplate>
                <strong>@context.Field</strong>: @context.Value
                <em>(@context.Count employees)</em>
            </GroupHeaderTemplate>
            <GroupFooterTemplate>
                <span>Total in @context.Value: @(ComputeGroupTotal(context))</span>
            </GroupFooterTemplate>
            <ChildContent>
                <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
                <SunfishGridColumn TItem="Employee" Field="Department" />
                <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
            </ChildContent>
        </SunfishDataGrid>
        <button @onclick="GroupTemplateByDept">Group by Department</button>
    </DemoSection>
</PageSection>

<PageSection Title="Editing">
    <DemoSection Title="Inline Editing"
                 Description="Edit an entire row at once. Click Edit to enter edit mode, then Save or Cancel."
                 Code="@_inlineEditCode">
        <SunfishDataGrid TItem="Employee"
                        Data="@_inlineEmployees"
                        EditMode="GridEditMode.Inline"
                        OnUpdate="@OnInlineUpdate"
                        OnDelete="@OnInlineDelete"
                        OnCreate="@OnInlineCreate"
                        OnModelInit="@OnInlineModelInit">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name">
                <EditorTemplate>
                    <input type="text" value="@context.Name" @onchange="@(e => SetName(context, e))" />
                </EditorTemplate>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="Department">
                <EditorTemplate>
                    <input type="text" value="@context.Department" @onchange="@(e => SetDepartment(context, e))" />
                </EditorTemplate>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right">
                <EditorTemplate>
                    <input type="number" value="@context.Salary" @onchange="@(e => SetSalary(context, e))" />
                </EditorTemplate>
            </SunfishGridColumn>
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="Popup Editing"
                 Description="Edit items in a popup dialog. Click Edit to open the form, make changes, and Save."
                 Code="@_popupEditCode">
        <SunfishDataGrid TItem="Employee"
                        Data="@_popupEmployees"
                        EditMode="GridEditMode.Popup"
                        OnUpdate="@OnPopupUpdate"
                        OnDelete="@OnPopupDelete"
                        OnCreate="@OnPopupCreate"
                        OnModelInit="@OnPopupModelInit">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name">
                <EditorTemplate>
                    <input type="text" value="@context.Name" @onchange="@(e => SetName(context, e))" />
                </EditorTemplate>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="Department">
                <EditorTemplate>
                    <input type="text" value="@context.Department" @onchange="@(e => SetDepartment(context, e))" />
                </EditorTemplate>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right">
                <EditorTemplate>
                    <input type="number" value="@context.Salary" @onchange="@(e => SetSalary(context, e))" />
                </EditorTemplate>
            </SunfishGridColumn>
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="InCell Editing"
                 Description="Double-click a cell to edit it in place. Changes are saved per-cell."
                 Code="@_inCellEditCode">
        <SunfishDataGrid TItem="Employee"
                        Data="@_inCellEmployees"
                        EditMode="GridEditMode.InCell"
                        OnUpdate="@OnInCellUpdate">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name">
                <EditorTemplate>
                    <input type="text" value="@context.Name" @onchange="@(e => SetName(context, e))" />
                </EditorTemplate>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="Department">
                <EditorTemplate>
                    <input type="text" value="@context.Department" @onchange="@(e => SetDepartment(context, e))" />
                </EditorTemplate>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right">
                <EditorTemplate>
                    <input type="number" value="@context.Salary" @onchange="@(e => SetSalary(context, e))" />
                </EditorTemplate>
            </SunfishGridColumn>
        </SunfishDataGrid>
    </DemoSection>
</PageSection>

<PageSection Title="Templates">
    <DemoSection Title="Column Templates"
                 Description="Use the Template parameter to customize cell rendering with arbitrary markup."
                 Code="@_columnTemplateCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name">
                <Template>
                    <strong>@context.Name</strong>
                </Template>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="Department">
                <Template>
                    <span style="padding:2px 8px;border-radius:12px;font-size:0.85em;background:@GetDeptColor(context.Department);color:#fff;">
                        @context.Department
                    </span>
                </Template>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="HireDate" Title="Hire Date">
                <Template>
                    @context.HireDate.ToString("MMMM d, yyyy")
                </Template>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="Salary" TextAlign="right">
                <Template>
                    <span style="font-weight:600;color:@(context.Salary >= 90000 ? "green" : "inherit");">
                        @context.Salary.ToString("C0")
                    </span>
                </Template>
            </SunfishGridColumn>
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="Header & Footer Templates"
                 Description="Customize column headers and add footer aggregates."
                 Code="@_headerFooterCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name">
                <HeaderTemplate>
                    <span style="font-weight:bold;text-transform:uppercase;">Employee</span>
                </HeaderTemplate>
            </SunfishGridColumn>
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right">
                <HeaderTemplate>
                    <span>Salary (USD)</span>
                </HeaderTemplate>
                <FooterTemplate>
                    <strong>Avg: @_employees.Average(e => e.Salary).ToString("C0")</strong>
                </FooterTemplate>
            </SunfishGridColumn>
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="Detail Template (Master-Detail)"
                 Description="Use DetailTemplate to show expandable detail rows. Click the arrow to expand."
                 Code="@_detailTemplateCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees">
            <DetailTemplate>
                <div style="padding:12px 24px;">
                    <p><strong>@context.Name</strong> — @context.Department</p>
                    <p>Hired: @context.HireDate.ToString("MMMM d, yyyy")</p>
                    <p>Annual Salary: @context.Salary.ToString("C2")</p>
                    <p>Monthly: @((context.Salary / 12).ToString("C2"))</p>
                </div>
            </DetailTemplate>
            <ChildContent>
                <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
                <SunfishGridColumn TItem="Employee" Field="Department" />
                <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
            </ChildContent>
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="No Data Template"
                 Description="Provide a custom template for the empty state when the grid has no data."
                 Code="@_noDataCode">
        <SunfishDataGrid TItem="Employee" Data="@(new List<Employee>())">
            <NoDataTemplate>
                <div style="text-align:center;padding:24px;color:#888;">
                    <p style="font-size:1.5em;">No employees found</p>
                    <p>Try adjusting your filters or adding new records.</p>
                </div>
            </NoDataTemplate>
            <ChildContent>
                <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
                <SunfishGridColumn TItem="Employee" Field="Department" />
            </ChildContent>
        </SunfishDataGrid>
    </DemoSection>
</PageSection>

<PageSection Title="Toolbar & Export">
    <DemoSection Title="Toolbar with Command Buttons"
                 Description="Use ToolbarTemplate to add command buttons above the grid."
                 Code="@_toolbarCode">
        <SunfishDataGrid @ref="_toolbarGrid"
                        TItem="Employee"
                        Data="@_toolbarEmployees"
                        EditMode="GridEditMode.Inline"
                        OnCreate="@OnToolbarCreate"
                        OnUpdate="@OnToolbarUpdate"
                        OnDelete="@OnToolbarDelete"
                        OnModelInit="@OnToolbarModelInit">
            <ToolbarTemplate>
                <SunfishGridToolbar TItem="Employee">
                    <SunfishGridCommandButton TItem="Employee" Command="Add" Text="Add Employee" />
                </SunfishGridToolbar>
            </ToolbarTemplate>
            <ChildContent>
                <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name">
                    <EditorTemplate>
                        <input type="text" value="@context.Name" @onchange="@(e => SetName(context, e))" />
                    </EditorTemplate>
                </SunfishGridColumn>
                <SunfishGridColumn TItem="Employee" Field="Department">
                    <EditorTemplate>
                        <input type="text" value="@context.Department" @onchange="@(e => SetDepartment(context, e))" />
                    </EditorTemplate>
                </SunfishGridColumn>
                <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right">
                    <EditorTemplate>
                        <input type="number" value="@context.Salary" @onchange="@(e => SetSalary(context, e))" />
                    </EditorTemplate>
                </SunfishGridColumn>
            </ChildContent>
        </SunfishDataGrid>
    </DemoSection>

    <DemoSection Title="CSV Export"
                 Description="Use the ExportToCsv method to export grid data. The export respects current filtering and sorting."
                 Code="@_csvExportCode">
        <SunfishDataGrid @ref="_exportGrid" TItem="Employee" Data="@_employees" Sortable="true" FilterMode="GridFilterMode.FilterRow">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="HireDate" Title="Hire Date" Format="yyyy-MM-dd" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
        <button @onclick="ExportCsv">Export to CSV</button>
        @if (!string.IsNullOrEmpty(_csvOutput))
        {
            <pre style="max-height:200px;overflow:auto;margin-top:8px;padding:8px;background:#f5f5f5;font-size:0.85em;">@_csvOutput</pre>
        }
    </DemoSection>
</PageSection>

<PageSection Title="Virtualization">
    <DemoSection Title="Virtual Scrolling"
                 Description="Enable virtualization for large datasets. Only visible rows are rendered in the DOM."
                 Code="@_virtualizationCode">
        <SunfishDataGrid TItem="Employee" Data="@_largeDataSet" EnableVirtualization="true" Height="300px">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
    </DemoSection>
</PageSection>

<PageSection Title="Frozen Columns">
    <DemoSection Title="Locked / Frozen Columns"
                 Description="Set Locked=true on a column to freeze it in place while the rest of the grid scrolls horizontally."
                 Code="@_frozenColumnsCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" Width="500px" Height="300px">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" Locked="true" Width="150px" />
            <SunfishGridColumn TItem="Employee" Field="Department" Width="200px" />
            <SunfishGridColumn TItem="Employee" Field="HireDate" Title="Hire Date" Format="yyyy-MM-dd" Width="200px" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" Width="200px" />
        </SunfishDataGrid>
    </DemoSection>
</PageSection>

<PageSection Title="Cell Selection">
    <DemoSection Title="Cell Selection Mode"
                 Description="Set SelectionUnit to Cell to allow selecting individual cells instead of entire rows."
                 Code="@_cellSelectionCode">
        <SunfishDataGrid TItem="Employee"
                        Data="@_employees"
                        SelectionUnit="GridSelectionUnit.Cell"
                        SelectionMode="GridSelectionMode.Single">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
    </DemoSection>
</PageSection>

<PageSection Title="Loading State">
    <DemoSection Title="Loading Overlay"
                 Description="Set IsLoading to true to display a loading overlay while data is being fetched."
                 Code="@_loadingCode">
        <SunfishDataGrid TItem="Employee" Data="@_employees" IsLoading="@_isLoading">
            <SunfishGridColumn TItem="Employee" Field="Name" Title="Full Name" />
            <SunfishGridColumn TItem="Employee" Field="Department" />
            <SunfishGridColumn TItem="Employee" Field="Salary" Format="C2" TextAlign="right" />
        </SunfishDataGrid>
        <button @onclick="ToggleLoading">Toggle Loading</button>
    </DemoSection>
</PageSection>

@code {
    // ── Shared Data ────────────────────────────────────────────────────
    private List<Employee> _employees =
    [
        new("Alice Johnson", "Engineering", new DateTime(2019, 3, 15), 95000m),
        new("Bob Smith", "Marketing", new DateTime(2020, 7, 1), 72000m),
        new("Carol White", "Engineering", new DateTime(2018, 1, 10), 105000m),
        new("David Brown", "Sales", new DateTime(2021, 11, 20), 68000m),
        new("Eve Davis", "Engineering", new DateTime(2022, 5, 5), 88000m),
        new("Frank Miller", "Marketing", new DateTime(2017, 9, 12), 78000m),
        new("Grace Lee", "Sales", new DateTime(2023, 2, 28), 65000m),
    ];

    public class Employee
    {
        public string Name { get; set; } = "";
        public string Department { get; set; } = "";
        public DateTime HireDate { get; set; }
        public decimal Salary { get; set; }

        public Employee() { }
        public Employee(string name, string department, DateTime hireDate, decimal salary)
        {
            Name = name;
            Department = department;
            HireDate = hireDate;
            Salary = salary;
        }
    }

    // ── Selection ──────────────────────────────────────────────────────
    private List<Employee> _selected = [];
    private List<Employee> _multiSelected = [];

    private void OnSelectionChanged(IEnumerable<Employee> items) => _selected = items.ToList();
    private void OnMultiSelectionChanged(IEnumerable<Employee> items) => _multiSelected = items.ToList();

    // ── Grouping ───────────────────────────────────────────────────────
    private SunfishDataGrid<Employee>? _groupGrid;
    private SunfishDataGrid<Employee>? _groupTemplateGrid;

    private async Task GroupByDepartment()
    {
        if (_groupGrid != null) await _groupGrid.GroupBy("Department");
    }

    private async Task ClearGroups()
    {
        if (_groupGrid != null) await _groupGrid.UngroupAll();
    }

    private async Task GroupTemplateByDept()
    {
        if (_groupTemplateGrid != null) await _groupTemplateGrid.GroupBy("Department");
    }

    // ── Editing (Inline) ───────────────────────────────────────────────
    private List<Employee> _inlineEmployees = null!;

    private void OnInlineCreate(GridEditEventArgs<Employee> args)
    {
        _inlineEmployees.Add(args.Item);
    }

    private void OnInlineUpdate(GridEditEventArgs<Employee> args)
    {
        var index = _inlineEmployees.FindIndex(e => e.Name == args.Item.Name);
        if (index >= 0) _inlineEmployees[index] = args.Item;
    }

    private void OnInlineDelete(GridEditEventArgs<Employee> args)
    {
        _inlineEmployees.Remove(args.Item);
    }

    private void OnInlineModelInit(GridModelInitEventArgs<Employee> args)
    {
        args.Item = new Employee("", "", DateTime.Today, 0m);
    }

    // ── Editing (Popup) ────────────────────────────────────────────────
    private List<Employee> _popupEmployees = null!;

    private void OnPopupCreate(GridEditEventArgs<Employee> args) => _popupEmployees.Add(args.Item);
    private void OnPopupUpdate(GridEditEventArgs<Employee> args)
    {
        var index = _popupEmployees.FindIndex(e => e.Name == args.Item.Name);
        if (index >= 0) _popupEmployees[index] = args.Item;
    }
    private void OnPopupDelete(GridEditEventArgs<Employee> args) => _popupEmployees.Remove(args.Item);
    private void OnPopupModelInit(GridModelInitEventArgs<Employee> args) =>
        args.Item = new Employee("", "", DateTime.Today, 0m);

    // ── Editing (InCell) ───────────────────────────────────────────────
    private List<Employee> _inCellEmployees = null!;
    private void OnInCellUpdate(GridEditEventArgs<Employee> args) { /* item mutated in place */ }

    // ── Editor Helpers ─────────────────────────────────────────────────
    private static void SetName(Employee e, ChangeEventArgs args) => e.Name = args.Value?.ToString() ?? "";
    private static void SetDepartment(Employee e, ChangeEventArgs args) => e.Department = args.Value?.ToString() ?? "";
    private static void SetSalary(Employee e, ChangeEventArgs args)
    {
        if (decimal.TryParse(args.Value?.ToString(), out var val)) e.Salary = val;
    }

    // ── Toolbar ────────────────────────────────────────────────────────
    private SunfishDataGrid<Employee>? _toolbarGrid;
    private List<Employee> _toolbarEmployees = null!;

    private void OnToolbarCreate(GridEditEventArgs<Employee> args) => _toolbarEmployees.Add(args.Item);
    private void OnToolbarUpdate(GridEditEventArgs<Employee> args)
    {
        var idx = _toolbarEmployees.FindIndex(e => e.Name == args.Item.Name);
        if (idx >= 0) _toolbarEmployees[idx] = args.Item;
    }
    private void OnToolbarDelete(GridEditEventArgs<Employee> args) => _toolbarEmployees.Remove(args.Item);
    private void OnToolbarModelInit(GridModelInitEventArgs<Employee> args) =>
        args.Item = new Employee("", "", DateTime.Today, 0m);

    // ── CSV Export ─────────────────────────────────────────────────────
    private SunfishDataGrid<Employee>? _exportGrid;
    private string _csvOutput = "";

    private async Task ExportCsv()
    {
        if (_exportGrid != null)
        {
            await _exportGrid.ExportToCsvAsync();
            _csvOutput = "CSV download triggered";
        }
    }

    // ── Virtualization ─────────────────────────────────────────────────
    private List<Employee> _largeDataSet = null!;

    // ── Loading ────────────────────────────────────────────────────────
    private bool _isLoading;
    private void ToggleLoading() => _isLoading = !_isLoading;

    // ── Template Helpers ───────────────────────────────────────────────
    private string ComputeGroupTotal(GridGroupHeaderContext<Employee> context)
    {
        var total = context.Items.Sum(e => e.Salary);
        return total.ToString("C2");
    }

    private static string GetDeptColor(string dept) => dept switch
    {
        "Engineering" => "#2196f3",
        "Marketing" => "#e91e63",
        "Sales" => "#4caf50",
        _ => "#757575"
    };

    // ── Lifecycle ──────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        // Create independent copies for editing demos
        _inlineEmployees = _employees.Select(e => new Employee(e.Name, e.Department, e.HireDate, e.Salary)).ToList();
        _popupEmployees = _employees.Select(e => new Employee(e.Name, e.Department, e.HireDate, e.Salary)).ToList();
        _inCellEmployees = _employees.Select(e => new Employee(e.Name, e.Department, e.HireDate, e.Salary)).ToList();
        _toolbarEmployees = _employees.Select(e => new Employee(e.Name, e.Department, e.HireDate, e.Salary)).ToList();

        // Generate large dataset for virtualization
        var depts = new[] { "Engineering", "Marketing", "Sales", "HR", "Finance" };
        _largeDataSet = Enumerable.Range(1, 1000).Select(i => new Employee(
            $"Employee {i}",
            depts[i % depts.Length],
            DateTime.Today.AddDays(-Random.Shared.Next(365, 2500)),
            50000m + Random.Shared.Next(0, 60000)
        )).ToList();
    }

