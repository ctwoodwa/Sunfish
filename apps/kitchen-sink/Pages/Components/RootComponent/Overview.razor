@page "/components/rootcomponent"
@page "/components/rootcomponent/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <SunfishAlert Severity="AlertSeverity.Info" style="margin-bottom:16px;">
        The RootComponent is provided by <strong>SunfishThemeProvider</strong>, which wraps the application to provide theming and CSS variables. It should be placed at the root of your component tree.
    </SunfishAlert>

    <DemoSection Title="Usage Pattern" Description="SunfishThemeProvider cascades a SunfishTheme to all child components and generates CSS custom properties for colors, typography, and shape tokens. It also integrates with the ThemeService for dark mode toggling." Code="@_usageCode">
        <SunfishAlert Severity="AlertSeverity.Warning">
            SunfishThemeProvider is a root-level wrapper and is already active in this demo application. The code example below shows how to configure it in your App.razor or MainLayout.razor.
        </SunfishAlert>
    </DemoSection>

    <DemoSection Title="Custom Theme" Description="Pass a custom SunfishTheme to override default colors, typography, and shape tokens." Code="@_customThemeCode">
        <SunfishThemeProvider Theme="@_demoTheme">
            <div style="padding:16px; border:1px solid #ddd; border-radius:8px;">
                <p style="color:var(--sf-color-primary);">This text uses the custom primary color.</p>
                <p style="color:var(--sf-color-secondary);">This text uses the custom secondary color.</p>
                <p style="font-family:var(--sf-font-family);">Font family from the theme.</p>
            </div>
        </SunfishThemeProvider>
    </DemoSection>

    <DemoSection Title="Theme Properties" Description="SunfishThemeProvider generates CSS variables that components use for consistent styling. Key parameters include Theme, ChildContent, and ThemeChanged." Code="@_propsCode">
        <div style="overflow-x:auto;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:2px solid #ddd;">
                        <th style="text-align: start; padding:8px;">Parameter</th>
                        <th style="text-align: start; padding:8px;">Type</th>
                        <th style="text-align: start; padding:8px;">Description</th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="border-bottom:1px solid #eee;">
                        <td style="padding:8px;"><code>Theme</code></td>
                        <td style="padding:8px;"><code>SunfishTheme</code></td>
                        <td style="padding:8px;">The theme configuration object with Colors, Typography, and Shape tokens.</td>
                    </tr>
                    <tr style="border-bottom:1px solid #eee;">
                        <td style="padding:8px;"><code>ChildContent</code></td>
                        <td style="padding:8px;"><code>RenderFragment</code></td>
                        <td style="padding:8px;">The application content tree that receives the cascaded theme.</td>
                    </tr>
                    <tr style="border-bottom:1px solid #eee;">
                        <td style="padding:8px;"><code>ThemeChanged</code></td>
                        <td style="padding:8px;"><code>EventCallback&lt;ThemeChangedEventArgs&gt;</code></td>
                        <td style="padding:8px;">Fires when the active theme changes (e.g., dark mode toggle).</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </DemoSection>
</PageSection>

@code {
    private readonly SunfishTheme _demoTheme = new()
    {
        Colors = new()
        {
            Primary = "#6a1b9a",
            Secondary = "#00897b",
        }
    };

    private const string _usageCode =
        "<!-- App.razor or MainLayout.razor -->\n" +
        "<SunfishThemeProvider>\n" +
        "    <Router AppAssembly=\"@typeof(App).Assembly\">\n" +
        "        ...\n" +
        "    </Router>\n" +
        "</SunfishThemeProvider>";

    private const string _customThemeCode =
        "<SunfishThemeProvider Theme=\"@_theme\">\n" +
        "    <p style=\"color:var(--sf-color-primary)\">Custom primary color.</p>\n" +
        "</SunfishThemeProvider>\n\n" +
        "@code {\n" +
        "    private SunfishTheme _theme = new()\n" +
        "    {\n" +
        "        Colors = new() { Primary = \"#6a1b9a\", Secondary = \"#00897b\" }\n" +
        "    };\n" +
        "}";

    private const string _propsCode =
        "// CSS variables generated by SunfishThemeProvider:\n" +
        "// --sf-color-primary, --sf-color-secondary,\n" +
        "// --sf-color-danger, --sf-color-warning,\n" +
        "// --sf-color-info, --sf-color-success,\n" +
        "// --sf-font-family, --sf-font-size-base,\n" +
        "// --sf-radius-md, --sf-shadow-sm, etc.";
}
