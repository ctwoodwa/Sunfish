@page "/components/forms/searchbox/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>SearchBox / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="SearchBox / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Forms/SearchBox/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>The search box provides a text input optimized for search queries, with a built-in search icon and clear button.</p>
        <p>
            This overview page is a stub — the live demo is forthcoming. The component is tracked
            in the Sunfish example catalog for cross-provider parity.
        </p>
    </Narrative>

    <Example>
        <div class="demo-placeholder" style="padding: 1.5rem; border: 1px dashed var(--sunfish-border, #d1d5db); border-radius: .5rem; color: var(--sunfish-muted, #6b7280); text-align: center;">
            <strong>SearchBox</strong> — overview demo coming soon.
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Forms", "SearchBox", "Overview"];
}
