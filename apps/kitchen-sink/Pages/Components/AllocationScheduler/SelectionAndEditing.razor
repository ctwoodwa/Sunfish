@page "/components/allocation-scheduler/selection-and-editing"
@layout ComponentDemoLayout
@using Sunfish.Components.Blazor.Components.DataDisplay
@using Sunfish.Foundation.Enums
@using Sunfish.Foundation.Models

<PageSection Title="Selection Modes">
    <DemoSection Title="Cell and Range Selection"
                 Description="Toggle between None, Cell, and Range selection. Click cells to see selection behaviour change."
                 Code="@_selectionCode">
        <div style="margin-bottom:1rem">
            <label>
                Selection Mode:
                <select @bind="_selectionMode">
                    <option value="@AllocationSelectionMode.None">None</option>
                    <option value="@AllocationSelectionMode.Cell">Cell</option>
                    <option value="@AllocationSelectionMode.Range">Range</option>
                </select>
            </label>
        </div>

        <SunfishAllocationScheduler TResource="StaffResource"
                                   Resources="@_resources"
                                   Allocations="@_allocations"
                                   AuthoritativeLevel="TimeGranularity.Week"
                                   ViewGrain="TimeGranularity.Week"
                                   ValueMode="AllocationValueMode.Hours"
                                   SelectionMode="@_selectionMode"
                                   VisibleStart="@_demoStart"
                                   MinVisibleColumns="2"
                                   DefaultRangeUnit="TimeGranularity.Month"
                                   OnSelectionChanged="@HandleSelectionChanged"
                                   Height="250px">
            <AllocationResourceColumns>
                <AllocationResourceColumn TResource="StaffResource" Field="Name" Title="Resource" Width="180px" />
                <AllocationResourceColumn TResource="StaffResource" Field="Role" Title="Role" Width="120px" />
            </AllocationResourceColumns>
        </SunfishAllocationScheduler>

        @if (_selectedCount > 0)
        {
            <p><strong>Selected cells:</strong> @_selectedCount</p>
        }
    </DemoSection>
</PageSection>

<PageSection Title="Bulk Range Editing">
    <DemoSection Title="Drag-Fill and Keyboard Edit"
                 Description="Enable AllowBulkEdit and SelectionMode=Range. Select a range of cells and apply a value. The OnRangeEdited event fires on commit."
                 Code="@_bulkEditCode">
        <SunfishAllocationScheduler TResource="StaffResource"
                                   Resources="@_resources"
                                   Allocations="@_editableAllocations"
                                   AuthoritativeLevel="TimeGranularity.Week"
                                   ViewGrain="TimeGranularity.Week"
                                   ValueMode="AllocationValueMode.Hours"
                                   SelectionMode="AllocationSelectionMode.Range"
                                   AllowBulkEdit="true"
                                   AllowDragFill="true"
                                   AllowKeyboardEdit="true"
                                   VisibleStart="@_demoStart"
                                   MinVisibleColumns="2"
                                   DefaultRangeUnit="TimeGranularity.Month"
                                   OnRangeEdited="@HandleRangeEdited"
                                   OnCellEdited="@HandleCellEdited"
                                   Height="250px">
            <AllocationResourceColumns>
                <AllocationResourceColumn TResource="StaffResource" Field="Name" Title="Resource" Width="180px" />
                <AllocationResourceColumn TResource="StaffResource" Field="Role" Title="Role" Width="120px" />
            </AllocationResourceColumns>
        </SunfishAllocationScheduler>

        @if (!string.IsNullOrEmpty(_rangeEditMessage))
        {
            <p><strong>Range edit:</strong> @_rangeEditMessage</p>
        }
        @if (!string.IsNullOrEmpty(_cellEditMessage))
        {
            <p><strong>Cell edit:</strong> @_cellEditMessage</p>
        }
    </DemoSection>
</PageSection>

<PageSection Title="Custom Context Menu">
    <DemoSection Title="Custom Commands"
                 Description="Extend the built-in context menu with custom commands using ContextMenuItems. 'Flag for Review' fires OnContextMenuAction. 'Copy Row to Clipboard' is disabled for Project Manager resources via CanExecuteAction."
                 Code="@_customMenuCode">
        <SunfishAllocationScheduler TResource="StaffResource"
                                   Resources="@_allResources"
                                   Allocations="@_allEditableAllocations"
                                   AuthoritativeLevel="TimeGranularity.Week"
                                   ViewGrain="TimeGranularity.Week"
                                   ValueMode="AllocationValueMode.Hours"
                                   EnableContextMenu="true"
                                   ContextMenuItems="@_customMenuItems"
                                   VisibleStart="@_demoStart"
                                   MinVisibleColumns="2"
                                   DefaultRangeUnit="TimeGranularity.Month"
                                   OnContextMenuAction="@HandleCustomMenuAction"
                                   CanExecuteAction="@HandleCanExecute"
                                   Height="400px">
            <AllocationResourceColumns>
                <AllocationResourceColumn TResource="StaffResource" Field="Name" Title="Resource" Width="180px" />
                <AllocationResourceColumn TResource="StaffResource" Field="Role" Title="Role" Width="120px" />
            </AllocationResourceColumns>
        </SunfishAllocationScheduler>

        @if (!string.IsNullOrEmpty(_customMenuMessage))
        {
            <p><strong>Last action:</strong> @_customMenuMessage</p>
        }
    </DemoSection>
</PageSection>

<PageSection Title="Day-Level Editing">
    <DemoSection Title="Daily Allocation Editing"
                 Description="Set AuthoritativeLevel and ViewGrain to TimeGranularity.Day for fine-grained daily allocation editing. Useful for short-sprint or operational scheduling. Ten resources across 4 weeks (Mon–Fri only)."
                 Code="@_dayCode">
        <SunfishAllocationScheduler TResource="StaffResource"
                                   Resources="@_tenResources"
                                   Allocations="@_dailyAllocations"
                                   AuthoritativeLevel="TimeGranularity.Day"
                                   ViewGrain="TimeGranularity.Day"
                                   ValueMode="AllocationValueMode.Hours"
                                   VisibleStart="@_demoStart"
                                   MinVisibleColumns="2"
                                   DefaultRangeUnit="TimeGranularity.Week"
                                   Height="380px">
            <AllocationResourceColumns>
                <AllocationResourceColumn TResource="StaffResource" Field="Name" Title="Resource" Width="180px" />
                <AllocationResourceColumn TResource="StaffResource" Field="Role" Title="Role" Width="120px" />
            </AllocationResourceColumns>
        </SunfishAllocationScheduler>
    </DemoSection>
</PageSection>

<PageSection Title="Disabled Slots">
    <DemoSection Title="Non-Editable Date Ranges"
                 Description="Configure disabled slot ranges (public holidays, company blackout periods) to render specific cells as locked and non-interactive. Define a list of DateRange objects and bind to DisabledSlots."
                 Code="@_disabledSlotsCode">
        <SunfishAllocationScheduler TResource="StaffResource"
                                   Resources="@_tenResources"
                                   Allocations="@_allBasicAllocations"
                                   AuthoritativeLevel="TimeGranularity.Week"
                                   ViewGrain="TimeGranularity.Week"
                                   ValueMode="AllocationValueMode.Hours"
                                   AllowKeyboardEdit="true"
                                   VisibleStart="@_demoStart"
                                   MinVisibleColumns="2"
                                   DefaultRangeUnit="TimeGranularity.Month"
                                   Height="380px">
            <AllocationResourceColumns>
                <AllocationResourceColumn TResource="StaffResource" Field="Name" Title="Resource" Width="180px" />
                <AllocationResourceColumn TResource="StaffResource" Field="Role" Title="Role" Width="120px" />
            </AllocationResourceColumns>
        </SunfishAllocationScheduler>
    </DemoSection>
</PageSection>

