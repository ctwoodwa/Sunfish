    private void BuildDailyAllocations()
    {
        _dailyAllocations = new();
        var start = GetCurrentMonday();
        var rangeEnd = start.AddDays(28); // 4 weeks

        var assignments = new (int ResId, int TaskId, string TaskName, decimal HoursPerDay)[]
        {
            (1,  101, "Backend API Development",    8m),
            (2,  101, "Backend API Development",    8m),
            (3,  103, "QA & Test Automation",       6m),
            (4,  108, "Project Coordination",        4m),
            (5,  102, "Frontend UI Build",           8m),
            (6,  101, "Backend API Development",    8m),
            (7,  105, "UX Research & Design",        6m),
            (8,  104, "Infrastructure & CI/CD",      7m),
            (9,  108, "Project Coordination",        5m),
            (10, 101, "Backend API Development",    8m),
        };

        foreach (var (resId, taskId, taskName, hours) in assignments)
        {
            for (var day = start; day < rangeEnd; day = day.AddDays(1))
            {
                if (day.DayOfWeek == DayOfWeek.Saturday || day.DayOfWeek == DayOfWeek.Sunday)
                    continue;

                _dailyAllocations.Add(new AllocationRecord
                {
                    AllocationId = Guid.NewGuid(),
                    ResourceId   = resId,
                    TaskId       = taskId,
                    TaskName     = taskName,
                    BucketStart  = day,
                    BucketEnd    = day.AddDays(1),
                    Value        = hours,
                    Unit         = AllocationUnit.Hours
                });
            }
        }
    }

    private static List<AllocationRecord> BuildWeeklyAllocations(
        int resourceId, int taskId, string taskName,
        DateTime weekStart, decimal[] hoursPerWeek)
    {
        var result = new List<AllocationRecord>();
        for (int i = 0; i < hoursPerWeek.Length; i++)
        {
            if (hoursPerWeek[i] == 0m) continue;
            var s = weekStart.AddDays(7 * i);
            result.Add(new AllocationRecord
            {
                AllocationId = Guid.NewGuid(),
                ResourceId   = resourceId,
                TaskId       = taskId,
                TaskName     = taskName,
                BucketStart  = s,
                BucketEnd    = s.AddDays(7),
                Value        = hoursPerWeek[i],
                Unit         = AllocationUnit.Hours
            });
        }
        return result;
    }

    private Task HandleCustomMenuAction(ContextMenuActionArgs args)
    {
        _customMenuMessage = args.CommandName switch
        {
            "flag-review" => $"Flagged {args.TargetCells.Count} cell(s) for review",
            "copy-row"    => $"Copied row for resource {args.TargetCells.FirstOrDefault()?.ResourceKey}",
            _             => $"Command: {args.CommandName} on {args.TargetCells.Count} cell(s)"
        };
        return Task.CompletedTask;
    }

    private Task HandleCanExecute(CanExecuteActionArgs args)
    {
        if (args.CommandName == "copy-row")
        {
            var key      = args.TargetCells.FirstOrDefault()?.ResourceKey;
            var resource = _allResources.FirstOrDefault(r => Equals(r.Id, key));
            if (resource?.Role == "Project Manager")
                args.IsEnabled = false;
        }
        return Task.CompletedTask;
    }

    private async Task HandleSelectionChanged(SelectionChangedArgs args)
    {
        _selectedCount = args.SelectedCells?.Count ?? 0;
        await Task.CompletedTask;
    }

    private async Task HandleRangeEdited(RangeEditedArgs args)
    {
        _rangeEditMessage = $"{args.AffectedRecords.Count} cells updated to {args.Value}h";
        await Task.CompletedTask;
    }

    private async Task HandleCellEdited(CellEditedArgs args)
    {
        _cellEditMessage = $"Resource {args.ResourceKey}, {args.BucketStart:MMM d}: {args.OldValue}h -> {args.NewValue}h";
        await Task.CompletedTask;
    }

    public class StaffResource
