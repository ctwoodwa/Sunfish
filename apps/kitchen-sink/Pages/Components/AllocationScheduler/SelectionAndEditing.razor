        _allBasicAllocations.AddRange(BuildWeeklyAllocations(5,  102, "Frontend UI Build",           w, new[] { 40m, 40m, 36m, 40m, 32m, 40m, 40m, 36m }));
        _allBasicAllocations.AddRange(BuildWeeklyAllocations(6,  101, "Backend API Development",     w, new[] { 32m, 40m, 40m, 32m, 40m, 40m, 36m, 40m }));
