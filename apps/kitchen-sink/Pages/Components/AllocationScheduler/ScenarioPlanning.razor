@page "/components/allocation-scheduler/scenario-planning"
@layout ComponentDemoLayout
@using Sunfish.UIAdapters.Blazor.Components.DataDisplay
@using Sunfish.Foundation.Enums
@using Sunfish.Foundation.Models
@using Sunfish.Foundation.BusinessLogic.Enums

<PageSection Title="Baseline & Scenario Sets">
    <DemoSection Title="Baseline & Scenario Sets"
                 Description="Bind AllocationSets and ScenarioOverrides to display the scenario strip. Switch between sets using ActiveSetId."
                 Code="@_baselineCode">
        <div style="margin-bottom:1rem">
            <label>
                Active Set:
                <select @bind="_activeSetId">
                    @foreach (var set in _sets)
                    {
                        <option value="@set.SetId">@set.Name</option>
                    }
                </select>
            </label>
        </div>

        <SunfishAllocationScheduler TResource="StaffResource"
                                   Resources="@_resources"
                                   Allocations="@_baselineAllocations"
                                   AllocationSets="@_sets"
                                   ScenarioOverrides="@_overrides"
                                   ActiveSetId="@_activeSetId"
                                   ActiveSetIdChanged="@(id => _activeSetId = id)"
                                   AuthoritativeLevel="TimeGranularity.Week"
                                   ViewGrain="TimeGranularity.Week"
                                   ValueMode="AllocationValueMode.Hours"
                                   VisibleStart="@_demoStart"
                                   MinVisibleColumns="2"
                                   DefaultRangeUnit="TimeGranularity.Month"
                                   OnScenarioChanged="@HandleScenarioChanged"
                                   Height="280px">
            <AllocationResourceColumns>
                <AllocationResourceColumn TResource="StaffResource" Field="Name" Title="Resource" Width="180px" />
                <AllocationResourceColumn TResource="StaffResource" Field="Role" Title="Role" Width="120px" />
            </AllocationResourceColumns>
        </SunfishAllocationScheduler>

        @if (!string.IsNullOrEmpty(_scenarioMessage))
        {
            <p><strong>Scenario event:</strong> @_scenarioMessage</p>
        }
    </DemoSection>
</PageSection>

<PageSection Title="Baseline Diff">
    <DemoSection Title="Baseline Diff"
                 Description="Enable ShowBaselineDiff to highlight cells that differ from the baseline when viewing a scenario."
                 Code="@_diffCode">
        <div style="margin-bottom:1rem">
            <label>
                <input type="checkbox" @bind="_showBaselineDiff" />
                Show Baseline Diff
            </label>
        </div>

        <SunfishAllocationScheduler TResource="StaffResource"
                                   Resources="@_resources"
                                   Allocations="@_baselineAllocations"
                                   AllocationSets="@_sets"
                                   ScenarioOverrides="@_overrides"
                                   ActiveSetId="@_scenarioSetId"
                                   CompareSetId="@_baselineSetId"
                                   ShowBaselineDiff="@_showBaselineDiff"
                                   AuthoritativeLevel="TimeGranularity.Week"
                                   ViewGrain="TimeGranularity.Week"
                                   ValueMode="AllocationValueMode.Hours"
                                   VisibleStart="@_demoStart"
                                   MinVisibleColumns="2"
                                   DefaultRangeUnit="TimeGranularity.Month"
                                   Height="250px">
            <AllocationResourceColumns>
                <AllocationResourceColumn TResource="StaffResource" Field="Name" Title="Resource" Width="180px" />
            </AllocationResourceColumns>
        </SunfishAllocationScheduler>
    </DemoSection>
</PageSection>

<PageSection Title="Comparison Panel">
    <DemoSection Title="Comparison Panel"
                 Description="Enable ShowComparisonPanel for a side-by-side view of baseline and scenario allocations."
                 Code="@_comparisonCode">
        <div style="margin-bottom:1rem">
            <label>
                <input type="checkbox" @bind="_showComparisonPanel" />
                Show Comparison Panel
            </label>
        </div>

        <SunfishAllocationScheduler TResource="StaffResource"
                                   Resources="@_resources"
                                   Allocations="@_baselineAllocations"
                                   AllocationSets="@_sets"
                                   ScenarioOverrides="@_overrides"
                                   ActiveSetId="@_scenarioSetId"
                                   CompareSetId="@_baselineSetId"
                                   ShowComparisonPanel="@_showComparisonPanel"
                                   AuthoritativeLevel="TimeGranularity.Week"
                                   ViewGrain="TimeGranularity.Week"
                                   ValueMode="AllocationValueMode.Hours"
                                   VisibleStart="@_demoStart"
                                   MinVisibleColumns="2"
                                   DefaultRangeUnit="TimeGranularity.Month"
                                   OnScenarioCreated="@HandleScenarioCreated"
                                   Height="350px">
            <AllocationResourceColumns>
                <AllocationResourceColumn TResource="StaffResource" Field="Name" Title="Resource" Width="180px" />
                <AllocationResourceColumn TResource="StaffResource" Field="Role" Title="Role" Width="120px" />
            </AllocationResourceColumns>
        </SunfishAllocationScheduler>

        @if (!string.IsNullOrEmpty(_createdMessage))
        {
            <p><strong>Scenario created:</strong> @_createdMessage</p>
        }
    </DemoSection>
</PageSection>

@code {
    private DateTime _demoStart = new(2026, 4, 6);
    private bool _showBaselineDiff = true;
    private bool _showComparisonPanel;
    private string _scenarioMessage = string.Empty;
    private string _createdMessage = string.Empty;

    private static readonly Guid _baselineSetId = Guid.NewGuid();
    private static readonly Guid _scenarioSetId = Guid.NewGuid();
    private Guid _activeSetId = _baselineSetId;

    private List<StaffResource> _resources = new()
    {
        new() { Id = 1, Name = "Alice Chen",  Role = "Dev",     Department = "Engineering" },
        new() { Id = 2, Name = "Bob Torres",  Role = "Dev",     Department = "Engineering" },
        new() { Id = 3, Name = "Carol Singh", Role = "QA",      Department = "Engineering" }
    };

    private List<AllocationSet> _sets = new()
    {
        new()
        {
            SetId = _baselineSetId,
            Name = "Q2 Baseline",
            Type = AllocationSetType.Baseline,
            Status = ScenarioStatus.Approved,
            IsLocked = true,
            CreatedBy = "PM",
            CreatedDate = new(2026, 3, 1)
        },
        new()
        {
            SetId = _scenarioSetId,
            Name = "Scenario A — Hire 2 Devs",
            Type = AllocationSetType.Scenario,
            Status = ScenarioStatus.Draft,
            ParentBaselineId = _baselineSetId,
            CreatedBy = "PM",
            CreatedDate = new(2026, 4, 1)
        }
    };

    private List<AllocationRecord> _baselineAllocations = new()
    {
        new() { AllocationId = Guid.NewGuid(), ResourceId = 1, TaskId = 101, TaskName = "Backend API",  BucketStart = new(2026, 4, 6),  BucketEnd = new(2026, 4, 13), Value = 32, Unit = AllocationUnit.Hours },
        new() { AllocationId = Guid.NewGuid(), ResourceId = 1, TaskId = 101, TaskName = "Backend API",  BucketStart = new(2026, 4, 13), BucketEnd = new(2026, 4, 20), Value = 40, Unit = AllocationUnit.Hours },
        new() { AllocationId = Guid.NewGuid(), ResourceId = 2, TaskId = 102, TaskName = "Frontend UI",  BucketStart = new(2026, 4, 6),  BucketEnd = new(2026, 4, 13), Value = 24, Unit = AllocationUnit.Hours },
        new() { AllocationId = Guid.NewGuid(), ResourceId = 3, TaskId = 103, TaskName = "Test Suite",   BucketStart = new(2026, 4, 13), BucketEnd = new(2026, 4, 20), Value = 16, Unit = AllocationUnit.Hours }
    };

    private List<ScenarioOverride> _overrides = new()
    {
        new()
        {
            OverrideId = Guid.NewGuid(),
            SetId = _scenarioSetId,
            Override = new()
            {
                AllocationId = Guid.NewGuid(),
                ResourceId = 1,
                TaskId = 101,
                TaskName = "Backend API",
                BucketStart = new(2026, 4, 6),
                BucketEnd = new(2026, 4, 13),
                Value = 24,
                Unit = AllocationUnit.Hours
            },
            OverrideReason = "Reduced to 3 days — onboarding new hire"
        }
    };

    private async Task HandleScenarioChanged(ScenarioChangedArgs args)
    {
        _scenarioMessage = $"Switched from set {args.PreviousSetId} to {args.NewSetId}";
        await Task.CompletedTask;
    }

    private async Task HandleScenarioCreated(ScenarioCreatedArgs args)
    {
        _createdMessage = $"New scenario '{args.NewSet.Name}' created (status: {args.NewSet.Status})";
        await Task.CompletedTask;
    }

    public class StaffResource
    {
        public int    Id         { get; set; }
        public string Name       { get; set; } = string.Empty;
        public string Role       { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
    }

    private const string _baselineCode =
        "<SunfishAllocationScheduler TResource=\"StaffResource\"\n" +
        "                           Resources=\"@_resources\"\n" +
        "                           Allocations=\"@_allocations\"\n" +
        "                           AllocationSets=\"@_sets\"\n" +
        "                           ScenarioOverrides=\"@_overrides\"\n" +
        "                           ActiveSetId=\"@_activeSetId\"\n" +
        "                           ActiveSetIdChanged=\"@(id => _activeSetId = id)\"\n" +
        "                           OnScenarioChanged=\"@HandleScenarioChanged\"\n" +
        "                           Height=\"280px\" />";

    private const string _diffCode =
        "<SunfishAllocationScheduler TResource=\"StaffResource\"\n" +
        "                           Resources=\"@_resources\"\n" +
        "                           Allocations=\"@_allocations\"\n" +
        "                           AllocationSets=\"@_sets\"\n" +
        "                           ScenarioOverrides=\"@_overrides\"\n" +
        "                           ActiveSetId=\"@_scenarioSetId\"\n" +
        "                           CompareSetId=\"@_baselineSetId\"\n" +
        "                           ShowBaselineDiff=\"@_showBaselineDiff\"\n" +
        "                           Height=\"250px\" />";

    private const string _comparisonCode =
        "<SunfishAllocationScheduler TResource=\"StaffResource\"\n" +
        "                           Resources=\"@_resources\"\n" +
        "                           Allocations=\"@_allocations\"\n" +
        "                           AllocationSets=\"@_sets\"\n" +
        "                           ScenarioOverrides=\"@_overrides\"\n" +
        "                           ShowComparisonPanel=\"@_showComparisonPanel\"\n" +
        "                           OnScenarioCreated=\"@HandleScenarioCreated\"\n" +
        "                           Height=\"350px\" />";
}
