    // ── Helper ───────────────────────────────────────────────────────────

    private static List<AllocationRecord> BuildWeeklyAllocations(
        int resourceId, int taskId, string taskName,
        DateTime weekStart, decimal[] hoursPerWeek)
    {
        var result = new List<AllocationRecord>();
        for (int i = 0; i < hoursPerWeek.Length; i++)
        {
            if (hoursPerWeek[i] == 0m) continue;
            var start = weekStart.AddDays(7 * i);
            result.Add(new AllocationRecord
            {
                AllocationId = Guid.NewGuid(),
                ResourceId   = resourceId,
                TaskId       = taskId,
                TaskName     = taskName,
                BucketStart  = start,
                BucketEnd    = start.AddDays(7),
                Value        = hoursPerWeek[i],
                Unit         = AllocationUnit.Hours
            });
        }
        return result;
    }

    // ── Event Handlers: Section 3 ────────────────────────────────────────

    private Task HandleCellEdited(CellEditedArgs args)
    {
        _lastEditMessage = $"Resource {args.ResourceKey}, {args.BucketStart:MMM d}–{args.BucketEnd:MMM d}: {args.OldValue}h → {args.NewValue}h";

        var record = _editableAllocations.FirstOrDefault(r =>
            Equals(r.ResourceId, args.ResourceKey) && r.BucketStart == args.BucketStart);

        if (record is not null)
            record.Value = args.NewValue;
        else
            _editableAllocations.Add(new AllocationRecord
            {
                AllocationId = Guid.NewGuid(),
                ResourceId   = args.ResourceKey,
                TaskId       = args.TaskId,
                BucketStart  = args.BucketStart,
                BucketEnd    = args.BucketEnd,
                Value        = args.NewValue,
                Unit         = AllocationUnit.Hours
            });

        return Task.CompletedTask;
    }

    private Task HandleRangeEdited(RangeEditedArgs args)
    {
        _lastEditMessage = $"Bulk update: {args.AffectedRecords.Count} cell(s) → {args.Value}h each";
        foreach (var r in args.AffectedRecords)
            r.Value = args.Value;
        return Task.CompletedTask;
    }

    // ── Event Handlers: Section 6 ────────────────────────────────────────

    private Task HandleTargetChanged(TargetChangedArgs args)
    {
        _targetMessage = $"Resource {args.ResourceKey}: target set to {args.TargetValue}h";
        return Task.CompletedTask;
    }

    // ── Event Handlers: Section 2 ────────────────────────────────────────

    private Task HandleRollupRangeChanged(VisibleRangeChangedArgs args)
    {
        _rollupRangeLabel = $"{args.NewStart:MMM d} — {args.NewEnd:MMM d, yyyy} ({args.ViewGrain})";
        return Task.CompletedTask;
    }

    // ── Event Handlers: Section 7 — Splitter ─────────────────────────────

    private void HandleSplitterPosChanged(double v)
    {
        _splitterPos      = v;
        _lastSplitterEvent = $"Moved to {v:F0}px";
    }

    private void HandleSplitterCollapsed(SplitterSide side) =>
        _lastSplitterEvent = $"Collapsed: {side}";

    private void HandleSplitterRestored(double pos)
    {
        _splitterPos       = pos;
        _lastSplitterEvent = $"Restored to {pos:F0}px";
    }

    private async Task SetSplitterNarrow()   => await (_splitterScheduler?.SetSplitterPosition(200) ?? Task.CompletedTask);
    private async Task SetSplitterDefault()  => await (_splitterScheduler?.SetSplitterPosition(300) ?? Task.CompletedTask);
    private async Task SetSplitterWide()     => await (_splitterScheduler?.SetSplitterPosition(500) ?? Task.CompletedTask);
    private async Task CollapseSplitterLeft()  => await (_splitterScheduler?.CollapseSplitter(SplitterSide.Left) ?? Task.CompletedTask);
    private async Task RestoreSplitterPane() => await (_splitterScheduler?.RestoreSplitter() ?? Task.CompletedTask);

    // ── Event Handlers: Section 8 — Navigation ───────────────────────────

    private Task HandleNavRangeChanged(VisibleRangeChangedArgs args)
    {
        _navRangeLabel = $"{args.NewStart:MMM d} — {args.NewEnd:MMM d, yyyy}";
        return Task.CompletedTask;
    }

    private async Task JumpToDate() => await (_navScheduler?.NavigateTo(_navDate)     ?? Task.CompletedTask);
    private async Task NavBack()    => await (_navScheduler?.NavigateBack()            ?? Task.CompletedTask);
    private async Task NavToday()   => await (_navScheduler?.NavigateToToday()         ?? Task.CompletedTask);
    private async Task NavForward() => await (_navScheduler?.NavigateForward()         ?? Task.CompletedTask);

