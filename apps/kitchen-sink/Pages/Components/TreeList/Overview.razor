@page "/components/treelist"
@page "/components/treelist/overview"
@layout ComponentDemoLayout
@using Sunfish.UIAdapters.Blazor.Components.DataDisplay
@using Sunfish.Foundation.Enums
@using Sunfish.Foundation.Models

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="TreeList displays hierarchical data in a grid-like format with expand/collapse and column definitions.">
        <SunfishTreeList TItem="Employee" Data="@_basicData" IdField="Id" ParentIdField="ParentId" Sortable="true">
            <SunfishTreeListColumn Field="Name" Title="Name" />
            <SunfishTreeListColumn Field="Department" Title="Department" />
            <SunfishTreeListColumn Field="Position" Title="Position" />
        </SunfishTreeList>
    </DemoSection>

    <DemoSection Title="Virtualization (Large Dataset)" Description="EnableVirtualization uses Blazor's built-in Virtualize component for efficient rendering of large datasets. This example renders 5,000 rows.">
        <div style="height:400px; overflow:auto;">
            <SunfishTreeList TItem="Employee" Data="@_largeData" EnableVirtualization="true" ItemHeight="36">
                <SunfishTreeListColumn Field="Name" Title="Name" />
                <SunfishTreeListColumn Field="Department" Title="Department" />
                <SunfishTreeListColumn Field="Position" Title="Position" />
            </SunfishTreeList>
        </div>
    </DemoSection>

    <DemoSection Title="Row Drag and Drop" Description="Set RowDraggable to true and handle OnRowDropped to reorder rows via drag and drop.">
        <SunfishTreeList TItem="Employee" Data="@_dragData" RowDraggable="true" OnRowDropped="HandleRowDrop">
            <SunfishTreeListColumn Field="Name" Title="Name" />
            <SunfishTreeListColumn Field="Department" Title="Department" />
        </SunfishTreeList>
        @if (_lastDrop is not null)
        {
            <p class="mt-2"><strong>Last drop:</strong> @_lastDrop</p>
        }
    </DemoSection>

    <DemoSection Title="Keyboard Navigation" Description="Set Navigable to true. Use Arrow keys to move, ArrowRight to expand, ArrowLeft to collapse, Enter to select, Home/End to jump.">
        <SunfishTreeList TItem="Employee" Data="@_basicData" IdField="Id" ParentIdField="ParentId" Navigable="true"
                        SelectionMode="TreeListSelectionMode.Single">
            <SunfishTreeListColumn Field="Name" Title="Name" />
            <SunfishTreeListColumn Field="Department" Title="Department" />
        </SunfishTreeList>
    </DemoSection>

    <DemoSection Title="Server-Side Data (OnRead)" Description="Delegate sorting, filtering, and paging to the server via OnRead. The component sends current state and expects the consumer to set Data and Total.">
        <SunfishTreeList TItem="Employee" Pageable="true" PageSize="5" Sortable="true"
                        FilterMode="TreeListFilterMode.FilterRow"
                        OnRead="HandleOnRead">
            <SunfishTreeListColumn Field="Name" Title="Name" />
            <SunfishTreeListColumn Field="Department" Title="Department" />
            <SunfishTreeListColumn Field="Position" Title="Position" />
        </SunfishTreeList>
    </DemoSection>
</PageSection>

@code {
    private record Employee
    {
        public string Id { get; init; } = "";
        public string? ParentId { get; init; }
        public string Name { get; init; } = "";
        public string Department { get; init; } = "";
        public string Position { get; init; } = "";
    }

    private List<Employee> _basicData = [];
    private List<Employee> _largeData = [];
    private List<Employee> _dragData = [];
    private List<Employee> _serverData = [];
    private string? _lastDrop;

    protected override void OnInitialized()
    {
        _basicData =
        [
            new() { Id = "1", Name = "Alice", Department = "Engineering", Position = "Director" },
            new() { Id = "2", ParentId = "1", Name = "Bob", Department = "Engineering", Position = "Lead" },
            new() { Id = "3", ParentId = "1", Name = "Carol", Department = "Engineering", Position = "Dev" },
            new() { Id = "4", Name = "Dave", Department = "Marketing", Position = "Director" },
            new() { Id = "5", ParentId = "4", Name = "Eve", Department = "Marketing", Position = "Analyst" },
        ];

        _largeData = Enumerable.Range(1, 5000)
            .Select(i => new Employee { Id = i.ToString(), Name = $"Employee {i}", Department = $"Dept {(i % 10) + 1}", Position = i % 5 == 0 ? "Manager" : "Staff" })
            .ToList();

        _dragData =
        [
            new() { Id = "d1", Name = "Task A", Department = "Backend" },
            new() { Id = "d2", Name = "Task B", Department = "Frontend" },
            new() { Id = "d3", Name = "Task C", Department = "DevOps" },
            new() { Id = "d4", Name = "Task D", Department = "QA" },
        ];

        _serverData = Enumerable.Range(1, 50)
            .Select(i => new Employee { Id = i.ToString(), Name = $"Server Employee {i}", Department = $"Dept {(i % 5) + 1}", Position = i % 3 == 0 ? "Lead" : "Engineer" })
            .ToList();
    }

    private void HandleRowDrop(TreeListRowDropEventArgs<Employee> args)
    {
        _lastDrop = $"Moved \"{args.Item.Name}\" {args.DropPosition.ToString().ToLower()} \"{args.DestinationItem?.Name}\" (index {args.DestinationIndex})";
    }

    private void HandleOnRead(TreeListReadEventArgs<Employee> args)
    {
        var query = _serverData.AsEnumerable();

        // Apply filters
        foreach (var kv in args.FilterValues.Where(f => !string.IsNullOrEmpty(f.Value)))
        {
            var field = kv.Key;
            var value = kv.Value;
            query = query.Where(e =>
            {
                var prop = typeof(Employee).GetProperty(field);
                var v = prop?.GetValue(e)?.ToString() ?? "";
                return v.Contains(value, StringComparison.OrdinalIgnoreCase);
            });
        }

        // Apply sort
        if (!string.IsNullOrEmpty(args.SortField))
        {
            var prop = typeof(Employee).GetProperty(args.SortField);
            if (prop is not null)
            {
                query = args.SortDirection == SortDirection.Descending
                    ? query.OrderByDescending(e => prop.GetValue(e))
                    : query.OrderBy(e => prop.GetValue(e));
            }
        }

        var total = query.Count();
        var paged = query.Skip((args.Page - 1) * args.PageSize).Take(args.PageSize);

        args.Data = paged;
        args.Total = total;
    }
}
