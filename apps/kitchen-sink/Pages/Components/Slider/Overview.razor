@page "/components/Slider"
@page "/components/Slider/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Code="@_basicCode">
        <SunfishField>
            <SunfishLabel>Volume: @_sliderValue</SunfishLabel>
            <SunfishSlider @bind-Value="_sliderValue" Min="0" Max="100" Step="5" />
        </SunfishField>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Vertical Orientation" Description="Set Orientation to Vertical to render the slider along the vertical axis." Code="@_verticalCode">
        <div style="display:flex;gap:32px;align-items:flex-end;height:200px;">
            <SunfishSlider @bind-Value="_verticalA" Min="0" Max="100" Step="10"
                          Orientation="SliderOrientation.Vertical" />
            <SunfishSlider @bind-Value="_verticalB" Min="0" Max="100" Step="10"
                          Orientation="SliderOrientation.Vertical" />
            <SunfishSlider @bind-Value="_verticalC" Min="0" Max="100" Step="10"
                          Orientation="SliderOrientation.Vertical" />
        </div>
        <p style="margin-top:8px;">Values: @_verticalA, @_verticalB, @_verticalC</p>
    </DemoSection>

    <DemoSection Title="Step Buttons" Description="Set ShowButtons to display increment/decrement buttons on either side of the slider." Code="@_buttonsCode">
        <SunfishField>
            <SunfishLabel>Quantity: @_quantityValue</SunfishLabel>
            <SunfishSlider @bind-Value="_quantityValue" Min="0" Max="20" Step="1" ShowButtons="true" />
        </SunfishField>
    </DemoSection>

    <DemoSection Title="Large Step" Description="LargeStep controls how many units the slider jumps when Page Up / Page Down is pressed." Code="@_largeStepCode">
        <SunfishField>
            <SunfishLabel>Year: @((int)_yearValue)</SunfishLabel>
            <SunfishSlider @bind-Value="_yearValue" Min="2000" Max="2030" Step="1" LargeStep="5" />
        </SunfishField>
        <p style="font-size:0.875em;">Press Page Up / Page Down to jump 5 years at a time.</p>
    </DemoSection>

    <DemoSection Title="Label Template" Description="LabelTemplate customises how tick labels are rendered along the slider track." Code="@_labelTemplateCode">
        <SunfishField>
            <SunfishSlider @bind-Value="_priceValue" Min="0" Max="500" Step="100">
                <LabelTemplate Context="val">
                    $@((int)val)
                </LabelTemplate>
            </SunfishSlider>
        </SunfishField>
        <p><strong>Price:</strong> $@((int)_priceValue)</p>
    </DemoSection>

    <DemoSection Title="Disabled" Description="A disabled slider prevents user interaction." Code="@_disabledCode">
        <SunfishField>
            <SunfishLabel>Volume</SunfishLabel>
            <SunfishSlider Value="50" Enabled="false" Min="0" Max="100" Step="5" />
        </SunfishField>
    </DemoSection>
</PageSection>

<PageSection Title="Events">
    <DemoSection Title="ValueChanged" Description="Handle slider changes with the ValueChanged callback or use two-way binding." Code="@_interactiveCode">
        <SunfishField>
            <SunfishLabel>Value: @_evSliderValue</SunfishLabel>
            <SunfishSlider Value="@_evSliderValue" ValueChanged="@(v => _evSliderValue = v)" Min="0" Max="100" Step="5" />
        </SunfishField>
        <p><strong>Slider value:</strong> @_evSliderValue</p>
    </DemoSection>
</PageSection>

<PageSection Title="Accessibility">
    <AccessibilityInfo
        KeyboardInteractions="@_keyboard"
        AriaAttributes="@_aria"
        ScreenReaderNotes="@_screenReader" />
</PageSection>

@code {
    private double _sliderValue = 50;
    private double _verticalA = 60;
    private double _verticalB = 40;
    private double _verticalC = 80;
    private double _quantityValue = 5;
    private double _yearValue = 2024;
    private double _priceValue = 200;
    private double _evSliderValue = 50;

    private const string _basicCode =
        "<SunfishSlider @bind-Value=\"_value\" Min=\"0\" Max=\"100\" Step=\"5\" />\n\n" +
        "@code { private double _value = 50; }";

    private const string _verticalCode =
        "<SunfishSlider @bind-Value=\"_value\" Min=\"0\" Max=\"100\" Step=\"10\"\n" +
        "              Orientation=\"SliderOrientation.Vertical\" />";

    private const string _buttonsCode =
        "<SunfishSlider @bind-Value=\"_quantity\" Min=\"0\" Max=\"20\" Step=\"1\" ShowButtons=\"true\" />";

    private const string _largeStepCode =
        "<SunfishSlider @bind-Value=\"_year\" Min=\"2000\" Max=\"2030\" Step=\"1\" LargeStep=\"5\" />";

    private const string _labelTemplateCode =
        "<SunfishSlider @bind-Value=\"_price\" Min=\"0\" Max=\"500\" Step=\"100\">\n" +
        "    <LabelTemplate Context=\"val\">\n" +
        "        $@((int)val)\n" +
        "    </LabelTemplate>\n" +
        "</SunfishSlider>";

    private const string _disabledCode =
        "<SunfishSlider Value=\"50\" Enabled=\"false\" Min=\"0\" Max=\"100\" Step=\"5\" />";

    private const string _interactiveCode =
        "<SunfishSlider Value=\"@_value\" ValueChanged=\"@(v => _value = v)\" Min=\"0\" Max=\"100\" Step=\"5\" />\n" +
        "<p><strong>Slider value:</strong> @_value</p>\n\n" +
        "@code {\n" +
        "    private double _value = 50;\n" +
        "}";

    private static readonly (string Key, string Action)[] _keyboard =
    [
        ("Tab", "Moves focus to the slider thumb"),
        ("Shift + Tab", "Moves focus to the previous focusable element"),
        ("Arrow Right / Arrow Up", "Increases the slider value by one step"),
        ("Arrow Left / Arrow Down", "Decreases the slider value by one step"),
        ("Page Up", "Increases the slider value by LargeStep"),
        ("Page Down", "Decreases the slider value by LargeStep"),
        ("Home", "Sets the slider to its minimum value"),
        ("End", "Sets the slider to its maximum value"),
    ];

    private static readonly (string Attribute, string Description)[] _aria =
    [
        ("role=\"slider\"", "Implicitly set by the <input type=\"range\"> element"),
        ("aria-valuenow", "Reflects the current value of the slider"),
        ("aria-valuemin", "Reflects the minimum value of the slider"),
        ("aria-valuemax", "Reflects the maximum value of the slider"),
        ("aria-disabled=\"true\"", "Applied when Enabled is false"),
        ("aria-label", "Can be set to provide an accessible name when no visible label is present"),
        ("aria-orientation", "Set to \"vertical\" when Orientation is SliderOrientation.Vertical"),
    ];

    private static readonly string[] _screenReader =
    [
        "Sliders are announced with their label, current value, range, and the \"slider\" role.",
        "Value changes are announced as the user adjusts the slider with arrow keys.",
        "Disabled sliders are announced as \"dimmed\" or \"unavailable\" depending on the screen reader.",
    ];
}
