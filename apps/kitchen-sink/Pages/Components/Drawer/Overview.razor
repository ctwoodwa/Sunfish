@page "/components/Drawer"
@page "/components/Drawer/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Code="@_basicCode">
        <SunfishButton OnClick="@(() => _drawerOpen = true)">Open Drawer</SunfishButton>
        <SunfishDrawer @bind-Expanded="_drawerOpen" Position="DrawerPosition.Right" Width="360px">
            <h3>Drawer Content</h3>
            <p>This is supplementary content displayed inside the drawer panel.</p>
            <SunfishButton OnClick="@(() => _drawerOpen = false)">Close</SunfishButton>
        </SunfishDrawer>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="All Positions" Description="Drawers can slide in from any edge of the viewport." Code="@_positionCode">
        <div class="demo-row">
            <SunfishButton OnClick="@(() => OpenPositionDrawer(DrawerPosition.Left))">Left</SunfishButton>
            <SunfishButton OnClick="@(() => OpenPositionDrawer(DrawerPosition.Right))">Right</SunfishButton>
            <SunfishButton OnClick="@(() => OpenPositionDrawer(DrawerPosition.Top))">Top</SunfishButton>
            <SunfishButton OnClick="@(() => OpenPositionDrawer(DrawerPosition.Bottom))">Bottom</SunfishButton>
        </div>
        <SunfishDrawer @bind-Expanded="_posDrawerOpen" Position="@_drawerPosition" Width="300px">
            <h3>@_drawerPosition Drawer</h3>
            <p>This drawer slides in from the @_drawerPosition.ToString().ToLower().</p>
            <SunfishButton OnClick="@(() => _posDrawerOpen = false)">Close</SunfishButton>
        </SunfishDrawer>
    </DemoSection>

    <DemoSection Title="Push Mode" Description="In Push mode the drawer shifts the adjacent page content aside instead of overlaying it." Code="@_pushCode">
        <div style="display:flex;overflow:hidden;border:1px solid var(--mar-border);border-radius:4px;min-height:160px;">
            <SunfishDrawer @bind-Expanded="_pushDrawerOpen" Position="DrawerPosition.Left" Mode="DrawerMode.Push" Width="200px">
                <ChildContent>
                <div style="padding:12px;">
                    <strong>Sidebar</strong>
                    <p style="font-size:0.85em;">Push mode shifts the main content to the right.</p>
                    <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _pushDrawerOpen = false)">Close</SunfishButton>
                </div>
                </ChildContent>
                <DrawerContent>
                    <div style="padding:12px;flex:1;">
                        <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _pushDrawerOpen = !_pushDrawerOpen)">
                            @(_pushDrawerOpen ? "Close Sidebar" : "Open Sidebar")
                        </SunfishButton>
                        <p style="margin-top:8px;">Main page content is pushed when the drawer opens.</p>
                    </div>
                </DrawerContent>
            </SunfishDrawer>
        </div>
    </DemoSection>

    <DemoSection Title="Mini Mode" Description="MiniMode keeps a narrow icon-strip visible when collapsed, expanding to full width when opened." Code="@_miniCode">
        <div style="display:flex;overflow:hidden;border:1px solid var(--mar-border);border-radius:4px;min-height:160px;">
            <SunfishDrawer @bind-Expanded="_miniDrawerOpen" Position="DrawerPosition.Left"
                          Mode="DrawerMode.Push" MiniMode="true" MiniWidth="48px" Width="180px">
                <ChildContent>
                <div style="padding:8px;">
                    @if (_miniDrawerOpen)
                    {
                        <strong>Navigation</strong>
                        <ul style="list-style:none;padding:0;margin-top:8px;">
                            <li>🏠 Home</li>
                            <li>📊 Reports</li>
                            <li>⚙️ Settings</li>
                        </ul>
                        <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _miniDrawerOpen = false)">Collapse</SunfishButton>
                    }
                    else
                    {
                        <div style="display:flex;flex-direction:column;gap:8px;align-items:center;">
                            <span>🏠</span>
                            <span>📊</span>
                            <span>⚙️</span>
                        </div>
                    }
                </div>
                </ChildContent>
                <DrawerContent>
                    <div style="padding:12px;flex:1;">
                        <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _miniDrawerOpen = !_miniDrawerOpen)">
                            @(_miniDrawerOpen ? "Collapse" : "Expand")
                        </SunfishButton>
                        <p style="margin-top:8px;">Content area adjusts to the drawer width.</p>
                    </div>
                </DrawerContent>
            </SunfishDrawer>
        </div>
    </DemoSection>

    <DemoSection Title="Data Binding" Description="Provide a Data collection and use TextField/UrlField/IconField to auto-render navigation items." Code="@_dataCode">
        <SunfishButton OnClick="@(() => _dataDrawerOpen = true)">Open Data Drawer</SunfishButton>
        <SunfishDrawer @bind-Expanded="_dataDrawerOpen" Position="DrawerPosition.Left" Width="220px"
                      Data="@_navItems" TextField="Label" UrlField="Url" IconField="Icon"
                      @bind-SelectedItem="_selectedNavItem">
        </SunfishDrawer>
        @if (_selectedNavItem is NavItem nav)
        {
            <p style="margin-top:8px;">Selected: <strong>@nav.Label</strong></p>
        }
    </DemoSection>

    <DemoSection Title="Item Template" Description="Use ItemTemplate to customise how each data-bound item is rendered." Code="@_itemTemplateCode">
        <SunfishButton OnClick="@(() => _templateDrawerOpen = true)">Open Templated Drawer</SunfishButton>
        <SunfishDrawer @bind-Expanded="_templateDrawerOpen" Position="DrawerPosition.Right" Width="240px"
                      Data="@_navItems">
            <ItemTemplate Context="item">
                @{
                    var nav = (NavItem)item;
                }
                <div style="display:flex;align-items:center;gap:8px;padding:6px 12px;">
                    <span>@nav.Icon</span>
                    <span>@nav.Label</span>
                </div>
            </ItemTemplate>
        </SunfishDrawer>
    </DemoSection>

    <DemoSection Title="Custom Width" Description="Set a custom Width for the drawer panel." Code="@_widthCode">
        <SunfishButton OnClick="@(() => _wideDrawerOpen = true)">Open Wide Drawer (500px)</SunfishButton>
        <SunfishDrawer @bind-Expanded="_wideDrawerOpen" Position="DrawerPosition.Right" Width="500px">
            <h3>Wide Drawer</h3>
            <p>This drawer has a custom width of 500px.</p>
            <SunfishButton OnClick="@(() => _wideDrawerOpen = false)">Close</SunfishButton>
        </SunfishDrawer>
    </DemoSection>
</PageSection>

<PageSection Title="Events">
    <DemoSection Title="OnClose" Description="Handle drawer close events with the OnClose callback." Code="@_eventCode">
        <SunfishButton OnClick="@(() => _evDrawerOpen = true)">Open Drawer</SunfishButton>
        <SunfishDrawer @bind-Expanded="_evDrawerOpen" OnClose="@OnDrawerClose" Position="DrawerPosition.Right" Width="360px">
            <h3>Event Drawer</h3>
            <p>Close this drawer to see the OnClose callback fire.</p>
            <SunfishButton OnClick="@(() => _evDrawerOpen = false)">Close</SunfishButton>
        </SunfishDrawer>
        @if (!string.IsNullOrEmpty(_closeLog))
        {
            <p style="margin-top:8px;">@_closeLog</p>
        }
    </DemoSection>
</PageSection>

<PageSection Title="Accessibility">
    <AccessibilityInfo
        KeyboardInteractions="@_keyboard"
        AriaAttributes="@_aria"
        ScreenReaderNotes="@_screenReader" />
</PageSection>

@code {
    private record NavItem(string Label, string Url, string Icon);

    private NavItem[] _navItems =
    [
        new("Home", "/", "🏠"),
        new("Reports", "/reports", "📊"),
        new("Settings", "/settings", "⚙️"),
    ];

    private bool _drawerOpen;
    private bool _posDrawerOpen;
    private DrawerPosition _drawerPosition = DrawerPosition.Right;
    private bool _pushDrawerOpen;
    private bool _miniDrawerOpen;
    private bool _dataDrawerOpen;
    private object? _selectedNavItem;
    private bool _templateDrawerOpen;
    private bool _wideDrawerOpen;
    private bool _evDrawerOpen;
    private string? _closeLog;

    private void OpenPositionDrawer(DrawerPosition position)
    {
        _drawerPosition = position;
        _posDrawerOpen = true;
    }

    private void OnDrawerClose()
    {
        _evDrawerOpen = false;
        _closeLog = $"OnClose fired at {DateTime.Now:HH:mm:ss}";
    }

    private const string _basicCode =
        "<SunfishButton OnClick=\"@(() => _drawerOpen = true)\">Open Drawer</SunfishButton>\n" +
        "<SunfishDrawer @bind-Expanded=\"_drawerOpen\" Position=\"DrawerPosition.Right\" Width=\"360px\">\n" +
        "    <h3>Drawer Content</h3>\n" +
        "    <SunfishButton OnClick=\"@(() => _drawerOpen = false)\">Close</SunfishButton>\n" +
        "</SunfishDrawer>\n\n" +
        "@code { private bool _drawerOpen; }";

    private const string _positionCode =
        "<SunfishDrawer @bind-Expanded=\"_open\" Position=\"DrawerPosition.Left\" Width=\"300px\">\n" +
        "    ...\n" +
        "</SunfishDrawer>\n\n" +
        "<!-- Also: DrawerPosition.Right, DrawerPosition.Top, DrawerPosition.Bottom -->";

    private const string _pushCode =
        "<SunfishDrawer @bind-Expanded=\"_open\" Position=\"DrawerPosition.Left\"\n" +
        "              Mode=\"DrawerMode.Push\" Width=\"200px\">\n" +
        "    <div>Sidebar content</div>\n" +
        "    <DrawerContent>\n" +
        "        <div>Main page content is pushed aside.</div>\n" +
        "    </DrawerContent>\n" +
        "</SunfishDrawer>";

    private const string _miniCode =
        "<SunfishDrawer @bind-Expanded=\"_open\" Position=\"DrawerPosition.Left\"\n" +
        "              Mode=\"DrawerMode.Push\" MiniMode=\"true\" MiniWidth=\"48px\" Width=\"180px\">\n" +
        "    <!-- icons when collapsed, full nav when expanded -->\n" +
        "    <DrawerContent>\n" +
        "        <div>Main content</div>\n" +
        "    </DrawerContent>\n" +
        "</SunfishDrawer>";

    private const string _dataCode =
        "<SunfishDrawer @bind-Expanded=\"_open\" Data=\"@_navItems\"\n" +
        "              TextField=\"Label\" UrlField=\"Url\" IconField=\"Icon\"\n" +
        "              @bind-SelectedItem=\"_selectedItem\">\n" +
        "</SunfishDrawer>";

    private const string _itemTemplateCode =
        "<SunfishDrawer @bind-Expanded=\"_open\" Data=\"@_navItems\">\n" +
        "    <ItemTemplate Context=\"item\">\n" +
        "        <div>@((NavItem)item).Icon  @((NavItem)item).Label</div>\n" +
        "    </ItemTemplate>\n" +
        "</SunfishDrawer>";

    private const string _widthCode =
        "<SunfishDrawer @bind-Expanded=\"_open\" Position=\"DrawerPosition.Right\" Width=\"500px\">\n" +
        "    ...\n" +
        "</SunfishDrawer>";

    private const string _eventCode =
        "<SunfishDrawer @bind-Expanded=\"_drawerOpen\" OnClose=\"@OnDrawerClose\" Position=\"DrawerPosition.Right\">\n" +
        "    ...\n" +
        "</SunfishDrawer>\n\n" +
        "@code {\n" +
        "    private bool _drawerOpen;\n" +
        "    private void OnDrawerClose() => _drawerOpen = false;\n" +
        "}";

    private static readonly (string Key, string Action)[] _keyboard =
    [
        ("Escape", "Closes the drawer"),
        ("Tab", "Moves focus through interactive elements within the drawer (focus is trapped)"),
        ("Shift + Tab", "Moves focus to the previous interactive element within the drawer"),
    ];

    private static readonly (string Attribute, string Description)[] _aria =
    [
        ("role=\"dialog\"", "Applied when the drawer overlays content and requires user interaction"),
        ("role=\"complementary\"", "Applied when the drawer provides supplementary content alongside the main content"),
        ("aria-modal=\"true\"", "Indicates that the drawer traps focus and blocks interaction with the page behind it"),
        ("aria-label", "Provides an accessible name for the drawer"),
        ("aria-hidden=\"true\"", "Applied to the drawer when it is closed to hide it from screen readers"),
    ];

    private static readonly string[] _screenReader =
    [
        "When opened, the drawer is announced as a dialog or complementary region depending on its role.",
        "Focus is trapped within the drawer when aria-modal is true, preventing interaction with background content.",
        "Pressing Escape closes the drawer and returns focus to the element that triggered it.",
    ];
}
