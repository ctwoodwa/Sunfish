@page "/components/forms/switch/accessibility"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Switch / Accessibility · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Switch / Accessibility"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/Switch/Accessibility/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishSwitch</code> renders an <code>&lt;input type="checkbox" role="switch"&gt;</code>,
            which is the ARIA-recommended construction for a two-state toggle. Screen readers announce
            the control as "switch, on" or "switch, off". <kbd>Space</kbd> toggles, <kbd>Tab</kbd>
            moves focus, and the <code>disabled</code> attribute removes it from the tab order.
        </p>
        <p>
            For a switch that represents a <em>required</em> or <em>invalid</em> preference, pass
            <code>aria-describedby</code> via <code>AdditionalAttributes</code> to reference a visible
            hint or error.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.5rem; max-width:560px;">

            <section>
                <h3 style="margin:0 0 .5rem;">Keyboard reference</h3>
                <table style="border-collapse:collapse; width:100%;">
                    <thead>
                        <tr>
                            <th style="text-align:left; padding:.4rem .6rem; border-bottom:1px solid var(--sf-color-border, #ddd);">Key</th>
                            <th style="text-align:left; padding:.4rem .6rem; border-bottom:1px solid var(--sf-color-border, #ddd);">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (keys, action) in _shortcuts)
                        {
                            <tr>
                                <td style="padding:.4rem .6rem; border-bottom:1px solid var(--sf-color-border, #eee);">@((MarkupString)keys)</td>
                                <td style="padding:.4rem .6rem; border-bottom:1px solid var(--sf-color-border, #eee);">@action</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem;">Announced as a switch</h3>
                <p style="margin:0 0 .5rem; color:#666; font-size:.85rem;">
                    The underlying input carries <code>role="switch"</code>; screen readers say
                    "switch, off/on".
                </p>
                <SunfishSwitch @bind-Value="_dark" OnLabel="Dark theme on" OffLabel="Dark theme off" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem;">Label association via aria-labelledby</h3>
                <SunfishLabel Id="airplane-label">Airplane mode</SunfishLabel>
                <SunfishSwitch @bind-Value="_airplane" aria-labelledby="airplane-label" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem;">With describedby hint</h3>
                <SunfishSwitch @bind-Value="_telemetry"
                               Label="Share anonymous telemetry"
                               aria-describedby="telemetry-hint" />
                <span id="telemetry-hint" style="display:block; margin-top:.35rem; color:#555; font-size:.85rem;">
                    Helps us prioritise bug fixes. You can change this any time.
                </span>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem;">Disabled is announced</h3>
                <SunfishSwitch Value="true" Enabled="false" Label="Admin override (locked)" />
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Forms", "Switch", "Accessibility"];

    private bool _dark;
    private bool _airplane;
    private bool _telemetry = true;

    private static readonly (string Keys, string Action)[] _shortcuts =
    [
        ("<kbd>Tab</kbd>",                "Move focus to / out of the switch"),
        ("<kbd>Shift</kbd>+<kbd>Tab</kbd>", "Move focus backward"),
        ("<kbd>Space</kbd>",              "Toggle the switch state"),
    ];
}
