@page "/components/editors/switch/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Switch / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Switch / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/Switch/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishSwitch</code> is a two-state toggle for on/off preferences. Two-way bind its state
            with <code>@@bind-Value</code>, set a <code>Label</code> for the accompanying text, and use
            <code>OnLabel</code> / <code>OffLabel</code> to show contextual text next to the thumb.
        </p>
        <p>
            See <a href="/components/editors/switch/events">events</a> and
            <a href="/components/editors/switch/validation">validation</a>.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:0.75rem;">
            <SunfishField>
                <SunfishSwitch @bind-Value="_switchOn" Label="Enable notifications" />
            </SunfishField>
            <p>Switch is on: <strong>@_switchOn</strong></p>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Editors", "Switch", "Overview"];

    private bool _switchOn;
}
