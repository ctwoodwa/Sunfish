@page "/components/forms/colorpicker/events"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>ColorPicker / Events · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="ColorPicker / Events"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/ColorPicker/Events/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishColorPicker</code> exposes four callbacks covering the full popup
            life-cycle:
        </p>
        <ul>
            <li><code>ValueChanged</code> — fires each time a value is committed (Apply, click-outside,
                palette pick when <code>ShowButtons="false"</code>, or Clear).</li>
            <li><code>OnChange</code> — a semantic alias for the committed value, emitted alongside
                <code>ValueChanged</code>.</li>
            <li><code>OnOpen(ColorPickerOpenEventArgs)</code> — fires before the popup opens. Set
                <code>args.IsCancelled = true</code> to block opening.</li>
            <li><code>OnClose(ColorPickerCloseEventArgs)</code> — fires before the popup closes.
                Setting <code>args.IsCancelled = true</code> keeps the popup open.</li>
            <li><code>ViewChanged</code> — fires when the user toggles between
                <code>Gradient</code> and <code>Palette</code>.</li>
        </ul>
        <p>
            Interact with the picker below — click the swatch trigger, switch views, pick a colour,
            hit Apply / Cancel / Clear — and watch the append-only event log populate on the right.
            A &ldquo;Cancel open&rdquo; switch lets you see the <code>IsCancelled</code> plumbing in
            action.
        </p>
    </Narrative>

    <Example>
        <div style="display:grid; grid-template-columns: minmax(0, 1fr) 340px; gap:1rem; align-items:start;">

            <div style="display:flex; flex-direction:column; gap:.75rem;">
                <SunfishColorPicker Value="@_color"
                                    ValueChanged="HandleValueChanged"
                                    OnChange="HandleOnChange"
                                    OnOpen="HandleOnOpen"
                                    OnClose="HandleOnClose"
                                    View="@_view"
                                    ViewChanged="HandleViewChanged"
                                    ShowButtons="true"
                                    ShowPreview="true"
                                    ShowClearButton="true" />

                <p style="margin:0; font-size:.85rem; color:#555;">
                    Current colour: <strong>@(_color ?? "(none)")</strong> — active view:
                    <strong>@_view</strong> — changes captured: <strong>@_changeCount</strong>
                </p>

                <label style="display:flex; gap:.5rem; align-items:center; font-size:.85rem;">
                    <input type="checkbox" @bind="_blockOpen" />
                    Cancel <code>OnOpen</code> (popup will not open)
                </label>

                <div style="display:flex; gap:.5rem;">
                    <SunfishButton Size="ButtonSize.Small" OnClick="ClearLog">Clear log</SunfishButton>
                    <SunfishButton Size="ButtonSize.Small"
                                   Variant="ButtonVariant.Secondary"
                                   OnClick="@(() => _color = null)">
                        Reset value
                    </SunfishButton>
                </div>
            </div>

            <aside style="border:1px solid var(--sf-color-border, #ddd); border-radius:4px; background:var(--sf-color-surface, #fafafa); height:360px; display:flex; flex-direction:column;">
                <header style="padding:.5rem .75rem; font-weight:600; border-bottom:1px solid var(--sf-color-border, #ddd);">
                    Event log (newest last)
                </header>
                <ol style="flex:1; overflow:auto; margin:0; padding:.5rem .75rem .5rem 2rem; font-family:ui-monospace, SFMono-Regular, Menlo, monospace; font-size:.8rem; line-height:1.45;">
                    @if (_log.Count == 0)
                    {
                        <li style="list-style:none; color:#888;">(no events yet — open the picker)</li>
                    }
                    else
                    {
                        @foreach (var entry in _log)
                        {
                            <li>
                                <span style="color:#888;">[@entry.Timestamp.ToString("HH:mm:ss.fff")]</span>
                                <strong>@entry.Event</strong> — @entry.Detail
                            </li>
                        }
                    }
                </ol>
            </aside>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Forms", "ColorPicker", "Events"];

    private string? _color = "#4472c4";
    private ColorPickerView _view = ColorPickerView.Gradient;
    private int _changeCount;
    private bool _blockOpen;

    private record LogEntry(DateTime Timestamp, string Event, string Detail);
    private readonly List<LogEntry> _log = new();

    private void HandleValueChanged(string? value)
    {
        _color = value;
        _changeCount++;
        Log("ValueChanged", value ?? "(cleared)");
    }

    private void HandleOnChange(object? value)
    {
        Log("OnChange", value?.ToString() ?? "(null)");
    }

    private void HandleOnOpen(ColorPickerOpenEventArgs args)
    {
        if (_blockOpen)
        {
            args.IsCancelled = true;
            Log("OnOpen", "IsCancelled=true (popup blocked)");
        }
        else
        {
            Log("OnOpen", "(opening)");
        }
    }

    private void HandleOnClose(ColorPickerCloseEventArgs args)
    {
        Log("OnClose", "(closing)");
    }

    private void HandleViewChanged(ColorPickerView view)
    {
        _view = view;
        Log("ViewChanged", view.ToString());
    }

    private void Log(string evt, string detail)
    {
        _log.Add(new LogEntry(DateTime.Now, evt, detail));
        if (_log.Count > 200) _log.RemoveAt(0);
    }

    private void ClearLog() => _log.Clear();
}
