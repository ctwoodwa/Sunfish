@page "/components/forms/checkbox/appearance"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Checkbox / Appearance · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Checkbox / Appearance"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/Checkbox/Appearance/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishCheckbox</code> is a binary form control with tri-state support via
            <code>Indeterminate</code>. The visual axes are:
        </p>
        <ul>
            <li><code>Label</code> — the adjacent text; omit for an icon-only / naked checkbox.</li>
            <li><code>LabelPosition</code> — <code>"after"</code> (default) or <code>"before"</code>.</li>
            <li><code>Value</code> — two-way bindable via <code>@@bind-Value</code>.</li>
            <li><code>Indeterminate</code> — mixed visual state (still reflects <code>Value</code> internally).</li>
            <li><code>Enabled</code> — set to <code>false</code> for a disabled appearance.</li>
        </ul>
    </Narrative>

    <Example>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:1.25rem; max-width:820px;">

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Unchecked</h3>
                <SunfishCheckbox Value="false" Label="Subscribe to newsletter" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Checked</h3>
                <SunfishCheckbox Value="true" Label="I agree to terms" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Indeterminate</h3>
                <SunfishCheckbox Indeterminate="true" Label="Select all (mixed)" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Label before</h3>
                <SunfishCheckbox @bind-Value="_labelBefore" Label="Before the box" LabelPosition="before" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Naked (no label)</h3>
                <SunfishCheckbox @bind-Value="_naked" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Disabled unchecked</h3>
                <SunfishCheckbox Value="false" Enabled="false" Label="Cannot opt in" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Disabled checked</h3>
                <SunfishCheckbox Value="true" Enabled="false" Label="Locked on" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Live (bound)</h3>
                <SunfishCheckbox @bind-Value="_live" Label="Toggle me" />
                <p style="margin:.5rem 0 0; font-size:.85rem;">Bound value: <strong>@_live</strong></p>
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Forms", "Checkbox", "Appearance"];

    private bool _labelBefore = true;
    private bool _naked;
    private bool _live;
}
