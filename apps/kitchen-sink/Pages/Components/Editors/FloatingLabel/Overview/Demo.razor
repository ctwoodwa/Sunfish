@page "/components/forms/floatinglabel/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>FloatingLabel / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="FloatingLabel / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/FloatingLabel/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishFloatingLabel</code> wraps any input to provide an animated label that floats above
            the field when focused or filled — a Material-style affordance that keeps form rows compact
            without sacrificing the hint text. Set the label with <code>Text</code> and place the input
            inside as <code>ChildContent</code>.
        </p>
        <p>
            See <a href="/components/editors/floatinglabel/controlled-state">controlled-state</a>.
        </p>
    </Narrative>

    <Example>
        <div class="demo-row">
            <SunfishFloatingLabel Text="Enter your name">
                <SunfishTextBox @bind-Value="_name" />
            </SunfishFloatingLabel>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Forms", "FloatingLabel", "Overview"];

    private string? _name;
}
