@page "/components/forms/datepicker/events"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>DatePicker / Events · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="DatePicker / Events"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/DatePicker/Events/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishDatePicker</code> exposes a single primary event — <code>ValueChanged</code>
            — which fires once per committed selection. The component is built on a standard
            <code>&lt;input type="text"&gt;</code> trigger, so the native DOM focus events
            (<code>@@onfocus</code>, <code>@@onblur</code>) are available through Blazor's attribute
            pass-through without any extra wiring. Together these three signals cover the full
            life-cycle: focus → open popup → pick a day → commit value → blur.
        </p>
        <p>
            Pick dates in the field below and observe the append-only log on the right. Every
            callback invocation is timestamped so the order of events is unambiguous.
        </p>
    </Narrative>

    <Example>
        <div style="display:grid; grid-template-columns: minmax(0, 1fr) 320px; gap:1rem; align-items:start;">

            <div style="display:flex; flex-direction:column; gap:.75rem;">
                <SunfishField>
                    <SunfishLabel>Delivery date</SunfishLabel>
                    <SunfishDatePicker Value="@_date"
                                       ValueChanged="HandleValueChanged"
                                       Placeholder="Select a date..."
                                       @onfocus="@(() => Log("focus", "DatePicker"))"
                                       @onblur="@(() => Log("blur", "DatePicker"))" />
                </SunfishField>

                <p style="margin:0; font-size:.85rem; color:#555;">
                    Current value: <strong>@(_date?.ToString("yyyy-MM-dd") ?? "(none)")</strong>
                    — changes captured: <strong>@_changeCount</strong>
                </p>

                <div style="display:flex; gap:.5rem;">
                    <SunfishButton Size="ButtonSize.Small" OnClick="ClearLog">Clear log</SunfishButton>
                    <SunfishButton Size="ButtonSize.Small"
                                   Variant="ButtonVariant.Secondary"
                                   OnClick="@(() => _date = null)">
                        Reset value
                    </SunfishButton>
                </div>
            </div>

            <aside style="border:1px solid var(--sf-color-border, #ddd); border-radius:4px; background:var(--sf-color-surface, #fafafa); height:320px; display:flex; flex-direction:column;">
                <header style="padding:.5rem .75rem; font-weight:600; border-bottom:1px solid var(--sf-color-border, #ddd);">
                    Event log (newest last)
                </header>
                <ol style="flex:1; overflow:auto; margin:0; padding:.5rem .75rem .5rem 2rem; font-family:ui-monospace, SFMono-Regular, Menlo, monospace; font-size:.8rem; line-height:1.45;">
                    @if (_log.Count == 0)
                    {
                        <li style="list-style:none; color:#888;">(no events yet — click the field and pick a date)</li>
                    }
                    else
                    {
                        @foreach (var entry in _log)
                        {
                            <li>
                                <span style="color:#888;">[@entry.Timestamp.ToString("HH:mm:ss.fff")]</span>
                                <strong>@entry.Event</strong> — @entry.Detail
                            </li>
                        }
                    }
                </ol>
            </aside>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Forms", "DatePicker", "Events"];

    private DateTime? _date;
    private int _changeCount;

    private record LogEntry(DateTime Timestamp, string Event, string Detail);
    private readonly List<LogEntry> _log = new();

    private void HandleValueChanged(DateTime? newValue)
    {
        _date = newValue;
        _changeCount++;
        Log("ValueChanged", newValue?.ToString("yyyy-MM-dd") ?? "(cleared)");
    }

    private void Log(string evt, string detail)
    {
        _log.Add(new LogEntry(DateTime.Now, evt, detail));
        if (_log.Count > 200) _log.RemoveAt(0);
    }

    private void ClearLog() => _log.Clear();
}
