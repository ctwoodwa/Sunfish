@page "/components/editors/rangeslider/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>RangeSlider / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="RangeSlider / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/RangeSlider/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishRangeSlider</code> lets users pick a start and end value from a continuous range
            using two draggable handles. Bind each end with <code>@@bind-StartValue</code> and
            <code>@@bind-EndValue</code>, and configure <code>Min</code> / <code>Max</code> to set bounds.
        </p>
        <p>
            See <a href="/components/editors/rangeslider/events">events</a> and
            <a href="/components/editors/rangeslider/validation">validation</a>.
        </p>
    </Narrative>

    <Example>
        <div class="demo-row">
            <SunfishRangeSlider @bind-StartValue="_start" @bind-EndValue="_end" Min="0" Max="100" />
            <span>@_start — @_end</span>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Editors", "RangeSlider", "Overview"];

    private double _start = 20;
    private double _end = 80;
}
