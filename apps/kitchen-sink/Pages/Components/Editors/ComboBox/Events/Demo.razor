@page "/components/forms/combobox/events"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Components.Forms.Inputs

<PageTitle>ComboBox / Events · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="ComboBox / Events"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/ComboBox/Events/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishComboBox</code> emits typed value callbacks plus an async data callback:
        </p>
        <ul>
            <li><code>ValueChanged</code> — two-way binding wire for the selected <code>TValue</code>.
                Fires when an option is clicked, <kbd>Enter</kbd>ed, cleared, or (when
                <code>AllowCustom="true"</code>) typed-then-matched.</li>
            <li><code>OnChange</code> — semantic alias that fires alongside <code>ValueChanged</code>.</li>
            <li><code>OnRead</code> — fires on open, filter, and scroll. Supplies
                <code>ComboBoxReadEventArgs&lt;TItem&gt;</code> with <code>Filter</code> /
                <code>FilterOperator</code> / <code>Skip</code> / <code>Take</code> / <code>Sorts</code>;
                handlers assign <code>Data</code> (and optionally <code>Total</code>). When
                <code>OnRead</code> is bound the <code>Data</code> parameter is ignored.</li>
            <li><code>@@onfocus</code> / <code>@@onblur</code> — native DOM focus events pass through
                via <code>AdditionalAttributes</code>.</li>
        </ul>
    </Narrative>

    <Example>
        <div style="display:grid; grid-template-columns: minmax(0, 1fr) 320px; gap:1rem; align-items:start;">

            <div style="display:flex; flex-direction:column; gap:1rem;">

                <section>
                    <h3 style="margin:0 0 .5rem;">ValueChanged / OnChange</h3>
                    <SunfishField>
                        <SunfishLabel>Country</SunfishLabel>
                        <SunfishComboBox TItem="Country" TValue="int?"
                                        Data="@_countries"
                                        TextField="Name" ValueField="Id"
                                        Value="@_value"
                                        ValueChanged="HandleValueChanged"
                                        OnChange="HandleOnChange"
                                        ShowClearButton="true"
                                        Placeholder="Type to search..."
                                        @onfocus="@(() => Log("focus", "input"))"
                                        @onblur="@(() => Log("blur", "input"))" />
                    </SunfishField>
                    <p style="margin:.5rem 0 0; font-size:.85rem; color:#555;">
                        Current value: <strong>@(_value?.ToString() ?? "(none)")</strong>
                        — changes: <strong>@_changeCount</strong>
                    </p>
                </section>

                <section>
                    <h3 style="margin:0 0 .5rem;">OnRead (server-side)</h3>
                    <p style="margin:0 0 .5rem; font-size:.85rem; color:#555;">
                        This combo has no <code>Data</code> — the <code>OnRead</code> handler builds
                        a response per keystroke. Look at the log to see each call with its
                        <code>Filter</code> value.
                    </p>
                    <SunfishField>
                        <SunfishLabel>Remote car</SunfishLabel>
                        <SunfishComboBox TItem="Car" TValue="int?"
                                        OnRead="HandleRead"
                                        TextField="Make" ValueField="Id"
                                        @bind-Value="@_remoteValue"
                                        ShowClearButton="true"
                                        DebounceDelay="200"
                                        Placeholder="Type a car brand..." />
                    </SunfishField>
                </section>

                <div style="display:flex; gap:.5rem;">
                    <SunfishButton Size="ButtonSize.Small" OnClick="ClearLog">Clear log</SunfishButton>
                    <SunfishButton Size="ButtonSize.Small" Variant="ButtonVariant.Secondary"
                                   OnClick="@(() => { _value = null; _remoteValue = null; })">
                        Reset values
                    </SunfishButton>
                </div>
            </div>

            <aside style="border:1px solid var(--sf-color-border, #ddd); border-radius:4px; background:var(--sf-color-surface, #fafafa); height:480px; display:flex; flex-direction:column;">
                <header style="padding:.5rem .75rem; font-weight:600; border-bottom:1px solid var(--sf-color-border, #ddd);">
                    Event log (newest last)
                </header>
                <ol style="flex:1; overflow:auto; margin:0; padding:.5rem .75rem .5rem 2rem; font-family:ui-monospace, SFMono-Regular, Menlo, monospace; font-size:.8rem; line-height:1.45;">
                    @if (_log.Count == 0)
                    {
                        <li style="list-style:none; color:#888;">(no events yet — focus a combo and type)</li>
                    }
                    else
                    {
                        @foreach (var entry in _log)
                        {
                            <li>
                                <span style="color:#888;">[@entry.Timestamp.ToString("HH:mm:ss.fff")]</span>
                                <strong>@entry.Event</strong> — @entry.Detail
                            </li>
                        }
                    }
                </ol>
            </aside>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Forms", "ComboBox", "Events"];

    private int? _value;
    private int? _remoteValue;
    private int _changeCount;

    private record LogEntry(DateTime Timestamp, string Event, string Detail);
    private readonly List<LogEntry> _log = new();

    private void HandleValueChanged(int? value)
    {
        _value = value;
        _changeCount++;
        Log("ValueChanged", value?.ToString() ?? "(cleared)");
    }

    private void HandleOnChange(int? value)
    {
        Log("OnChange", value?.ToString() ?? "(cleared)");
    }

    private async Task HandleRead(ComboBoxReadEventArgs<Car> args)
    {
        Log("OnRead",
            $"filter=\"{args.Filter ?? string.Empty}\" op={args.FilterOperator}");

        // Simulate network delay; in real code this would hit a service.
        await Task.Delay(120);

        IEnumerable<Car> source = _allCars;
        if (!string.IsNullOrEmpty(args.Filter))
        {
            source = source.Where(c =>
                c.Make.Contains(args.Filter, StringComparison.OrdinalIgnoreCase));
        }
        var page = source.ToList();
        args.Data = page;
        args.Total = page.Count;
    }

    private void Log(string evt, string detail)
    {
        _log.Add(new LogEntry(DateTime.Now, evt, detail));
        if (_log.Count > 200) _log.RemoveAt(0);
    }

    private void ClearLog() => _log.Clear();

    private record Country(int Id, string Name, string Code);
    private record Car(int Id, string Make);

    private readonly List<Country> _countries = new()
    {
        new(1, "United States", "US"),
        new(2, "Canada", "CA"),
        new(3, "United Kingdom", "GB"),
        new(4, "Germany", "DE"),
        new(5, "France", "FR"),
        new(6, "Japan", "JP"),
    };

    private readonly List<Car> _allCars = new()
    {
        new(1, "Honda"), new(2, "Opel"), new(3, "Audi"), new(4, "Lancia"),
        new(5, "BMW"), new(6, "Mercedes"), new(7, "Tesla"), new(8, "VW"),
        new(9, "Alfa Romeo"), new(10, "Chevrolet"), new(11, "Ford"),
        new(12, "Cadillac"), new(13, "Dodge"), new(14, "Jeep"),
        new(15, "Chrysler"), new(16, "Lincoln"),
    };
}
