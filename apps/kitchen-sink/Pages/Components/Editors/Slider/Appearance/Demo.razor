@page "/components/forms/slider/appearance"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Slider / Appearance · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Slider / Appearance"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/Slider/Appearance/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishSlider</code> picks a single numeric value from a range. The visual axes are:
        </p>
        <ul>
            <li><code>Orientation</code> — <code>SliderOrientation.Horizontal</code> (default) or
                <code>Vertical</code>.</li>
            <li><code>ShowButtons</code> — renders - / + stepper buttons flanking the track.</li>
            <li><code>LargeStep</code> — emits tick marks at each large-step boundary.</li>
            <li><code>LabelTemplate</code> — a <code>RenderFragment&lt;double&gt;</code> that renders
                a live label based on the current value.</li>
            <li><code>Enabled</code> — set to <code>false</code> for a disabled appearance.</li>
        </ul>
    </Narrative>

    <Example>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:1.5rem; max-width:820px;">

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Plain (0–100)</h3>
                <SunfishSlider @bind-Value="_a" Min="0" Max="100" Step="1" />
                <p style="margin:.25rem 0 0; font-size:.85rem;">Value: <strong>@_a</strong></p>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">With label</h3>
                <SunfishField>
                    <SunfishLabel>Volume (@_volume)</SunfishLabel>
                    <SunfishSlider @bind-Value="_volume" Min="0" Max="100" Step="5" />
                </SunfishField>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">With stepper buttons</h3>
                <SunfishSlider @bind-Value="_b" Min="0" Max="10" Step="1" ShowButtons="true" />
                <p style="margin:.25rem 0 0; font-size:.85rem;">Value: <strong>@_b</strong></p>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">With ticks (LargeStep=25)</h3>
                <SunfishSlider @bind-Value="_c" Min="0" Max="100" Step="1" LargeStep="25" />
                <p style="margin:.25rem 0 0; font-size:.85rem;">Value: <strong>@_c</strong></p>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">With template label</h3>
                <SunfishSlider @bind-Value="_d" Min="0" Max="100" Step="5">
                    <LabelTemplate Context="v">
                        <strong>@v%</strong>
                    </LabelTemplate>
                </SunfishSlider>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Vertical</h3>
                <div style="height:180px; display:flex; align-items:center; justify-content:center;">
                    <SunfishSlider @bind-Value="_e" Min="0" Max="100" Step="1" Orientation="SliderOrientation.Vertical" />
                </div>
                <p style="margin:.25rem 0 0; font-size:.85rem;">Value: <strong>@_e</strong></p>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Fractional step</h3>
                <SunfishSlider @bind-Value="_f" Min="0" Max="1" Step="0.05" />
                <p style="margin:.25rem 0 0; font-size:.85rem;">Value: <strong>@_f.ToString("0.00")</strong></p>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.8rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Disabled</h3>
                <SunfishSlider Value="50" Min="0" Max="100" Step="1" Enabled="false" ShowButtons="true" />
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Forms", "Slider", "Appearance"];

    private double _a = 30;
    private double _volume = 45;
    private double _b = 5;
    private double _c = 50;
    private double _d = 75;
    private double _e = 60;
    private double _f = 0.5;
}
