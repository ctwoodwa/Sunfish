@page "/components/editors/dateinput/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>DateInput / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="DateInput / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Editors/DateInput/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishDateInput</code> is a keyboard-first date text field that parses and formats
            <code>DateTime?</code> values without a popup calendar. Two-way bind the value with
            <code>@@bind-Value</code>, constrain the allowed range with <code>Min</code> / <code>Max</code>,
            and adjust the field footprint with <code>Width</code>.
        </p>
        <p>
            See <a href="/components/editors/dateinput/format">format</a>,
            <a href="/components/editors/dateinput/events">events</a>, and
            <a href="/components/editors/dateinput/validation">validation</a>.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:0.75rem;">
            <SunfishDateInput @bind-Value="_date" Placeholder="Enter a date" />
            <p>Selected: <strong>@(_date?.ToString("MM/dd/yyyy") ?? "none")</strong></p>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Editors", "DateInput", "Overview"];

    private DateTime? _date;
}
