@page "/components/feedback/progressbar/appearance"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Enums

<PageTitle>ProgressBar / Appearance · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="ProgressBar / Appearance"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Feedback/ProgressBar/Appearance/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishProgressBar</code>'s surface is driven by CSS custom properties and a
            <code>ProgressCssClass</code> hook on the fill element. The examples below walk a fixed
            value through a palette of <em>ThemeColor-style</em> utility classes — one per semantic
            intent — using <code>ProgressCssClass</code>. A custom <code>LabelTemplate</code> is
            used to format the value as bytes downloaded.
        </p>
        <p>
            Theme providers ship these utility classes so an app can switch palettes without
            touching component markup.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1rem;">

            <section>
                <h3 style="margin:0 0 .5rem;">Theme colours</h3>
                <div style="display:flex; flex-direction:column; gap:.5rem;">
                    <SunfishProgressBar Value="65" ShowLabel="true" ProgressCssClass="sf-progressbar__fill--primary" />
                    <SunfishProgressBar Value="65" ShowLabel="true" ProgressCssClass="sf-progressbar__fill--success" />
                    <SunfishProgressBar Value="65" ShowLabel="true" ProgressCssClass="sf-progressbar__fill--warning" />
                    <SunfishProgressBar Value="65" ShowLabel="true" ProgressCssClass="sf-progressbar__fill--danger" />
                    <SunfishProgressBar Value="65" ShowLabel="true" ProgressCssClass="sf-progressbar__fill--info" />
                </div>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem;">Chunked theme colour</h3>
                <SunfishProgressBar Value="70" ChunkCount="10" ProgressCssClass="sf-progressbar__chunk--success" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem;">Custom LabelTemplate (bytes downloaded)</h3>
                <SunfishProgressBar Value="@_downloaded" Max="@_total">
                    <LabelTemplate Context="current">
                        <strong>@FormatBytes(current)</strong> / @FormatBytes(_total)
                    </LabelTemplate>
                </SunfishProgressBar>
                <div class="demo-row" style="margin-top:.5rem; display:flex; gap:.5rem;">
                    <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _downloaded = Math.Max(0, _downloaded - 262144))">-256 KB</SunfishButton>
                    <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _downloaded = Math.Min(_total, _downloaded + 262144))">+256 KB</SunfishButton>
                </div>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem;">Non-animated determinate</h3>
                <SunfishProgressBar Value="40" Animated="false" ShowLabel="true" />
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Feedback", "ProgressBar", "Appearance"];

    private double _downloaded = 1_572_864;
    private const double _total = 2_097_152;

    private static string FormatBytes(double bytes)
    {
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576:F1} MB";
        if (bytes >= 1024) return $"{bytes / 1024:F0} KB";
        return $"{bytes:F0} B";
    }
}
