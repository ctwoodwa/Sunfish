@page "/components/media/pdfviewer/overview"
@layout MainLayout
@using MediaComponents = Sunfish.UIAdapters.Blazor.Components.Media
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Enums

<PageTitle>PDF Viewer / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="PDF Viewer / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Media/PdfViewer/Overview/Demo.razor">

    <Narrative>
        <p>
            <code>SunfishPdfViewer</code> (<code>Sunfish.UIAdapters.Blazor.Components.Media</code>)
            embeds a PDF via a native <code>&lt;iframe&gt;</code>, letting the browser's built-in
            PDF renderer do the heavy lifting. A toolbar above the document provides page
            navigation, zoom, and a download action.
        </p>
        <p>
            The <code>ToolbarMode</code> parameter controls the chrome density:
            <code>Hidden</code>, <code>Compact</code> (download only), or <code>Full</code>
            (page + zoom + download).
        </p>
        <ul>
            <li><code>Source</code> — URL or <code>data:application/pdf;base64,...</code> URI.</li>
            <li><code>Width</code> / <code>Height</code> — CSS sizing.</li>
            <li><code>InitialPage</code>, <code>PageCount</code> — initial state / toolbar bounds.</li>
            <li><code>OnPageChange</code> — fires on toolbar nav (see gaps below).</li>
        </ul>
        <p style="font-size:.85rem;opacity:.75;">
            Gap: the native browser PDF viewer does not emit page events into the host page, so
            <code>OnPageChange</code> fires only on toolbar-driven navigation, not on the user's
            own scroll or in-page nav inside the viewer.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.25rem;">
            <div>
                <h4 style="margin:0 0 .5rem;">Full toolbar</h4>
                <MediaComponents.SunfishPdfViewer Source="@_sampleSource"
                                                  PageCount="10"
                                                  ToolbarMode="PdfToolbarMode.Full"
                                                  Height="420px"
                                                  OnPageChange="OnPageChanged" />
                <p style="margin:.5rem 0 0;font-size:.85rem;">
                    Toolbar page nav observed: <code>@_lastPage</code>
                </p>
            </div>

            <div>
                <h4 style="margin:0 0 .5rem;">Compact toolbar (download only)</h4>
                <MediaComponents.SunfishPdfViewer Source="@_sampleSource"
                                                  ToolbarMode="PdfToolbarMode.Compact"
                                                  Height="260px" />
            </div>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Media", "PDF Viewer", "Overview"];

    // Public sample PDF — a single-page W3C test document.
    private const string _sampleSource = "https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf";
    private int _lastPage = 1;

    private Task OnPageChanged(int page)
    {
        _lastPage = page;
        return Task.CompletedTask;
    }
}
