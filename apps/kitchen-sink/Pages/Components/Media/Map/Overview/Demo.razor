@page "/components/media/map/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Enums
@using MapMarker = Sunfish.UIAdapters.Blazor.Components.Media.MapMarker
@using MapClickEventArgs = Sunfish.UIAdapters.Blazor.Components.Media.MapClickEventArgs
@using SunfishMap = Sunfish.UIAdapters.Blazor.Components.Media.SunfishMap

<PageTitle>Map / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Map / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Media/Map/Overview/Demo.razor">

    <Narrative>
        <p>
            <code>SunfishMap</code> (<code>Sunfish.UIAdapters.Blazor.Components.Media</code>) is the
            MVP Media-family map surface. It renders a framed preview client-side and delegates
            tile-layer rendering, marker placement, and popup display to a Leaflet-compatible JS
            module loaded from <code>@SunfishMap.JsModulePath</code>.
        </p>
        <p>
            This MVP is marked <strong>partial</strong> in the component-mapping catalog: the
            public parameter surface is final, but the JS engine module is not yet bundled. When
            the module is absent, the preview fallback remains visible and markers are persisted
            in-memory only.
        </p>
        <ul>
            <li><code>Latitude</code> / <code>Longitude</code> — map center.</li>
            <li><code>Zoom</code> — initial zoom level (default 4).</li>
            <li><code>Markers</code> — <code>List&lt;MapMarker&gt;</code> with per-marker <code>OnClick</code>.</li>
            <li><code>TileUrl</code> — tile template URL (default OpenStreetMap).</li>
            <li><code>Attribution</code> — attribution HTML rendered in the corner.</li>
            <li><code>OnReady</code>, <code>OnMapClick</code> — lifecycle and click events.</li>
        </ul>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.25rem;">
            <div>
                <h4 style="margin:0 0 .5rem;">World map, centered on London</h4>
                <Sunfish.UIAdapters.Blazor.Components.Media.SunfishMap
                    Latitude="51.5074"
                    Longitude="-0.1278"
                    Zoom="6"
                    Markers="_markers"
                    OnMapClick="OnMapClicked"
                    Height="360px" />
                <p style="margin:.5rem 0 0;font-size:.85rem;">
                    Last click: <code>@_lastClick</code>
                </p>
            </div>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Media", "Map", "Overview"];

    private string _lastClick = "(none)";

    private readonly List<MapMarker> _markers = new()
    {
        new MapMarker { Latitude = 51.5074, Longitude = -0.1278, Title = "London", Icon = MapMarkerIcon.Pin },
        new MapMarker { Latitude = 48.8566, Longitude = 2.3522,  Title = "Paris",  Icon = MapMarkerIcon.Circle },
        new MapMarker { Latitude = 52.5200, Longitude = 13.4050, Title = "Berlin", Icon = MapMarkerIcon.Default },
    };

    private Task OnMapClicked(MapClickEventArgs args)
    {
        _lastClick = $"({args.Latitude:0.##}, {args.Longitude:0.##})";
        return Task.CompletedTask;
    }
}
