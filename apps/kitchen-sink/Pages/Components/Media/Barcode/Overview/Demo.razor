@page "/components/media/barcode/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Enums

<PageTitle>Barcode / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Barcode / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Media/Barcode/Overview/Demo.razor">

    <Narrative>
        <p>
            <code>SunfishBarcode</code> (<code>Sunfish.UIAdapters.Blazor.Components.Media</code>)
            is the MVP Media-family barcode surface. It renders an inline SVG with rect-based
            bars — no JS interop, fully server-renderable.
        </p>
        <p>
            MVP encoding: <strong>Code128</strong> uses a deterministic pass-through hash
            (11 bars per character derived from the char code). The output is visually plausible
            and stable, but is <strong>not a scannable Code128 payload</strong>. Other
            symbologies (Code39, EAN-13, EAN-8, UPC-A, QrCode) render a "not yet" placeholder
            until real encoders land.
        </p>
        <ul>
            <li><code>Value</code> — the text to encode.</li>
            <li><code>Symbology</code> — <code>BarcodeSymbology.Code128</code> (only one implemented in MVP).</li>
            <li><code>Width</code> — per-bar module width in px (default 2).</li>
            <li><code>Height</code> — bar height in px (default 80).</li>
            <li><code>ShowText</code> + <code>TextAlignment</code> — human-readable value under the bars.</li>
            <li><code>Color</code> — bar color.</li>
        </ul>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.5rem;">
            <div>
                <h4 style="margin:0 0 .5rem;">Default Code128</h4>
                <Sunfish.UIAdapters.Blazor.Components.Media.SunfishBarcode Value="SUNFISH-2026" />
            </div>

            <div>
                <h4 style="margin:0 0 .5rem;">Custom color and compact sizing</h4>
                <Sunfish.UIAdapters.Blazor.Components.Media.SunfishBarcode
                    Value="ORDER-00042"
                    Symbology="BarcodeSymbology.Code128"
                    Color="#6a1b9a"
                    Width="3"
                    Height="60"
                    TextAlignment="TextAlignment.Center" />
            </div>

            <div>
                <h4 style="margin:0 0 .5rem;">Not-yet symbology (QR code placeholder)</h4>
                <Sunfish.UIAdapters.Blazor.Components.Media.SunfishBarcode
                    Value="hello" Symbology="BarcodeSymbology.QrCode" />
            </div>

            <div>
                <h4 style="margin:0 0 .5rem;">Without text</h4>
                <Sunfish.UIAdapters.Blazor.Components.Media.SunfishBarcode
                    Value="SKU-XYZ" ShowText="false" Width="3" Height="100" />
            </div>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Media", "Barcode", "Overview"];
}
