@page "/components/data-display/listview/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>ListView / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="ListView / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/DataDisplay/ListView/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishListView&lt;TItem&gt;</code> renders a flat, template-driven list of items. Provide
            a collection to <code>Data</code> and supply an <code>ItemTemplate</code> to control how each
            record appears. Toggles include <code>Pageable</code> / <code>PageSize</code> for paging and
            <code>SelectionMode</code> for row selection.
        </p>
        <p>
            Sibling demos cover
            <a href="/components/data-display/listview/paging">paging</a>,
            <a href="/components/data-display/listview/editing">editing</a>,
            <a href="/components/data-display/listview/templates">templates</a>, and
            <a href="/components/data-display/listview/loading-on-demand">loading-on-demand</a>.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.25rem;">
            <div class="demo-row">
                <SunfishListView Data="_items" TItem="string">
                    <ItemTemplate Context="item">
                        <span>@item</span>
                    </ItemTemplate>
                </SunfishListView>
            </div>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Data Display", "ListView", "Overview"];

    private readonly List<string> _items = ["Apple", "Banana", "Cherry", "Date", "Elderberry"];
}
