@page "/components/forms/listbox/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>ListBox / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="ListBox / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/DataDisplay/ListBox/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishListBox</code> presents a scrollable, selectable list of items. Bind <code>Data</code>,
            configure <code>TextField</code> / <code>ValueField</code>, and choose single or multiple mode via
            <code>SelectionMode</code>. Use <code>Height</code> to constrain the visible area.
        </p>
        <p>
            Sibling demos cover
            <a href="/components/data-display/listbox/transfer-items">transfer-items</a>,
            <a href="/components/data-display/listbox/templates">templates</a>, and
            <a href="/components/data-display/listbox/events">events</a>.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.25rem;">
            <div class="demo-row">
                <SunfishListBox Data="@_items"
                                TextField="Name"
                                ValueField="Id"
                                @bind-Value="_selected"
                                Height="180px" />
            </div>
            <p><strong>Selected:</strong> @(_selected is not null ? GetName(_selected) : "none")</p>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Forms", "ListBox", "Overview"];

    private object? _selected;

    private readonly List<object> _items = new()
    {
        new ListItem { Id = "1", Name = "Apples" },
        new ListItem { Id = "2", Name = "Bananas" },
        new ListItem { Id = "3", Name = "Cherries" },
        new ListItem { Id = "4", Name = "Dates" },
        new ListItem { Id = "5", Name = "Elderberries" },
    };

    private static string GetName(object item)
        => item.GetType().GetProperty("Name")?.GetValue(item)?.ToString() ?? "";

    private class ListItem
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
    }
}
