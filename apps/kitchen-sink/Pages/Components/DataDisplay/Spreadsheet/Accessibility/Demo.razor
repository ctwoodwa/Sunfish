@page "/components/data-display/spreadsheet/accessibility"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Enums
@using Sunfish.UIAdapters.Blazor.Components.DataDisplay.Spreadsheet

<PageTitle>Spreadsheet / Accessibility · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Spreadsheet / Accessibility"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/DataDisplay/Spreadsheet/Accessibility/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishSpreadsheet</code> renders an Excel-style cell matrix. The outer container is
            marked <code>role="grid"</code> and labelled via <code>AriaLabel</code>. Column letters
            (<code>A</code>, <code>B</code>, ...) render as <code>&lt;th scope="col"&gt;</code>; row numbers
            (<code>1</code>, <code>2</code>, ...) render as <code>&lt;th scope="row"&gt;</code>. Each
            editable cell contains a native <code>&lt;input type="text"&gt;</code> whose
            <code>aria-label</code> is its A1 reference — a screen reader announces
            <em>"edit text, B2"</em> when the user tabs in.
        </p>
        <p>
            <strong>MVP status.</strong> Cell-level labels, <code>ReadOnly</code>, and basic selection work
            today. Richer a11y features — Excel-style <kbd>F2</kbd>/<kbd>Esc</kbd> edit mode,
            <kbd>Ctrl</kbd>+<kbd>Home</kbd>/<kbd>End</kbd> navigation, formula-bar linkage via
            <code>aria-controls</code>, and <code>aria-rowindex</code>/<code>aria-colindex</code> — are
            <em>planned</em> and documented below.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.5rem;">

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.95rem;">Order totals (editable)</h3>
                <p style="margin:.25rem 0 .75rem 0; font-size:.9rem; opacity:.85;">
                    Tab into a cell — the screen reader announces its A1 address. Edit a number in column B
                    or C, then tab out to recompute column D.
                </p>
                <Sunfish.UIAdapters.Blazor.Components.DataDisplay.Spreadsheet.SunfishSpreadsheet Rows="_rows"
                                                                                                 AriaLabel="Order totals spreadsheet"
                                                                                                 Height="260px"
                                                                                                 OnCellChanged="HandleCellChanged" />
                <div role="status" aria-live="polite" style="margin-top:.5rem; font-size:.85rem;">
                    @if (_lastEdit is not null)
                    {
                        <span>
                            Cell <strong>@SpreadsheetAddress.ToA1(_lastEdit.Row, _lastEdit.Column)</strong>
                            changed from "@(_lastEdit.OldValue ?? string.Empty)" to
                            "@(_lastEdit.NewValue ?? string.Empty)".
                        </span>
                    }
                    else
                    {
                        <span>No edits yet.</span>
                    }
                </div>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.95rem;">Read-only variant</h3>
                <p style="margin:.25rem 0 .75rem 0; font-size:.9rem; opacity:.85;">
                    <code>ReadOnly="true"</code> replaces each cell's editable input with a static
                    <code>&lt;span&gt;</code>. The container keeps <code>role="grid"</code> so AT still
                    reports tabular structure.
                </p>
                <Sunfish.UIAdapters.Blazor.Components.DataDisplay.Spreadsheet.SunfishSpreadsheet Rows="_rows"
                                                                                                 AriaLabel="Order totals (read-only snapshot)"
                                                                                                 ReadOnly="true"
                                                                                                 Height="200px" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">ARIA &amp; semantic contract (shipped)</h3>
                <dl style="display:grid; grid-template-columns: max-content 1fr; column-gap:1rem; row-gap:.35rem; margin:0; font-size:.9rem;">
                    <dt><code>role="grid"</code></dt>
                    <dd>On the outer wrapper — announces the component as an interactive grid.</dd>
                    <dt><code>aria-label</code></dt>
                    <dd>From <code>AriaLabel</code>. Falls back to <em>"Spreadsheet"</em> when unset.</dd>
                    <dt><code>&lt;th scope="col"&gt;</code> / <code>&lt;th scope="row"&gt;</code></dt>
                    <dd>Column letters (<code>A</code>…) and row numbers (<code>1</code>…) are real scoped headers.</dd>
                    <dt><code>role="gridcell"</code></dt>
                    <dd>On every data cell, editable or not.</dd>
                    <dt>Per-cell <code>aria-label="A1"</code></dt>
                    <dd>Each editable <code>&lt;input&gt;</code> exposes its A1 reference as its accessible name.</dd>
                    <dt><code>ReadOnly</code></dt>
                    <dd>Swaps inputs for static spans — AT announces cells as read-only text.</dd>
                </dl>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Planned a11y contract (engineering targets)</h3>
                <dl style="display:grid; grid-template-columns: max-content 1fr; column-gap:1rem; row-gap:.35rem; margin:0; font-size:.9rem;">
                    <dt><code>aria-rowindex</code> / <code>aria-colindex</code></dt>
                    <dd><em>Planned — MVP.</em> 1-based indices on every row / cell. Required once virtualization ships.</dd>
                    <dt><code>aria-readonly="true"</code></dt>
                    <dd><em>Planned — MVP.</em> Per-cell attribute for locked cells (distinct from whole-grid <code>ReadOnly</code>).</dd>
                    <dt>Formula-bar linkage</dt>
                    <dd><em>Planned — MVP.</em> An external formula bar input would pair with the grid via <code>aria-controls="grid-id"</code> and mirror the active cell.</dd>
                    <dt><kbd>F2</kbd> edit mode</dt>
                    <dd><em>Planned — MVP.</em> Excel convention: Enter cell-edit mode without replacing the value; <kbd>Escape</kbd> cancels.</dd>
                    <dt><kbd>Ctrl</kbd>+<kbd>Home</kbd> / <kbd>Ctrl</kbd>+<kbd>End</kbd></dt>
                    <dd><em>Planned — MVP.</em> Jump to A1 / last used cell.</dd>
                    <dt>Range-selection announcement</dt>
                    <dd><em>Planned — MVP.</em> Live region announces "Selected A1:C4, 12 cells" when a range is selected.</dd>
                </dl>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Keyboard shortcuts</h3>
                <table style="border-collapse:collapse; font-size:.9rem;">
                    <thead>
                        <tr>
                            <th style="text-align:left; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Keys</th>
                            <th style="text-align:left; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Effect</th>
                            <th style="text-align:left; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Tab</kbd> / <kbd>Shift</kbd>+<kbd>Tab</kbd></td><td style="padding:.35rem .75rem;">Move to the next / previous editable cell.</td><td style="padding:.35rem .75rem;">Shipped (native tab order).</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Enter</kbd></td><td style="padding:.35rem .75rem;">Commit the current edit and blur the input.</td><td style="padding:.35rem .75rem;">Shipped (native input behaviour).</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Arrow</kbd> keys</td><td style="padding:.35rem .75rem;">Move between cells (outside of edit mode).</td><td style="padding:.35rem .75rem;"><em>Planned — MVP.</em></td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>F2</kbd></td><td style="padding:.35rem .75rem;">Enter cell-edit mode with the caret at the end.</td><td style="padding:.35rem .75rem;"><em>Planned — MVP.</em></td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Escape</kbd></td><td style="padding:.35rem .75rem;">Cancel the in-progress edit, restore the prior value.</td><td style="padding:.35rem .75rem;"><em>Planned — MVP.</em></td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Ctrl</kbd>+<kbd>Home</kbd> / <kbd>End</kbd></td><td style="padding:.35rem .75rem;">Jump to A1 / last used cell.</td><td style="padding:.35rem .75rem;"><em>Planned — MVP.</em></td></tr>
                    </tbody>
                </table>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Screen-reader output (expected)</h3>
                <pre style="background:var(--sunfish-surface-muted, #f3f4f6); padding:.75rem; border-radius:.375rem; font-size:.85rem; overflow:auto;"><code>Order totals spreadsheet, grid
  Column header: A
  Column header: B
  Row header: 1
    A1, edit text, "Item"
    B1, edit text, "Qty"
  Row header: 2
    A2, edit text, "Widget A"
    B2, edit text, "3"
    D2, edit text, "37.5"   (formula =B2*C2)</code></pre>
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Data Display", "Spreadsheet", "Accessibility"];

    private SpreadsheetCellChangedEventArgs? _lastEdit;

    private readonly List<SpreadsheetRow> _rows = new()
    {
        new SpreadsheetRow { Cells = new() {
            SpreadsheetCell.Text("Item"),
            SpreadsheetCell.Text("Qty"),
            SpreadsheetCell.Text("Price"),
            SpreadsheetCell.Text("Total"),
        } },
        new SpreadsheetRow { Cells = new() {
            SpreadsheetCell.Text("Widget A"),
            SpreadsheetCell.Number(3),
            SpreadsheetCell.Number(12.5),
            SpreadsheetCell.FormulaExpr("=B2*C2"),
        } },
        new SpreadsheetRow { Cells = new() {
            SpreadsheetCell.Text("Widget B"),
            SpreadsheetCell.Number(5),
            SpreadsheetCell.Number(8),
            SpreadsheetCell.FormulaExpr("=B3*C3"),
        } },
        new SpreadsheetRow { Cells = new() {
            SpreadsheetCell.Text("Sum"),
            new SpreadsheetCell(),
            new SpreadsheetCell(),
            SpreadsheetCell.FormulaExpr("=SUM(D2:D3)"),
        } },
    };

    private Task HandleCellChanged(SpreadsheetCellChangedEventArgs args)
    {
        _lastEdit = args;
        return Task.CompletedTask;
    }
}
