@page "/components/data-display/spreadsheet/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Enums
@using Sunfish.UIAdapters.Blazor.Components.DataDisplay.Spreadsheet

<PageTitle>Spreadsheet / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Spreadsheet / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/DataDisplay/Spreadsheet/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishSpreadsheet</code> renders an Excel-style grid with A/B/C column headers, 1/2/3
            row headers, and per-cell text inputs. Back the grid with a <code>Data</code> matrix
            (<code>string[,]</code>), a list of <code>Rows</code> with typed cells, or just
            <code>RowCount</code> + <code>ColumnCount</code> for an empty canvas.
        </p>
        <p>
            Formulas are evaluated at render time. Supported forms: <code>=SUM(A1:A3)</code>,
            <code>=AVG(A1:A3)</code>, <code>=MIN</code>/<code>MAX</code>/<code>COUNT</code>, and basic
            <code>=A1+B2</code> arithmetic with <code>+</code>, <code>-</code>, <code>*</code>, <code>/</code>.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.25rem;">
            <div class="demo-row">
                <Sunfish.UIAdapters.Blazor.Components.DataDisplay.Spreadsheet.SunfishSpreadsheet Rows="_rows"
                                                                                                 Height="280px"
                                                                                                 OnCellChanged="HandleCellChanged" />
            </div>
            @if (_lastEdit is not null)
            {
                <div style="padding:8px;background:#e3f2fd;border-radius:4px;font-size:13px;">
                    Last edit: <strong>@SpreadsheetAddress.ToA1(_lastEdit.Row, _lastEdit.Column)</strong>
                    changed from "@(_lastEdit.OldValue ?? string.Empty)" to "@(_lastEdit.NewValue ?? string.Empty)"
                </div>
            }
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Data Display", "Spreadsheet", "Overview"];

    private SpreadsheetCellChangedEventArgs? _lastEdit;

    private readonly List<SpreadsheetRow> _rows = new()
    {
        new SpreadsheetRow { Cells = new() {
            SpreadsheetCell.Text("Item"),
            SpreadsheetCell.Text("Qty"),
            SpreadsheetCell.Text("Price"),
            SpreadsheetCell.Text("Total"),
        } },
        new SpreadsheetRow { Cells = new() {
            SpreadsheetCell.Text("Widget A"),
            SpreadsheetCell.Number(3),
            SpreadsheetCell.Number(12.5),
            SpreadsheetCell.FormulaExpr("=B2*C2"),
        } },
        new SpreadsheetRow { Cells = new() {
            SpreadsheetCell.Text("Widget B"),
            SpreadsheetCell.Number(5),
            SpreadsheetCell.Number(8),
            SpreadsheetCell.FormulaExpr("=B3*C3"),
        } },
        new SpreadsheetRow { Cells = new() {
            SpreadsheetCell.Text("Sum"),
            new SpreadsheetCell(),
            new SpreadsheetCell(),
            SpreadsheetCell.FormulaExpr("=SUM(D2:D3)"),
        } },
    };

    private Task HandleCellChanged(SpreadsheetCellChangedEventArgs args)
    {
        _lastEdit = args;
        return Task.CompletedTask;
    }
}
