@page "/components/data-display/map/accessibility"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Components.DataDisplay.Map
@using Sunfish.Foundation.Models

<PageTitle>Map / Accessibility · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Map / Accessibility"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/DataDisplay/Map/Accessibility/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishMap</code> is a canvas/tile-based widget driven by a custom keyboard
            model, not native form controls — so it is the canonical use case for
            <code>role="application"</code> with <code>aria-roledescription="map"</code> and a
            keyboard interaction contract documented inline. The visual map is supplemented by an
            equivalent textual marker list so screen-reader users, keyboard-only users, and users
            with Reduce-Motion / no-JS have a non-visual path to the same information
            (WCAG 1.1.1 Non-text Content, 2.1.1 Keyboard).
        </p>
        <p>
            A map control that relies only on mouse panning and zooming fails WCAG. The patterns
            below show (a) an application-shaped map container with a documented keyboard model
            and live-region announcements for pan / zoom, and (b) a parallel accessible data
            table that lists every marker with its coordinates and label. Both views are kept in
            sync and either is a valid alternative for users.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.75rem;">

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Map with application role &amp; live-region status</h3>
                <p style="margin:.25rem 0 .75rem 0; font-size:.9rem;">
                    The map wrapper advertises <code>role="application"</code> so AT hands raw
                    keystrokes to the widget; an <code>aria-roledescription</code> of
                    <em>map</em> names the pattern. A visually-hidden live region announces the
                    current viewport after pan / zoom.
                </p>
                <div role="application"
                     aria-roledescription="map"
                     aria-label="@_ariaLabel"
                     aria-describedby="map-kb-help"
                     tabindex="0"
                     style="height:400px; outline-offset:2px;">
                    <SunfishMap Center="@_dcCenter"
                                Zoom="12"
                                Height="100%"
                                Width="100%"
                                Markers="_markers"
                                OnZoomEnd="HandleZoomEnd"
                                OnPanEnd="HandlePanEnd">
                        <MapLayers>
                            <MapLayer Type="@MapLayerType.Tile"
                                      UrlTemplate="@_tileUrl"
                                      Attribution="@_tileAttribution"
                                      Subdomains="@_subdomains" />
                        </MapLayers>
                    </SunfishMap>
                </div>

                <div id="map-kb-help" style="margin-top:.5rem; font-size:.85rem; opacity:.8;">
                    Keyboard: <kbd>Arrow</kbd> keys pan, <kbd>+</kbd> / <kbd>-</kbd> zoom,
                    <kbd>Home</kbd> recenters, <kbd>Tab</kbd> moves focus to the next marker.
                </div>

                <div role="status" aria-live="polite" aria-atomic="true"
                     class="sf-visually-hidden"
                     style="position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;">
                    @_liveStatus
                </div>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Marker list — accessible data-table fallback</h3>
                <p style="margin:.25rem 0 .75rem 0; font-size:.9rem;">
                    Every marker on the map is also listed here as a focusable button. This is
                    the non-visual equivalent of the map and is the required WCAG 1.1.1 text
                    alternative for the marker data. Activating a row focuses the map on that
                    marker and announces the new center.
                </p>
                <table style="border-collapse:collapse; font-size:.9rem; min-width:100%;"
                       aria-label="Markers on the map">
                    <thead>
                        <tr>
                            <th style="text-align: start; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Place</th>
                            <th style="text-align: start; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Latitude</th>
                            <th style="text-align: start; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Longitude</th>
                            <th style="text-align: start; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Focus</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var marker in _markers)
                        {
                            <tr>
                                <td style="padding:.35rem .75rem;">@marker.Title</td>
                                <td style="padding:.35rem .75rem;">@marker.Latitude.ToString("F4")</td>
                                <td style="padding:.35rem .75rem;">@marker.Longitude.ToString("F4")</td>
                                <td style="padding:.35rem .75rem;">
                                    <SunfishButton Variant="ButtonVariant.Secondary"
                                                   Size="ButtonSize.Small"
                                                   OnClick="() => FocusMarker(marker)"
                                                   aria-label="@($"Center map on {marker.Title}")">Focus</SunfishButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">ARIA &amp; semantic contract</h3>
                <dl style="display:grid; grid-template-columns: max-content 1fr; column-gap:1rem; row-gap:.35rem; margin:0; font-size:.875rem;">
                    <dt><code>role="application"</code></dt>
                    <dd>Applied to the wrapper because the widget uses a custom keyboard model that must bypass screen-reader browse modes.</dd>
                    <dt><code>aria-roledescription="map"</code></dt>
                    <dd>Names the pattern for screen readers so users hear "map" instead of "application".</dd>
                    <dt><code>aria-label</code></dt>
                    <dd>Describes what the map shows — the viewport summary (center, zoom, marker count) updates as the map moves.</dd>
                    <dt><code>aria-describedby</code></dt>
                    <dd>Points at the visible "Keyboard: Arrow keys pan..." help text so the instructions are announced on focus.</dd>
                    <dt><code>role="status"</code> + <code>aria-live="polite"</code></dt>
                    <dd>Visually-hidden region that announces the updated viewport after a pan / zoom without stealing focus.</dd>
                    <dt><strong>Marker list</strong></dt>
                    <dd>Real <code>&lt;table&gt;</code> with a row per marker — the canonical WCAG 1.1.1 text alternative for the visual data.</dd>
                    <dt><strong>Focus indicator</strong></dt>
                    <dd>The map container is focusable (<code>tabindex="0"</code>) so keyboard users can enter it from the tab order.</dd>
                </dl>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Known gaps</h3>
                <ul style="margin:0; font-size:.875rem;">
                    <li>Arrow-key pan and <kbd>+</kbd> / <kbd>-</kbd> zoom are not yet implemented inside <code>SunfishMap</code> — the pattern above documents the target contract. Today the map responds to mouse and touch only. Planned for the a11y keyboard pass.</li>
                    <li>The marker list is authored at the demo level; a future API could let <code>SunfishMap</code> render this list as an opt-in <code>AlternativeView</code>.</li>
                    <li>Forced-colors (Windows High Contrast) verification is pending — marker glyphs need a non-color outline.</li>
                </ul>
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Data Display", "Map", "Accessibility"];

    private readonly string[] _subdomains = ["a", "b", "c"];
    private const string _tileUrl = "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png";
    private const string _tileAttribution = "&copy; <a href='https://osm.org/copyright'>OpenStreetMap contributors</a>";

    private readonly MapCenter _dcCenter = new() { Latitude = 38.8977, Longitude = -77.0365 };

    private readonly List<MapMarker> _markers = new()
    {
        new() { Title = "White House",   Latitude = 38.8977, Longitude = -77.0365 },
        new() { Title = "Capitol",       Latitude = 38.8899, Longitude = -77.0091 },
        new() { Title = "Lincoln Mem.",  Latitude = 38.8893, Longitude = -77.0502 },
        new() { Title = "Union Station", Latitude = 38.8973, Longitude = -77.0063 },
    };

    private string _ariaLabel =
        "Map of Washington DC. Center: 38.8977 N, -77.0365 W. Zoom level 12. 4 markers shown.";

    private string _liveStatus = string.Empty;

    private void HandleZoomEnd(MapZoomEndEventArgs args)
    {
        var c = args.Center;
        _liveStatus = c is null
            ? $"Zoom changed to {args.Zoom:F0}."
            : $"Zoom changed to {args.Zoom:F0}. Center: {c.Latitude:F4} N, {c.Longitude:F4} W.";
    }

    private void HandlePanEnd(MapPanEndEventArgs args)
    {
        var c = args.Center;
        if (c is null) return;
        _liveStatus = $"Map panned. Center: {c.Latitude:F4} N, {c.Longitude:F4} W.";
    }

    private void FocusMarker(MapMarker marker)
    {
        _liveStatus = $"Centered on {marker.Title}. {marker.Latitude:F4} N, {marker.Longitude:F4} W.";
    }
}
