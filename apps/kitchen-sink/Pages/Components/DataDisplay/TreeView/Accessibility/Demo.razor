@page "/components/navigation/treeview/accessibility"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>TreeView / Accessibility · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="TreeView / Accessibility"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/DataDisplay/TreeView/Accessibility/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishTreeView</code> implements the
            <a href="https://www.w3.org/WAI/ARIA/apg/patterns/treeview/" target="_blank" rel="noopener">WAI-ARIA
            TreeView pattern</a>. The root is a <code>&lt;ul role="tree"&gt;</code> labelled via
            the <code>AriaLabel</code> parameter, every node is a <code>&lt;li role="treeitem"&gt;</code>,
            and children are grouped into a nested <code>&lt;ul role="group"&gt;</code> that is
            revealed or hidden as its parent expands.
        </p>
        <p>
            Each treeitem exposes its state: <code>aria-expanded</code> is set whenever the node
            has children, <code>aria-selected</code> reflects selection, and (when
            <code>CheckBoxMode</code> is enabled) each row has a native
            <code>&lt;input type="checkbox"&gt;</code> with <code>aria-checked</code> surfacing
            the tri-state (<code>"true"</code>, <code>"false"</code>, <code>"mixed"</code>) used
            for partially-checked ancestors.
        </p>
        <p>
            Keyboard interaction follows the WAI-ARIA pattern — arrow keys navigate siblings and
            expand / collapse, <kbd>Enter</kbd> / <kbd>Space</kbd> select and toggle checkboxes,
            <kbd>Home</kbd> / <kbd>End</kbd> jump to the first / last visible node,
            <kbd>F2</kbd> starts inline editing when <code>AllowEditing</code> is on, and the
            single-character <kbd>*</kbd> expands all siblings of the focused node.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.5rem;">

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Try it with keyboard &amp; screen reader</h3>
                <p style="margin:.25rem 0 .75rem 0; font-size:.9rem;">
                    Click a node to give the tree focus, then try the keys listed below.
                    Checkboxes are in <code>Multiple</code> mode with full propagation — try
                    toggling a parent and watch ancestor/descendant aria state update.
                </p>
                <SunfishTreeView Data="_data"
                                 IdField="Id"
                                 ParentIdField="ParentId"
                                 TextField="Name"
                                 AriaLabel="Project files"
                                 SelectionMode="TreeSelectionMode.Multiple"
                                 CheckBoxMode="CheckBoxMode.Multiple"
                                 AllowCheckChildren="true"
                                 AllowCheckParents="true"
                                 ExpandedItems="@(new[] { "1", "2" })" />
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">ARIA &amp; semantic contract</h3>
                <dl style="display:grid; grid-template-columns: max-content 1fr; column-gap:1rem; row-gap:.35rem; margin:0;">
                    <dt><code>role="tree"</code> + <code>aria-label="..."</code></dt>
                    <dd>Root container — accessible name comes from <code>AriaLabel</code>.</dd>
                    <dt><code>role="treeitem"</code></dt>
                    <dd>Applied to every visible node.</dd>
                    <dt><code>aria-expanded="true" / "false"</code></dt>
                    <dd>Set on every node that has children.</dd>
                    <dt><code>aria-selected="true" / "false"</code></dt>
                    <dd>Reflects the node's selection state.</dd>
                    <dt><code>role="group"</code></dt>
                    <dd>Applied to the nested <code>&lt;ul&gt;</code> that holds children.</dd>
                    <dt><code>aria-checked="true" / "false" / "mixed"</code></dt>
                    <dd>Tri-state on the per-node checkbox. <code>"mixed"</code> is announced as "partially checked".</dd>
                    <dt><code>Disabled</code></dt>
                    <dd>Blocks all interaction; the toggle button is also marked <code>disabled</code>.</dd>
                    <dt><code>ReadOnly</code></dt>
                    <dd>Visual state stays but selection / checking cannot change.</dd>
                </dl>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Keyboard shortcuts</h3>
                <table style="border-collapse:collapse; font-size:.9rem;">
                    <thead>
                        <tr>
                            <th style="text-align: start; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Keys</th>
                            <th style="text-align: start; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Effect</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Arrow Down</kbd></td><td style="padding:.35rem .75rem;">Move focus to the next visible node.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Arrow Up</kbd></td><td style="padding:.35rem .75rem;">Move focus to the previous visible node.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Arrow Right</kbd></td><td style="padding:.35rem .75rem;">Expand a collapsed parent, or move to its first child if already expanded.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Arrow Left</kbd></td><td style="padding:.35rem .75rem;">Collapse an expanded parent, or move focus to the parent node.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Home</kbd> / <kbd>End</kbd></td><td style="padding:.35rem .75rem;">Focus the first / last visible node.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Enter</kbd> or <kbd>Space</kbd></td><td style="padding:.35rem .75rem;">Toggle checkbox (if shown) and select the focused node.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>*</kbd></td><td style="padding:.35rem .75rem;">Expand all siblings of the focused node at its level.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>F2</kbd></td><td style="padding:.35rem .75rem;">Start inline editing (when <code>AllowEditing</code> is true).</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Escape</kbd></td><td style="padding:.35rem .75rem;">Cancel inline editing without committing.</td></tr>
                    </tbody>
                </table>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Screen-reader output (expected)</h3>
                <pre style="background:var(--sunfish-surface-muted, #f3f4f6); padding:.75rem; border-radius:.375rem; font-size:.85rem; overflow:auto;"><code>Project files, tree
  Documents, treeitem, expanded
    group
      Reports, treeitem, expanded
        group
          Q1.pdf, treeitem, level 3
          Q2.pdf, treeitem, level 3
      Images, treeitem, collapsed
  Downloads, treeitem, level 1</code></pre>
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Navigation", "TreeView", "Accessibility"];

    private record FileNode(string Id, string? ParentId, string Name);

    private readonly List<FileNode> _data = new()
    {
        new("1", null, "Documents"),
        new("2", "1", "Reports"),
        new("3", "2", "Q1.pdf"),
        new("4", "2", "Q2.pdf"),
        new("5", "1", "Images"),
        new("6", "5", "logo.png"),
        new("7", null, "Downloads"),
    };
}
