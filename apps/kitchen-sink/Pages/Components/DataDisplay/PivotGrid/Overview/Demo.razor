@page "/components/data-display/pivotgrid/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Enums
@using Sunfish.UIAdapters.Blazor.Components.DataDisplay.Pivot

<PageTitle>PivotGrid / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="PivotGrid / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/DataDisplay/PivotGrid/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishPivotGrid&lt;TItem&gt;</code> cross-tabulates a flat data source into row groups,
            column groups, and measure aggregates. Declare dimensions via <code>RowFields</code> /
            <code>ColumnFields</code>, add one or more <code>Measures</code> (each with a
            <code>PivotAggregation</code>), and toggle <code>ShowGrandTotals</code> /
            <code>ShowSubTotals</code>.
        </p>
        <p>
            The MVP surface uses server-side reflection and in-memory <code>GroupBy</code>; virtualization,
            cell merging, named ranges, and export are deferred.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.25rem;">
            <div class="demo-row">
                <Sunfish.UIAdapters.Blazor.Components.DataDisplay.Pivot.SunfishPivotGrid TItem="SalesRecord"
                                                                                        Data="_salesData"
                                                                                        RowFields="_rowFields"
                                                                                        ColumnFields="_columnFields"
                                                                                        Measures="_measures"
                                                                                        ShowGrandTotals="true"
                                                                                        Height="320px" />
            </div>
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Data Display", "PivotGrid", "Overview"];

    private readonly List<string> _rowFields = new() { "Region" };
    private readonly List<string> _columnFields = new() { "Product" };
    private readonly List<PivotMeasure> _measures = new()
    {
        new PivotMeasure
        {
            Field = "Revenue",
            Aggregation = PivotAggregation.Sum,
            DisplayName = "Revenue",
            Format = "C0",
        },
    };

    private readonly List<SalesRecord> _salesData = new()
    {
        new SalesRecord("North", "Widget A", 1200),
        new SalesRecord("North", "Widget B", 800),
        new SalesRecord("South", "Widget A", 950),
        new SalesRecord("South", "Widget B", 1100),
        new SalesRecord("East",  "Widget A", 700),
        new SalesRecord("East",  "Widget B", 1500),
        new SalesRecord("West",  "Widget A", 1300),
        new SalesRecord("West",  "Widget B", 600),
    };

    public record SalesRecord(string Region, string Product, double Revenue);
}
