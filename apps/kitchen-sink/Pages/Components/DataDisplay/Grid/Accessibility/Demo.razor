@page "/components/data-display/grid/accessibility"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Grid / Accessibility · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Grid / Accessibility"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/DataDisplay/Grid/Accessibility/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            The <strong>Grid</strong> entry point renders <code>SunfishDataGrid&lt;TItem&gt;</code> — it
            is the same Blazor component as <a href="/components/data-display/datagrid/accessibility">DataGrid</a>,
            exposed under this route for Telerik-style naming parity. Because the grid emits a real HTML
            <code>&lt;table&gt;</code>, native table semantics (<code>&lt;thead&gt;</code>,
            <code>&lt;tbody&gt;</code>, <code>&lt;th scope="col"&gt;</code>, <code>&lt;td&gt;</code>) carry
            through to assistive tech without any <code>role</code> overrides.
        </p>
        <p>
            This page focuses on the <em>table-flavoured</em> a11y contract — caption / labelled-by linkage,
            <code>aria-sort</code> on sortable headers, and keyboard cell navigation via
            <code>Navigable="true"</code>. For the full feature-matrix demo (selection, paging, editing),
            see the DataGrid page.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.5rem;">

            <section>
                <h3 id="grid-a11y-heading" style="margin:0 0 .5rem 0; font-size:.95rem;">Quarterly revenue by region</h3>
                <p id="grid-a11y-desc" style="margin:.25rem 0 .75rem 0; font-size:.9rem; opacity:.85;">
                    Click a column header to sort; <code>aria-sort</code> updates live. Tab into the grid,
                    then use arrow keys to move between cells.
                </p>
                <SunfishDataGrid Data="_revenue"
                                 TItem="RegionRevenue"
                                 aria-labelledby="grid-a11y-heading"
                                 aria-describedby="grid-a11y-desc"
                                 Sortable="true"
                                 Navigable="true">
                    <SunfishGridColumn TItem="RegionRevenue" Field="@nameof(RegionRevenue.Region)" Title="Region" />
                    <SunfishGridColumn TItem="RegionRevenue" Field="@nameof(RegionRevenue.Q1)" Title="Q1" Format="C0" TextAlign="right" />
                    <SunfishGridColumn TItem="RegionRevenue" Field="@nameof(RegionRevenue.Q2)" Title="Q2" Format="C0" TextAlign="right" />
                    <SunfishGridColumn TItem="RegionRevenue" Field="@nameof(RegionRevenue.Q3)" Title="Q3" Format="C0" TextAlign="right" />
                    <SunfishGridColumn TItem="RegionRevenue" Field="@nameof(RegionRevenue.Q4)" Title="Q4" Format="C0" TextAlign="right" />
                </SunfishDataGrid>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">ARIA &amp; semantic contract</h3>
                <dl style="display:grid; grid-template-columns: max-content 1fr; column-gap:1rem; row-gap:.35rem; margin:0; font-size:.9rem;">
                    <dt><code>&lt;table&gt;</code> (native)</dt>
                    <dd>Real table element — no <code>role="grid"</code> override. Cell/header association is native.</dd>
                    <dt><code>&lt;th scope="col"&gt;</code></dt>
                    <dd>Every column header gets <code>scope="col"</code> so screen readers announce the header with each cell.</dd>
                    <dt><code>aria-labelledby</code> / <code>aria-label</code></dt>
                    <dd>Pair the grid with a visible heading (shown above) or pass <code>aria-label</code> directly for a standalone accessible name.</dd>
                    <dt><code>aria-describedby</code></dt>
                    <dd>Optional — link to descriptive prose (instructions, data disclaimers).</dd>
                    <dt><code>aria-sort="ascending" / "descending" / "none"</code></dt>
                    <dd>Automatically applied to the active sort column; absent / "none" on the rest.</dd>
                    <dt><code>&lt;caption&gt;</code></dt>
                    <dd>Not emitted by <code>SunfishDataGrid</code>; prefer <code>aria-labelledby</code> pointing at a visible <code>&lt;h*&gt;</code>.</dd>
                    <dt><code>aria-rowcount</code> / <code>aria-colcount</code></dt>
                    <dd>Not required for the default (non-virtual) grid. For row-virtualized data (DataGrid <em>Virtualization</em> demo) these should be set to the total row count — currently <strong>planned</strong>.</dd>
                </dl>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Keyboard shortcuts</h3>
                <table style="border-collapse:collapse; font-size:.9rem;">
                    <thead>
                        <tr>
                            <th style="text-align: start; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Keys</th>
                            <th style="text-align: start; padding:.35rem .75rem; border-bottom:1px solid var(--sunfish-border, #d1d5db);">Effect</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Tab</kbd></td><td style="padding:.35rem .75rem;">Enter / leave the grid (single-stop, cell focus is internal).</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Arrow Up</kbd> / <kbd>Down</kbd></td><td style="padding:.35rem .75rem;">Move between rows in the focused column.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Arrow Left</kbd> / <kbd>Right</kbd></td><td style="padding:.35rem .75rem;">Move between columns in the focused row.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Home</kbd> / <kbd>End</kbd></td><td style="padding:.35rem .75rem;">Jump to first / last cell of the focused row.</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Enter</kbd> on a header</td><td style="padding:.35rem .75rem;">Toggle sort (ascending → descending → none).</td></tr>
                        <tr><td style="padding:.35rem .75rem;"><kbd>Space</kbd></td><td style="padding:.35rem .75rem;">Activate the focused command / selection checkbox (when enabled).</td></tr>
                    </tbody>
                </table>
            </section>

            <section>
                <h3 style="margin:0 0 .5rem 0; font-size:.9rem; opacity:.7; text-transform:uppercase; letter-spacing:.05em;">Screen-reader output (expected)</h3>
                <pre style="background:var(--sunfish-surface-muted, #f3f4f6); padding:.75rem; border-radius:.375rem; font-size:.85rem; overflow:auto;"><code>Quarterly revenue by region, table, 5 columns, 4 rows
  Region, column header, sort ascending
  Q1, column header
  ...
  Row 1: North, $48,000, $52,000, ...
  Region: North
  Q2: $52,000</code></pre>
            </section>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Data Display", "Grid", "Accessibility"];

    private record RegionRevenue(string Region, decimal Q1, decimal Q2, decimal Q3, decimal Q4);

    private readonly List<RegionRevenue> _revenue =
    [
        new("North", 48_000m, 52_000m, 61_000m, 58_000m),
        new("South", 39_500m, 42_100m, 47_800m, 51_200m),
        new("East",  55_200m, 58_400m, 60_100m, 63_500m),
        new("West",  42_800m, 44_600m, 49_300m, 53_100m),
    ];
}
