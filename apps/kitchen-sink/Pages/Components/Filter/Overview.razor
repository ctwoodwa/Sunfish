@page "/components/filter"
@page "/components/filter/overview"
@layout ComponentDemoLayout
@using FilterOperator = Sunfish.Foundation.Models.FilterOperator
@using FilterDescriptor = Sunfish.Foundation.Models.FilterDescriptor
@using CompositeFilterDescriptor = Sunfish.Foundation.Models.CompositeFilterDescriptor

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="A composable filter builder for constructing query expressions with add, remove, and apply." Code="@_basicCode">
        <SunfishFilter @bind-Value="_filter" OnApply="HandleApply" />
        @if (_applied)
        {
            <div style="margin-top:12px;padding:12px;background:#f5f5f5;border-radius:4px;">
                <strong>Applied filter:</strong>
                @if (_filter?.FilterDescriptors.Count > 0)
                {
                    <ul style="margin:8px 0 0 0;">
                        @foreach (var fd in _filter.FilterDescriptors)
                        {
                            <li>@fd.Field @fd.Operator @fd.Value</li>
                        }
                    </ul>
                }
                else
                {
                    <span>No filter rows</span>
                }
            </div>
        }
    </DemoSection>

    <DemoSection Title="Pre-populated Filter" Description="Initialize the filter with existing descriptors." Code="@_prepopCode">
        <SunfishFilter Value="@_preFilter" ValueChanged="v => _preFilter = v" />
    </DemoSection>
</PageSection>

@code {
    private CompositeFilterDescriptor? _filter = new();
    private bool _applied;

    private CompositeFilterDescriptor? _preFilter = new()
    {
        LogicalOperator = FilterCompositionLogicalOperator.And,
        FilterDescriptors = new List<FilterDescriptor>
        {
            new() { Field = "Name", Operator = FilterOperator.Contains, Value = "Sunfish" },
            new() { Field = "Status", Operator = FilterOperator.IsEqualTo, Value = "Active" }
        }
    };

    private void HandleApply()
    {
        _applied = true;
    }

    private const string _basicCode =
        "<SunfishFilter @bind-Value=\"_filter\" OnApply=\"HandleApply\" />\n\n" +
        "@code {\n" +
        "    private CompositeFilterDescriptor? _filter = new();\n" +
        "\n" +
        "    private void HandleApply()\n" +
        "    {\n" +
        "        // Use _filter.FilterDescriptors to build query\n" +
        "    }\n" +
        "}";

    private const string _prepopCode =
        "<SunfishFilter Value=\"@_filter\" ValueChanged=\"v => _filter = v\" />\n\n" +
        "@code {\n" +
        "    private CompositeFilterDescriptor? _filter = new()\n" +
        "    {\n" +
        "        FilterDescriptors = new()\n" +
        "        {\n" +
        "            new() { Field = \"Name\", Operator = FilterOperator.Contains, Value = \"Sunfish\" }\n" +
        "        }\n" +
        "    };\n" +
        "}";
}
