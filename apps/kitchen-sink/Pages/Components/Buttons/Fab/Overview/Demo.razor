@page "/components/buttons/fab/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Fab / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Fab / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Buttons/Fab/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>The Floating Action Button (FAB) represents the primary action on a screen.</p>
        <p>
            This overview page is a stub — the live demo is forthcoming. The component is tracked
            in the Sunfish example catalog for cross-provider parity.
        </p>
    </Narrative>

    <Example>
        <div class="demo-placeholder" style="padding: 1.5rem; border: 1px dashed var(--sunfish-border, #d1d5db); border-radius: .5rem; color: var(--sunfish-muted, #6b7280); text-align: center;">
            <strong>Fab</strong> — overview demo coming soon.
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Buttons", "Fab", "Overview"];
}
