@page "/components/buttons/fab/events"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Fab / Events · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Fab / Events"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Buttons/Fab/Events/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishFab</code> exposes a single semantic callback — <code>OnClick</code> —
            carrying the underlying <code>MouseEventArgs</code>. Because the component
            forwards <code>AdditionalAttributes</code> onto the rendered <code>&lt;button&gt;</code>,
            DOM-level <code>focus</code> / <code>blur</code> events are available through the
            standard <code>@@onfocus</code> and <code>@@onblur</code> pass-through directives.
        </p>
        <p>
            The two FABs below are rendered inline (<code>PositionMode="static"</code>) so the
            event log can sit next to them. Click each one, tab through them, and watch
            the log on the right.
        </p>
    </Narrative>

    <Example>
        <div style="display:grid; grid-template-columns: minmax(0, 1fr) 320px; gap:1rem; align-items:start;">

            <div>
                <div class="demo-row" style="display:flex; flex-wrap:wrap; gap:1rem; align-items:center;">
                    <SunfishFab PositionMode="static"
                                Size="FabSize.Medium"
                                Icon="plus"
                                OnClick="@(e => Append("OnClick", $"Compose (button {e.Button})"))"
                                @onfocus="@(() => Append("focus", "Compose"))"
                                @onblur="@(() => Append("blur", "Compose"))">
                        Compose
                    </SunfishFab>

                    <SunfishFab PositionMode="static"
                                Size="FabSize.Medium"
                                Icon="edit"
                                OnClick="@(e => Append("OnClick", $"Edit (button {e.Button})"))"
                                @onfocus="@(() => Append("focus", "Edit"))"
                                @onblur="@(() => Append("blur", "Edit"))" />

                    <SunfishFab PositionMode="static"
                                Size="FabSize.Medium"
                                Icon="plus"
                                Enabled="false"
                                OnClick="@(_ => Append("OnClick", "Disabled (will not fire)"))" />
                </div>

                <p style="margin:.75rem 0 0; color:#555; font-size:.9rem;">
                    Compose clicks: <strong>@_composeClicks</strong> — Edit clicks: <strong>@_editClicks</strong>
                </p>

                <div style="margin-top:1rem;">
                    <h4 style="margin:0 0 .5rem;">Async OnClick (simulated save)</h4>
                    <SunfishFab PositionMode="static" Size="FabSize.Medium" Icon="check"
                                Enabled="@(!_saving)"
                                OnClick="HandleAsyncSave">
                        @(_saving ? "Saving…" : "Save")
                    </SunfishFab>
                    <span style="margin-left:.75rem; color:#555; font-size:.85rem;">
                        Status: <strong>@_saveStatus</strong>
                    </span>
                </div>

                <div style="margin-top:1rem; display:flex; gap:.5rem; align-items:center;">
                    <SunfishButton Variant="ButtonVariant.Secondary" OnClick="ClearLog">Clear log</SunfishButton>
                    <span style="color:#666; font-size:.85rem;">Events captured: @_log.Count</span>
                </div>
            </div>

            <aside style="border:1px solid var(--sf-color-border, #ddd); border-radius:4px; background:var(--sf-color-surface, #fafafa); height:380px; display:flex; flex-direction:column;">
                <header style="padding:.5rem .75rem; font-weight:600; border-bottom:1px solid var(--sf-color-border, #ddd);">
                    Event log
                </header>
                <ol style="flex:1; overflow:auto; margin:0; padding:.5rem .75rem .5rem 2rem; font-family:ui-monospace, SFMono-Regular, Menlo, monospace; font-size:.8rem; line-height:1.45;">
                    @if (_log.Count == 0)
                    {
                        <li style="list-style:none; color:#888;">(no events yet)</li>
                    }
                    else
                    {
                        @foreach (var entry in _log)
                        {
                            <li>
                                <span style="color:#888;">[@entry.Timestamp.ToString("HH:mm:ss.fff")]</span>
                                <strong>@entry.Event</strong> — @entry.Detail
                            </li>
                        }
                    }
                </ol>
            </aside>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Buttons", "Fab", "Events"];

    private record LogEntry(DateTime Timestamp, string Event, string Detail);
    private readonly List<LogEntry> _log = new();
    private int _composeClicks;
    private int _editClicks;
    private bool _saving;
    private string _saveStatus = "idle";

    private async Task HandleAsyncSave()
    {
        _saving = true;
        _saveStatus = "saving";
        Append("OnClick", "Save (async started)");
        try
        {
            await Task.Delay(800);
            _saveStatus = "saved";
            Append("async", "Save completed");
        }
        finally
        {
            _saving = false;
        }
    }

    private void Append(string evt, string detail)
    {
        if (evt == "OnClick" && detail.StartsWith("Compose")) _composeClicks++;
        if (evt == "OnClick" && detail.StartsWith("Edit"))    _editClicks++;

        _log.Add(new LogEntry(DateTime.Now, evt, detail));
        if (_log.Count > 200) _log.RemoveAt(0);
    }

    private void ClearLog() => _log.Clear();
}
