@page "/components/loader"
@page "/components/loader/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="A loader displays a centered loading indicator." Code="@_basicCode">
        <div style="height: 120px; position: relative; border: 1px solid #e0e0e0; border-radius: 4px;">
            <SunfishLoader Visible="@_visible" Text="Loading data..." />
        </div>
        <div class="demo-row" style="margin-top: 8px;">
            <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _visible = !_visible)">
                @(_visible ? "Hide" : "Show") Loader
            </SunfishButton>
        </div>
    </DemoSection>

    <DemoSection Title="With Content Overlay" Description="When child content is provided, the loader overlays on top of it." Code="@_overlayCode">
        <SunfishLoader Visible="@_overlayVisible" Text="Refreshing...">
            <div style="padding: 24px; border: 1px solid #e0e0e0; border-radius: 4px;">
                <p>This content is overlaid by the loader when visible.</p>
                <p>Item 1 - Product A</p>
                <p>Item 2 - Product B</p>
                <p>Item 3 - Product C</p>
            </div>
        </SunfishLoader>
        <div class="demo-row" style="margin-top: 8px;">
            <SunfishButton Size="ButtonSize.Small" OnClick="@(() => _overlayVisible = !_overlayVisible)">
                Toggle Overlay
            </SunfishButton>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Sizes" Description="Choose from small, medium, or large spinner sizes." Code="@_sizesCode">
        <div class="demo-row" style="gap: 32px; align-items: center;">
            <div style="text-align: center;">
                <SunfishLoader Size="SpinnerSize.Small" Text="Small" />
            </div>
            <div style="text-align: center;">
                <SunfishLoader Size="SpinnerSize.Medium" Text="Medium" />
            </div>
            <div style="text-align: center;">
                <SunfishLoader Size="SpinnerSize.Large" Text="Large" />
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Custom Theme Color" Description="Apply a custom color to the loader text." Code="@_themeColorCode">
        <SunfishLoader Text="Loading with custom color" ThemeColor="#0078d4" />
    </DemoSection>
</PageSection>

@code {
    private bool _visible = true;
    private bool _overlayVisible = true;

    private const string _basicCode =
        "<SunfishLoader Visible=\"@_visible\" Text=\"Loading data...\" />\n\n" +
        "<SunfishButton OnClick=\"@(() => _visible = !_visible)\">\n" +
        "    Toggle Loader\n" +
        "</SunfishButton>\n\n" +
        "@code { private bool _visible = true; }";

    private const string _overlayCode =
        "<SunfishLoader Visible=\"@_overlayVisible\" Text=\"Refreshing...\">\n" +
        "    <div style=\"padding: 24px;\">\n" +
        "        <p>This content is overlaid by the loader.</p>\n" +
        "    </div>\n" +
        "</SunfishLoader>\n\n" +
        "@code { private bool _overlayVisible = true; }";

    private const string _sizesCode =
        "<SunfishLoader Size=\"SpinnerSize.Small\" Text=\"Small\" />\n" +
        "<SunfishLoader Size=\"SpinnerSize.Medium\" Text=\"Medium\" />\n" +
        "<SunfishLoader Size=\"SpinnerSize.Large\" Text=\"Large\" />";

    private const string _themeColorCode =
        "<SunfishLoader Text=\"Loading with custom color\" ThemeColor=\"#0078d4\" />";
}
