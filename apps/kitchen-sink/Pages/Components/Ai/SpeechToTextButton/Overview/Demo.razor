@page "/components/ai/speechtotextbutton/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Components.AI

<PageTitle>SpeechToTextButton / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="SpeechToTextButton / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/AI/SpeechToTextButton/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishSpeechToTextButton</code> wraps the browser Web Speech API
            (<code>window.SpeechRecognition</code> / <code>window.webkitSpeechRecognition</code>)
            as a toggleable microphone button. The <code>Language</code> parameter forwards a
            BCP-47 code, <code>Continuous</code> controls whether recognition persists until the
            user clicks again, and recognized text is emitted via the
            <code>OnTranscribe</code> callback.
        </p>
        <p>
            <strong>MVP status:</strong> the button shell and feature-detection stub land in this
            release; full JS-module wiring that actually starts/stops recognition and round-trips
            transcripts via <code>DotNetObjectReference</code> is deferred to a follow-up
            (mapping remains <em>partial</em>).
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:.75rem;">
            <SunfishSpeechToTextButton Language="en-US"
                                       Continuous="false"
                                       OnTranscribe="HandleTranscribe" />
            @if (!string.IsNullOrEmpty(_transcript))
            {
                <p style="font-size:.85rem; opacity:.8;">Transcript: <strong>@_transcript</strong></p>
            }
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "AI", "SpeechToTextButton", "Overview"];

    private string? _transcript;

    private void HandleTranscribe(string text)
    {
        _transcript = string.IsNullOrEmpty(text) ? "(stopped)" : text;
    }
}
