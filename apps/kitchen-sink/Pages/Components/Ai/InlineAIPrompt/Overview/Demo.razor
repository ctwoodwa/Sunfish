@page "/components/ai/inlineaiprompt/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Components.AI

<PageTitle>InlineAIPrompt / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="InlineAIPrompt / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/AI/InlineAIPrompt/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishInlineAIPrompt</code> is the contextual inline prompt popover for
            rewriting or expanding a selection of text. The surface is toggled via the
            <code>Show</code> parameter (two-way bound), the editor content is bound to
            <code>Value</code>, and confirmation fires a cancellable
            <code>OnInline</code> event carrying an
            <code>InlineAIPromptEventArgs</code>. Optional <code>Suggestions</code> render as
            quick-action chips under the editor.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1rem;">
            <div>
                <button type="button" class="sf-btn sf-btn--primary"
                        style="padding:.5rem 1rem; cursor:pointer;"
                        @onclick="() => _show = true">
                    Open inline prompt
                </button>
            </div>
            <SunfishInlineAIPrompt @bind-Show="_show"
                                   @bind-Value="_value"
                                   Suggestions="_suggestions"
                                   OnInline="HandleInlineAsync" />
            @if (!string.IsNullOrEmpty(_lastResult))
            {
                <p style="font-size:.85rem; opacity:.8;">Last result: <strong>@_lastResult</strong></p>
            }
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "AI", "InlineAIPrompt", "Overview"];

    private bool _show;
    private string? _value = "Sunfish is a UI toolkit.";
    private string? _lastResult;

    private readonly List<string> _suggestions = new()
    {
        "Shorten",
        "Expand",
        "Fix grammar",
        "Make it friendlier",
    };

    private Task HandleInlineAsync(InlineAIPromptEventArgs args)
    {
        _lastResult = args.Prompt;
        return Task.CompletedTask;
    }
}
