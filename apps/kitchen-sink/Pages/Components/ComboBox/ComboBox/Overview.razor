@page "/components/ComboBox"
@page "/components/ComboBox/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Code="@_basicCode">
        <SunfishField>
            <SunfishLabel>Country</SunfishLabel>
            <SunfishComboBox TItem="Country"
                            TValue="int?"
                            Data="@_countries"
                            TextField="Name"
                            ValueField="Id"
                            Value="@_selectedValue"
                            ValueChanged="@(v => _selectedValue = v)"
                            Placeholder="Type to search..." />
        </SunfishField>
        <p><strong>Selected ID:</strong> @_selectedValue</p>
    </DemoSection>
</PageSection>

<PageSection Title="Features">
    <DemoSection Title="StartsWith Filter" Description="Filter using StartsWith mode instead of Contains." Code="@_startsWithCode">
        <SunfishComboBox TItem="Country"
                        TValue="int?"
                        Data="@_countries"
                        TextField="Name"
                        ValueField="Id"
                        Value="@_startsWithValue"
                        ValueChanged="@(v => _startsWithValue = v)"
                        FilterMode="ComboBoxFilterMode.StartsWith"
                        Placeholder="Type to filter..." />
    </DemoSection>

    <DemoSection Title="Clear Button" Description="Show a clear button to reset the selection." Code="@_clearCode">
        <SunfishComboBox TItem="Country"
                        TValue="int?"
                        Data="@_countries"
                        TextField="Name"
                        ValueField="Id"
                        Value="@_clearValue"
                        ValueChanged="@(v => _clearValue = v)"
                        ShowClearButton="true"
                        Placeholder="Select or type..." />
    </DemoSection>
</PageSection>

@code {
    private int? _selectedValue;
    private int? _startsWithValue;
    private int? _clearValue;

    private record Country(int Id, string Name, string Code);

    private readonly List<Country> _countries = new()
    {
        new(1, "United States", "US"),
        new(2, "Canada", "CA"),
        new(3, "United Kingdom", "GB"),
        new(4, "Germany", "DE"),
        new(5, "France", "FR"),
        new(6, "Japan", "JP"),
        new(7, "Australia", "AU"),
        new(8, "Brazil", "BR"),
    };

    private const string _basicCode =
        "<SunfishComboBox TItem=\"Country\" TValue=\"int\"\n" +
        "                Data=\"@_countries\"\n" +
        "                TextField=\"Name\" ValueField=\"Id\"\n" +
        "                Value=\"@_selected\" ValueChanged=\"@(v => _selected = v)\"\n" +
        "                Placeholder=\"Type to search...\" />";

    private const string _startsWithCode =
        "<SunfishComboBox TItem=\"Country\" TValue=\"int\"\n" +
        "                Data=\"@_countries\"\n" +
        "                TextField=\"Name\" ValueField=\"Id\"\n" +
        "                FilterMode=\"ComboBoxFilterMode.StartsWith\"\n" +
        "                Placeholder=\"Type to filter...\" />";

    private const string _clearCode =
        "<SunfishComboBox TItem=\"Country\" TValue=\"int\"\n" +
        "                Data=\"@_countries\"\n" +
        "                TextField=\"Name\" ValueField=\"Id\"\n" +
        "                ShowClearButton=\"true\"\n" +
        "                Placeholder=\"Select or type...\" />";
}
