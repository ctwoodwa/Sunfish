@page "/components/DataSheet/virtualization"
@layout ComponentDemoLayout
@using Sunfish.Foundation.Enums
@using Sunfish.Foundation.Models.DataSheet
@using Sunfish.UIAdapters.Blazor.Components.DataDisplay

<PageSection Title="Virtualization">
    <p>
        This page demonstrates <code>SunfishDataSheet</code> virtualization with
        varying row counts. Only rows visible in the viewport (plus an overscan
        buffer of 5 rows) are rendered to the DOM at any time. Toggle the row
        count selector to see performance with 100, 1,000, and 5,000 rows.
    </p>
    <p>
        <em>10,000 rows are supported with <code>EnableVirtualization=true</code>
        in Blazor Server; the demo caps at 5,000 due to WASM host constraints.
        See the virtualization-and-performance spec for thresholds.</em>
    </p>
</PageSection>

<PageSection Title="A -- Row Count Toggle">
    <DemoSection Title="Virtualized Grid"
                 Description="Select a row count. The grid re-populates with generated data and enables virtualization for 1,000 and 5,000 rows.">

        <div class="ds-demo-controls" style="margin-bottom:12px;">
            <label>Row count: </label>
            <button @onclick='() => SetRowCount(100)' class="@(ActiveCss(100))">100</button>
            <button @onclick='() => SetRowCount(1000)' class="@(ActiveCss(1000))">1,000</button>
            <button @onclick='() => SetRowCount(5000)' class="@(ActiveCss(5000))">5,000</button>
            <span style="margin-left:12px;">Current: @_currentCount rows</span>
        </div>

        <SunfishDataSheet TItem="VirtRow"
                         Data="@_virtRows"
                         KeyField="Id"
                         EnableVirtualization="@(_currentCount >= 1000)"
                         Height="400px"
                         OnSaveAll="@HandleVirtSave"
                         EmptyStateMessage="Select a row count above.">
            <SunfishDataSheetColumn TItem="VirtRow"
                                   Field="Name" Title="Name" ColumnType="DataSheetColumnType.Text"
                                   Editable="true" Width="200px" />
            <SunfishDataSheetColumn TItem="VirtRow"
                                   Field="Value" Title="Value" ColumnType="DataSheetColumnType.Number"
                                   Editable="true" Width="120px" />
            <SunfishDataSheetColumn TItem="VirtRow"
                                   Field="Category" Title="Category" ColumnType="DataSheetColumnType.Text"
                                   Editable="true" Width="160px" />
            <SunfishDataSheetColumn TItem="VirtRow"
                                   Field="IsEnabled" Title="Enabled" ColumnType="DataSheetColumnType.Checkbox"
                                   Editable="true" Width="100px" />
        </SunfishDataSheet>
    </DemoSection>
</PageSection>

@code {
    private int _currentCount = 100;
    private List<VirtRow> _virtRows = [];

    protected override void OnInitialized()
    {
        SetRowCount(100);
    }

    private void SetRowCount(int count)
    {
        _currentCount = count;
        _virtRows = Enumerable.Range(1, count)
            .Select(i => new VirtRow
            {
                Name = $"Item {i}",
                Value = i * 1.5m,
                Category = i % 3 == 0 ? "Alpha" : i % 3 == 1 ? "Beta" : "Gamma",
                IsEnabled = i % 2 == 0
            })
            .ToList();
    }

    private string ActiveCss(int count) =>
        _currentCount == count ? "ds-btn-active" : "";

    private Task HandleVirtSave(DataSheetSaveArgs<VirtRow> args) => Task.CompletedTask;

    private record VirtRow
    {
        public Guid Id { get; init; } = Guid.NewGuid();
        public string Name { get; set; } = "";
        public decimal Value { get; set; }
        public string Category { get; set; } = "";
        public bool IsEnabled { get; set; }
    }
}
