        "        Constrained: Min 150px, Max 400px\n" +
        "    </SunfishSplitterPane>\n" +
        "    <SunfishSplitterPane>\n" +
        "        Flexible Pane\n" +
        "    </SunfishSplitterPane>\n" +
        "</SunfishSplitter>";

    private const string _nonResizableCode =
