        "    <SunfishSplitterPane Size=\"200px\" Resizable=\"false\">\n" +
        "        Fixed (200px)\n" +
        "    </SunfishSplitterPane>\n" +
        "    <SunfishSplitterPane Size=\"50%\">\n" +
        "        Resizable Pane\n" +
        "    </SunfishSplitterPane>\n" +
        "    <SunfishSplitterPane>\n" +
        "        Fill Pane\n" +
        "    </SunfishSplitterPane>\n" +
        "</SunfishSplitter>";

    private const string _collapsibleCode =
        "<SunfishSplitter Orientation=\"SplitterOrientation.Horizontal\" Collapsible=\"true\"\n" +
        "                OnCollapse=\"@OnCollapseHandler\" OnExpand=\"@OnExpandHandler\">\n" +
        "    <SunfishSplitterPane Size=\"30%\">\n" +
        "        Sidebar\n" +
        "    </SunfishSplitterPane>\n" +
        "    <SunfishSplitterPane>\n" +
