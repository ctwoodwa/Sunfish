@page "/components/splitter"
@page "/components/splitter/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Horizontal" Description="Drag the separator to resize panes. Sizes are expressed in percentages." Code="@_basicCode">
        <div class="demo-row" style="height:300px;">
            <SunfishSplitter Orientation="SplitterOrientation.Horizontal">
                <SunfishSplitterPane Size="50%">
                    <div style="padding:1rem;">Left Pane</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane Size="50%">
                    <div style="padding:1rem;">Right Pane</div>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
    </DemoSection>

    <DemoSection Title="Vertical Orientation" Description="Set Orientation to Vertical to stack panes top-to-bottom." Code="@_verticalCode">
        <div class="demo-row" style="height:400px;">
            <SunfishSplitter Orientation="SplitterOrientation.Vertical" Height="100%">
                <SunfishSplitterPane Size="40%">
                    <div style="padding:1rem;">Top Pane</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane>
                    <div style="padding:1rem;">Bottom Pane (fills remaining space)</div>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Constraints">
    <DemoSection Title="Min / Max Size" Description="Use Min and Max to constrain pane sizes. Try dragging past the limits." Code="@_constraintsCode">
        <div class="demo-row" style="height:300px;">
            <SunfishSplitter Orientation="SplitterOrientation.Horizontal">
                <SunfishSplitterPane Size="250px" Min="150px" Max="400px">
                    <div style="padding:1rem;">
                        <strong>Constrained Pane</strong><br />
                        Min: 150px &middot; Max: 400px
                    </div>
                </SunfishSplitterPane>
                <SunfishSplitterPane>
                    <div style="padding:1rem;">Flexible Pane</div>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
    </DemoSection>

    <DemoSection Title="Non-Resizable Pane" Description="Set Resizable=false to lock a pane's size." Code="@_nonResizableCode">
        <div class="demo-row" style="height:300px;">
            <SunfishSplitter Orientation="SplitterOrientation.Horizontal">
                <SunfishSplitterPane Size="200px" Resizable="false">
                    <div style="padding:1rem;">
                        <strong>Fixed (200px)</strong><br />
                        Resizable = false
                    </div>
                </SunfishSplitterPane>
                <SunfishSplitterPane Size="50%">
                    <div style="padding:1rem;">Resizable Pane</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane>
                    <div style="padding:1rem;">Fill Pane</div>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Collapse">
    <DemoSection Title="Collapsible Panes" Description="Double-click the separator or click the collapse button to toggle. Keyboard: press Enter on a focused separator." Code="@_collapsibleCode">
        <div class="demo-row" style="height:300px;">
            <SunfishSplitter Orientation="SplitterOrientation.Horizontal" Collapsible="true"
                            OnCollapse="@OnCollapseHandler" OnExpand="@OnExpandHandler">
                <SunfishSplitterPane Size="30%">
                    <div style="padding:1rem;">Sidebar</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane>
                    <div style="padding:1rem;">
                        Main Content
                        @if (!string.IsNullOrEmpty(_collapseLog))
                        {
                            <div style="margin-top:0.5rem;font-size:0.8rem;color:var(--sf-color-text-secondary);">
                                @_collapseLog
                            </div>
                        }
                    </div>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Multiple Panes">
    <DemoSection Title="Three Panes" Description="The splitter supports any number of panes. The last pane automatically fills remaining space." Code="@_threePaneCode">
        <div class="demo-row" style="height:300px;">
            <SunfishSplitter Orientation="SplitterOrientation.Horizontal" Collapsible="true">
                <SunfishSplitterPane Size="200px" Min="120px">
                    <div style="padding:1rem;">Navigation</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane Size="50%">
                    <div style="padding:1rem;">Content</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane Min="150px">
                    <div style="padding:1rem;">Details</div>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
    </DemoSection>

    <DemoSection Title="Nested Splitters" Description="Nest splitters with different orientations to build complex layouts." Code="@_nestedCode">
        <div class="demo-row" style="height:400px;">
            <SunfishSplitter Orientation="SplitterOrientation.Horizontal" Height="100%">
                <SunfishSplitterPane Size="200px" Min="120px">
                    <div style="padding:1rem;">Sidebar</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane>
                    <SunfishSplitter Orientation="SplitterOrientation.Vertical" Height="100%">
                        <SunfishSplitterPane Size="60%">
                            <div style="padding:1rem;">Editor</div>
                        </SunfishSplitterPane>
                        <SunfishSplitterPane>
                            <div style="padding:1rem;">Terminal</div>
                        </SunfishSplitterPane>
                    </SunfishSplitter>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Events">
    <DemoSection Title="Resize Events" Description="OnResizeStart, OnResize, and OnResizeEnd fire during the drag lifecycle." Code="@_eventsCode">
        <div class="demo-row" style="height:300px;">
            <SunfishSplitter Orientation="SplitterOrientation.Horizontal"
                            OnResizeStart="@OnResizeStartHandler"
                            OnResize="@OnResizeHandler"
                            OnResizeEnd="@OnResizeEndHandler">
                <SunfishSplitterPane Size="50%">
                    <div style="padding:1rem;">Drag to resize</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane>
                    <div style="padding:1rem;">
                        <strong>Event Log</strong>
                        <div style="font-size:0.8rem;white-space:pre-wrap;max-height:200px;overflow:auto;margin-top:0.5rem;">@_eventLog</div>
                    </div>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
    </DemoSection>

    <DemoSection Title="State Management" Description="Use GetState() and SetState() to save and restore splitter layout." Code="@_stateCode">
        <div style="margin-bottom:0.5rem;">
            <SunfishButton OnClick="SaveState">Save State</SunfishButton>
            <SunfishButton OnClick="RestoreState" Disabled="@(_savedState is null)">Restore State</SunfishButton>
        </div>
        <div class="demo-row" style="height:300px;">
            <SunfishSplitter @ref="_stateSplitter" Orientation="SplitterOrientation.Horizontal" Collapsible="true">
                <SunfishSplitterPane Size="30%">
                    <div style="padding:1rem;">Pane 1</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane Size="40%">
                    <div style="padding:1rem;">Pane 2</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane>
                    <div style="padding:1rem;">Pane 3</div>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
        @if (_savedState is not null)
        {
            <div style="font-size:0.8rem;margin-top:0.5rem;color:var(--sf-color-text-secondary);">
                Saved: @string.Join(", ", _savedState.PaneSizes)
            </div>
        }
    </DemoSection>
</PageSection>

<PageSection Title="Styling">
    <DemoSection Title="Custom Bar Size" Description="Override --mar-splitter-bar-size to change the separator thickness." Code="@_barSizeCode">
        <div class="demo-row" style="height:250px;">
            <SunfishSplitter Orientation="SplitterOrientation.Horizontal"
                            Style="--mar-splitter-bar-size: 10px;">
                <SunfishSplitterPane Size="50%">
                    <div style="padding:1rem;">Thicker separator (10px)</div>
                </SunfishSplitterPane>
                <SunfishSplitterPane>
                    <div style="padding:1rem;">Right Pane</div>
                </SunfishSplitterPane>
            </SunfishSplitter>
        </div>
    </DemoSection>
</PageSection>

@code {
    // ── Collapse demo ───────────────────────────────────────────────────
    private string _collapseLog = "";

    private void OnCollapseHandler(SplitterCollapseEventArgs args)
    {
        _collapseLog = $"Pane {args.PaneIndex} collapsed";
    }

    private void OnExpandHandler(SplitterCollapseEventArgs args)
    {
        _collapseLog = $"Pane {args.PaneIndex} expanded";
    }

    // ── Events demo ─────────────────────────────────────────────────────
    private string _eventLog = "";

    private void OnResizeStartHandler(SplitterResizeEventArgs args)
    {
        _eventLog = $"ResizeStart: pane {args.PaneIndex}\n" + _eventLog;
    }

    private void OnResizeHandler(SplitterResizeEventArgs args)
    {
        // Only keep last few lines to avoid flooding
        var lines = _eventLog.Split('\n');
        if (lines.Length > 20)
            _eventLog = string.Join('\n', lines[..20]);
        _eventLog = $"Resize: pane {args.PaneIndex} → {args.NewSize}\n" + _eventLog;
    }

    private void OnResizeEndHandler(SplitterResizeEventArgs args)
    {
        _eventLog = $"ResizeEnd: pane {args.PaneIndex} → {args.NewSize}\n" + _eventLog;
    }

    // ── State demo ──────────────────────────────────────────────────────
    private SunfishSplitter? _stateSplitter;
    private SplitterState? _savedState;

    private void SaveState()
    {
        _savedState = _stateSplitter?.GetState();
    }

    private void RestoreState()
    {
        if (_savedState is not null)
            _stateSplitter?.SetState(_savedState);
    }

    // ── Code snippets ───────────────────────────────────────────────────
    private const string _basicCode =
        "<SunfishSplitter Orientation=\"SplitterOrientation.Horizontal\">\n" +
        "    <SunfishSplitterPane Size=\"50%\">\n" +
        "        Left Pane\n" +
        "    </SunfishSplitterPane>\n" +
        "    <SunfishSplitterPane Size=\"50%\">\n" +
        "        Right Pane\n" +
        "    </SunfishSplitterPane>\n" +
        "</SunfishSplitter>";

    private const string _verticalCode =
