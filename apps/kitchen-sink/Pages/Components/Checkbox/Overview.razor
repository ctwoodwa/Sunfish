@page "/components/Checkbox"
@page "/components/Checkbox/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Code="@_basicCode">
        <SunfishField>
            <SunfishCheckbox @bind-Checked="_checked" Label="Accept terms and conditions" />
        </SunfishField>
        <p><strong>Checked:</strong> @_checked</p>
    </DemoSection>

    <DemoSection Title="Indeterminate" Description="The indeterminate state represents a partially checked state, commonly used for parent checkboxes in a tree." Code="@_indeterminateCode">
        <SunfishField>
            <SunfishCheckbox Indeterminate="true" Label="Select all (indeterminate)" />
        </SunfishField>
        <div style="margin-left:16px;display:flex;flex-direction:column;gap:4px;">
            <SunfishField>
                <SunfishCheckbox @bind-Checked="_childA" Label="Option A" />
            </SunfishField>
            <SunfishField>
                <SunfishCheckbox @bind-Checked="_childB" Label="Option B" />
            </SunfishField>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Label Position" Description="Control whether the label appears before or after the checkbox with LabelPosition." Code="@_labelPositionCode">
        <SunfishField>
            <SunfishCheckbox @bind-Checked="_labelAfter" Label="Label after (default)" LabelPosition="after" />
        </SunfishField>
        <SunfishField>
            <SunfishCheckbox @bind-Checked="_labelBefore" Label="Label before" LabelPosition="before" />
        </SunfishField>
    </DemoSection>

    <DemoSection Title="Disabled" Description="A disabled checkbox prevents user interaction." Code="@_disabledCode">
        <SunfishField>
            <SunfishCheckbox Checked="true" Enabled="false" Label="Checked and disabled" />
        </SunfishField>
        <SunfishField>
            <SunfishCheckbox Checked="false" Enabled="false" Label="Unchecked and disabled" />
        </SunfishField>
    </DemoSection>
</PageSection>

<PageSection Title="Events">
    <DemoSection Title="CheckedChanged" Description="Handle checkbox toggle with the CheckedChanged callback, or use two-way binding." Code="@_interactiveCode">
        <SunfishField>
            <SunfishCheckbox Checked="@_evChecked" CheckedChanged="@(v => _evChecked = v)" Label="Toggle me" />
        </SunfishField>
        <p><strong>Checked:</strong> @_evChecked</p>
    </DemoSection>
</PageSection>

<PageSection Title="Accessibility">
    <AccessibilityInfo
        KeyboardInteractions="@_keyboard"
        AriaAttributes="@_aria"
        ScreenReaderNotes="@_screenReader" />
</PageSection>

@code {
    // Overview
    private bool _checked;
    private bool _childA;
    private bool _childB;

    // Appearance
    private bool _labelAfter = true;
    private bool _labelBefore;

    // Events
    private bool _evChecked;

    private const string _basicCode =
        "<SunfishCheckbox @bind-Checked=\"_checked\" Label=\"Accept terms and conditions\" />\n\n" +
        "@code { private bool _checked; }";

    private const string _indeterminateCode =
        "<SunfishCheckbox Indeterminate=\"true\" Label=\"Select all (indeterminate)\" />\n" +
        "<SunfishCheckbox @bind-Checked=\"_childA\" Label=\"Option A\" />\n" +
        "<SunfishCheckbox @bind-Checked=\"_childB\" Label=\"Option B\" />";

    private const string _labelPositionCode =
        "<SunfishCheckbox @bind-Checked=\"_val\" Label=\"Label after (default)\" LabelPosition=\"after\" />\n" +
        "<SunfishCheckbox @bind-Checked=\"_val\" Label=\"Label before\" LabelPosition=\"before\" />";

    private const string _disabledCode =
        "<SunfishCheckbox Checked=\"true\" Enabled=\"false\" Label=\"Checked and disabled\" />\n" +
        "<SunfishCheckbox Checked=\"false\" Enabled=\"false\" Label=\"Unchecked and disabled\" />";

    private const string _interactiveCode =
        "<SunfishCheckbox Checked=\"@_checked\" CheckedChanged=\"@(v => _checked = v)\" Label=\"Toggle me\" />\n" +
        "<p><strong>Checked:</strong> @_checked</p>\n\n" +
        "@code {\n" +
        "    private bool _checked;\n" +
        "}";

    private static readonly (string Key, string Action)[] _keyboard =
    [
        ("Tab", "Moves focus to the checkbox"),
        ("Shift + Tab", "Moves focus to the previous focusable element"),
        ("Space", "Toggles the checkbox checked state"),
    ];

    private static readonly (string Attribute, string Description)[] _aria =
    [
        ("role=\"checkbox\"", "Implicitly set by the <input type=\"checkbox\"> element"),
        ("aria-checked", "Reflects the current checked state; \"mixed\" for indeterminate"),
        ("aria-disabled=\"true\"", "Applied when Enabled is false"),
        ("aria-label", "Provided by the Label parameter"),
    ];

    private static readonly string[] _screenReader =
    [
        "Checkboxes are announced with their label, checked state, and the \"checkbox\" role.",
        "Toggling the checkbox announces the new state (\"checked\" or \"not checked\").",
        "Indeterminate checkboxes are announced as \"mixed\" by screen readers.",
        "Disabled checkboxes are announced as \"dimmed\" or \"unavailable\" depending on the screen reader.",
    ];
}
