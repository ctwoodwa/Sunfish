@page "/components/ColorPicker"
@page "/components/ColorPicker/overview"
@layout ComponentDemoLayout
@using Sunfish.Foundation.Enums
@using Sunfish.Foundation.Models

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Code="@_basicCode">
        <SunfishColorPicker @bind-Value="@_color" />
        <div style="width: 48px; height: 48px; background: @(_color ?? "transparent"); border-radius: 4px; margin-top: 8px; border: 1px solid #ccc;"></div>
        <p><strong>Selected color:</strong> @(_color ?? "(none)")</p>
    </DemoSection>
</PageSection>

<PageSection Title="Value Format">
    <DemoSection Title="Hex Format" Description="Returns colors as #rrggbb hex strings." Code="@_hexCode">
        <SunfishColorPicker @bind-Value="@_hexColor" ValueFormat="ColorFormat.Hex" />
        <p><strong>Hex value:</strong> @_hexColor</p>
    </DemoSection>

    <DemoSection Title="RGB Format" Description="Returns colors as rgb(r, g, b) strings (default)." Code="@_rgbCode">
        <SunfishColorPicker @bind-Value="@_rgbColor" ValueFormat="ColorFormat.Rgb" />
        <p><strong>RGB value:</strong> @_rgbColor</p>
    </DemoSection>
</PageSection>

<PageSection Title="Views">
    <DemoSection Title="Gradient View" Description="HSV canvas with hue slider and text inputs." Code="@_gradientCode">
        <SunfishColorPicker @bind-Value="@_gradColor" View="ColorPickerView.Gradient" />
        <p><strong>Color:</strong> @_gradColor</p>
    </DemoSection>

    <DemoSection Title="Palette View" Description="Color swatches for quick selection." Code="@_paletteCode">
        <SunfishColorPicker @bind-Value="@_palColor" View="ColorPickerView.Palette" />
        <p><strong>Color:</strong> @_palColor</p>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Show Buttons" Description="Apply / Cancel buttons are shown by default." Code="@_buttonsCode">
        <SunfishColorPicker @bind-Value="@_btnColor" ShowButtons="true" />
    </DemoSection>

    <DemoSection Title="No Buttons (instant apply)" Description="ShowButtons=false commits the color immediately on selection." Code="@_noBtnsCode">
        <SunfishColorPicker @bind-Value="@_noBtnColor" ShowButtons="false" />
        <p><strong>Color:</strong> @_noBtnColor</p>
    </DemoSection>

    <DemoSection Title="Without Clear Button" Code="@_noClearCode">
        <SunfishColorPicker @bind-Value="@_noClearColor" ShowClearButton="false" />
    </DemoSection>

    <DemoSection Title="Without Preview" Code="@_noPreviewCode">
        <SunfishColorPicker @bind-Value="@_noPreviewColor" ShowPreview="false" />
    </DemoSection>

    <DemoSection Title="Disabled" Description="A disabled color picker prevents user interaction." Code="@_disabledCode">
        <SunfishColorPicker Value="#0078d4" Disabled="true" />
    </DemoSection>
</PageSection>

<PageSection Title="Events">
    <DemoSection Title="OnChange + ValueChanged" Description="Handle color events." Code="@_eventsCode">
        <SunfishColorPicker @bind-Value="@_evColor"
                           OnChange="@OnColorChange"
                           OnOpen="@OnColorPickerOpen"
                           OnClose="@OnColorPickerClose" />
        <div style="width: 48px; height: 48px; background: @(_evColor ?? "transparent"); border-radius: 4px; margin-top: 8px; border: 1px solid #ccc;"></div>
        <ul>
            @foreach (var log in _eventLog.TakeLast(5))
            {
                <li>@log</li>
            }
        </ul>
    </DemoSection>
</PageSection>

<PageSection Title="Programmatic Control">
    <DemoSection Title="Open / Close via Reference" Code="@_refCode">
        <SunfishColorPicker @bind-Value="@_refColor" @ref="_cpRef" />
        <button type="button" @onclick="async () => { if (_cpRef is not null) await _cpRef.Open(); }">Open</button>
        <button type="button" @onclick="async () => { if (_cpRef is not null) await _cpRef.Close(); }">Close</button>
    </DemoSection>
</PageSection>

<PageSection Title="Accessibility">
    <AccessibilityInfo
        KeyboardInteractions="@_keyboard"
        AriaAttributes="@_aria"
        ScreenReaderNotes="@_screenReader" />
</PageSection>

@code {
    private string? _color = "#0078d4";
    private string? _hexColor = "#ff5733";
    private string? _rgbColor = "rgb(40, 47, 137)";
    private string? _gradColor = "#00b050";
    private string? _palColor = "#ff0000";
    private string? _btnColor = "#0078d4";
    private string? _noBtnColor = "#800080";
    private string? _noClearColor = "#008080";
    private string? _noPreviewColor = "#808000";
    private string? _evColor = "#0078d4";
    private string? _refColor = "#c0392b";
    private SunfishColorPicker? _cpRef;

    private readonly List<string> _eventLog = new();

    private void OnColorChange(object newColor) =>
        _eventLog.Add($"OnChange: {newColor}");

    private void OnColorPickerOpen(ColorPickerOpenEventArgs args) =>
        _eventLog.Add("OnOpen fired");

    private void OnColorPickerClose(ColorPickerCloseEventArgs args) =>
        _eventLog.Add("OnClose fired");

    private const string _basicCode =
        "<SunfishColorPicker @bind-Value=\"@_color\" />\n\n" +
        "@code { private string? _color = \"#0078d4\"; }";

    private const string _hexCode =
        "<SunfishColorPicker @bind-Value=\"@_hexColor\" ValueFormat=\"ColorFormat.Hex\" />";

    private const string _rgbCode =
        "<SunfishColorPicker @bind-Value=\"@_rgbColor\" ValueFormat=\"ColorFormat.Rgb\" />";

    private const string _gradientCode =
        "<SunfishColorPicker @bind-Value=\"@_color\" View=\"ColorPickerView.Gradient\" />";

    private const string _paletteCode =
        "<SunfishColorPicker @bind-Value=\"@_color\" View=\"ColorPickerView.Palette\" />";

    private const string _buttonsCode =
        "<SunfishColorPicker @bind-Value=\"@_color\" ShowButtons=\"true\" />";

    private const string _noBtnsCode =
        "<SunfishColorPicker @bind-Value=\"@_color\" ShowButtons=\"false\" />";

    private const string _noClearCode =
        "<SunfishColorPicker @bind-Value=\"@_color\" ShowClearButton=\"false\" />";

    private const string _noPreviewCode =
        "<SunfishColorPicker @bind-Value=\"@_color\" ShowPreview=\"false\" />";

    private const string _disabledCode =
        "<SunfishColorPicker Value=\"#0078d4\" Disabled=\"true\" />";

    private const string _eventsCode =
        "<SunfishColorPicker @bind-Value=\"@_color\"\n" +
        "                   OnChange=\"@OnColorChange\"\n" +
        "                   OnOpen=\"@OnOpen\"\n" +
        "                   OnClose=\"@OnClose\" />\n\n" +
        "@code {\n" +
        "    private void OnColorChange(object c) => Console.WriteLine(c);\n" +
        "    private void OnOpen(ColorPickerOpenEventArgs a) { }\n" +
        "    private void OnClose(ColorPickerCloseEventArgs a) { }\n" +
        "}";

    private const string _refCode =
        "<SunfishColorPicker @bind-Value=\"@_color\" @ref=\"_cpRef\" />\n" +
        "<button @onclick=\"() => _cpRef?.Open()\">Open</button>\n\n" +
        "@code { private SunfishColorPicker? _cpRef; }";

    private static readonly (string Key, string Action)[] _keyboard =
    [
        ("Tab", "Moves focus to the color picker trigger button"),
        ("Shift + Tab", "Moves focus to the previous focusable element"),
        ("Enter / Space", "Opens or closes the color picker popup"),
        ("Escape", "Cancels and closes the popup"),
        ("Enter (in popup)", "Applies the selected color and closes the popup"),
        ("Arrow keys (canvas)", "Adjusts saturation (horizontal) and brightness (vertical) by 2%"),
    ];

    private static readonly (string Attribute, string Description)[] _aria =
    [
        ("aria-haspopup=\"dialog\"", "Trigger button announces it opens a dialog"),
        ("aria-expanded", "Reflects whether the popup is open"),
        ("aria-label", "Trigger button announces the current color value"),
        ("aria-disabled=\"true\"", "Applied when Disabled=true / Enabled=false"),
        ("role=\"dialog\" + aria-modal=\"true\"", "Popup panel identified as a modal dialog"),
        ("role=\"grid\"", "Palette swatches organised as a grid"),
        ("role=\"gridcell\"", "Each palette swatch announced with its color value"),
    ];

    private static readonly string[] _screenReader =
    [
        "The trigger button announces its label and current color value when focused.",
        "Opening the popup moves the ARIA context into a modal dialog.",
        "Palette tiles are individually labelled with their hex color values.",
        "The canvas has a descriptive label and supports keyboard arrow-key navigation.",
        "Sliders announce their current numeric values (hue 0–360, opacity 0–100%).",
    ];
}
