@page "/components/validation"
@page "/components/validation/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="Validation components display field-level and summary validation messages." Code="@_basicCode">
        <div class="demo-row">
            <SunfishForm>
                <SunfishField>
                    <SunfishLabel>Required Field</SunfishLabel>
                    <SunfishTextBox @bind-Value="_value" />
                </SunfishField>
                <SunfishAlert Severity="@(_value is null or { Length: 0 } ? AlertSeverity.Warning : AlertSeverity.Success)">
                    @(_value is null or { Length: 0 } ? "This field is required." : "Looks good!")
                </SunfishAlert>
            </SunfishForm>
        </div>
    </DemoSection>
</PageSection>

@code {
    private string? _value;

    private const string _basicCode =
        "<SunfishField>\n" +
        "    <SunfishLabel>Required Field</SunfishLabel>\n" +
        "    <SunfishTextBox @bind-Value=\"_value\" />\n" +
        "    <SunfishValidationMessage TValue=\"string\" Message=\"This field is required.\" />\n" +
        "</SunfishField>";
}
