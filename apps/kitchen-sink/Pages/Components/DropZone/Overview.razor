@page "/components/dropzone"
@page "/components/dropzone/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="A drag-and-drop file zone that accepts files via drag or click." Code="@_basicCode">
        <SunfishDropZone OnDrop="HandleDrop" Note="Supports JPG, PNG, and PDF up to 10 MB" />
        @if (!string.IsNullOrEmpty(_status))
        {
            <p><strong>Status:</strong> @_status</p>
        }
    </DemoSection>

    <DemoSection Title="Restricted Types" Description="Limit accepted file types using the Accept parameter." Code="@_restrictedCode">
        <SunfishDropZone Accept=".pdf,.docx"
                        Multiple="true"
                        MaxFileSize="@(5 * 1024 * 1024)"
                        Note="Only PDF and DOCX files, max 5 MB each"
                        OnDrop="HandleDrop" />
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Custom Content" Description="Use ChildContent to provide custom drop zone content." Code="@_customCode">
        <SunfishDropZone OnDrop="HandleDrop">
            <div style="text-align:center;padding:32px;">
                <p style="font-size:1.25rem;font-weight:600;">Upload your documents</p>
                <p style="color:#666;">Drop files here or click to browse</p>
            </div>
        </SunfishDropZone>
    </DemoSection>

    <DemoSection Title="Disabled" Description="A disabled drop zone prevents file upload." Code="@_disabledCode">
        <SunfishDropZone Enabled="false" Note="Uploads are currently disabled" />
    </DemoSection>
</PageSection>

@code {
    private string? _status;

    private void HandleDrop(DropZoneEventArgs args)
    {
        _status = "Drop event received. Files would be processed here.";
    }

    private const string _basicCode =
        "<SunfishDropZone OnDrop=\"HandleDrop\" Note=\"Supports JPG, PNG, and PDF up to 10 MB\" />\n\n" +
        "@code {\n" +
        "    private void HandleDrop(DropZoneEventArgs args)\n" +
        "    {\n" +
        "        // Process dropped files\n" +
        "    }\n" +
        "}";

    private const string _restrictedCode =
        "<SunfishDropZone Accept=\".pdf,.docx\"\n" +
        "                Multiple=\"true\"\n" +
        "                MaxFileSize=\"@(5 * 1024 * 1024)\"\n" +
        "                Note=\"Only PDF and DOCX files, max 5 MB each\"\n" +
        "                OnDrop=\"HandleDrop\" />";

    private const string _customCode =
        "<SunfishDropZone OnDrop=\"HandleDrop\">\n" +
        "    <div style=\"text-align:center;padding:32px;\">\n" +
        "        <p style=\"font-size:1.25rem;font-weight:600;\">Upload your documents</p>\n" +
        "        <p style=\"color:#666;\">Drop files here or click to browse</p>\n" +
        "    </div>\n" +
        "</SunfishDropZone>";

    private const string _disabledCode =
        "<SunfishDropZone Enabled=\"false\" Note=\"Uploads are currently disabled\" />";
}
