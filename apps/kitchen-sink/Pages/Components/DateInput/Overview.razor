@page "/components/dateinput"
@page "/components/dateinput/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="A keyboard-driven date input field that parses and formats date values." Code="@_basicCode">
        <SunfishDateInput @bind-Value="_date" Placeholder="Enter a date" />
        <p><strong>Selected:</strong> @(_date?.ToString("MM/dd/yyyy") ?? "none")</p>
    </DemoSection>

    <DemoSection Title="Min and Max" Description="Restrict the selectable date range with Min and Max." Code="@_rangeCode">
        <SunfishDateInput @bind-Value="_rangeDate"
                         Min="@_minDate"
                         Max="@_maxDate"
                         Width="220px" />
        <p><strong>Selected:</strong> @(_rangeDate?.ToString("MM/dd/yyyy") ?? "none")</p>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Custom Width" Description="Set the width of the input using the Width parameter." Code="@_widthCode">
        <SunfishDateInput @bind-Value="_widthDate" Width="300px" />
    </DemoSection>

    <DemoSection Title="Disabled and Read-Only" Description="Prevent user interaction with Enabled or ReadOnly." Code="@_disabledCode">
        <div style="display:flex;gap:16px;">
            <SunfishDateInput Value="@DateTime.Today" Enabled="false" />
            <SunfishDateInput Value="@DateTime.Today" ReadOnly="true" />
        </div>
    </DemoSection>
</PageSection>

@code {
    private DateTime? _date;
    private DateTime? _rangeDate = DateTime.Today;
    private DateTime? _widthDate;
    private DateTime _minDate = DateTime.Today.AddDays(-30);
    private DateTime _maxDate = DateTime.Today.AddDays(30);

    private const string _basicCode =
        "<SunfishDateInput @bind-Value=\"_date\" Placeholder=\"Enter a date\" />\n" +
        "<p><strong>Selected:</strong> @(_date?.ToString(\"MM/dd/yyyy\") ?? \"none\")</p>\n\n" +
        "@code {\n" +
        "    private DateTime? _date;\n" +
        "}";

    private const string _rangeCode =
        "<SunfishDateInput @bind-Value=\"_date\"\n" +
        "                 Min=\"@_minDate\"\n" +
        "                 Max=\"@_maxDate\"\n" +
        "                 Width=\"220px\" />";

    private const string _widthCode =
        "<SunfishDateInput @bind-Value=\"_date\" Width=\"300px\" />";

    private const string _disabledCode =
        "<SunfishDateInput Value=\"@DateTime.Today\" Enabled=\"false\" />\n" +
        "<SunfishDateInput Value=\"@DateTime.Today\" ReadOnly=\"true\" />";
}
