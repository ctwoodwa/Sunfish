@page "/components/appbar"
@page "/components/appbar/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="AppBar provides a top-level navigation bar for your application." Code="@_basicCode">
        <div class="demo-row">
            <SunfishAppBar Position="AppBarPosition.Top">
                <span>My Application</span>
            </SunfishAppBar>
        </div>
    </DemoSection>
</PageSection>

@code {
    private const string _basicCode =
        "<SunfishAppBar Position=\"AppBarPosition.Top\">\n" +
        "    <span>My Application</span>\n" +
        "</SunfishAppBar>";
}
