@page "/components/Avatar"
@page "/components/Avatar/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="Avatars display initials representing a user or entity." Code="@_basicCode">
        <div class="demo-row">
            <SunfishAvatar Initials="AB" />
            <SunfishAvatar Initials="CD" />
            <SunfishAvatar Initials="EF" />
        </div>
    </DemoSection>

    <DemoSection Title="Image Avatar" Description="Provide a Src URL to show a photo. Use Alt for accessible text." Code="@_imageCode">
        <div class="demo-row">
            <SunfishAvatar Src="https://i.pravatar.cc/80?img=1" Alt="Alice Johnson" />
            <SunfishAvatar Src="https://i.pravatar.cc/80?img=5" Alt="Bob Smith" />
            <SunfishAvatar Src="https://i.pravatar.cc/80?img=12" Alt="Carol White" />
        </div>
    </DemoSection>

    <DemoSection Title="Custom Content" Description="Use ChildContent for icons or custom markup inside the avatar." Code="@_childCode">
        <div class="demo-row">
            <SunfishAvatar>👤</SunfishAvatar>
            <SunfishAvatar>🤖</SunfishAvatar>
            <SunfishAvatar>★</SunfishAvatar>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Sizes" Description="Avatars are available in multiple sizes." Code="@_sizesCode">
        <div class="demo-row">
            <SunfishAvatar Size="AvatarSize.ExtraSmall" Initials="XS" />
            <SunfishAvatar Size="AvatarSize.Small" Initials="SM" />
            <SunfishAvatar Size="AvatarSize.Medium" Initials="MD" />
            <SunfishAvatar Size="AvatarSize.Large" Initials="LG" />
            <SunfishAvatar Size="AvatarSize.ExtraLarge" Initials="XL" />
        </div>
    </DemoSection>

    <DemoSection Title="Bordered" Description="Add a visible border around the avatar with Bordered." Code="@_borderedCode">
        <div class="demo-row">
            <SunfishAvatar Initials="AB" Bordered="true" />
            <SunfishAvatar Src="https://i.pravatar.cc/80?img=3" Alt="User" Bordered="true" />
            <SunfishAvatar Initials="CD" Bordered="true" Size="AvatarSize.Large" />
        </div>
    </DemoSection>

    <DemoSection Title="Square vs Round" Description="Set Rounded to false for a square avatar." Code="@_roundedCode">
        <div class="demo-row">
            <SunfishAvatar Initials="RD" Rounded="true" />
            <SunfishAvatar Initials="SQ" Rounded="false" />
            <SunfishAvatar Src="https://i.pravatar.cc/80?img=8" Alt="Round" Rounded="true" />
            <SunfishAvatar Src="https://i.pravatar.cc/80?img=8" Alt="Square" Rounded="false" />
        </div>
    </DemoSection>

    <DemoSection Title="Custom Size" Description="Set explicit pixel dimensions with Width and Height." Code="@_customSizeCode">
        <div class="demo-row">
            <SunfishAvatar Initials="64" Width="64px" Height="64px" />
            <SunfishAvatar Initials="32" Width="32px" Height="32px" />
            <SunfishAvatar Src="https://i.pravatar.cc/96?img=15" Alt="Custom" Width="96px" Height="96px" />
        </div>
    </DemoSection>

    <DemoSection Title="Avatar Group" Description="Stack multiple avatars together for a compact group display." Code="@_groupCode">
        <div style="display:flex;flex-direction:row;">
            <div style="margin-right:-8px;"><SunfishAvatar Src="https://i.pravatar.cc/40?img=1" Alt="User 1" Size="AvatarSize.Small" Bordered="true" /></div>
            <div style="margin-right:-8px;"><SunfishAvatar Src="https://i.pravatar.cc/40?img=2" Alt="User 2" Size="AvatarSize.Small" Bordered="true" /></div>
            <div style="margin-right:-8px;"><SunfishAvatar Src="https://i.pravatar.cc/40?img=3" Alt="User 3" Size="AvatarSize.Small" Bordered="true" /></div>
            <SunfishAvatar Initials="+5" Size="AvatarSize.Small" Bordered="true" />
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Accessibility">
    <AccessibilityInfo
        KeyboardInteractions="@_keyboard"
        AriaAttributes="@_aria"
        ScreenReaderNotes="@_screenReader" />
</PageSection>

@code {
    // Overview
    private const string _basicCode =
        "<SunfishAvatar Initials=\"AB\" />\n" +
        "<SunfishAvatar Initials=\"CD\" />\n" +
        "<SunfishAvatar Initials=\"EF\" />";

    private const string _imageCode =
        "<SunfishAvatar Src=\"https://i.pravatar.cc/80?img=1\" Alt=\"Alice Johnson\" />\n" +
        "<SunfishAvatar Src=\"https://i.pravatar.cc/80?img=5\" Alt=\"Bob Smith\" />";

    private const string _childCode =
        "<SunfishAvatar>👤</SunfishAvatar>\n" +
        "<SunfishAvatar>🤖</SunfishAvatar>";

    // Appearance
    private const string _sizesCode =
        "<SunfishAvatar Size=\"AvatarSize.ExtraSmall\" Initials=\"XS\" />\n" +
        "<SunfishAvatar Size=\"AvatarSize.Small\" Initials=\"SM\" />\n" +
        "<SunfishAvatar Size=\"AvatarSize.Medium\" Initials=\"MD\" />\n" +
        "<SunfishAvatar Size=\"AvatarSize.Large\" Initials=\"LG\" />\n" +
        "<SunfishAvatar Size=\"AvatarSize.ExtraLarge\" Initials=\"XL\" />";

    private const string _borderedCode =
        "<SunfishAvatar Initials=\"AB\" Bordered=\"true\" />\n" +
        "<SunfishAvatar Src=\"...\" Alt=\"User\" Bordered=\"true\" />";

    private const string _roundedCode =
        "<SunfishAvatar Initials=\"RD\" Rounded=\"true\" />\n" +
        "<SunfishAvatar Initials=\"SQ\" Rounded=\"false\" />";

    private const string _customSizeCode =
        "<SunfishAvatar Initials=\"64\" Width=\"64px\" Height=\"64px\" />\n" +
        "<SunfishAvatar Initials=\"32\" Width=\"32px\" Height=\"32px\" />\n" +
        "<SunfishAvatar Src=\"...\" Alt=\"Custom\" Width=\"96px\" Height=\"96px\" />";

    private const string _groupCode =
        "@* Overlap avatars with negative margins *@\n" +
        "<div style=\"display:flex;\">\n" +
        "    <div style=\"margin-right:-8px;\"><SunfishAvatar Src=\"...\" Size=\"AvatarSize.Small\" Bordered=\"true\" /></div>\n" +
        "    <div style=\"margin-right:-8px;\"><SunfishAvatar Src=\"...\" Size=\"AvatarSize.Small\" Bordered=\"true\" /></div>\n" +
        "    <SunfishAvatar Initials=\"+5\" Size=\"AvatarSize.Small\" Bordered=\"true\" />\n" +
        "</div>";

    // Accessibility
    private static readonly (string Key, string Action)[] _keyboard =
    [
        ("Tab", "Moves focus to the avatar if it is interactive"),
        ("Enter", "Activates the avatar if it is a clickable element"),
    ];

    private static readonly (string Attribute, string Description)[] _aria =
    [
        ("role=\"img\"", "Applied to indicate the avatar represents an image"),
        ("aria-label", "Provides alt text describing the avatar, such as the user's name"),
    ];

    private static readonly string[] _screenReader =
    [
        "Avatars with initials are announced with their aria-label text.",
        "Image-based avatars should include descriptive alt text for screen readers.",
        "Decorative avatars that duplicate adjacent text can use aria-hidden=\"true\".",
    ];
}
