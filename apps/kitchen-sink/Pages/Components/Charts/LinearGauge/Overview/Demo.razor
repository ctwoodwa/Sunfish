@page "/components/charts/lineargauge/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>LinearGauge / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="LinearGauge / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Charts/LinearGauge/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishLinearGauge</code> renders a horizontal or vertical bar gauge with an optional
            pointer, scale, and value label. Core parameters are <code>Value</code>, <code>Min</code>,
            and <code>Max</code>; chrome is controlled through <code>ShowPointer</code>,
            <code>ShowScale</code>, and <code>ShowLabel</code>.
        </p>
        <p>
            This overview shows the default horizontal layout. Separate demo pages cover
            <a href="/components/charts/lineargauge/multiple-pointers">multiple pointers</a> and
            <a href="/components/charts/lineargauge/vertical-orientation">vertical orientation</a>.
        </p>
    </Narrative>

    <Example>
        <div class="demo-row" style="max-width:420px;">
            <SunfishLinearGauge Value="62"
                                Min="0"
                                Max="100"
                                ShowPointer="true"
                                ShowScale="true"
                                ShowLabel="true" />
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Charts", "LinearGauge", "Overview"];
}
