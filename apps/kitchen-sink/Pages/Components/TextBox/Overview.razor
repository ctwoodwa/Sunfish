@page "/components/TextBox"
@page "/components/TextBox/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Code="@_basicCode">
        <SunfishField>
            <SunfishLabel>Name</SunfishLabel>
            <SunfishTextBox Value="@_name" ValueChanged="@(v => _name = v)" Placeholder="Enter your name" />
        </SunfishField>
    </DemoSection>

    <DemoSection Title="States" Code="@_statesCode">
        <SunfishField>
            <SunfishLabel>Invalid Input</SunfishLabel>
            <SunfishTextBox Value="" IsInvalid="true" Placeholder="This field has an error" />
            <SunfishValidation Severity="ValidationSeverity.Error" Message="This field is required." />
        </SunfishField>
        <SunfishField>
            <SunfishLabel>Disabled Input</SunfishLabel>
            <SunfishTextBox Value="Cannot edit" Disabled="true" />
        </SunfishField>
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Adornments" Description="Prefix and suffix adornments enhance inputs with icons, labels, or actions." Code="@_adornmentsCode">
        <SunfishField>
            <SunfishLabel>Email</SunfishLabel>
            <SunfishTextBox Value="@_email" ValueChanged="@(v => _email = v)" Placeholder="Enter email" InputType="email" ShowPrefixSeparator="true">
                <Prefix>
                    <SunfishIcon Name="mail" Size="IconSize.Small" />
                </Prefix>
            </SunfishTextBox>
        </SunfishField>
        <SunfishField>
            <SunfishLabel>Website</SunfishLabel>
            <SunfishTextBox Value="@_website" ValueChanged="@(v => _website = v)" Placeholder="example.com" ShowPrefixSeparator="true">
                <Prefix><span>https://</span></Prefix>
            </SunfishTextBox>
        </SunfishField>
        <SunfishField>
            <SunfishLabel>Price</SunfishLabel>
            <SunfishTextBox Value="@_price" ValueChanged="@(v => _price = v)" Placeholder="0.00">
                <Prefix><span>$</span></Prefix>
                <Suffix><span>USD</span></Suffix>
            </SunfishTextBox>
        </SunfishField>
    </DemoSection>
</PageSection>

<PageSection Title="Playground">
    <DemoSection Title="Interactive Adornments" Description="Configure prefix and suffix adornments dynamically. Toggle adornments on or off, choose an icon from the dropdown, or enter custom text.">
        <div class="demo-playground">
            <div class="demo-playground-controls">
                <h4>Prefix</h4>
                <SunfishField>
                    <SunfishLabel>Mode</SunfishLabel>
                    <SunfishDropDownList TItem="string" TValue="string"
                                        Data="@_adornmentModes"
                                        Value="@_prefixMode"
                                        ValueChanged="@(v => _prefixMode = v ?? "none")"
                                        Placeholder="Select mode" />
                </SunfishField>
                @if (_prefixMode == "icon")
                {
                    <SunfishField>
                        <SunfishLabel>Icon</SunfishLabel>
                        <SunfishDropDownList TItem="string" TValue="string"
                                            Data="@_iconNames"
                                            Value="@_prefixIcon"
                                            ValueChanged="@(v => _prefixIcon = v ?? _iconNames[0])"
                                            Filterable="true"
                                            Placeholder="Pick an icon" />
                    </SunfishField>
                }
                else if (_prefixMode == "text")
                {
                    <SunfishField>
                        <SunfishLabel>Text</SunfishLabel>
                        <SunfishTextBox Value="@_prefixText" ValueChanged="@(v => _prefixText = v)" Placeholder="e.g. https://" />
                    </SunfishField>
                }
                @if (_prefixMode != "none")
                {
                    <SunfishField>
                        <SunfishCheckbox Checked="@_prefixSep" CheckedChanged="@(v => _prefixSep = v)" Label="Show separator" />
                    </SunfishField>
                }

                <h4>Suffix</h4>
                <SunfishField>
                    <SunfishLabel>Mode</SunfishLabel>
                    <SunfishDropDownList TItem="string" TValue="string"
                                        Data="@_adornmentModes"
                                        Value="@_suffixMode"
                                        ValueChanged="@(v => _suffixMode = v ?? "none")"
                                        Placeholder="Select mode" />
                </SunfishField>
                @if (_suffixMode == "icon")
                {
                    <SunfishField>
                        <SunfishLabel>Icon</SunfishLabel>
                        <SunfishDropDownList TItem="string" TValue="string"
                                            Data="@_iconNames"
                                            Value="@_suffixIcon"
                                            ValueChanged="@(v => _suffixIcon = v ?? _iconNames[0])"
                                            Filterable="true"
                                            Placeholder="Pick an icon" />
                    </SunfishField>
                }
                else if (_suffixMode == "text")
                {
                    <SunfishField>
                        <SunfishLabel>Text</SunfishLabel>
                        <SunfishTextBox Value="@_suffixText" ValueChanged="@(v => _suffixText = v)" Placeholder="e.g. USD" />
                    </SunfishField>
                }
                @if (_suffixMode != "none")
                {
                    <SunfishField>
                        <SunfishCheckbox Checked="@_suffixSep" CheckedChanged="@(v => _suffixSep = v)" Label="Show separator" />
                    </SunfishField>
                }

                <h4>Input</h4>
                <SunfishField>
                    <SunfishLabel>Placeholder</SunfishLabel>
                    <SunfishTextBox Value="@_playPlaceholder" ValueChanged="@(v => _playPlaceholder = v)" Placeholder="Placeholder text" />
                </SunfishField>
                <SunfishField>
                    <SunfishCheckbox Checked="@_playDisabled" CheckedChanged="@(v => _playDisabled = v)" Label="Disabled" />
                </SunfishField>
                <SunfishField>
                    <SunfishCheckbox Checked="@_playInvalid" CheckedChanged="@(v => _playInvalid = v)" Label="Invalid" />
                </SunfishField>
            </div>

            <div class="demo-playground-preview">
                <h4>Result</h4>
                <SunfishField>
                    <SunfishLabel>Preview</SunfishLabel>
                    @RenderPreviewTextBox()
                </SunfishField>
                <p style="margin-top: 8px; font-size: 0.85rem; color: var(--color-text-muted);">
                    <strong>Value:</strong> @(string.IsNullOrEmpty(_playValue) ? "(empty)" : _playValue)
                </p>
            </div>
        </div>
    </DemoSection>
</PageSection>

<PageSection Title="Events">
    <DemoSection Title="Interactive" Description="Handle value changes with the ValueChanged callback." Code="@_interactiveCode">
        <SunfishField>
            <SunfishLabel>Type something</SunfishLabel>
            <SunfishTextBox Value="@_evName" ValueChanged="@(v => _evName = v)" Placeholder="Enter your name" />
        </SunfishField>
        <p><strong>Value:</strong> @_evName</p>
    </DemoSection>
</PageSection>

<PageSection Title="Accessibility">
    <AccessibilityInfo
        KeyboardInteractions="@_keyboard"
        AriaAttributes="@_aria"
        ScreenReaderNotes="@_screenReader" />
</PageSection>

@code {
    // Overview
    private string _name = "";

    private const string _basicCode =
        "<SunfishField>\n" +
        "    <SunfishLabel>Name</SunfishLabel>\n" +
        "    <SunfishTextBox Value=\"@_name\" ValueChanged=\"@(v => _name = v)\" Placeholder=\"Enter your name\" />\n" +
        "</SunfishField>";

    private const string _statesCode =
        "<SunfishField>\n" +
        "    <SunfishTextBox Value=\"\" IsInvalid=\"true\" Placeholder=\"This field has an error\" />\n" +
        "    <SunfishValidation Severity=\"ValidationSeverity.Error\" Message=\"This field is required.\" />\n" +
        "</SunfishField>\n\n" +
        "<SunfishField>\n" +
        "    <SunfishTextBox Value=\"Cannot edit\" Disabled=\"true\" />\n" +
        "</SunfishField>";

    // Appearance
    private string _email = "";
    private string _website = "";
    private string _price = "";

    private const string _adornmentsCode =
        "<SunfishTextBox Value=\"@_email\" Placeholder=\"Enter email\" ShowPrefixSeparator=\"true\">\n" +
        "    <Prefix><SunfishIcon Name=\"mail\" Size=\"IconSize.Small\" /></Prefix>\n" +
        "</SunfishTextBox>\n\n" +
        "<SunfishTextBox Value=\"@_website\" Placeholder=\"example.com\" ShowPrefixSeparator=\"true\">\n" +
        "    <Prefix><span>https://</span></Prefix>\n" +
        "</SunfishTextBox>\n\n" +
        "<SunfishTextBox Value=\"@_price\" Placeholder=\"0.00\">\n" +
        "    <Prefix><span>$</span></Prefix>\n" +
        "    <Suffix><span>USD</span></Suffix>\n" +
        "</SunfishTextBox>";

    // Playground
    private static readonly string[] _adornmentModes = ["none", "icon", "text"];
    private static readonly string[] _iconNames =
    [
        "search", "calendar", "clock", "edit", "trash", "upload", "download",
        "info", "warning", "error", "success", "check", "close", "plus", "minus",
        "refresh", "layers", "code", "copy", "monitor"
    ];

    private RenderFragment RenderPreviewTextBox() => __builder =>
    {
        var hasPrefix = _prefixMode != "none";
        var hasSuffix = _suffixMode != "none";

        // Build prefix fragment
        RenderFragment? prefix = _prefixMode switch
        {
            "icon" => b => { b.OpenComponent<SunfishIcon>(0); b.AddAttribute(1, "Name", _prefixIcon); b.AddAttribute(2, "Size", IconSize.Small); b.CloseComponent(); },
            "text" => b => { b.OpenElement(0, "span"); b.AddContent(1, _prefixText); b.CloseElement(); },
            _ => null
        };

        // Build suffix fragment
        RenderFragment? suffix = _suffixMode switch
        {
            "icon" => b => { b.OpenComponent<SunfishIcon>(0); b.AddAttribute(1, "Name", _suffixIcon); b.AddAttribute(2, "Size", IconSize.Small); b.CloseComponent(); },
            "text" => b => { b.OpenElement(0, "span"); b.AddContent(1, _suffixText); b.CloseElement(); },
            _ => null
        };

        __builder.OpenComponent<SunfishTextBox>(0);
        __builder.AddAttribute(1, "Value", _playValue);
        __builder.AddAttribute(2, "ValueChanged", EventCallback.Factory.Create<string>(this, v => { _playValue = v; StateHasChanged(); }));
        __builder.AddAttribute(3, "Placeholder", _playPlaceholder);
        __builder.AddAttribute(4, "Disabled", _playDisabled);
        __builder.AddAttribute(5, "IsInvalid", _playInvalid);
        __builder.AddAttribute(6, "ShowPrefixSeparator", hasPrefix && _prefixSep);
        __builder.AddAttribute(7, "ShowSuffixSeparator", hasSuffix && _suffixSep);
        if (prefix != null) __builder.AddAttribute(8, "Prefix", prefix);
        if (suffix != null) __builder.AddAttribute(9, "Suffix", suffix);
        __builder.CloseComponent();
    };

    private string _prefixMode = "none";
    private string _prefixIcon = "search";
    private string _prefixText = "$";
    private bool _prefixSep;
    private string _suffixMode = "none";
    private string _suffixIcon = "check";
    private string _suffixText = "USD";
    private bool _suffixSep;
    private string _playValue = "";
    private string _playPlaceholder = "Type here...";
    private bool _playDisabled;
    private bool _playInvalid;

    // Events
    private string _evName = "";

    private const string _interactiveCode =
        "<SunfishTextBox Value=\"@_name\" ValueChanged=\"@(v => _name = v)\" Placeholder=\"Enter your name\" />\n" +
        "<p><strong>Value:</strong> @_name</p>\n\n" +
        "@code {\n" +
        "    private string _name = \"\";\n" +
        "}";

    // Accessibility
    private static readonly (string Key, string Action)[] _keyboard =
    [
        ("Tab", "Moves focus to the text field"),
        ("Shift + Tab", "Moves focus to the previous focusable element"),
        ("Escape", "Clears focus from the text field"),
    ];

    private static readonly (string Attribute, string Description)[] _aria =
    [
        ("role=\"textbox\"", "Implicitly set by the <input type=\"text\"> element"),
        ("aria-invalid=\"true\"", "Applied when the IsInvalid parameter is set"),
        ("aria-disabled=\"true\"", "Applied when the Disabled parameter is set"),
        ("aria-label", "Can be set to provide an accessible name when no visible label is present"),
        ("aria-describedby", "References validation messages when present"),
    ];

    private static readonly string[] _screenReader =
    [
        "Text fields are announced with their label and the \"edit text\" role.",
        "Invalid fields are announced with their error state and associated validation message.",
        "Disabled fields are announced as \"dimmed\" or \"unavailable\" depending on the screen reader.",
        "Prefix and suffix adornments are decorative and do not affect screen reader announcements.",
    ];
}
