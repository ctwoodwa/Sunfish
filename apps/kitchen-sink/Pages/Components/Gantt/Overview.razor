@page "/components/gantt"
@page "/components/gantt/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="Gantt chart displays project tasks on a timeline with hierarchical grouping, progress tracking, and interactive editing. This example shows four columns (Title with expand/collapse, PercentComplete, Start, End), two timeline views (Week and Month), and update/delete handlers." Code="@_basicCode">
        <div class="demo-row">
            <SunfishGantt TItem="GanttTask"
                         Data="@_tasks"
                         IdField="Id"
                         ParentIdField="ParentId"
                         Height="500px"
                         Width="100%"
                         OnUpdate="@UpdateItem"
                         OnDelete="@DeleteItem"
                         @bind-View="_currentView">
                <GanttColumns>
                    <GanttColumn TItem="GanttTask"
                                 Field="Title"
                                 Expandable="true"
                                 Width="220px"
                                 Title="Task Title" />
                    <GanttColumn TItem="GanttTask"
                                 Field="PercentComplete"
                                 Width="80px"
                                 Title="% Done"
                                 DisplayFormat="{0:N0}%"
                                 TextAlign="right" />
                    <GanttColumn TItem="GanttTask"
                                 Field="Start"
                                 Width="100px"
                                 DisplayFormat="{0:d}" />
                    <GanttColumn TItem="GanttTask"
                                 Field="End"
                                 Width="100px"
                                 DisplayFormat="{0:d}" />
                </GanttColumns>
                <GanttViews>
                    <GanttWeekView />
                    <GanttMonthView />
                </GanttViews>
            </SunfishGantt>
        </div>
    </DemoSection>
</PageSection>

@code {
    private GanttView _currentView = GanttView.Week;

    private List<GanttTask> _tasks = GenerateSampleData();

    private static List<GanttTask> GenerateSampleData()
    {
        var today = DateTime.Today;
        return new List<GanttTask>
        {
            // Parent 1: Planning
            new() { Id = "1", Title = "Planning", Start = today, End = today.AddDays(12), PercentComplete = 80 },
            new() { Id = "1.1", ParentId = "1", Title = "Requirements Gathering", Start = today, End = today.AddDays(4), PercentComplete = 100 },
            new() { Id = "1.2", ParentId = "1", Title = "Stakeholder Review", Start = today.AddDays(4), End = today.AddDays(7), PercentComplete = 100 },
            new() { Id = "1.3", ParentId = "1", Title = "Scope Finalization", Start = today.AddDays(7), End = today.AddDays(12), PercentComplete = 40 },

            // Parent 2: Design
            new() { Id = "2", Title = "Design", Start = today.AddDays(10), End = today.AddDays(22), PercentComplete = 50 },
            new() { Id = "2.1", ParentId = "2", Title = "Wireframes", Start = today.AddDays(10), End = today.AddDays(14), PercentComplete = 100 },
            new() { Id = "2.2", ParentId = "2", Title = "UI Mockups", Start = today.AddDays(14), End = today.AddDays(19), PercentComplete = 30 },
            new() { Id = "2.3", ParentId = "2", Title = "Design Review", Start = today.AddDays(19), End = today.AddDays(22), PercentComplete = 0 },

            // Parent 3: Development
            new() { Id = "3", Title = "Development", Start = today.AddDays(20), End = today.AddDays(40), PercentComplete = 15 },
            new() { Id = "3.1", ParentId = "3", Title = "Backend API", Start = today.AddDays(20), End = today.AddDays(30), PercentComplete = 30 },
            new() { Id = "3.2", ParentId = "3", Title = "Frontend UI", Start = today.AddDays(25), End = today.AddDays(35), PercentComplete = 10 },
            new() { Id = "3.3", ParentId = "3", Title = "Integration", Start = today.AddDays(35), End = today.AddDays(40), PercentComplete = 0 },

            // Parent 4: Testing
            new() { Id = "4", Title = "Testing", Start = today.AddDays(38), End = today.AddDays(50), PercentComplete = 0 },
            new() { Id = "4.1", ParentId = "4", Title = "Unit Tests", Start = today.AddDays(38), End = today.AddDays(42), PercentComplete = 0 },
            new() { Id = "4.2", ParentId = "4", Title = "Integration Tests", Start = today.AddDays(42), End = today.AddDays(47), PercentComplete = 0 },

            // Parent 5: Deployment
            new() { Id = "5", Title = "Deployment", Start = today.AddDays(48), End = today.AddDays(55), PercentComplete = 0 },
            new() { Id = "5.1", ParentId = "5", Title = "Staging Release", Start = today.AddDays(48), End = today.AddDays(51), PercentComplete = 0 },
            new() { Id = "5.2", ParentId = "5", Title = "Production Release", Start = today.AddDays(51), End = today.AddDays(55), PercentComplete = 0 },
        };
    }

    private void UpdateItem(GanttUpdateEventArgs args)
    {
        var item = args.Item as GanttTask;
        var found = _tasks.FirstOrDefault(d => d.Id == item?.Id);
        if (found is not null && item is not null)
        {
            found.Title = item.Title;
            found.Start = item.Start;
            found.End = item.End;
            found.PercentComplete = item.PercentComplete;
        }
    }

    private void DeleteItem(GanttDeleteEventArgs args)
    {
        var item = args.Item as GanttTask;
        if (item is not null)
            _tasks.RemoveAll(d => d.Id == item.Id || d.ParentId == item.Id);
    }

    private const string _basicCode = @"<SunfishGantt TItem=""GanttTask""
             Data=""@_tasks""
             IdField=""Id""
             ParentIdField=""ParentId""
             Height=""500px""
             OnUpdate=""@UpdateItem""
             OnDelete=""@DeleteItem""
             @bind-View=""_currentView"">
    <GanttColumns>
        <GanttColumn TItem=""GanttTask"" Field=""Title"" Expandable=""true"" Width=""220px"" Title=""Task Title"" />
        <GanttColumn TItem=""GanttTask"" Field=""PercentComplete"" Width=""80px"" Title=""% Done"" DisplayFormat=""{0:N0}%"" TextAlign=""right"" />
        <GanttColumn TItem=""GanttTask"" Field=""Start"" Width=""100px"" DisplayFormat=""{0:d}"" />
        <GanttColumn TItem=""GanttTask"" Field=""End"" Width=""100px"" DisplayFormat=""{0:d}"" />
    </GanttColumns>
    <GanttViews>
        <GanttWeekView />
        <GanttMonthView />
    </GanttViews>
</SunfishGantt>";
}
