@page "/components/fileselect"
@page "/components/fileselect/overview"
@layout ComponentDemoLayout
@using Sunfish.UIAdapters.Blazor.Components.Forms.Inputs

<PageSection Title="File Select">

    <DemoSection Title="Basic File Select" Code="@_basicCode">
        <SunfishFileUpload OnSelect="HandleSelect" OnRemove="HandleRemove" />
        @if (!string.IsNullOrEmpty(_status))
        {
            <p class="demo-status">@_status</p>
        }
    </DemoSection>

    <DemoSection Title="Single File — Restricted Types" Code="@_restrictedCode">
        <SunfishFileUpload Multiple="false"
                          AllowedExtensions='@(new List<string> { ".pdf", ".docx" })'
                          MaxFileSize="@(4 * 1024 * 1024)"
                          MinFileSize="@(1024L)"
                          Accept=".pdf,.docx"
                          OnSelect="HandleSelect" />
    </DemoSection>

    <DemoSection Title="With Initial Files" Code="@_initialCode">
        <SunfishFileUpload Files="@_initialFiles" Multiple="true" OnSelect="HandleSelect" />
    </DemoSection>

    <DemoSection Title="Disabled" Code="@_disabledCode">
        <SunfishFileUpload Enabled="false" />
    </DemoSection>

</PageSection>

@code {
    private string? _status;

    private void HandleSelect(FileSelectEventArgs args)
    {
        var valid = args.Files.Count(f => !f.IsInvalid);
        var invalid = args.Files.Count(f => f.IsInvalid);
        _status = $"Selected {args.Files.Count} file(s): {valid} valid, {invalid} invalid.";
    }

    private void HandleRemove(FileSelectEventArgs args)
    {
        _status = $"Removed: {string.Join(", ", args.Files.Select(f => f.Name))}";
    }

    private readonly List<FileSelectFileInfo> _initialFiles =
    [
        new FileSelectFileInfo { Id = "1", Name = "report.pdf", Extension = ".pdf", Size = 2 * 1024 * 1024 },
        new FileSelectFileInfo { Id = "2", Name = "image.jpg", Extension = ".jpg", Size = 512 * 1024 }
    ];

    private const string _basicCode =
        "<SunfishFileUpload OnSelect=\"HandleSelect\" OnRemove=\"HandleRemove\" />";

    private const string _restrictedCode =
        "<SunfishFileUpload Multiple=\"false\"\n" +
        "                  AllowedExtensions='@(new List<string> { \".pdf\", \".docx\" })'\n" +
        "                  MaxFileSize=\"@(4 * 1024 * 1024)\"\n" +
        "                  MinFileSize=\"@(1024L)\"\n" +
        "                  Accept=\".pdf,.docx\"\n" +
        "                  OnSelect=\"HandleSelect\" />";

    private const string _initialCode =
        "<SunfishFileUpload Files=\"@_initialFiles\" Multiple=\"true\" OnSelect=\"HandleSelect\" />";

    private const string _disabledCode =
        "<SunfishFileUpload Enabled=\"false\" />";
}
