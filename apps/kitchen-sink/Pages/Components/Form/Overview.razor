@page "/components/form"
@page "/components/form/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="Form provides validation, field layout, and submit handling for input components." Code="@_basicCode">
        <div class="demo-row">
            <SunfishForm>
                <SunfishField>
                    <SunfishLabel>Name</SunfishLabel>
                    <SunfishTextBox @bind-Value="_name" />
                </SunfishField>
                <SunfishField>
                    <SunfishLabel>Email</SunfishLabel>
                    <SunfishTextBox @bind-Value="_email" />
                </SunfishField>
                <SunfishButton Variant="ButtonVariant.Primary">Submit</SunfishButton>
            </SunfishForm>
        </div>
    </DemoSection>
</PageSection>

@code {
    private string? _name;
    private string? _email;

    private const string _basicCode =
        "<SunfishForm>\n" +
        "    <SunfishField>\n" +
        "        <SunfishLabel>Name</SunfishLabel>\n" +
        "        <SunfishTextBox @bind-Value=\"_name\" />\n" +
        "    </SunfishField>\n" +
        "    <SunfishButton Variant=\"ButtonVariant.Primary\">Submit</SunfishButton>\n" +
        "</SunfishForm>";
}
