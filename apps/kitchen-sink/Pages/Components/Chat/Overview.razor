@page "/components/chat"
@page "/components/chat/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="A chat component with a message list and input area for sending messages." Code="@_basicCode">
        <SunfishChat Messages="@_messages"
                    User="You"
                    OnSendMessage="@HandleSendMessage"
                    Height="350px"
                    Width="500px" />
    </DemoSection>
</PageSection>

<PageSection Title="Appearance">
    <DemoSection Title="Without Timestamps" Description="Hide timestamps for a cleaner appearance." Code="@_noTimestampCode">
        <SunfishChat Messages="@_noTsMessages"
                    User="You"
                    ShowTimestamp="false"
                    OnSendMessage="@HandleNoTsMessage"
                    Height="300px"
                    Width="400px" />
    </DemoSection>

    <DemoSection Title="With Header" Description="Add a custom header to the chat panel." Code="@_headerCode">
        <SunfishChat Messages="@_headerMessages"
                    User="You"
                    OnSendMessage="@HandleHeaderMessage"
                    Height="350px"
                    Width="500px">
            <HeaderContent>
                <div style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: #f0f0f0; border-bottom: 1px solid #e0e0e0;">
                    <strong>Support Chat</strong>
                    <span style="margin-left: auto; font-size: 0.8em; color: #666;">Online</span>
                </div>
            </HeaderContent>
        </SunfishChat>
    </DemoSection>
</PageSection>

@code {
    private List<ChatMessage> _messages = new()
    {
        new ChatMessage { Author = "Support", Text = "Hello! How can I help you today?", IsUser = false, Timestamp = DateTime.Now.AddMinutes(-5) },
        new ChatMessage { Author = "You", Text = "I have a question about my order.", IsUser = true, Timestamp = DateTime.Now.AddMinutes(-4) },
        new ChatMessage { Author = "Support", Text = "Sure, I'd be happy to help. What's your order number?", IsUser = false, Timestamp = DateTime.Now.AddMinutes(-3) },
    };

    private List<ChatMessage> _noTsMessages = new()
    {
        new ChatMessage { Author = "Bot", Text = "Welcome! Ask me anything.", IsUser = false },
        new ChatMessage { Author = "You", Text = "What is Sunfish?", IsUser = true },
        new ChatMessage { Author = "Bot", Text = "Sunfish is a provider-first Blazor component library for .NET 10.", IsUser = false },
    };

    private List<ChatMessage> _headerMessages = new()
    {
        new ChatMessage { Author = "Agent", Text = "Welcome to support. How can we assist you?", IsUser = false, Timestamp = DateTime.Now.AddMinutes(-2) },
    };

    private void HandleSendMessage(string text)
    {
        _messages.Add(new ChatMessage { Author = "You", Text = text, IsUser = true, Timestamp = DateTime.Now });
        // Simulate a reply
        _messages.Add(new ChatMessage { Author = "Support", Text = $"Thanks for your message: \"{text}\". We'll look into it.", IsUser = false, Timestamp = DateTime.Now });
    }

    private void HandleNoTsMessage(string text)
    {
        _noTsMessages.Add(new ChatMessage { Author = "You", Text = text, IsUser = true });
        _noTsMessages.Add(new ChatMessage { Author = "Bot", Text = "I received your message.", IsUser = false });
    }

    private void HandleHeaderMessage(string text)
    {
        _headerMessages.Add(new ChatMessage { Author = "You", Text = text, IsUser = true, Timestamp = DateTime.Now });
        _headerMessages.Add(new ChatMessage { Author = "Agent", Text = "Let me check that for you.", IsUser = false, Timestamp = DateTime.Now });
    }

    private const string _basicCode =
        "<SunfishChat Messages=\"@_messages\"\n" +
        "            User=\"You\"\n" +
        "            OnSendMessage=\"@HandleSendMessage\"\n" +
        "            Height=\"350px\"\n" +
        "            Width=\"500px\" />\n\n" +
        "@code {\n" +
        "    private List<ChatMessage> _messages = new()\n" +
        "    {\n" +
        "        new ChatMessage { Author = \"Support\", Text = \"Hello!\", IsUser = false },\n" +
        "    };\n\n" +
        "    private void HandleSendMessage(string text)\n" +
        "    {\n" +
        "        _messages.Add(new ChatMessage { Author = \"You\", Text = text, IsUser = true });\n" +
        "    }\n" +
        "}";

    private const string _noTimestampCode =
        "<SunfishChat Messages=\"@_messages\"\n" +
        "            User=\"You\"\n" +
        "            ShowTimestamp=\"false\"\n" +
        "            OnSendMessage=\"@HandleMessage\" />";

    private const string _headerCode =
        "<SunfishChat Messages=\"@_messages\" User=\"You\" OnSendMessage=\"@HandleMessage\">\n" +
        "    <HeaderContent>\n" +
        "        <div style=\"padding: 8px; background: #f0f0f0;\">\n" +
        "            <strong>Support Chat</strong>\n" +
        "        </div>\n" +
        "    </HeaderContent>\n" +
        "</SunfishChat>";
}
