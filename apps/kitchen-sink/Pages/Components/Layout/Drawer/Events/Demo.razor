@page "/components/layout/drawer/events"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.Foundation.Enums

<PageTitle>Drawer / Events · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Drawer / Events"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Layout/Drawer/Events/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishDrawer</code> exposes three events:
        </p>
        <ul>
            <li><code>ExpandedChanged</code> — fires whenever the drawer opens or closes, whether
                from the backdrop click, <code>OnClose</code>, or the public API (<code>ExpandAsync</code>,
                <code>CollapseAsync</code>, <code>ToggleAsync</code>). Supports
                <code>@@bind-Expanded</code>.</li>
            <li><code>OnClose</code> — fires specifically when the drawer closes. Useful when you
                need a "just closed" hook without reacting to the open transition.</li>
            <li><code>SelectedItemChanged</code> — fires on data-driven drawers when the user picks
                an item (available as <code>@@bind-SelectedItem</code>).</li>
        </ul>
        <p>
            The log records each invocation in real time.
        </p>
    </Narrative>

    <Example>
        <div style="display:grid; grid-template-columns:minmax(0, 1fr) minmax(0, 360px); gap:1.25rem;">

            <div>
                <h4 style="margin:0 0 .5rem;">Drawer with instrumentation</h4>
                <div style="display:flex; flex-wrap:wrap; gap:.5rem;">
                    <SunfishButton Variant="ButtonVariant.Primary" OnClick="OpenAsync">ExpandAsync()</SunfishButton>
                    <SunfishButton Variant="ButtonVariant.Secondary" OnClick="CloseAsync">CollapseAsync()</SunfishButton>
                    <SunfishButton Variant="ButtonVariant.Secondary" OnClick="ToggleAsync">ToggleAsync()</SunfishButton>
                    <SunfishButton Variant="ButtonVariant.Primary" OnClick="ClearLog">Clear Log</SunfishButton>
                </div>
                <p style="margin:.5rem 0 0; font-size:.85rem; opacity:.75;">
                    Expanded: <strong>@_expanded</strong> — selected:
                    <strong>@(_selected?.Text ?? "(none)")</strong>
                </p>

                <SunfishDrawer @ref="_drawer"
                               Position="DrawerPosition.Left"
                               Expanded="_expanded"
                               ExpandedChanged="HandleExpandedChanged"
                               OnClose="HandleOnClose"
                               Data="@_navItems"
                               TextField="Text"
                               IconField="Icon"
                               SelectedItem="_selected"
                               SelectedItemChanged="HandleSelectedItemChanged" />
            </div>

            <div>
                <h4 style="margin:0 0 .5rem;">Event log</h4>
                <div style="border:1px solid var(--sunfish-border, #d0d0d0); border-radius:8px; background:var(--sunfish-surface-2, #fafafa); padding:.75rem; height:320px; overflow:auto; font-family:ui-monospace, SFMono-Regular, Menlo, monospace; font-size:.8rem;">
                    @if (_log.Count == 0)
                    {
                        <em style="opacity:.6;">No events yet — open the drawer and click a nav item.</em>
                    }
                    else
                    {
                        @foreach (var entry in _log)
                        {
                            <div>@entry</div>
                        }
                    }
                </div>
            </div>

        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Layout", "Drawer", "Events"];

    private SunfishDrawer? _drawer;
    private bool _expanded;
    private NavItem? _selected;

    private readonly List<string> _log = new();

    private void Log(string message)
    {
        var ts = DateTime.Now.ToString("HH:mm:ss.fff");
        _log.Insert(0, $"[{ts}] {message}");
        if (_log.Count > 100) _log.RemoveRange(100, _log.Count - 100);
    }

    private void ClearLog() => _log.Clear();

    private async Task OpenAsync()
    {
        if (_drawer is not null)
        {
            await _drawer.ExpandAsync();
            Log("Invoked ExpandAsync()");
        }
    }

    private async Task CloseAsync()
    {
        if (_drawer is not null)
        {
            await _drawer.CollapseAsync();
            Log("Invoked CollapseAsync()");
        }
    }

    private async Task ToggleAsync()
    {
        if (_drawer is not null)
        {
            await _drawer.ToggleAsync();
            Log("Invoked ToggleAsync()");
        }
    }

    private void HandleExpandedChanged(bool value)
    {
        _expanded = value;
        Log($"ExpandedChanged -> {value}");
    }

    private void HandleOnClose()
    {
        Log("OnClose");
    }

    private void HandleSelectedItemChanged(object? item)
    {
        _selected = item as NavItem;
        Log($"SelectedItemChanged -> {_selected?.Text ?? "(null)"}");
    }

    public class NavItem
    {
        public string Text { get; set; } = "";
        public string Icon { get; set; } = "";
    }

    private readonly List<NavItem> _navItems =
    [
        new() { Text = "Home", Icon = "home" },
        new() { Text = "Inbox", Icon = "inbox" },
        new() { Text = "Team", Icon = "users" },
        new() { Text = "Settings", Icon = "settings" },
    ];
}
