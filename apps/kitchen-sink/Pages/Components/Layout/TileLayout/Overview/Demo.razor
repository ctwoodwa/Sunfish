@page "/components/layout/tilelayout/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Layout.Tiles
@using Sunfish.UIAdapters.Blazor.Components.Showcase
@using Sunfish.UIAdapters.Blazor.Enums

<PageTitle>TileLayout / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="TileLayout / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/Layout/TileLayout/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishTileLayout</code> (new MVP surface under
            <code>Sunfish.UIAdapters.Blazor.Components.Layout.Tiles</code>)
            arranges dashboard-style tiles on a CSS grid. Each
            <code>SunfishTile</code> specifies its <code>Col</code>,
            <code>Row</code>, <code>ColSpan</code>, and <code>RowSpan</code>
            within a parent grid of <code>Columns</code> columns and
            <code>RowHeight</code>-pixel rows separated by <code>Gap</code>.
            Drag-to-reorder and drag-to-resize handles are tracked as
            documented gaps and arrive alongside the dock drag-to-dock wave.
        </p>
        <ul>
            <li><code>Columns</code> (default 4), <code>RowHeight</code> (px), <code>Gap</code> (px).</li>
            <li><code>Reorderable</code> (<c>bool</c>) &amp; <code>Resizable</code> (<c>TileLayoutResizing</c>) — parameters wired; interaction deferred.</li>
            <li><code>OnTileReorder</code> &amp; <code>OnTileResize</code> — cancellable event callbacks.</li>
        </ul>
    </Narrative>

    <Example>
        <SunfishTileLayout Columns="4" RowHeight="120" Gap="12"
                           Reorderable="true"
                           Resizable="TileLayoutResizing.Enabled"
                           OnTileReorder="HandleReorder"
                           OnTileResize="HandleResize">
            <SunfishTile Id="sales" Col="1" Row="1" ColSpan="2" RowSpan="2">
                <Header>Sales this quarter</Header>
                <ChildContent>
                    <div style="font-size:1.75rem;font-weight:700;">$1.42M</div>
                    <small style="opacity:.75;">+12.4% vs prior quarter</small>
                </ChildContent>
            </SunfishTile>
            <SunfishTile Id="active-users" Col="3" Row="1" ColSpan="2" RowSpan="1">
                <Header>Active users</Header>
                <ChildContent>
                    <div style="font-size:1.25rem;">18,204</div>
                </ChildContent>
            </SunfishTile>
            <SunfishTile Id="latency" Col="3" Row="2" ColSpan="1" RowSpan="1">
                <Header>p95 latency</Header>
                <ChildContent>
                    <div>142 ms</div>
                </ChildContent>
            </SunfishTile>
            <SunfishTile Id="errors" Col="4" Row="2" ColSpan="1" RowSpan="1">
                <Header>Errors / hour</Header>
                <ChildContent>
                    <div>7</div>
                </ChildContent>
            </SunfishTile>
            <SunfishTile Id="releases" Col="1" Row="3" ColSpan="4" RowSpan="1">
                <Header>Recent releases</Header>
                <ChildContent>
                    <div style="display:flex;gap:.75rem;font-size:.85rem;opacity:.8;">
                        <span>v2.4.0 - Fri</span>
                        <span>v2.3.9 - Wed</span>
                        <span>v2.3.8 - Mon</span>
                    </div>
                </ChildContent>
            </SunfishTile>
        </SunfishTileLayout>

        @if (!string.IsNullOrEmpty(_lastEvent))
        {
            <p style="margin-top:.75rem;font-size:.85rem;opacity:.75;">
                Last event: <code>@_lastEvent</code>
            </p>
        }
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Layout", "TileLayout", "Overview"];

    private string _lastEvent = string.Empty;

    private Task HandleReorder(TileReorderCancellableEventArgs args)
    {
        _lastEvent = $"reorder {args.TileId}: {args.OldIndex} -> {args.NewIndex}";
        return Task.CompletedTask;
    }

    private Task HandleResize(TileResizeEventArgs args)
    {
        _lastEvent = $"resize {args.TileId}: {args.NewColSpan}x{args.NewRowSpan}";
        return Task.CompletedTask;
    }
}
