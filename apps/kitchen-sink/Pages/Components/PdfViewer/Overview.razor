@page "/components/pdfviewer"
@page "/components/pdfviewer/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <DemoSection Title="Basic Usage" Description="PDF Viewer displays PDF documents with toolbar controls for page navigation and zoom. Uses browser native PDF support." Code="@_basicCode">
        <SunfishPdfViewer Url="demo.pdf" Height="500px" />
    </DemoSection>
</PageSection>

<PageSection Title="Features">
    <DemoSection Title="With URL" Description="Provide a URL to load and display a PDF document." Code="@_urlCode">
        <div style="margin-bottom:12px;display:flex;gap:8px;align-items:center;">
            <label style="font-size:13px;">PDF URL:</label>
            <input type="text" @bind="_pdfUrl" style="flex:1;padding:6px;border:1px solid #ccc;border-radius:4px;" />
            <button @onclick="LoadPdf" style="padding:6px 16px;border:1px solid #1976d2;background:#1976d2;color:white;border-radius:4px;cursor:pointer;">Load</button>
        </div>
        <SunfishPdfViewer Url="@_activePdfUrl"
                         Height="500px"
                         Page="_currentPage"
                         PageChanged="PageChanged"
                         Zoom="_currentZoom"
                         ZoomChanged="ZoomChanged" />
    </DemoSection>

    <DemoSection Title="Without Toolbar" Description="Hide the toolbar for a clean embedded view." Code="@_noToolbarCode">
        <SunfishPdfViewer Url="demo.pdf"
                         ShowToolbar="false"
                         Height="300px" />
    </DemoSection>

    <DemoSection Title="Custom Size" Description="Control the width and height of the viewer to fit different layouts." Code="@_customSizeCode">
        <SunfishPdfViewer Url="demo.pdf"
                         Width="600px"
                         Height="400px" />
    </DemoSection>
</PageSection>

@code {
    private string _pdfUrl = "demo.pdf";
    private string? _activePdfUrl = "demo.pdf";
    private int _currentPage = 1;
    private double _currentZoom = 1.0;

    private void LoadPdf()
    {
        _activePdfUrl = string.IsNullOrWhiteSpace(_pdfUrl) ? null : _pdfUrl;
    }

    private Task PageChanged(int page)
    {
        _currentPage = page;
        return Task.CompletedTask;
    }

    private Task ZoomChanged(double zoom)
    {
        _currentZoom = zoom;
        return Task.CompletedTask;
    }

    private const string _basicCode =
        "<SunfishPdfViewer Url=\"demo.pdf\" Height=\"500px\" />";

    private const string _urlCode =
        "<SunfishPdfViewer Url=\"@_pdfUrl\"\n" +
        "                 Height=\"500px\"\n" +
        "                 Page=\"_currentPage\"\n" +
        "                 PageChanged=\"PageChanged\"\n" +
        "                 Zoom=\"_currentZoom\"\n" +
        "                 ZoomChanged=\"ZoomChanged\" />";

    private const string _noToolbarCode =
        "<SunfishPdfViewer Url=\"demo.pdf\"\n" +
        "                 ShowToolbar=\"false\"\n" +
        "                 Height=\"300px\" />";

    private const string _customSizeCode =
        "<SunfishPdfViewer Url=\"demo.pdf\"\n" +
        "                 Width=\"600px\"\n" +
        "                 Height=\"400px\" />";
}
