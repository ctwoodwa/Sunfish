@page "/components/numerictextbox"
@page "/components/numerictextbox/overview"
@layout ComponentDemoLayout

<PageSection Title="Overview">
    <SunfishAlert Severity="AlertSeverity.Info" style="margin-bottom:16px;">
        The NumericTextBox is provided by the <strong>SunfishNumericInput</strong> component.
    </SunfishAlert>

    <DemoSection Title="Basic Usage" Description="SunfishNumericInput provides a numeric input field with increment and decrement buttons." Code="@_basicCode">
        <SunfishNumericInput @bind-Value="_basicValue" Placeholder="Enter a number" />
        <p style="margin-top:8px;">Value: <strong>@_basicValue</strong></p>
    </DemoSection>

    <DemoSection Title="Min, Max, and Step" Description="Constrain the input range with Min and Max. Use Step to control the increment/decrement amount." Code="@_rangeCode">
        <SunfishNumericInput @bind-Value="_rangeValue" Min="0" Max="100" Step="5" Placeholder="0 to 100, step 5" />
        <p style="margin-top:8px;">Value: <strong>@_rangeValue</strong></p>
    </DemoSection>

    <DemoSection Title="Decimal Values" Description="Set Step to a fractional value for decimal input." Code="@_decimalCode">
        <SunfishNumericInput @bind-Value="_decimalValue" Min="0" Max="10" Step="0.25" Placeholder="0.25 increments" />
        <p style="margin-top:8px;">Value: <strong>@_decimalValue</strong></p>
    </DemoSection>

    <DemoSection Title="Disabled" Description="Set Disabled to true to prevent user interaction." Code="@_disabledCode">
        <SunfishNumericInput Value="42" Disabled="true" />
    </DemoSection>
</PageSection>

@code {
    private double _basicValue = 10;
    private double _rangeValue = 50;
    private double _decimalValue = 2.5;

    private const string _basicCode =
        "<SunfishNumericInput @bind-Value=\"_value\"\n" +
        "                    Placeholder=\"Enter a number\" />\n\n" +
        "@code {\n" +
        "    private double _value = 10;\n" +
        "}";

    private const string _rangeCode =
        "<SunfishNumericInput @bind-Value=\"_value\"\n" +
        "                    Min=\"0\"\n" +
        "                    Max=\"100\"\n" +
        "                    Step=\"5\"\n" +
        "                    Placeholder=\"0 to 100, step 5\" />";

    private const string _decimalCode =
        "<SunfishNumericInput @bind-Value=\"_value\"\n" +
        "                    Min=\"0\"\n" +
        "                    Max=\"10\"\n" +
        "                    Step=\"0.25\" />";

    private const string _disabledCode =
        "<SunfishNumericInput Value=\"42\" Disabled=\"true\" />";
}
