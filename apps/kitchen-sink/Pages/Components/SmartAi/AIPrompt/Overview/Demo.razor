@page "/components/smart-ai/aiprompt/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>AIPrompt / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="AIPrompt / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/SmartAi/AIPrompt/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishAIPrompt</code> is a framework-agnostic surface for sending user prompts
            to an AI backend. Input is collected via <code>Placeholder</code> and submitted through
            the <code>OnPromptSubmit</code> <code>EventCallback&lt;string&gt;</code>. The caller
            controls loading state via <code>IsProcessing</code> and can seed quick starters with
            the <code>Suggestions</code> list.
        </p>
        <p>
            This overview demonstrates the canonical request/response loop with suggestion chips.
            Sibling demos cover
            <a href="/components/smart-ai/aiprompt/templates">templates</a>,
            <a href="/components/smart-ai/aiprompt/commands">commands</a>,
            <a href="/components/smart-ai/aiprompt/events">events</a>,
            <a href="/components/smart-ai/aiprompt/localization">localization</a>, and
            <a href="/components/smart-ai/aiprompt/keyboard-navigation">keyboard navigation</a>.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:1.25rem; max-width:560px;">
            <SunfishAIPrompt Placeholder="Ask about our products..."
                             ButtonText="Generate"
                             Suggestions="_suggestions"
                             OnPromptSubmit="HandlePrompt"
                             IsProcessing="_isProcessing" />
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Smart AI", "AIPrompt", "Overview"];

    private bool _isProcessing;
    private readonly List<string> _suggestions = new()
    {
        "Summarize this document",
        "Write a product description",
        "Generate test data"
    };

    private async Task HandlePrompt(string prompt)
    {
        _isProcessing = true;
        StateHasChanged();
        await Task.Delay(1000);
        _isProcessing = false;
    }
}
