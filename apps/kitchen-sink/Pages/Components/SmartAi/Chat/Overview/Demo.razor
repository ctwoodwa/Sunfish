@page "/components/communication/chat/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>Chat / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="Chat / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/SmartAi/Chat/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishChat</code> renders a conversation surface with a scrollable message list
            and an input composer. Messages are a list of <code>ChatMessage</code> records, the
            local user is identified via <code>User</code>, and outbound text is delivered through
            the <code>OnSendMessage</code> <code>EventCallback&lt;string&gt;</code>. Optional
            <code>HeaderContent</code> and <code>ShowTimestamp</code> let hosts tune the chrome.
        </p>
        <p>
            This overview shows a minimal bot-echo loop. Sibling demos cover
            <a href="/components/smart-ai/chatui/toolbar">toolbar</a>,
            <a href="/components/smart-ai/chatui/templates">templates</a>,
            <a href="/components/smart-ai/chatui/events">events</a>,
            <a href="/components/smart-ai/chatui/keyboard-navigation">keyboard navigation</a>, and
            <a href="/components/smart-ai/chatui/rtl">RTL</a>.
        </p>
    </Narrative>

    <Example>
        <SunfishChat Messages="@_messages"
                     User="You"
                     OnSendMessage="@HandleSendMessage"
                     Height="350px"
                     Width="500px" />
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Communication", "Chat", "Overview"];

    private readonly List<ChatMessage> _messages = new()
    {
        new ChatMessage { Author = "Support", Text = "Hello! How can I help you today?", IsUser = false, Timestamp = DateTime.Now.AddMinutes(-5) },
        new ChatMessage { Author = "You", Text = "I have a question about my order.", IsUser = true, Timestamp = DateTime.Now.AddMinutes(-4) },
        new ChatMessage { Author = "Support", Text = "Sure, I'd be happy to help. What's your order number?", IsUser = false, Timestamp = DateTime.Now.AddMinutes(-3) },
    };

    private void HandleSendMessage(string text)
    {
        _messages.Add(new ChatMessage { Author = "You", Text = text, IsUser = true, Timestamp = DateTime.Now });
        _messages.Add(new ChatMessage { Author = "Support", Text = $"Thanks for your message: \"{text}\". We'll look into it.", IsUser = false, Timestamp = DateTime.Now });
    }
}
