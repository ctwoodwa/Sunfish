@page "/components/smart-ai/promptbox/overview"
@layout MainLayout
@using Sunfish.UIAdapters.Blazor.Components.Showcase

<PageTitle>PromptBox / Overview · Sunfish Kitchen Sink</PageTitle>

<SunfishExamplePanel Title="PromptBox / Overview"
                     Breadcrumb="@_breadcrumb"
                     GitHubUrl="https://github.com/ctwoodwa/Sunfish/blob/main/apps/kitchen-sink/Pages/Components/SmartAi/PromptBox/Overview/Demo.razor"
                     Sources="@GeneratedSources">

    <Narrative>
        <p>
            <code>SunfishPromptBox</code> collects a single line of text from the user via a modal
            dialog. Visibility is two-way bound through <code>@@bind-Visible</code>, the input
            value through <code>@@bind-Value</code>, and confirmation/cancellation are surfaced as
            <code>OnConfirm</code> and <code>OnCancel</code> callbacks. <code>Title</code>,
            <code>InputLabel</code>, and <code>Placeholder</code> control the labels.
        </p>
        <p>
            This overview demonstrates the basic confirm/cancel loop. A full
            <a href="/components/smart-ai/promptbox/overview">overview</a> page is the only demo in
            the catalog for this component today; richer variants live under the sibling
            <a href="/components/smart-ai/aiprompt/overview">AIPrompt</a> component.
        </p>
    </Narrative>

    <Example>
        <div style="display:flex; flex-direction:column; gap:0.75rem;">
            <div class="demo-row">
                <SunfishButton Variant="ButtonVariant.Primary" OnClick="@(() => _promptOpen = true)">Open Prompt</SunfishButton>
            </div>
            <SunfishPromptBox @bind-Visible="_promptOpen"
                              Title="Enter Your Name"
                              InputLabel="Full Name"
                              Placeholder="e.g. John Doe"
                              OnConfirm="@HandleConfirm"
                              OnCancel="@HandleCancel" />
            @if (!string.IsNullOrEmpty(_result))
            {
                <p>Result: <strong>@_result</strong></p>
            }
        </div>
    </Example>

</SunfishExamplePanel>

@code {
    private static readonly string[] _breadcrumb =
        ["Components", "Smart AI", "PromptBox", "Overview"];

    private bool _promptOpen;
    private string? _result;

    private void HandleConfirm(string? value) => _result = $"Confirmed: {value}";
    private void HandleCancel() => _result = "Cancelled.";
}
