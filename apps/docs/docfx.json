{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "foundation/bin/Debug/net11.0/Sunfish.Foundation.dll",
            "ui-core/bin/Debug/net11.0/Sunfish.UICore.dll",
            "ui-adapters-blazor/bin/Debug/net11.0/Sunfish.UIAdapters.Blazor.dll"
          ],
          "src": "../../packages"
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "properties": {
        "TargetFramework": "net11.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": [
          "articles/**/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "*.md"
        ]
      },
      {
        "files": [
          "component-specs/**/**.md",
          "component-specs/**/toc.yml",
          "component-specs/toc.yml"
        ]
      },
      {
        "files": [
          "blocks/**/**.md",
          "blocks/**/toc.yml",
          "blocks/toc.yml",
          "accelerators/**/**.md",
          "accelerators/**/toc.yml",
          "accelerators/toc.yml",
          "libraries/**/**.md",
          "libraries/**/toc.yml",
          "libraries/toc.yml",
          "foundation/**/**.md",
          "foundation/**/toc.yml",
          "foundation/toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": ["images/**", "logo.svg"]
      },
      {
        "files": ["component-specs/**/images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "Sunfish Documentation",
      "_appName": "Sunfish",
      "_appFooter": "Sunfish &mdash; MIT License",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/ctwoodwa/Sunfish",
        "branch": "main"
      }
    }
  }
}
