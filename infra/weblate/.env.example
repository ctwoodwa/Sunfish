# Sunfish Weblate self-hosted configuration.
# Copy to `.env` (gitignored) and fill in before `docker compose up -d`.
# See `infra/weblate/README.md` for the full ops runbook.

# --- Public URL the translator UI is served from -----------------------------
# Used in email invites + CSRF. Must match the reverse-proxy / DNS record.
WEBLATE_SITE_DOMAIN=translate.sunfish.example

# --- Initial admin account ---------------------------------------------------
# Log in and rotate the password immediately after first bring-up.
WEBLATE_ADMIN_NAME=Sunfish Admin
WEBLATE_ADMIN_EMAIL=admin@sunfish.example
WEBLATE_ADMIN_PASSWORD=change-this-on-first-login

# --- Django secret key -------------------------------------------------------
# Generate with: `python -c "import secrets; print(secrets.token_urlsafe(50))"`
# Never reuse between environments. Never commit.
WEBLATE_SECRET_KEY=replace-with-50-char-secret

# --- Postgres ----------------------------------------------------------------
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# --- Valkey / Redis ----------------------------------------------------------
REDIS_PASSWORD=replace-with-strong-valkey-password

# --- Machine-translation backend --------------------------------------------
# llama.cpp server must be running at the URL below. See infra/weblate/mt-backends.md.
WEBLATE_MT_OPENAI_BASE_URL=http://host.docker.internal:8080/v1
WEBLATE_MT_OPENAI_KEY=local-llama-cpp

# --- Email (required for translator invites + password resets) --------------
WEBLATE_EMAIL_HOST=smtp.sunfish.example
WEBLATE_EMAIL_HOST_USER=weblate@sunfish.example
WEBLATE_EMAIL_HOST_PASSWORD=replace-with-smtp-password
WEBLATE_DEFAULT_FROM_EMAIL=translate-noreply@sunfish.example

# --- HTTP port (change if 8080 conflicts on the VM) -------------------------
WEBLATE_HTTP_PORT=8080
