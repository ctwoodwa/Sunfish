@page "/account/shortcuts"
@layout AccountLayout

<PageTitle>Keyboard shortcuts · Sunfish PM</PageTitle>

<SettingsPageHeader Title="Keyboard shortcuts"
                    Description="Quick reference for keyboard shortcuts." />

<SettingsSection Title="Navigation">
    <SettingsCard>
        <SettingsFieldRow Label="Go to Dashboard" Value="G then D" />
        <SettingsFieldRow Label="Go to Task Board" Value="G then B" />
        <SettingsFieldRow Label="Go to Settings" Value="Ctrl + ," />
        <SettingsFieldRow Label="Search" Value="Ctrl + K" />
    </SettingsCard>
</SettingsSection>

<SettingsSection Title="Tasks">
    <SettingsCard>
        <SettingsFieldRow Label="New task" Value="N" />
        <SettingsFieldRow Label="Edit task" Value="E" />
        <SettingsFieldRow Label="Delete task" Value="Del" />
        <SettingsFieldRow Label="Assign task" Value="A" />
    </SettingsCard>
</SettingsSection>

<SettingsSection Title="General">
    <SettingsCard>
        <SettingsFieldRow Label="Toggle dark mode" Value="Ctrl + Shift + D" />
        <SettingsFieldRow Label="Toggle sidebar" Value="Ctrl + B" />
        <SettingsFieldRow Label="Show shortcuts" Value="?" />
    </SettingsCard>
</SettingsSection>
