<PageTitle>Account details · Marilo PM</PageTitle>

<SettingsPageHeader Title="Account"
                    Description="Profile, workspace identity, and sign-in details." />

<SettingsSection Title="Profile">
    <SettingsCard>
        <SettingsFieldRow Label="Full name" Value="Avery Chen" />
        <SettingsFieldRow Label="Email" Value="avery.chen@example.com" />
        <SettingsFieldRow Label="Job title" Value="Program Manager" />
        <SettingsFieldRow Label="Timezone" Value="Australia/Melbourne (AEDT)" />
        <SettingsFieldRow Label="Locale" Value="English (Australia)" />
