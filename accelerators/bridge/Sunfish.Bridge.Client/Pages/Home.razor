@page "/"

<PageTitle>Dashboard · Sunfish PM</PageTitle>

<h1 style="margin:0 0 4px;">Dashboard</h1>
<p style="color:#6b7280;margin:0 0 24px;">Welcome to the Sunfish PM demo.</p>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:32px;">
    @foreach (var kpi in _kpis)
    {
        <SunfishCard>
            <SunfishCardBody>
                <div style="font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">@kpi.Label</div>
                <div style="font-size:30px;font-weight:700;line-height:1;">@kpi.Value</div>
                @if (kpi.Sub is not null)
                {
                    <div style="font-size:12px;color:#6b7280;margin-top:4px;">@kpi.Sub</div>
                }
            </SunfishCardBody>
        </SunfishCard>
    }
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
    <SunfishCard>
        <SunfishCardHeader>Recent Milestones</SunfishCardHeader>
        <SunfishCardBody>
            <SunfishDataGrid TItem="MilestoneRow" Data="@_milestones" Striped="true">
                <SunfishGridColumn TItem="MilestoneRow" Field="Name" Title="Milestone" />
                <SunfishGridColumn TItem="MilestoneRow" Field="DueDate" Title="Due" Format="MMM d" />
                <SunfishGridColumn TItem="MilestoneRow" Field="Status" />
            </SunfishDataGrid>
        </SunfishCardBody>
    </SunfishCard>

    <SunfishCard>
        <SunfishCardHeader>Top Risks</SunfishCardHeader>
        <SunfishCardBody>
            <SunfishDataGrid TItem="RiskRow" Data="@_risks" Striped="true">
                <SunfishGridColumn TItem="RiskRow" Field="Title" />
                <SunfishGridColumn TItem="RiskRow" Field="Severity" />
                <SunfishGridColumn TItem="RiskRow" Field="Owner" />
            </SunfishDataGrid>
        </SunfishCardBody>
    </SunfishCard>
</div>

@code {
    record KpiCard(string Label, string Value, string? Sub = null);
    record MilestoneRow(string Name, DateTime DueDate, string Status);
    record RiskRow(string Title, string Severity, string Owner);

    readonly KpiCard[] _kpis =
    [
        new("Active Projects", "12", "+2 this month"),
        new("Open Risks", "4", "1 critical"),
        new("Budget Used", "62%", "$1.24M of $2M"),
        new("On-Track Tasks", "184", "of 201 total"),
    ];

    readonly MilestoneRow[] _milestones =
    [
        new("Alpha Release",     new DateTime(2026, 4, 15), "On Track"),
        new("UX Review",         new DateTime(2026, 4, 22), "At Risk"),
        new("Beta Launch",       new DateTime(2026, 5, 1),  "Planned"),
        new("Stakeholder Demo",  new DateTime(2026, 5, 10), "Planned"),
    ];

    readonly RiskRow[] _risks =
    [
        new("Vendor delivery delay", "High",   "J. Park"),
        new("Scope creep – Phase 2", "Medium", "A. Chen"),
        new("Key resource on leave",  "Medium", "T. Smith"),
        new("Budget overrun",         "Low",    "A. Chen"),
    ];
}
