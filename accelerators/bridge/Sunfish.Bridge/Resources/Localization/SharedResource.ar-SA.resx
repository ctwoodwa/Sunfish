<?xml version="1.0" encoding="utf-8"?>
<root>
  <!-- Sunfish.Bridge SharedResource — Arabic (Saudi Arabia) satellite. RTL locale. -->
  <xsd:schema id="root" xmlns="" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xsd:import namespace="http://www.w3.org/XML/1998/namespace" />
    <xsd:element name="root" msdata:IsDataSet="true">
      <xsd:complexType>
        <xsd:choice maxOccurs="unbounded">
          <xsd:element name="data">
            <xsd:complexType>
              <xsd:sequence>
                <xsd:element name="value" type="xsd:string" minOccurs="0" msdata:Ordinal="1" />
                <xsd:element name="comment" type="xsd:string" minOccurs="0" msdata:Ordinal="2" />
              </xsd:sequence>
              <xsd:attribute name="name" type="xsd:string" use="required" />
              <xsd:attribute name="type" type="xsd:string" />
              <xsd:attribute ref="xml:space" />
            </xsd:complexType>
          </xsd:element>
        </xsd:choice>
      </xsd:complexType>
    </xsd:element>
  </xsd:schema>
  <resheader name="resmimetype"><value>text/microsoft-resx</value></resheader>
  <resheader name="version"><value>2.0</value></resheader>
  <resheader name="reader"><value>System.Resources.ResXResourceReader, System.Windows.Forms</value></resheader>
  <resheader name="writer"><value>System.Resources.ResXResourceWriter, System.Windows.Forms</value></resheader>

  <data name="errors.not-found" xml:space="preserve">
    <value>غير موجود</value>
    <comment>Translator: Title of HTTP 404 page; appears as page heading in tenant browser-shell.</comment>
  </data>
  <data name="errors.not-found.detail" xml:space="preserve">
    <value>تعذر العثور على المورد المطلوب.</value>
    <comment>Translator: Body text under the 404 title; full sentence.</comment>
  </data>
  <data name="errors.unauthorized" xml:space="preserve">
    <value>سجل الدخول للمتابعة</value>
    <comment>Translator: Imperative title — sign in to continue. Pairs with sign-in button.</comment>
  </data>
  <data name="errors.unauthorized.detail" xml:space="preserve">
    <value>انتهت جلستك أو لم تقم بتسجيل الدخول.</value>
    <comment>Translator: Body text on HTTP 401; mentions both expired and never-signed-in states.</comment>
  </data>
</root>
