@page "/Error"
@using System.Diagnostics
@using Microsoft.Extensions.Localization
@using Sunfish.Bridge.Localization
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@LocalizedTitle</PageTitle>

<h1 class="text-danger">@LocalizedTitle</h1>
<h2 class="text-danger">@LocalizedDetail</h2>

@if (ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@RequestId</code>
    </p>
}

<h3>Development Mode</h3>
<p>
    Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
</p>
<p>
    <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
    It can result in displaying sensitive information from exceptions to end users.
    For local debugging, enable the <strong>Development</strong> environment by setting the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong>
    and restarting the app.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    // Localized title + detail. The factory at Sunfish.Bridge.Localization.SunfishProblemDetailsFactory
    // resolves these same keys for JSON ProblemDetails responses; this Razor page surfaces the
    // matching strings on the HTML re-execute path so server-rendered errors share the bundle.
    // Selection is driven off HTTP status code: 401 → unauthorized, 403 → forbidden, 404 → not-found,
    // 409 → conflict, anything else → not-found pair as the safest generic fallback.
    private string LocalizedTitle => StatusCode switch
    {
        401 => Localizer["errors.unauthorized"],
        403 => Localizer["errors.forbidden"],
        404 => Localizer["errors.not-found"],
        409 => Localizer["errors.conflict"],
        _ => Localizer["errors.not-found"],
    };

    private string LocalizedDetail => StatusCode switch
    {
        401 => Localizer["errors.unauthorized.detail"],
        403 => Localizer["errors.forbidden.detail"],
        404 => Localizer["errors.not-found.detail"],
        409 => Localizer["errors.conflict.detail"],
        _ => Localizer["errors.not-found.detail"],
    };

    private int StatusCode => HttpContext?.Response?.StatusCode ?? 500;

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
