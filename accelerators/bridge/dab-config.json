{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "postgresql",
    "connection-string": "@env('ConnectionStrings__sunfishbridgedb')"
  },
  "runtime": {
    "rest": {
      "enabled": false,
      "path": "/api",
      "request-body-strict": true
    },
    "graphql": {
      "enabled": true,
      "path": "/graphql",
      "allow-introspection": true
    },
    "mcp": {
      "enabled": true,
      "path": "/mcp",
      "dml-tools": {
        "describe-entities": true,
        "create-record": true,
        "read-records": true,
        "update-record": true,
        "delete-record": true,
        "execute-entity": true
      }
    },
    "host": {
      "cors": {
        "origins": [
          "*"
        ],
        "allow-credentials": false
      },
      "authentication": {
        "provider": "StaticWebApps"
      },
      "mode": "development"
    }
  },
  "entities": {
    "Project": {
      "description": "Top-level unit of work in the Bridge PM demo. Owns tasks, milestones, risks, budget lines, and a member roster.",
      "source": {
        "object": "projects",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Project",
          "plural": "projects"
        }
      },
      "rest": {
        "enabled": false
      },
      "permissions": [
        {
          "role": "Owner",
          "actions": [
            {
              "action": "create"
            },
            {
              "action": "read"
            },
            {
              "action": "update"
            },
            {
              "action": "delete"
            }
          ]
        },
        {
          "role": "Admin",
          "actions": [
            {
              "action": "create"
            },
            {
              "action": "read"
            },
            {
              "action": "update"
            },
            {
              "action": "delete"
            }
          ]
        },
        {
          "role": "ProjectManager",
          "actions": [
            {
              "action": "create"
            },
            {
              "action": "read"
            },
            {
              "action": "update"
            },
            {
              "action": "delete"
            }
          ]
        },
        {
          "role": "TeamMember",
          "actions": [
            {
              "action": "read"
            }
          ]
        },
        {
          "role": "Viewer",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
