@page "/"
@using Sunfish.Anchor.Services
@using Sunfish.UIAdapters.Blazor.Components.LocalFirst
@implements IDisposable
@inject AnchorSessionService Session
@inject NavigationManager Nav

<PageTitle>Sunfish Anchor</PageTitle>

@if (!Session.IsOnboarded)
{
    <div class="anchor-dashboard">
        <p>Redirecting to onboarding…</p>
    </div>
    return;
}

<div class="anchor-dashboard">
    <header class="anchor-status-bar">
        <SunfishNodeHealthBar NodeHealth="Session.NodeHealth"
                              LinkStatus="Session.LinkStatus"
                              DataFreshness="Session.DataFreshness" />
    </header>

    <section class="anchor-hero">
        <h1>Welcome to Sunfish Anchor</h1>
        <p class="anchor-hero-sub">
            Local-first desktop dashboard — your data lives on this device.
            Sync is opt-in per bundle.
        </p>
        <dl class="anchor-identity">
            <dt>Team</dt>
            <dd><code>@Session.TeamId</code></dd>
            <dt>Node</dt>
            <dd><code>@Session.NodeId</code></dd>
            <dt>Role</dt>
            <dd>@(Session.Attestation?.Role ?? "—")</dd>
        </dl>
    </section>

    <section class="anchor-card">
        <h2>Data freshness</h2>
        <p class="anchor-muted">Derived from <code>AnchorSessionService.LastSyncedAt</code>.</p>
        <SunfishFreshnessBadge LastSyncedAt="Session.LastSyncedAt"
                               StalenessThreshold="TimeSpan.FromMinutes(5)"
                               Prefix="As of " />
    </section>

    <section class="anchor-card">
        <h2>Optimistic write demo</h2>
        <p class="anchor-muted">
            Simulates a local-first write: the button confirms after 1 second,
            modelling paper §5.2's optimistic-write loop. Real wiring to the
            outbound queue lands in a later wave.
        </p>
        <SunfishOptimisticButton Label="Save demo record"
                                 OnClick="@HandleDemoWriteAsync" />
    </section>

    <section class="anchor-card anchor-deferred">
        <h2>Deferred scope</h2>
        <ul>
            <li>Report catalog (ADR 0021) — Wave 4</li>
            <li>Audit log surface — Wave 4</li>
            <li>Sync toggle (ADR 0013) — next slice</li>
            <li>Platform packaging (.msix / .dmg / notarization) — Wave 4.5</li>
            <li>Auto-update channel — Wave 4.5</li>
        </ul>
    </section>
</div>

@code {
    protected override void OnInitialized()
    {
        if (!Session.IsOnboarded)
        {
            Nav.NavigateTo("/onboarding", replace: true);
            return;
        }
        Session.PropertyChanged += OnSessionChanged;
    }

    private void OnSessionChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private async Task<bool> HandleDemoWriteAsync()
    {
        await Task.Delay(TimeSpan.FromSeconds(1));
        Session.MarkSynced(DateTimeOffset.UtcNow);
        return true;
    }

    public void Dispose() => Session.PropertyChanged -= OnSessionChanged;
}

<style>
    .anchor-dashboard { max-width: 960px; margin: 0 auto; padding: 1rem 1.5rem 3rem; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; }
    .anchor-status-bar { margin-bottom: 1.5rem; }
    .anchor-hero h1 { font-size: 1.75rem; margin: 0 0 0.5rem; letter-spacing: -0.01em; }
    .anchor-hero-sub { color: #555; margin: 0 0 1rem; line-height: 1.5; }
    .anchor-identity { display: grid; grid-template-columns: auto 1fr; column-gap: 1rem; row-gap: 0.25rem; margin: 0; font-size: 0.875rem; }
    .anchor-identity dt { color: #666; font-weight: 600; }
    .anchor-identity dd { margin: 0; font-family: Consolas, Menlo, monospace; overflow-wrap: anywhere; }
    .anchor-card { margin-top: 1.5rem; padding: 1.25rem 1.5rem; border: 1px solid #e5e5e5; border-radius: 8px; background: #fafafa; }
    .anchor-card h2 { margin: 0 0 0.5rem; font-size: 1.0625rem; }
    .anchor-muted { color: #666; margin: 0 0 0.75rem; font-size: 0.875rem; line-height: 1.5; }
    .anchor-deferred ul { margin: 0; padding-left: 1.25rem; color: #555; font-size: 0.875rem; }
</style>
