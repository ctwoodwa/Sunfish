@inject Sunfish.Anchor.Services.AnchorSessionService Session
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Sunfish Anchor</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        @if (!Session.IsOnboarded)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="onboarding">
                    <span class="bi bi-qr-code-scan" aria-hidden="true"></span> Onboarding
                </NavLink>
            </div>
        }
        @*
            Nav items (Reports, Audit, Bundles, Settings) stay deferred per
            accelerators/anchor/README.md. The Wave 3.3+3.4 scope is deliberately
            narrow: status-bar + home + onboarding only.
        *@
    </nav>
</div>
